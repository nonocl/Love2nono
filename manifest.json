function pickRandom() {
  const txt = document.getElementById('picker-list').value;
  const opts = txt.split('\n').filter(x => x.trim()).map(x => x.trim());
  if (opts.length === 0) { alert('Ajoute des options'); return; }
  const r = document.getElementById('picker-result');
  let i = 0;
  const final = opts[Math.floor(Math.random()*opts.length)];
  const interval = setInterval(() => {
    r.textContent = '🎯 ' + opts[Math.floor(Math.random()*opts.length)];
    i++;
    if (i > 15) { clearInterval(interval); r.textContent = '🎯 ' + final; }
  }, 80);
}

