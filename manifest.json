  { id: 'english_duo', name: '🇬🇧👯 Duo EN' }
];
let _mbTab = 'all';
let _mbCurrent = null;

function getAllMBios() {
  const out = [];
  for (const cat in MATCH_BIOS) {
    MATCH_BIOS[cat].forEach((b, i) => out.push({ ...b, cat, id: cat + '-' + i }));
  }
  return out;
}
function getMBios(tab) {
  if (tab === 'all') return getAllMBios();
  const out = [];
  (MATCH_BIOS[tab] || []).forEach((b, i) => out.push({ ...b, cat: tab, id: tab + '-' + i }));
  return out;
}
function getMBFavs() {
  try { return JSON.parse(localStorage.getItem('nw_mbio_favs') || '[]'); } catch { return []; }
}
function saveMBFavs(d) { localStorage.setItem('nw_mbio_favs', JSON.stringify(d)); }

function renderMatchBio() {
  // Tabs
  const tabsHtml = MB_TABS.map(t => 
    `<button class="btn ${t.id === _mbTab ? 'primary' : 'alt'}" onclick="matchBioTab('${t.id}')" style="font-size:11px; padding:5px 11px; flex-shrink:0; border-radius:14px;">${t.name}</button>`
  ).join('');
  document.getElementById('mb-tabs').innerHTML = tabsHtml;
  
  // Première bio
  if (!_mbCurrent || _mbCurrent.cat !== _mbTab && _mbTab !== 'all') matchBioRoll();
  else if (!_mbCurrent) matchBioRoll();
  else renderCurrentMB();
  
  renderMatchBioFavs();
  renderMatchBioList();
}

function matchBioTab(t) {
  _mbTab = t;
  _mbCurrent = null;
  renderMatchBio();
}

function matchBioRoll() {
  const pool = getMBios(_mbTab);
  if (!pool.length) return;
  let n;
  do {
    n = pool[Math.floor(Math.random() * pool.length)];
  } while (pool.length > 1 && _mbCurrent && n.id === _mbCurrent.id);
  _mbCurrent = n;
  renderCurrentMB();
}
function renderCurrentMB() {
  if (!_mbCurrent) return;
  document.getElementById('mb-text').textContent = _mbCurrent.t;
  document.getElementById('mb-source').textContent = _mbCurrent.s ? '— ' + _mbCurrent.s : '';
  // Update fav button
  const favs = getMBFavs();
  const isFav = favs.some(f => f.id === _mbCurrent.id);
  document.getElementById('mb-fav-btn').textContent = isFav ? '❤️' : '🤍';
}
function matchBioCopy() {
  if (!_mbCurrent) return;
  const txt = _mbCurrent.t + (_mbCurrent.s ? '\n— ' + _mbCurrent.s : '');
  if (navigator.clipboard) {
    navigator.clipboard.writeText(txt).then(() => toast('📋 Copié !'));
  } else {
    const ta = document.createElement('textarea');
    ta.value = txt;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    toast('📋 Copié !');
  }
}
function matchBioSave() {
  if (!_mbCurrent) return;
  const favs = getMBFavs();
  const idx = favs.findIndex(f => f.id === _mbCurrent.id);
  if (idx >= 0) {
    favs.splice(idx, 1);
    toast('❌ Retirée des favoris');
  } else {
    favs.push(_mbCurrent);
    toast('❤️ Ajoutée aux favoris');
  }
  saveMBFavs(favs);
  renderCurrentMB();
  renderMatchBioFavs();
}
function renderMatchBioFavs() {
  const favs = getMBFavs();
  const div = document.getElementById('mb-favs');
  if (!favs.length) {
    div.innerHTML = '<p style="font-size:11px; color:var(--textSec); text-align:center; padding:10px;">Aucune favorite. Tap ❤️ pour en ajouter.</p>';
    return;
  }
  div.innerHTML = favs.map(f => `<div style="background:var(--surface); padding:12px; border-radius:12px; margin-top:6px; border-left:3px solid var(--accent);">
    <div style="font-size:13px; line-height:1.5; font-style:italic;">${escapeHtml(f.t)}</div>
    ${f.s ? `<div style="font-size:10px; color:var(--textSec); margin-top:4px;">— ${escapeHtml(f.s)}</div>` : ''}
    <div style="display:flex; gap:6px; margin-top:8px;">
      <button class="btn alt" onclick="matchBioCopyFav('${escapeHtml(f.id)}')" style="font-size:11px; padding:4px 10px; flex:1;">📋 Copier</button>
      <button class="btn alt" onclick="matchBioRemoveFav('${escapeHtml(f.id)}')" style="font-size:11px; padding:4px 10px; color:var(--danger);">✗</button>
    </div>
  </div>`).join('');
}
function matchBioCopyFav(id) {
  const f = getMBFavs().find(x => x.id === id);
  if (!f) return;
  const txt = f.t + (f.s ? '\n— ' + f.s : '');
  navigator.clipboard?.writeText(txt);
  toast('📋 Copié !');
}
function matchBioRemoveFav(id) {
  saveMBFavs(getMBFavs().filter(f => f.id !== id));
  renderMatchBioFavs();
  renderCurrentMB();
}
function renderMatchBioList() {
  const q = (document.getElementById('mb-search')?.value || '').toLowerCase();
  const all = getAllMBios();
  const filtered = q ? all.filter(b => b.t.toLowerCase().includes(q) || (b.s || '').toLowerCase().includes(q)) : all;
  
  const catLabels = {anime:'🎌 Anime', musique:'🎵 Musique', films:'🎬 Films', citations:'📜 Citations', litteraire:'📚 Litt.', drole:'😂 Drôle', pickup:'💘 Pickup', mood:'🌙 Mood', premier_degre:'👤 Direct'};
  
  document.getElementById('mb-list').innerHTML = filtered.map(b => `<div onclick="matchBioPick('${escapeHtml(b.id)}')" style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-bottom:5px; cursor:pointer; border-left:3px solid var(--primary);">
    <div style="font-size:9px; color:var(--primary); font-weight:700; margin-bottom:3px;">${catLabels[b.cat] || b.cat}</div>
    <div style="font-size:12px; line-height:1.4; font-style:italic;">${escapeHtml(b.t)}</div>
    ${b.s ? `<div style="font-size:9px; color:var(--textSec); margin-top:3px;">— ${escapeHtml(b.s)}</div>` : ''}
  </div>`).join('') || '<p style="text-align:center; color:var(--textSec); padding:20px;">Aucun résultat</p>';
}
function matchBioPick(id) {
  const all = getAllMBios();
  const b = all.find(x => x.id === id);
  if (!b) return;
  _mbCurrent = b;
  renderCurrentMB();
  // Scroll up
  document.getElementById('mb-current').scrollIntoView({ behavior: 'smooth', block: 'center' });
}



