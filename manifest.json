// JEU: SUDOKU
// ============================================================
let _sud = null;
let _sudSelected = null;

function newSudoku(diff) {
  diff = diff || _sud?.difficulty || 'easy';
  // Generate a valid sudoku then remove cells
  const grid = generateSudoku();
  const solution = grid.map(r => r.slice());
  const holes = { easy: 35, medium: 45, hard: 55 }[diff] || 35;
  let removed = 0;
  while (removed < holes) {
    const r = Math.floor(Math.random()*9), c = Math.floor(Math.random()*9);
    if (grid[r][c] !== 0) { grid[r][c] = 0; removed++; }
  }
  _sud = { grid, solution, original: grid.map(r=>r.slice()), difficulty: diff, selected: null };
  _sudSelected = null;
  renderSudoku();
}

function generateSudoku() {
  const grid = Array.from({length:9}, () => Array(9).fill(0));
  fillSudoku(grid);
  return grid;
}

function fillSudoku(grid) {
  const empty = findEmpty(grid);
  if (!empty) return true;
  const [r, c] = empty;
  const nums = [1,2,3,4,5,6,7,8,9].sort(() => Math.random()-0.5);
  for (const n of nums) {
    if (isValidSud(grid, r, c, n)) {
      grid[r][c] = n;
      if (fillSudoku(grid)) return true;
      grid[r][c] = 0;
    }
  }
  return false;
}

function findEmpty(grid) {
  for (let r=0; r<9; r++) for (let c=0; c<9; c++) if (grid[r][c]===0) return [r,c];
  return null;
}

function isValidSud(grid, r, c, n) {
  for (let i=0; i<9; i++) {
    if (grid[r][i] === n || grid[i][c] === n) return false;
  }
  const br = Math.floor(r/3)*3, bc = Math.floor(c/3)*3;
  for (let i=br; i<br+3; i++) for (let j=bc; j<bc+3; j++) if (grid[i][j] === n) return false;
  return true;
}

function renderSudoku() {
  const board = document.getElementById('sudoku-board');
  board.innerHTML = '';
  for (let r=0; r<9; r++) for (let c=0; c<9; c++) {
    const cell = document.createElement('button');
    const isOriginal = _sud.original[r][c] !== 0;
    const isSelected = _sudSelected && _sudSelected[0]===r && _sudSelected[1]===c;
    const v = _sud.grid[r][c];
    const wrongValue = v !== 0 && !isOriginal && v !== _sud.solution[r][c];
    // borders for 3x3 sub-grids
    let borderStyle = 'border:0.5px solid var(--border);';
    if (r%3===0) borderStyle += ' border-top:2px solid var(--text);';
    if (c%3===0) borderStyle += ' border-left:2px solid var(--text);';
    if (r===8) borderStyle += ' border-bottom:2px solid var(--text);';
    if (c===8) borderStyle += ' border-right:2px solid var(--text);';
    cell.style.cssText = `
      aspect-ratio:1; ${borderStyle}
      background:${isSelected ? 'var(--primary)' : (isOriginal ? 'var(--surfaceAlt)' : 'var(--surface)')};
      color:${isSelected ? 'white' : (wrongValue ? 'var(--danger)' : (isOriginal ? 'var(--text)' : 'var(--primary)'))};
      font-weight:${isOriginal ? '700' : '600'}; font-size:16px; cursor:pointer; padding:0;
    `;
    cell.textContent = v || '';
    cell.onclick = () => { if (!isOriginal) { _sudSelected = [r,c]; renderSudoku(); } };
    board.appendChild(cell);
  }
}

function sudokuInput(n) {
  if (!_sudSelected) return;
  const [r, c] = _sudSelected;
  if (_sud.original[r][c] !== 0) return;
  _sud.grid[r][c] = n;
  renderSudoku();
  // Check if solved
  let solved = true;
  for (let r=0; r<9; r++) for (let c=0; c<9; c++) if (_sud.grid[r][c] !== _sud.solution[r][c]) { solved = false; break; }
  if (solved) setTimeout(() => alert('🎉 Sudoku résolu !'), 200);
}

