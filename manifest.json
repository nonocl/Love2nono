function getZodiacBirthday() {
  return localStorage.getItem('nw_zodiac_bday') || '';
}
function astroSettings() {
  const cur = getZodiacBirthday();
  const v = prompt('Ta date de naissance (jj/mm/aaaa) :', cur);
  if (v === null) return;
  // Parse
  const m = v.match(/(\d{1,2})\/(\d{1,2})\/(\d{4})/);
  if (!m) return toast('Format invalide');
  localStorage.setItem('nw_zodiac_bday', v);
  renderAstro();
}
function seedRandom(seed, arr) {
  const s = (seed * 9301 + 49297) % 233280;
  return arr[s % arr.length];
}
function renderAstro() {
  const bday = getZodiacBirthday();
  if (!bday) {
    document.getElementById('astro-content').innerHTML = `<div style="text-align:center; padding:40px 14px;">
      <div style="font-size:64px;">🌙</div>
      <div style="font-size:16px; font-weight:700; margin-top:14px;">Configure ton signe</div>
      <p style="font-size:12px; color:var(--textSec); margin-top:6px;">Renseigne ta date de naissance pour avoir ton horoscope du jour.</p>
      <button class="btn primary" onclick="astroSettings()" style="margin-top:14px;">📅 Ajouter ma date</button>
    </div>`;
    return;
  }
  const m = bday.match(/(\d{1,2})\/(\d{1,2})\/(\d{4})/);
  const day = parseInt(m[1]), month = parseInt(m[2]);
  const z = getZodiacBy(month, day);
  const today = todayKey();
  const dateSeed = parseInt(today.replace(/-/g,''));
  const ageSeed = ZODIAC.indexOf(z);
  
  const amour = seedRandom(dateSeed + ageSeed*7, HOROSCOPES.amour);
  const travail = seedRandom(dateSeed * 2 + ageSeed*11, HOROSCOPES.travail);
  const energie = seedRandom(dateSeed * 3 + ageSeed*13, HOROSCOPES.energie);
  const conseil = seedRandom(dateSeed * 5 + ageSeed*17, HOROSCOPES.conseil);
  // Score chiffres chance
  let s = dateSeed + ageSeed;
  const lucky = []; while (lucky.length < 3) { s = (s*97+13) % 99; if (!lucky.includes(s)) lucky.push(s); }
  const colors = ['🔴','🟢','🔵','🟡','🟣','🟠','🟤','⚫','⚪','🩷'];
  const luckyColor = colors[ageSeed % colors.length];
  
  const html = `<div style="background:linear-gradient(135deg, #9B59B6, #FF6FA3); color:white; padding:18px; border-radius:18px; text-align:center;">
    <div style="font-size:60px;">${z.emoji}</div>
    <div style="font-size:24px; font-weight:900; margin-top:4px;">${z.name}</div>
    <div style="font-size:12px; opacity:0.9; margin-top:4px; font-style:italic;">${z.traits}</div>
  </div>
  <h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-top:16px;">🔮 Horoscope du jour</h3>
  <div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:8px;">
    <div style="font-size:12px; color:var(--primary); font-weight:700;">💕 Amour</div>
    <div style="font-size:13px; line-height:1.5; margin-top:4px;">${escapeHtml(amour)}</div>
  </div>
  <div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:6px;">
    <div style="font-size:12px; color:var(--primary); font-weight:700;">💼 Travail / études</div>
    <div style="font-size:13px; line-height:1.5; margin-top:4px;">${escapeHtml(travail)}</div>
  </div>
  <div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:6px;">
    <div style="font-size:12px; color:var(--primary); font-weight:700;">⚡ Énergie</div>
    <div style="font-size:13px; line-height:1.5; margin-top:4px;">${escapeHtml(energie)}</div>
  </div>
  <div style="background:linear-gradient(135deg, #FFD166, #FF8C42); color:white; padding:14px; border-radius:12px; margin-top:6px;">
    <div style="font-size:12px; font-weight:700;">💫 Conseil de l'univers</div>
    <div style="font-size:13px; line-height:1.5; margin-top:4px;">${escapeHtml(conseil)}</div>
  </div>
  <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:8px; margin-top:14px;">
    <div style="background:var(--surface); padding:10px; border-radius:10px; text-align:center;">
      <div style="font-size:10px; color:var(--textSec);">Chiffres chance</div>
      <div style="font-size:18px; font-weight:800;">${lucky.join(' · ')}</div>
    </div>
    <div style="background:var(--surface); padding:10px; border-radius:10px; text-align:center;">
      <div style="font-size:10px; color:var(--textSec);">Couleur du jour</div>
      <div style="font-size:24px;">${luckyColor}</div>
    </div>
  </div>`;
  document.getElementById('astro-content').innerHTML = html;
}

