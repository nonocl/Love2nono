// FOREX
// ============================================================
const FOREX_DEFAULT = {
  EUR: 1, USD: 1.07, GBP: 0.85, JPY: 165, CHF: 0.95, CAD: 1.46,
  AUD: 1.62, CNY: 7.75, BRL: 5.4, MXN: 18.5, INR: 89, KRW: 1450,
  RUB: 100, TRY: 36, MAD: 10.7, DZD: 144, TND: 3.35
};
const FOREX_NAMES = {
  EUR: '€ Euro', USD: '$ Dollar US', GBP: '£ Livre', JPY: '¥ Yen', CHF: 'CHF Franc suisse',
  CAD: '$ Dollar canadien', AUD: '$ Dollar australien', CNY: '¥ Yuan', BRL: 'R$ Real',
  MXN: '$ Peso mex', INR: '₹ Roupie', KRW: '₩ Won', RUB: '₽ Rouble', TRY: '₺ Livre turque',
  MAD: 'DH Dirham', DZD: 'DA Dinar algérien', TND: 'D Dinar tunisien'
};
function getForexRates() {
  try { return Object.assign({}, FOREX_DEFAULT, JSON.parse(localStorage.getItem('nw_forex') || '{}')); } catch(e) { return FOREX_DEFAULT; }
}
function initForex() {
  const rates = getForexRates();
  const fromSel = document.getElementById('forex-from');
  const toSel = document.getElementById('forex-to');
  fromSel.innerHTML = ''; toSel.innerHTML = '';
  for (const code of Object.keys(FOREX_NAMES)) {
    fromSel.insertAdjacentHTML('beforeend', `<option value="${code}">${FOREX_NAMES[code]}</option>`);
    toSel.insertAdjacentHTML('beforeend', `<option value="${code}">${FOREX_NAMES[code]}</option>`);
  }
  fromSel.value = 'EUR';
  toSel.value = 'USD';
  renderForex();
}
function renderForex() {
  const amount = parseFloat(document.getElementById('forex-amount').value) || 0;
  const from = document.getElementById('forex-from').value;
  const to = document.getElementById('forex-to').value;
  const rates = getForexRates();
  const eur = amount / (rates[from]||1);
  const result = eur * (rates[to]||1);
  document.getElementById('forex-result').innerHTML = `${result.toFixed(2)} <span style="font-size:14px; color:var(--textSec);">${to}</span>`;
}
function swapForex() {
  const f = document.getElementById('forex-from'), t = document.getElementById('forex-to');
  [f.value, t.value] = [t.value, f.value];
  renderForex();
}
function openForexEdit() {
  const rates = getForexRates();
  const el = document.getElementById('forex-edit-list');
  el.innerHTML = '';
  for (const code of Object.keys(FOREX_NAMES)) {
    if (code === 'EUR') continue;
    el.insertAdjacentHTML('beforeend', `
      <div style="display:flex; gap:8px; align-items:center; margin-bottom:6px;">
        <span style="flex:1; font-size:13px;">${FOREX_NAMES[code]}</span>
        <input type="number" class="input" id="forex-rate-${code}" step="0.0001" value="${rates[code]||0}" style="width:120px;">
      </div>
    `);
  }
  openModal('modal-forex-edit');
}
function saveForexRates() {
  const cur = getForexRates();
  for (const code of Object.keys(FOREX_NAMES)) {
    if (code === 'EUR') continue;
    const el = document.getElementById('forex-rate-' + code);
    if (el) cur[code] = parseFloat(el.value) || cur[code];
  }
  localStorage.setItem('nw_forex', JSON.stringify(cur));
  closeModal('modal-forex-edit');
  renderForex();
}

