  </div>
  <div style="background:var(--surface); padding:18px; border-radius:14px; margin-top:14px;">
    <label style="font-size:11px; color:var(--textSec);">Fréquence</label>
    <div id="tg-freq" style="font-size:32px; font-weight:900; color:var(--primary); text-align:center;">440 Hz</div>
    <input type="range" id="tg-slider" min="20" max="20000" value="440" oninput="tgUpdate()" style="width:100%;">
    <div style="display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:6px; margin-top:10px;">
      <button class="btn alt" onclick="tgPreset(110)">110 Hz</button>
      <button class="btn alt" onclick="tgPreset(440)">440 Hz</button>
      <button class="btn alt" onclick="tgPreset(1000)">1 kHz</button>
      <button class="btn alt" onclick="tgPreset(8000)">8 kHz</button>
    </div>
    <label style="font-size:11px; color:var(--textSec); margin-top:14px; display:block;">Forme d'onde</label>
    <select id="tg-wave" class="input" style="margin-top:4px;">
      <option value="sine">Sinus</option>
      <option value="square">Carré</option>
      <option value="triangle">Triangle</option>
      <option value="sawtooth">Dent de scie</option>
    </select>
    <button class="btn primary full" id="tg-btn" onclick="tgToggle()" style="margin-top:14px; padding:18px;">▶️ Démarrer</button>
  </div>`;
  document.getElementById('tonegen-content').innerHTML = html;
}
let _tgOsc = null, _tgCtx = null;
function tgUpdate() {
  const v = document.getElementById('tg-slider').value;
  document.getElementById('tg-freq').textContent = parseInt(v) + ' Hz';
  if (_tgOsc) _tgOsc.frequency.value = parseInt(v);
}
function tgPreset(f) { document.getElementById('tg-slider').value = f; tgUpdate(); }
function tgToggle() {
  const btn = document.getElementById('tg-btn');
  if (_tgOsc) {
    _tgOsc.stop(); _tgOsc = null; if (_tgCtx) { _tgCtx.close(); _tgCtx = null; }
    btn.textContent = '▶️ Démarrer';
  } else {
    try {
      _tgCtx = new (window.AudioContext || window.webkitAudioContext)();
      _tgOsc = _tgCtx.createOscillator();
      const gain = _tgCtx.createGain();
      gain.gain.value = 0.15;
      _tgOsc.frequency.value = parseInt(document.getElementById('tg-slider').value);
      _tgOsc.type = document.getElementById('tg-wave').value;
      _tgOsc.connect(gain); gain.connect(_tgCtx.destination);
      _tgOsc.start();
      btn.textContent = '⏸ Stop';
    } catch (e) { toast('❌ Audio non supporté'); }
  }
}
