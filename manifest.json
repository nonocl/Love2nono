// ============================================================
function getSimSavedKey() { return 'nw_simsaved'; }
function getSimSaved() {
  try { return JSON.parse(localStorage.getItem(getSimSavedKey()) || '[]'); }
  catch(e) { return []; }
}
function setSimSaved(arr) { localStorage.setItem(getSimSavedKey(), JSON.stringify(arr)); }

async function saveSocialSim(net) {
  const d = window.simData[net];
  // Force sync from inputs
  rerenderSim(net);
  const name = prompt('Nom du profil à sauvegarder ?', d.handle || d.name || net);
  if (!name) return;
  const arr = getSimSaved();
  // Stocker version copy de simData[net]
  arr.push({ id: Date.now(), net, name, data: JSON.parse(JSON.stringify(d)), savedAt: new Date().toISOString() });
  // Limite : 50 sauvegardes max
  if (arr.length > 50) arr.shift();
  setSimSaved(arr);
  toast('💾 Profil sauvegardé');
}

async function renderSimSavedList() {
  const arr = getSimSaved();
  const el = document.getElementById('sim-saved-list');
  el.innerHTML = '';
  if (arr.length === 0) {
    el.innerHTML = `<p style="font-size:12px; color:var(--textSec); padding:10px 0;">Aucun profil sauvegardé. Crée-en un et tape sur 💾.</p>`;
    return;
  }
  const netLabels = { discord:'💜 Discord', instagram:'📷 Instagram', tiktok:'🎵 TikTok', x:'𝕏 X', snapchat:'👻 Snapchat' };
  arr.slice().reverse().forEach(p => {
    const row = document.createElement('div');
    row.style.cssText = 'display:flex; gap:8px; align-items:center; padding:10px 12px; background:var(--surface); border-radius:12px; margin-bottom:6px;';
    row.innerHTML = `
      <div style="flex:1; min-width:0;">
        <div style="font-size:14px; font-weight:600;">${escapeHtml(p.name)}</div>
        <div style="font-size:11px; color:var(--textSec);">${netLabels[p.net]||p.net} · ${new Date(p.savedAt).toLocaleDateString('fr-FR')}</div>
      </div>
      <button class="btn alt" style="padding:6px 10px; font-size:12px;" onclick="loadSimSaved(${p.id})">📂</button>
      <button class="btn ghost" style="padding:6px 10px; font-size:12px; color:var(--danger);" onclick="deleteSimSaved(${p.id})">🗑️</button>
    `;
    el.appendChild(row);
  });
}
function loadSimSaved(id) {
  const arr = getSimSaved();
  const p = arr.find(x => x.id === id);
  if (!p) return;
  window.simData[p.net] = JSON.parse(JSON.stringify(p.data));
  goTo('sim-' + p.net);
}
function deleteSimSaved(id) {
  if (!confirm('Supprimer ce profil sauvegardé ?')) return;
  let arr = getSimSaved();
  arr = arr.filter(x => x.id !== id);
  setSimSaved(arr);
  renderSimSavedList();
}

// ============================================================
// EXPORT IMAGE
// ============================================================
async function exportSocialSim(net) {
  const previewIds = { discord:'disc-preview', instagram:'ig-preview', tiktok:'tt-preview', x:'x-preview', snapchat:'sc-preview' };
  const target = document.querySelector('#' + previewIds[net] + ' > div');
  if (!target) { toast('Aperçu introuvable'); return; }
  // Use foreignObject SVG -> canvas trick (no html2canvas needed)
  toast('Export en cours…');
  try {
    const rect = target.getBoundingClientRect();
    const W = Math.ceil(rect.width * 2);
    const H = Math.ceil(rect.height * 2);
    const clone = target.cloneNode(true);
    // Inline computed styles : copier les styles depuis le DOM original
    inlineStyles(target, clone);
    const svgNs = 'http://www.w3.org/2000/svg';
    const svg = document.createElementNS(svgNs, 'svg');
    svg.setAttribute('xmlns', svgNs);
    svg.setAttribute('width', W);
    svg.setAttribute('height', H);
    svg.setAttribute('viewBox', `0 0 ${rect.width} ${rect.height}`);
    const fo = document.createElementNS(svgNs, 'foreignObject');
    fo.setAttribute('width', '100%'); fo.setAttribute('height', '100%');
    const wrap = document.createElement('div');
    wrap.setAttribute('xmlns', 'http://www.w3.org/1999/xhtml');
    wrap.appendChild(clone);
    fo.appendChild(wrap);
    svg.appendChild(fo);
    const xml = new XMLSerializer().serializeToString(svg);
    const blob = new Blob([xml], { type:'image/svg+xml;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.onload = () => {
      const canvas = document.createElement('canvas');
      canvas.width = W; canvas.height = H;
      const ctx = canvas.getContext('2d');
      ctx.fillStyle = '#000'; ctx.fillRect(0,0,W,H);
      ctx.drawImage(img, 0, 0, W, H);
      canvas.toBlob(b => {
        if (!b) { toast('Erreur export'); return; }
        const a = document.createElement('a');
        a.href = URL.createObjectURL(b);
        a.download = `nono-${net}-${Date.now()}.png`;
        document.body.appendChild(a); a.click(); a.remove();
        URL.revokeObjectURL(url);
        toast('✅ Image téléchargée');
      }, 'image/png');
    };
    img.onerror = () => { toast('Erreur de rendu (image avatar?)'); URL.revokeObjectURL(url); };
    img.src = url;
  } catch (e) {
    console.error(e);
    toast('Erreur d\'export : ' + e.message);
  }
}

// Inline les styles computed pour l'export SVG
function inlineStyles(src, dst) {
  const cs = getComputedStyle(src);
  let styleStr = '';
  const props = ['display','position','top','left','right','bottom','width','height','min-width','min-height','max-width','padding','padding-top','padding-right','padding-bottom','padding-left','margin','margin-top','margin-right','margin-bottom','margin-left','background','background-color','background-image','background-size','background-position','background-repeat','color','font-family','font-size','font-weight','font-style','line-height','text-align','letter-spacing','text-transform','border','border-radius','box-shadow','flex','flex-direction','flex-wrap','justify-content','align-items','gap','grid-template-columns','grid-template-rows','aspect-ratio','overflow','white-space','opacity','transform','z-index','object-fit'];
  for (const p of props) {
    const v = cs.getPropertyValue(p);
    if (v) styleStr += `${p}:${v};`;
  }
  dst.setAttribute('style', styleStr);
  for (let i=0; i<src.children.length; i++) {
    if (dst.children[i]) inlineStyles(src.children[i], dst.children[i]);
  }
}


