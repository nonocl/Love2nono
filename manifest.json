<!-- ======= SETTINGS ======= -->
<div class="page" id="page-settings">
  <div class="page-header">
    <button class="back-btn" onclick="goBack()">‹</button>
    <div class="page-title">Paramètres</div>
    <div style="width:40px;"></div>
  </div>

  <div class="section">
    <h3 style="font-size:15px; font-weight:700; margin-bottom:12px;">🎨 Thèmes</h3>
    <div class="theme-grid" id="theme-grid"></div>
    <button class="btn alt full" style="margin-top:12px;" onclick="goTo('custom-theme')">🎨 Créer un thème custom</button>
    <button class="btn primary full" style="margin-top:8px;" onclick="goTo('appearance')">✨ Disposition accueil</button>
    <button class="btn ghost full" style="margin-top:8px;" onclick="resetTheme()">↻ Réinitialiser</button>
  </div>

  <div class="section">
    <h3 style="font-size:15px; font-weight:700; margin-bottom:12px;">🖼️ Fond d'écran</h3>
    <button class="btn primary full" onclick="document.getElementById('wallpaper-input').click()">📷 Choisir une image</button>
    <input type="file" id="wallpaper-input" class="hidden-file" accept="image/*">
    <div id="wallpaper-controls" style="display:none; margin-top:14px;">
      <div class="input-row">
        <label>Opacité</label>
        <input type="range" id="wallpaper-opacity" min="0" max="100" value="50" oninput="updateWallpaper()">
        <span class="value" id="wallpaper-op-val">50%</span>
      </div>
      <div class="input-row">
        <label>Flou</label>
        <input type="range" id="wallpaper-blur" min="0" max="20" value="0" oninput="updateWallpaper()">
        <span class="value" id="wallpaper-bl-val">0px</span>
      </div>
      <button class="btn ghost full" style="margin-top:8px;" onclick="removeWallpaper()" style="color:var(--danger);">🗑️ Enlever le fond</button>
    </div>
  </div>

  <div class="section">
    <h3 style="font-size:15px; font-weight:700; margin-bottom:12px;">💾 Données</h3>
    <button class="btn alt full" onclick="exportAll()">📥 Exporter une sauvegarde</button>
    <div style="height:8px;"></div>
    <button class="btn alt full" onclick="document.getElementById('import-input').click()">📤 Importer une sauvegarde</button>
    <input type="file" id="import-input" class="hidden-file" accept="application/json">
    <div style="height:8px;"></div>
    <button class="btn alt full" onclick="resetAppCache()" style="margin-bottom:8px;">🧹 Réparer l'app (vider cache)</button>
    <p style="font-size:11px; color:var(--textSec); margin-top:-4px; margin-bottom:8px;">Si l'app affiche un bug d'affichage ou ne se charge pas correctement.</p>
    <button class="btn ghost full" onclick="resetAll()" style="color:var(--danger); border-color:var(--danger);">⚠️ Tout réinitialiser</button>
  </div>

  <div class="section">
    <h3 style="font-size:15px; font-weight:700; margin-bottom:12px;">À propos</h3>
    <p style="font-size:13px; color:var(--textSec); line-height:1.5;">
      <strong style="color:var(--text);">Love2nono</strong><br>
      Galerie PFP + boîte à outils, 100% locale et hors-ligne.<br><br>
      Version 1.0.0<br>
      Made with 💖 pour Nono
    </p>
  </div>
</div>

