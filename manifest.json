  { c:'Géométrie', n:'Aire du cercle', f:'A = π·r²', e:'r = rayon' },
  { c:'Géométrie', n:'Périmètre du cercle', f:'P = 2π·r', e:'r = rayon' },
  { c:'Géométrie', n:'Aire du triangle', f:'A = (b·h)/2', e:'b = base, h = hauteur' },
  { c:'Trigonométrie', n:'Cos / Sin / Tan', f:'cos = adj/hyp · sin = opp/hyp · tan = opp/adj', e:'Dans un triangle rectangle' },
  { c:'Trigonométrie', n:'Identité fondamentale', f:'cos²(x) + sin²(x) = 1', e:'Pour tout x réel' },
  { c:'Algèbre', n:'Identités remarquables', f:'(a+b)² = a² + 2ab + b² · (a-b)² = a² - 2ab + b² · (a-b)(a+b) = a² - b²', e:'À connaître par cœur' },
  { c:'Algèbre', n:'Discriminant', f:'Δ = b² - 4ac', e:'Pour ax² + bx + c = 0. Si Δ>0 : 2 solutions, Δ=0 : 1 solution, Δ<0 : aucune' },
  { c:'Algèbre', n:'Solutions équation 2nd degré', f:'x = (-b ± √Δ) / 2a', e:'Si Δ ≥ 0' },
  { c:'Fonctions', n:'Dérivée x^n', f:'(x^n)\' = n·x^(n-1)', e:'Pour n entier' },
  { c:'Fonctions', n:'Dérivée somme/produit', f:'(u+v)\' = u\'+v\' · (uv)\' = u\'v + uv\'', e:'Règles de base' },
  { c:'Fonctions', n:'Dérivée 1/x', f:'(1/x)\' = -1/x²', e:'Pour x ≠ 0' },
