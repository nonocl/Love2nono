// === Double tap pour toggle favori ===
let _lastTap = { time: 0, target: null };
function setupDoubleTapFav() {
  document.addEventListener('touchend', (e) => {
    const tile = e.target.closest('.home-tile');
    if (!tile) return;
    const now = Date.now();
    if (_lastTap.target === tile && now - _lastTap.time < 350) {
      // Double tap !
      e.preventDefault();
      const page = tile.getAttribute('data-page');
      if (page) {
        toggleFav(page);
        if (navigator.vibrate) navigator.vibrate(30);
      }
      _lastTap = { time: 0, target: null };
    } else {
      _lastTap = { time: now, target: tile };
    }
  }, { passive: false });
}

// === Shake = retour accueil ===
let _shakeAccel = { x:0, y:0, z:0 };
let _shakeLast = 0;
function setupShake() {
  if (!window.DeviceMotionEvent) return;
  // iOS demande la permission
  const start = () => {
    window.addEventListener('devicemotion', (e) => {
      const acc = e.accelerationIncludingGravity;
      if (!acc) return;
      const dx = Math.abs(acc.x - _shakeAccel.x);
      const dy = Math.abs(acc.y - _shakeAccel.y);
      const dz = Math.abs(acc.z - _shakeAccel.z);
      _shakeAccel = { x:acc.x, y:acc.y, z:acc.z };
      const total = dx + dy + dz;
      const now = Date.now();
      if (total > 35 && now - _shakeLast > 1500) {
        _shakeLast = now;
        if (state.page !== 'home') {
          if (navigator.vibrate) navigator.vibrate([50, 50, 50]);
          toast('🏠 Retour à l\'accueil');
          goTo('home');
        }
      }
    });
  };
  if (typeof DeviceMotionEvent.requestPermission === 'function') {
    // iOS - need user interaction to ask
    document.addEventListener('click', function once() {
      DeviceMotionEvent.requestPermission().then(state => {
        if (state === 'granted') start();
      }).catch(() => {});
      document.removeEventListener('click', once);
    }, { once: true });
  } else {
    start();
  }
}

