// ============================================================
// COUNTERS (depuis combien de jours)
// ============================================================
function daysBetween(d1, d2) {
  const a = new Date(d1); a.setHours(0,0,0,0);
  const b = new Date(d2); b.setHours(0,0,0,0);
  return Math.round((b-a)/(1000*60*60*24));
}

async function renderCounters() {
  const counters = await dbAll('counters');
  const el = document.getElementById('counters-list');
  el.innerHTML = '';
  if (counters.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">⏱️</div><h3>Aucun compteur</h3><p>Crée des compteurs pour suivre des jours écoulés ou à venir.</p></div>`;
    return;
  }
  const today = new Date();
  for (const c of counters) {
    const days = c.type === 'since' ? daysBetween(c.date, today) : daysBetween(today, c.date);
    const card = document.createElement('div');
    card.className = 'counter-card';
    card.innerHTML = `
      <button class="del-btn" data-id="${c.id}">×</button>
      <div class="counter-name">${escapeHtml(c.name)}</div>
      <div class="counter-value">${days < 0 ? 0 : days}</div>
      <div class="counter-unit">${c.type==='since' ? 'jour'+(days>1?'s':'')+' écoulé'+(days>1?'s':'') : 'jour'+(days>1?'s':'')+' restant'+(days>1?'s':'')}</div>
      <div class="counter-date">${c.type==='since'?'Depuis le ':'Jusqu\'au '} ${new Date(c.date).toLocaleDateString('fr-FR')}</div>
    `;
    card.querySelector('.del-btn').onclick = async (e) => {
      e.stopPropagation();
      if (confirm('Supprimer ce compteur ?')) { await dbDel('counters', c.id); renderCounters(); }
    };
    el.appendChild(card);
  }
}

function openCounterModal() {
  document.getElementById('counter-name-input').value = '';
