const audioEl = document.getElementById('audio-el');

// ----- ID3 tag parser (basic, ID3v2.3/2.4 + cover art) -----
async function parseID3(file) {
  const result = { title: null, artist: null, album: null, cover: null, duration: null };
  try {
    const buf = await file.slice(0, 1024 * 1024).arrayBuffer(); // first 1 MB
    const view = new DataView(buf);
    const u8 = new Uint8Array(buf);
    // Header
    if (view.getUint8(0) !== 0x49 || view.getUint8(1) !== 0x44 || view.getUint8(2) !== 0x33) return result; // 'ID3'
    const major = view.getUint8(3);
    const flags = view.getUint8(5);
    const size = ((view.getUint8(6) & 0x7F) << 21) | ((view.getUint8(7) & 0x7F) << 14) | ((view.getUint8(8) & 0x7F) << 7) | (view.getUint8(9) & 0x7F);
    let offset = 10;
    if (flags & 0x40) {
      // skip extended header
      const ehSize = view.getUint32(10);
      offset += ehSize;
    }
    const end = Math.min(10 + size, buf.byteLength);
    while (offset < end - 10) {
      const fid = String.fromCharCode(u8[offset], u8[offset+1], u8[offset+2], u8[offset+3]);
      if (!/^[A-Z0-9]{4}$/.test(fid)) break;
      let fsize;
      if (major >= 4) {
        fsize = ((u8[offset+4]&0x7F)<<21)|((u8[offset+5]&0x7F)<<14)|((u8[offset+6]&0x7F)<<7)|(u8[offset+7]&0x7F);
      } else {
        fsize = (u8[offset+4]<<24)|(u8[offset+5]<<16)|(u8[offset+6]<<8)|u8[offset+7];
      }
      const fstart = offset + 10;
      if (fsize <= 0 || fstart + fsize > end) break;
      if (fid === 'TIT2' || fid === 'TPE1' || fid === 'TALB') {
        const text = decodeID3Text(u8, fstart, fsize);
        if (fid === 'TIT2') result.title = text;
        if (fid === 'TPE1') result.artist = text;
        if (fid === 'TALB') result.album = text;
      } else if (fid === 'APIC') {
        // cover art
        const pic = parseAPIC(u8, fstart, fsize);
        if (pic) result.cover = pic;
      }
      offset = fstart + fsize;
    }
  } catch (e) { console.warn('id3 parse', e); }
  return result;
}

function decodeID3Text(u8, start, size) {
  const enc = u8[start];
  const data = u8.slice(start + 1, start + size);
  try {
    if (enc === 0) return new TextDecoder('iso-8859-1').decode(data).replace(/\0+$/,'');
    if (enc === 1) {
      // UTF-16 with BOM
      let bom = (data[0]<<8) | data[1];
      const off = (bom === 0xFFFE || bom === 0xFEFF) ? 2 : 0;
      const le = bom === 0xFFFE;
      return new TextDecoder(le ? 'utf-16le' : 'utf-16be').decode(data.slice(off)).replace(/\0+$/,'');
    }
    if (enc === 2) return new TextDecoder('utf-16be').decode(data).replace(/\0+$/,'');
    if (enc === 3) return new TextDecoder('utf-8').decode(data).replace(/\0+$/,'');
  } catch (e) { return null; }
  return null;
}

function parseAPIC(u8, start, size) {
  try {
    const enc = u8[start];
    let p = start + 1;
    // mime (null-terminated ASCII)
    let mimeEnd = p;
    while (u8[mimeEnd] !== 0 && mimeEnd < start + size) mimeEnd++;
    const mime = new TextDecoder('iso-8859-1').decode(u8.slice(p, mimeEnd));
    p = mimeEnd + 1;
    p++; // picture type
    // description (null-terminated)
    if (enc === 1 || enc === 2) {
      while (p < start + size - 1 && !(u8[p]===0 && u8[p+1]===0)) p++;
      p += 2;
    } else {
      while (p < start + size && u8[p] !== 0) p++;
      p++;
    }
    const data = u8.slice(p, start + size);
    const blob = new Blob([data], { type: mime || 'image/jpeg' });
    return blob;
  } catch (e) { return null; }
}

async function blobToDataURL(blob) {
  return new Promise((res, rej) => {
    const r = new FileReader();
    r.onload = () => res(r.result);
    r.onerror = () => rej(r.error);
    r.readAsDataURL(blob);
  });
}

// ----- Import -----
// Queue d'imports en attente d'édition
let _importQueue = [];   // [{tags, blob, filename, size, tempCover}]
let _importIndex = 0;
let _editingTrackId = null;  // si on édite une piste existante (et non un import)
let _editTrackCats = new Set();
let _editTrackCoverData = null;

document.getElementById('music-import').addEventListener('change', async (e) => {
  const files = Array.from(e.target.files || []);
  if (!files.length) return;
  toast(`Préparation de ${files.length} piste${files.length>1?'s':''}...`, 1500);
  _importQueue = [];
  for (const f of files) {
    try {
      const tags = await parseID3(f);
      const baseName = f.name.replace(/\.[^.]+$/, '');
      const cover = tags.cover ? await blobToDataURL(tags.cover) : null;
      const blob = new Blob([await f.arrayBuffer()], { type: f.type || 'audio/mpeg' });
      _importQueue.push({
        title: tags.title || baseName,
        artist: tags.artist || '',
        album: tags.album || '',
        cover, blob,
        filename: f.name,
        size: f.size,
      });
    } catch (err) { console.warn('prep err', err); }
  }
  e.target.value = '';
  if (_importQueue.length === 0) return;
  _importIndex = 0;
  openImportEditor();
});

async function openImportEditor() {
  if (_importIndex >= _importQueue.length) {
    toast(`${_importQueue.length} piste${_importQueue.length>1?'s':''} ajoutée${_importQueue.length>1?'s':''} 🎵`);
    _importQueue = [];
    renderMusicLibrary();
    return;
  }
  const item = _importQueue[_importIndex];
  _editingTrackId = null;
  _editTrackCats = new Set();
  _editTrackCoverData = item.cover || null;
  document.getElementById('track-edit-title').textContent = `Piste ${_importIndex+1} / ${_importQueue.length}`;
  document.getElementById('track-edit-title-input').value = item.title;
  document.getElementById('track-edit-artist-input').value = item.artist;
  document.getElementById('track-edit-album-input').value = item.album;
  document.getElementById('track-edit-batch-info').textContent = _importQueue.length > 1 ? `(import en cours)` : '';
  document.getElementById('track-edit-skip').style.display = _importQueue.length > 1 ? 'inline-flex' : 'none';
  updateTrackEditCover();
  await renderTrackEditCats();
  openModal('modal-track-edit');
}

function updateTrackEditCover() {
  const el = document.getElementById('track-edit-cover');
  const clr = document.getElementById('track-cover-clear');
  if (_editTrackCoverData) {
    el.style.backgroundImage = `url('${_editTrackCoverData}')`;
    el.textContent = '';
    clr.style.display = 'block';
  } else {
    el.style.backgroundImage = '';
    el.textContent = '🎵';
    clr.style.display = 'none';
  }
}

document.getElementById('track-cover-input').addEventListener('change', async (e) => {
  const f = e.target.files?.[0]; if (!f) return;
  // Resize to 500x500 max
  const dataUrl = await new Promise(res => {
    const r = new FileReader();
    r.onload = () => res(r.result);
    r.readAsDataURL(f);
  });
  const img = new Image();
  img.onload = () => {
    const max = 500;
    const scale = Math.min(1, max / Math.max(img.naturalWidth, img.naturalHeight));
    const c = document.createElement('canvas');
    c.width = img.naturalWidth * scale;
    c.height = img.naturalHeight * scale;
    c.getContext('2d').drawImage(img, 0, 0, c.width, c.height);
    _editTrackCoverData = c.toDataURL('image/jpeg', 0.85);
    updateTrackEditCover();
  };
  img.src = dataUrl;
  e.target.value = '';
});

function clearTrackEditCover() {
  _editTrackCoverData = null;
  updateTrackEditCover();
}

async function renderTrackEditCats() {
  const cats = await dbAll('music_cats');
  const el = document.getElementById('track-edit-cats');
  el.innerHTML = '';
  if (cats.length === 0) {
    el.innerHTML = '<span style="color:var(--textSec); font-size:12px;">Aucune catégorie. Crée-en depuis 🏷️ sur la page musique.</span>';
    return;
  }
  for (const c of cats.sort((a,b)=>a.name.localeCompare(b.name))) {
    const b = document.createElement('button');
    const sel = _editTrackCats.has(c.id);
    b.className = 'chip' + (sel?' active':'');
    if (sel) { b.style.background = c.color; b.style.borderColor = c.color; }
    b.innerHTML = `${c.icon ? c.icon+' ' : ''}${escapeHtml(c.name)}`;
    b.onclick = () => {
      if (_editTrackCats.has(c.id)) _editTrackCats.delete(c.id); else _editTrackCats.add(c.id);
      renderTrackEditCats();
    };
    el.appendChild(b);
  }
}

async function saveTrackEdit() {
  const title = document.getElementById('track-edit-title-input').value.trim();
  const artist = document.getElementById('track-edit-artist-input').value.trim();
  const album = document.getElementById('track-edit-album-input').value.trim();
  if (!title) { alert('Donne un titre.'); return; }

  let trackId;
  if (_editingTrackId !== null) {
    // Édition d'une piste existante
    const t = await dbGet('tracks', _editingTrackId);
    t.title = title; t.artist = artist || null; t.album = album || null;
    t.cover = _editTrackCoverData;
    await dbPut('tracks', t);
    trackId = _editingTrackId;
    if (player.currentTrack && player.currentTrack.id === trackId) {
      player.currentTrack = t;
      updatePlayerUI();
      updateMediaSession();
    }
  } else {
    // Import
    const item = _importQueue[_importIndex];
    const track = {
      title, artist: artist || null, album: album || null,
      cover: _editTrackCoverData,
      blob: item.blob,
      filename: item.filename,
      size: item.size,
      is_favorite: 0,
      added_at: new Date().toISOString(),
    };
    trackId = await dbAdd('tracks', track);
  }

  // Save categories
  const links = await dbAll('track_cats');
  for (const l of links.filter(x => x.track_id === trackId)) await dbDel('track_cats', l.key);
  for (const cid of _editTrackCats) await dbAdd('track_cats', { key: `${trackId}_${cid}`, track_id: trackId, cat_id: cid });

  closeModal('modal-track-edit');
  if (_editingTrackId !== null) {
    _editingTrackId = null;
    renderMusicLibrary();
  } else {
    _importIndex++;
    setTimeout(openImportEditor, 100);
  }
}

function skipTrackEdit() {
  // Sauvegarder avec valeurs par défaut et passer au suivant
  const item = _importQueue[_importIndex];
  dbAdd('tracks', {
    title: item.title, artist: item.artist || null, album: item.album || null,
    cover: item.cover || null, blob: item.blob,
    filename: item.filename, size: item.size,
    is_favorite: 0, added_at: new Date().toISOString(),
  }).then(() => {
    _importIndex++;
    closeModal('modal-track-edit');
    setTimeout(openImportEditor, 100);
  });
}

// Ouvrir l'éditeur complet pour une piste existante
async function openTrackEditFull() {
  closeModal('modal-track-menu');
  const tid = player.trackMenuId;
  const t = await dbGet('tracks', tid);
  if (!t) return;
  _editingTrackId = tid;
  _editTrackCoverData = t.cover || null;
