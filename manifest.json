const SCHOOL_VAC = {
  '2025-2026': {
    'Toussaint': { start: '2025-10-18', end: '2025-11-03', zones:'A,B,C' },
    'Noël': { start: '2025-12-20', end: '2026-01-05', zones:'A,B,C' },
    'Hiver A': { start: '2026-02-07', end: '2026-02-23', zones:'A' },
    'Hiver B': { start: '2026-02-21', end: '2026-03-09', zones:'B' },
    'Hiver C': { start: '2026-02-14', end: '2026-03-02', zones:'C' },
    'Printemps A': { start: '2026-04-04', end: '2026-04-20', zones:'A' },
    'Printemps B': { start: '2026-04-18', end: '2026-05-04', zones:'B' },
    'Printemps C': { start: '2026-04-11', end: '2026-04-27', zones:'C' },
    'Été': { start: '2026-07-04', end: '2026-09-01', zones:'A,B,C' },
  }
};
function renderSchoolCal() {
  const zone = document.getElementById('school-zone').value;
  const year = '2025-2026';
  const data = SCHOOL_VAC[year];
  const today = new Date();
  let html = `<h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-bottom:8px;">Année ${year}</h3>`;
  for (const [name, info] of Object.entries(data)) {
    if (!info.zones.split(',').includes(zone) && info.zones !== 'A,B,C') continue;
    const start = new Date(info.start), end = new Date(info.end);
    const days = Math.floor((start - today)/(1000*60*60*24));
    let status = '';
    if (today >= start && today <= end) status = `<span style="color:var(--success); font-weight:700;">🌴 EN COURS</span>`;
    else if (today < start) status = `<span style="color:var(--primary); font-weight:700;">dans ${days}j</span>`;
    else status = `<span style="color:var(--textSec);">passé</span>`;
    const cleanName = name.replace(/ A| B| C$/,'');
    html += `
      <div style="background:var(--surface); padding:12px; border-radius:10px; margin-bottom:6px;">
        <div style="display:flex; align-items:center; gap:8px;">
          <strong style="flex:1;">${escapeHtml(cleanName)}</strong>
          ${status}
        </div>
        <div style="font-size:12px; color:var(--textSec); margin-top:4px;">Du ${new Date(info.start).toLocaleDateString('fr-FR')} au ${new Date(info.end).toLocaleDateString('fr-FR')}</div>
      </div>
    `;
  }
  document.getElementById('school-cal-content').innerHTML = html;
}

