function renderGraphCalc() {
  let html = `<div style="background:linear-gradient(135deg,#06FFA5,#5DADE2,#9B59B6); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">📈</div><div style="font-size:16px; font-weight:800;">Calculatrice graphique</div>
    <div style="font-size:11px; opacity:0.9;">Trace y = f(x) · plage configurable</div>
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📝 Fonction (utilise x)</h3>
  <input type="text" id="gc-fn" class="input" value="x*x" placeholder="ex: 2*x+3, x*x, sin(x), Math.cos(x), x**2 - 4" oninput="gcPlot()" autocomplete="off">
  <div style="display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:6px; margin-top:8px;">
    <div><label style="font-size:10px; color:var(--textSec);">x min</label><input type="number" id="gc-xmin" class="input" value="-10" oninput="gcPlot()" inputmode="decimal"></div>
    <div><label style="font-size:10px; color:var(--textSec);">x max</label><input type="number" id="gc-xmax" class="input" value="10" oninput="gcPlot()" inputmode="decimal"></div>
    <div><label style="font-size:10px; color:var(--textSec);">y min</label><input type="number" id="gc-ymin" class="input" value="-10" oninput="gcPlot()" inputmode="decimal"></div>
    <div><label style="font-size:10px; color:var(--textSec);">y max</label><input type="number" id="gc-ymax" class="input" value="10" oninput="gcPlot()" inputmode="decimal"></div>
  </div>
  <canvas id="gc-canvas" width="600" height="400" style="width:100%; background:var(--surface); border-radius:10px; margin-top:14px;"></canvas>
  <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:6px; margin-top:8px;">
    <button class="btn alt" onclick="gcPreset('x*x')" style="font-size:10px;">x²</button>
    <button class="btn alt" onclick="gcPreset('Math.sin(x)')" style="font-size:10px;">sin(x)</button>
    <button class="btn alt" onclick="gcPreset('Math.cos(x)')" style="font-size:10px;">cos(x)</button>
    <button class="btn alt" onclick="gcPreset('Math.log(x)')" style="font-size:10px;">ln(x)</button>
    <button class="btn alt" onclick="gcPreset('Math.exp(x)')" style="font-size:10px;">e^x</button>
    <button class="btn alt" onclick="gcPreset('1/x')" style="font-size:10px;">1/x</button>
  </div>`;
  document.getElementById('graphcalc-content').innerHTML = html;
  setTimeout(gcPlot, 50);
}
function gcPreset(fn) { document.getElementById('gc-fn').value = fn; gcPlot(); }
function gcPlot() {
  const canvas = document.getElementById('gc-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const w = canvas.width, h = canvas.height;
  const xmin = parseFloat(document.getElementById('gc-xmin').value);
  const xmax = parseFloat(document.getElementById('gc-xmax').value);
  const ymin = parseFloat(document.getElementById('gc-ymin').value);
  const ymax = parseFloat(document.getElementById('gc-ymax').value);
  ctx.fillStyle = '#1a1a1a'; ctx.fillRect(0, 0, w, h);
  // Grid
  ctx.strokeStyle = '#333'; ctx.lineWidth = 1;
  for (let x = Math.ceil(xmin); x <= Math.floor(xmax); x++) {
    const px = ((x - xmin) / (xmax - xmin)) * w;
    ctx.beginPath(); ctx.moveTo(px, 0); ctx.lineTo(px, h); ctx.stroke();
  }
  for (let y = Math.ceil(ymin); y <= Math.floor(ymax); y++) {
    const py = h - ((y - ymin) / (ymax - ymin)) * h;
    ctx.beginPath(); ctx.moveTo(0, py); ctx.lineTo(w, py); ctx.stroke();
  }
  // Axes
  ctx.strokeStyle = '#777'; ctx.lineWidth = 1.5;
  if (xmin <= 0 && xmax >= 0) {
    const px = ((0 - xmin) / (xmax - xmin)) * w;
    ctx.beginPath(); ctx.moveTo(px, 0); ctx.lineTo(px, h); ctx.stroke();
  }
  if (ymin <= 0 && ymax >= 0) {
    const py = h - ((0 - ymin) / (ymax - ymin)) * h;
    ctx.beginPath(); ctx.moveTo(0, py); ctx.lineTo(w, py); ctx.stroke();
  }
  // Function
  const fnStr = document.getElementById('gc-fn').value;
  try {
    const f = new Function('x', 'return ' + fnStr);
    ctx.strokeStyle = '#FF6FA3'; ctx.lineWidth = 2; ctx.beginPath();
    let started = false;
    for (let px = 0; px < w; px++) {
      const x = xmin + (px / w) * (xmax - xmin);
      try {
        const y = f(x);
        if (typeof y !== 'number' || !isFinite(y)) { started = false; continue; }
        const py = h - ((y - ymin) / (ymax - ymin)) * h;
        if (!started || py < -100 || py > h + 100) { ctx.moveTo(px, Math.max(-50, Math.min(h+50, py))); started = true; }
        else ctx.lineTo(px, py);
      } catch (e) { started = false; }
    }
    ctx.stroke();
  } catch (e) {
    ctx.fillStyle = '#E14D6B'; ctx.font = '14px sans-serif';
    ctx.fillText('Erreur dans la formule', 20, 30);
  }
}

