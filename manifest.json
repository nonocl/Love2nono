function ngPick(arr) { return arr[Math.floor(Math.random()*arr.length)]; }
function ngGen() {
  const type = document.getElementById('ng-type').value;
  const count = parseInt(document.getElementById('ng-count').value) || 10;
  const names = [];
  for (let i = 0; i < count; i++) {
    let n = '';
    if (type === 'pseudo') {
      const usePre = Math.random() > 0.5;
      const useSuf = Math.random() > 0.4;
      n = (usePre ? ngPick(NG_DATA.pseudo) : '') + ngPick(NG_DATA.pseudoMid) + (useSuf ? ngPick(NG_DATA.pseudoSuf) : '');
    } else if (type === 'discord') {
      n = ngPick(NG_DATA.discord) + ngPick(NG_DATA.discordCore) + ngPick(NG_DATA.discord);
    } else if (type === 'prenom_fr') {
      const m = Math.random() > 0.5 ? NG_DATA.prenom_fr : NG_DATA.prenom_fr_f;
      n = ngPick(m);
    } else if (type === 'prenom_it') {
      const m = Math.random() > 0.5 ? NG_DATA.prenom_it : NG_DATA.prenom_it_f;
      n = ngPick(m);
    } else if (type === 'perso_fantasy') {
      n = ngPick(NG_DATA.fantasyPre) + ngPick(NG_DATA.fantasySuf);
    } else if (type === 'ville') {
      n = ngPick(NG_DATA.villePre) + ngPick(NG_DATA.villeSuf);
    } else if (type === 'marque') {
      n = ngPick(NG_DATA.marquePre) + ' ' + ngPick(NG_DATA.marqueSuf);
    } else if (type === 'animal') {
      n = ngPick(NG_DATA.animalPre);
    } else if (type === 'groupe') {
      n = ngPick(NG_DATA.groupePre) + ' ' + ngPick(NG_DATA.groupeSuf);
    } else if (type === 'elfe') {
      n = ngPick(NG_DATA.elfePre) + (Math.random() > 0.5 ? ngPick(NG_DATA.elfeSuf) : '');
    }
    names.push(n);
  }
  document.getElementById('ng-list').innerHTML = names.map(n => 
    `<div onclick="navigator.clipboard?.writeText('${n.replace(/'/g, "\\'")}'); toast('📋 Copié');" style="background:var(--surface); padding:12px 14px; border-radius:10px; margin-bottom:4px; cursor:pointer; font-size:15px; font-weight:600;">${escapeHtml(n)}</div>`
  ).join('');
}


// ============================================================
// CRYPTO HELPERS (XOR + base64 - simple mais hors ligne)
// ============================================================
function cryptString(text, key) {
  let out = '';
  for (let i = 0; i < text.length; i++) {
    out += String.fromCharCode(text.charCodeAt(i) ^ key.charCodeAt(i % key.length));
  }
  return btoa(unescape(encodeURIComponent(out)));
}
function decryptString(b64, key) {
  try {
    const text = decodeURIComponent(escape(atob(b64)));
    let out = '';
    for (let i = 0; i < text.length; i++) {
      out += String.fromCharCode(text.charCodeAt(i) ^ key.charCodeAt(i % key.length));
    }
    return out;
  } catch { return null; }
}

