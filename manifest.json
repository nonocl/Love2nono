function getRestos() { try { return JSON.parse(localStorage.getItem('nw_restos') || '[]'); } catch { return []; } }
function saveRestos(r) { localStorage.setItem('nw_restos', JSON.stringify(r)); }
function renderRestos() {
  const restos = getRestos();
  const avg = restos.length > 0 ? (restos.reduce((s, r) => s + r.note, 0) / restos.length).toFixed(1) : 0;
  let html = `<div style="background:linear-gradient(135deg,#FF6FA3,#FFD166); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🍽</div><div style="font-size:16px; font-weight:800;">Restos visités</div>
    <div style="font-size:11px; opacity:0.9;">${restos.length} restos · note moyenne ${avg}/10</div>
  </div>
  <div style="background:var(--surface); padding:12px; border-radius:12px; margin-top:14px;">
    <input type="text" id="rs-name" class="input" placeholder="Nom du resto" autocomplete="off">
    <input type="text" id="rs-cuisine" class="input" placeholder="Type de cuisine (italien, sushi...)" style="margin-top:6px;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:6px;">
      <input type="number" id="rs-note" class="input" placeholder="Note /10" min="0" max="10" step="0.5">
      <button class="btn primary" onclick="rsAdd()">➕</button>
    </div>
  </div>`;
  restos.slice().reverse().forEach((r, idx) => {
    const realIdx = restos.length - 1 - idx;
    const stars = '⭐'.repeat(Math.round(r.note / 2));
    html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px;">
      <div style="display:flex; justify-content:space-between; align-items:flex-start;">
        <div style="flex:1;">
          <div style="font-size:14px; font-weight:700;">${escapeHtml(r.name)}</div>
          <div style="font-size:11px; color:var(--textSec);">${escapeHtml(r.cuisine)} · ${stars} ${r.note}/10</div>
        </div>
        <button onclick="rsDel(${realIdx})" style="background:none; border:none; color:var(--danger);">✗</button>
      </div>
    </div>`;
  });
  document.getElementById('restos-content').innerHTML = html;
}
function rsAdd() {
  const name = document.getElementById('rs-name').value.trim();
  const cuisine = document.getElementById('rs-cuisine').value.trim();
  const note = parseFloat(document.getElementById('rs-note').value);
  if (!name || isNaN(note)) return;
  const r = getRestos();
  r.push({ name: name.slice(0, 50), cuisine: cuisine.slice(0, 30), note: Math.max(0, Math.min(10, note)) });
  saveRestos(r);
  document.getElementById('rs-name').value = ''; document.getElementById('rs-cuisine').value = ''; document.getElementById('rs-note').value = '';
  renderRestos();
}
function rsDel(i) { const r = getRestos(); r.splice(i,1); saveRestos(r); renderRestos(); }

// === 27. LEVER/COUCHER SOLEIL ===
function renderSunTimes() {
  const today = new Date();
  const yday = Math.floor((today - new Date(today.getFullYear(), 0, 0)) / 86400000);
  // Approximation simple pour Paris (~48.85°N)
  const lat = 48.85;
  const decl = 23.45 * Math.sin(2 * Math.PI * (yday - 81) / 365) * Math.PI / 180;
  const cosH = -Math.tan(lat * Math.PI / 180) * Math.tan(decl);
  const dayLength = 24 * Math.acos(Math.max(-1, Math.min(1, cosH))) / Math.PI;
  const sunrise = 12 - dayLength / 2;
  const sunset = 12 + dayLength / 2;
  function fmt(h) { const hh = Math.floor(h); const mm = Math.round((h - hh) * 60); return `${String(hh).padStart(2,'0')}:${String(mm).padStart(2,'0')}`; }
  let html = `<div style="background:linear-gradient(135deg,#FFD166,#FF8C42); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">☀️</div><div style="font-size:16px; font-weight:800;">Lever / coucher soleil</div>
    <div style="font-size:11px; opacity:0.9;">${today.toLocaleDateString('fr-FR', {weekday:'long', day:'numeric', month:'long'})}</div>
  </div>
  <p style="font-size:10px; color:var(--textSec); margin-top:8px; padding:8px; background:var(--surface); border-radius:8px;">Calculé pour Paris (48.85°N). Approximatif.</p>
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:14px;">
    <div style="background:linear-gradient(135deg,#FFD166,#FF8C42); color:white; padding:24px; border-radius:14px; text-align:center;">
      <div style="font-size:48px;">🌅</div>
      <div style="font-size:11px; opacity:0.9;">Lever</div>
      <div style="font-size:24px; font-weight:900;">${fmt(sunrise)}</div>
    </div>
    <div style="background:linear-gradient(135deg,#9B59B6,#FF6FA3); color:white; padding:24px; border-radius:14px; text-align:center;">
      <div style="font-size:48px;">🌇</div>
      <div style="font-size:11px; opacity:0.9;">Coucher</div>
      <div style="font-size:24px; font-weight:900;">${fmt(sunset)}</div>
    </div>
  </div>
  <div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:8px; text-align:center;">
    <div style="font-size:11px; color:var(--textSec);">Durée du jour</div>
    <div style="font-size:24px; font-weight:900; color:var(--primary);">${Math.floor(dayLength)}h ${Math.round((dayLength - Math.floor(dayLength)) * 60)}min</div>
  </div>`;
  document.getElementById('suntimes-content').innerHTML = html;
}

// === 28. HTTP STATUS DECODER ===
const HTTP_STATUS = {
  100:'Continue · Continue',101:'Switching Protocols · Changement de protocole',
  200:'OK · Tout va bien',201:'Created · Créé',202:'Accepted · Accepté',204:'No Content · Pas de contenu',
  301:'Moved Permanently · Déplacé définitivement',302:'Found · Trouvé (redirection temp)',304:'Not Modified · Non modifié (cache)',307:'Temporary Redirect · Redirection temporaire',308:'Permanent Redirect · Redirection permanente',
  400:'Bad Request · Requête incorrecte',401:'Unauthorized · Non authentifié',403:'Forbidden · Accès interdit',404:'Not Found · Page introuvable',405:'Method Not Allowed · Méthode non autorisée',408:'Request Timeout · Délai dépassé',409:'Conflict · Conflit',418:'I\'m a Teapot · Je suis une théière (blague RFC)',429:'Too Many Requests · Trop de requêtes',
  500:'Internal Server Error · Erreur serveur',501:'Not Implemented · Non implémenté',502:'Bad Gateway · Mauvaise passerelle',503:'Service Unavailable · Service indisponible',504:'Gateway Timeout · Délai passerelle dépassé'
};
function renderHttpStatus() {
  let html = `<div style="background:linear-gradient(135deg,#5DADE2,#787C7E); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🌐</div><div style="font-size:16px; font-weight:800;">HTTP status decoder</div>
  </div>
  <input type="number" id="hs-code" class="input" placeholder="Code HTTP (404, 500...)" min="100" max="599" oninput="hsDecode()" style="margin-top:14px;">
  <div id="hs-result" style="margin-top:14px;"></div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:18px;">📚 Codes courants</h3>`;
  Object.entries(HTTP_STATUS).forEach(([code, desc]) => {
    const c = parseInt(code);
    const color = c < 200 ? '#787C7E' : c < 300 ? '#5DD68F' : c < 400 ? '#5DADE2' : c < 500 ? '#FF8C42' : '#E14D6B';
    html += `<div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-top:5px; display:flex; gap:10px; align-items:center;">
      <div style="background:${color}; color:white; padding:4px 10px; border-radius:6px; font-weight:900; min-width:50px; text-align:center;">${code}</div>
      <div style="font-size:12px; flex:1;">${escapeHtml(desc)}</div>
    </div>`;
  });
  document.getElementById('httpstatus-content').innerHTML = html;
}
function hsDecode() {
  const code = parseInt(document.getElementById('hs-code').value);
  if (!code || code < 100 || code > 599) { document.getElementById('hs-result').innerHTML = ''; return; }
  const desc = HTTP_STATUS[code] || 'Code non standard';
  const color = code < 200 ? '#787C7E' : code < 300 ? '#5DD68F' : code < 400 ? '#5DADE2' : code < 500 ? '#FF8C42' : '#E14D6B';
  const cat = code < 200 ? 'Information' : code < 300 ? 'Succès' : code < 400 ? 'Redirection' : code < 500 ? 'Erreur client' : 'Erreur serveur';
  document.getElementById('hs-result').innerHTML = `<div style="background:${color}; color:white; padding:24px; border-radius:14px; text-align:center;">
    <div style="font-size:48px; font-weight:900;">${code}</div>
    <div style="font-size:11px; opacity:0.9; margin-top:4px;">${cat}</div>
    <div style="font-size:14px; font-weight:700; margin-top:10px;">${escapeHtml(desc)}</div>
  </div>`;
}

