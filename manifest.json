function getFavs() {
  try { return JSON.parse(localStorage.getItem('nw_favs') || '[]'); } catch { return []; }
}
function saveFavs(arr) { localStorage.setItem('nw_favs', JSON.stringify(arr)); }

function isFav(page) { return getFavs().includes(page); }

function toggleFav(page) {
  const favs = getFavs();
  const idx = favs.indexOf(page);
  if (idx === -1) {
    favs.push(page);
    toast('⭐ Ajouté aux favoris');
  } else {
    favs.splice(idx, 1);
    toast('Retiré des favoris');
  }
  saveFavs(favs);
  renderFavs();
  updateTileStars();
}

// Affiche la section favoris
function renderFavs() {
  const favs = getFavs();
  const sec = document.getElementById('fav-section');
  const grid = document.getElementById('fav-grid');
  const count = document.getElementById('fav-count');
  if (!favs.length) { sec.style.display = 'none'; return; }
  sec.style.display = '';
  count.textContent = favs.length;
  // Pour chaque favori, on retrouve la tuile d'origine et on la clone
  let html = '';
  for (const page of favs) {
    // Cherche dans PAGE_INDEX
    const meta = PAGE_INDEX.find(p => p.page === page);
    if (meta) {
      const onclick = page.startsWith('watch_')
        ? `_curWatchType='${page.slice(6)}'; goTo('watch')`
        : `goTo('${page}')`;
      html += `<button class="home-tile is-fav" onclick="${onclick}" data-page="${page}"><span class="ico">${meta.ico}</span><span class="lbl">${meta.name}</span></button>`;
    }
  }
  grid.innerHTML = html;
  attachLongPress(grid);
}

// Met à jour l'étoile sur toutes les tuiles
function updateTileStars() {
  const favs = getFavs();
  document.querySelectorAll('.home-tile').forEach(tile => {
    const onclick = tile.getAttribute('onclick') || '';
    // Extrait page from goTo('xxx') 
    const m = onclick.match(/goTo\(['"]([^'"]+)['"]\)/);
    if (m) {
      let page = m[1];
      // Cas spécial watchlist
      if (page === 'watch') {
        const wm = onclick.match(/_curWatchType=['"]([^'"]+)['"]/) || onclick.match(/goToWatch\(['"]([^'"]+)['"]\)/);
        if (wm) page = 'watch_' + wm[1];
      }
      tile.classList.toggle('is-fav', favs.includes(page));
      tile.setAttribute('data-page', page);
    }
  });
}

// Long-press sur tuiles pour ouvrir menu
let _lpTimer = null, _lpTarget = null;
function attachLongPress(container) {
  container.querySelectorAll('.home-tile').forEach(tile => {
    if (tile._lpAttached) return;
    tile._lpAttached = true;
    const start = (e) => {
      _lpTarget = tile;
      _lpTimer = setTimeout(() => {
        e.preventDefault();
        showTileMenu(tile, e);
        _lpTimer = null;
        // Vibration feedback
        if (navigator.vibrate) navigator.vibrate(50);
      }, 500);
    };
    const cancel = () => { if (_lpTimer) clearTimeout(_lpTimer); _lpTimer = null; };
    tile.addEventListener('touchstart', start, { passive:true });
    tile.addEventListener('touchend', cancel);
    tile.addEventListener('touchmove', cancel);
    tile.addEventListener('touchcancel', cancel);
    // Aussi clic droit pour desktop
    tile.addEventListener('contextmenu', (e) => {
      e.preventDefault();
      showTileMenu(tile, e);
    });
  });
}

function showTileMenu(tile, e) {
  const page = tile.getAttribute('data-page');
  if (!page) return;
  _lpTarget = tile;
  const menu = document.getElementById('tile-menu');
  const bg = document.getElementById('tile-menu-bg');
  const fav = isFav(page);
  document.getElementById('tile-menu-fav-ico').textContent = fav ? '⭐' : '☆';
  document.getElementById('tile-menu-fav-txt').textContent = fav ? 'Retirer des favoris' : 'Ajouter aux favoris';
  // Position près de la tuile
  const rect = tile.getBoundingClientRect();
  let x = rect.left + rect.width / 2 - 80;
  let y = rect.bottom + 8;
  // Clamp à l'écran
  if (x < 8) x = 8;
  if (x + 160 > window.innerWidth - 8) x = window.innerWidth - 168;
  if (y + 60 > window.innerHeight - 8) y = rect.top - 60;
  menu.style.left = x + 'px';
  menu.style.top = y + 'px';
  menu.classList.add('open');
  bg.classList.add('open');
}
function closeTileMenu() {
  document.getElementById('tile-menu').classList.remove('open');
  document.getElementById('tile-menu-bg').classList.remove('open');
}
function toggleFavFromMenu() {
  if (!_lpTarget) return;
  const page = _lpTarget.getAttribute('data-page');
  closeTileMenu();
  if (page) toggleFav(page);
}

// Init au chargement de l'accueil
function initHomeFavs() {
  // Indexer toutes les tuiles
  updateTileStars();
  // Attacher long-press partout
  document.querySelectorAll('.home-grid').forEach(g => attachLongPress(g));
  // Render section favoris
  renderFavs();
}

async function runSearch() {
  const q = document.getElementById('search-input').value.trim().toLowerCase();
  const out = document.getElementById('search-results');
  if (!q || q.length < 2) {
    out.innerHTML = '<p style="color:var(--textSec); padding:20px; text-align:center; font-size:13px;">Tape au moins 2 caractères...</p>';
    return;
  }
  const results = [];
  const match = (s) => s && String(s).toLowerCase().includes(q);

  // Notes
  for (const n of await dbAll('notes')) {
    if (match(n.title) || match(n.content)) {
      results.push({ icon: '📌', label: 'Note', name: n.title || '(sans titre)', preview: (n.content||'').slice(0,60), action: () => { closeModal('modal-search'); openNote(n); } });
    }
  }
  // Homework
  for (const h of await dbAll('homework')) {
    if (match(h.name) || match(h.subject) || match(h.note)) {
      results.push({ icon: '📝', label: 'Devoir', name: h.name, preview: `${h.subject||''} · ${h.due||''}`, action: () => { closeModal('modal-search'); goTo('homework'); } });
    }
  }
  // Grades
  for (const g of await dbAll('grades')) {
    if (match(g.subject) || match(g.name)) {
      results.push({ icon: '📊', label: 'Note', name: `${g.value}/${g.max} en ${g.subject}`, preview: g.name || '', action: () => { closeModal('modal-search'); goTo('grades'); } });
    }
  }
  // Tracks
  for (const t of await dbAll('tracks')) {
    if (match(t.title) || match(t.artist) || match(t.album)) {
      results.push({ icon: '🎵', label: 'Musique', name: t.title, preview: t.artist || '', action: () => { closeModal('modal-search'); goTo('music'); } });
    }
  }
  // Watchlist (all types)
  for (const w of await dbAll('watchlist')) {
    if (match(w.name) || (w.genres && w.genres.some(g => match(g))) || match(w.note)) {
      results.push({ icon: WATCH_TYPES[w.type]?.icon||'🎬', label: WATCH_TYPES[w.type]?.single||'item', name: w.name, preview: WATCH_STATUS[w.status]?.label||'', action: () => { closeModal('modal-search'); _curWatchType=w.type; setTimeout(() => openWatchDetail(w), 50); goTo('watch'); } });
    }
  }
  // Friends
  for (const f of await dbAll('friends')) {
    if (match(f.name) || match(f.discord) || match(f.how) || match(f.note)) {
      results.push({ icon: '👥', label: 'Ami', name: f.name, preview: f.discord || f.how || '', action: () => { closeModal('modal-search'); goTo('friends'); } });
    }
  }
  // Vault (no password preview!)
  for (const v of await dbAll('vault')) {
    if (match(v.app) || match(v.username) || match(v.email) || match(v.url)) {
      results.push({ icon: '🔐', label: 'Compte', name: v.app, preview: v.username || v.email || '', action: () => { closeModal('modal-search'); openVaultView(v); } });
    }
  }
  // Videos
  for (const v of await dbAll('videos')) {
    if (match(v.name)) {
      results.push({ icon: '🎥', label: 'Vidéo', name: v.name, preview: formatVideoTime(v.duration||0), action: () => { closeModal('modal-search'); openVideo(v); } });
    }
  }
  // Wallet transactions
  for (const t of await dbAll('wallet_tx')) {
    if (match(t.name) || match(t.note)) {
      const sign = t.kind === 'in' ? '+' : '−';
      results.push({ icon: t.kind==='in'?'💵':'💸', label: t.kind==='in'?'Rentrée':'Sortie', name: t.name, preview: `${sign}${t.amount.toFixed(2)} €`, action: () => { closeModal('modal-search'); goTo('wallet'); } });
    }
  }
  // Calendar events
  for (const e of await dbAll('events')) {
    if (match(e.name) || match(e.note)) {
      results.push({ icon: '📆', label: 'Événement', name: e.name, preview: new Date(e.date).toLocaleDateString('fr-FR') + (e.time?' '+e.time:''), action: () => { closeModal('modal-search'); const d = new Date(e.date); _calYear=d.getFullYear(); _calMonth=d.getMonth(); _calSelectedDate=e.date; goTo('calendar'); } });
    }
  }
  // Sobriety
  for (const s of await dbAll('sobriety')) {
    if (match(s.name) || match(s.note)) {
      results.push({ icon: s.icon||'🌿', label: 'Sobriété', name: s.name, preview: 'Arrêt le ' + new Date(s.startDate).toLocaleDateString('fr-FR'), action: () => { closeModal('modal-search'); goTo('sobriety'); } });
    }
  }
  // Wheels
  for (const w of await dbAll('wheels')) {
    if (match(w.name) || w.options.some(o => match(o))) {
      results.push({ icon: '🎡', label: 'Roue', name: w.name, preview: w.options.length + ' options', action: () => { closeModal('modal-search'); openWheelSpin(w); } });
    }
  }
  // Sleep notes
  for (const sl of await dbAll('sleep_log')) {
    if (match(sl.note)) {
      results.push({ icon: '😴', label: 'Nuit', name: new Date(sl.date).toLocaleDateString('fr-FR'), preview: (sl.note||'').slice(0,50), action: () => { closeModal('modal-search'); goTo('sleep'); } });
    }
  }
  // Weight notes
  for (const wg of await dbAll('weight_log')) {
    if (match(wg.note)) {
      results.push({ icon: '⚖️', label: 'Pesée', name: new Date(wg.date).toLocaleDateString('fr-FR') + ' · ' + wg.value.toFixed(1) + ' kg', preview: wg.note||'', action: () => { closeModal('modal-search'); goTo('weight'); } });
    }
  }
  // Quotes
  for (const q2 of await dbAll('quotes')) {
    if (match(q2.text) || match(q2.author)) {
      results.push({ icon: '💬', label: 'Citation', name: (q2.text||'').slice(0,40), preview: q2.author || '', action: () => { closeModal('modal-search'); goTo('quotes'); } });
    }
  }
  // Wishes
  for (const w of await dbAll('wishes')) {
    if (match(w.name) || match(w.note)) {
      results.push({ icon: '💝', label: 'Wishlist', name: w.name, preview: w.price||'', action: () => { closeModal('modal-search'); goTo('wishlist'); } });
    }
  }
  // Cards (deck cards)
  for (const c of await dbAll('cards')) {
    if (match(c.front) || match(c.back)) {
      results.push({ icon: '🃏', label: 'Carte', name: (c.front||'').slice(0,40), preview: (c.back||'').slice(0,40), action: () => { closeModal('modal-search'); goTo('flashcards'); } });
    }
  }
  // Decks
  for (const d of await dbAll('decks')) {
    if (match(d.name) || match(d.description)) {
      results.push({ icon: '🃏', label: 'Deck', name: d.name, preview: d.description||'', action: () => { closeModal('modal-search'); openDeckDetail(d); } });
    }
  }
  // Render
  if (results.length === 0) {
    out.innerHTML = '<p style="color:var(--textSec); padding:20px; text-align:center; font-size:13px;">Aucun résultat pour "' + escapeHtml(q) + '"</p>';
    return;
  }
  out.innerHTML = '';
  for (const r of results.slice(0, 50)) {
    const row = document.createElement('button');
    row.className = 'list-row';
    row.style.marginBottom = '4px';
    row.innerHTML = `
      <span style="font-size:22px;">${r.icon}</span>
      <div class="info">
        <div class="name">${escapeHtml(r.name)}</div>
        <div class="sub">${escapeHtml(r.label)} · ${escapeHtml(r.preview)}</div>
      </div>
    `;
    row.onclick = r.action;
    out.appendChild(row);
  }
  if (results.length > 50) {
    const info = document.createElement('p');
    info.style.cssText = 'color:var(--textSec); padding:12px; text-align:center; font-size:12px;';
    info.textContent = `+ ${results.length - 50} autres résultats — affine ta recherche`;
    out.appendChild(info);
  }
}

// ============================================================
// GRADES
// ============================================================
let _editingGrade = null;

async function renderGrades() {
  const grades = await dbAll('grades');
  // datalist for subjects
  const subjects = [...new Set(grades.map(g => g.subject).filter(Boolean))];
  const dl = document.getElementById('grade-subjects-dl');
  dl.innerHTML = subjects.map(s => `<option value="${escapeHtml(s)}">`).join('');
  // Avg
  const avgEl = document.getElementById('grades-avg');
  const infoEl = document.getElementById('grades-avg-info');
  if (grades.length === 0) {
    avgEl.textContent = '—';
    infoEl.textContent = '0 note';
  } else {
    let sumPts = 0, sumCoef = 0;
    for (const g of grades) {
      const norm = (g.value / g.max) * 20;
      sumPts += norm * g.coef;
      sumCoef += g.coef;
    }
    const avg = sumPts / sumCoef;
    avgEl.textContent = avg.toFixed(2);
    infoEl.textContent = `${grades.length} note${grades.length>1?'s':''}`;
  }
  // By subject
  const bySub = {};
  for (const g of grades) {
    const s = g.subject || '(autre)';
    if (!bySub[s]) bySub[s] = [];
    bySub[s].push(g);
  }
  const el = document.getElementById('grades-by-subject');
  el.innerHTML = '';
  if (grades.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">📊</div><h3>Aucune note</h3><p>Ajoute tes notes par matière avec leur coefficient.</p></div>`;
    return;
  }
  for (const sub of Object.keys(bySub).sort()) {
    const list = bySub[sub];
    let sumPts = 0, sumCoef = 0;
    for (const g of list) {
      sumPts += (g.value / g.max) * 20 * g.coef;
      sumCoef += g.coef;
    }
    const subAvg = sumPts / sumCoef;
    const sec = document.createElement('div');
    sec.className = 'section';
    sec.innerHTML = `
      <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:10px;">
        <h3 style="font-size:15px; font-weight:700;">${escapeHtml(sub)}</h3>
        <div style="font-size:18px; font-weight:800; color:var(--primary);">${subAvg.toFixed(2)}</div>
      </div>
      <div class="grade-list"></div>
    `;
    const lEl = sec.querySelector('.grade-list');
    list.sort((a,b) => (b.date||'').localeCompare(a.date||''));
    for (const g of list) {
      const row = document.createElement('button');
      row.style.cssText = 'display:flex; align-items:center; gap:10px; padding:8px 10px; background:var(--surfaceAlt); border-radius:10px; margin-bottom:4px; width:100%; text-align:left;';
      const color = g.value/g.max >= 0.5 ? 'var(--success)' : 'var(--danger)';
      row.innerHTML = `
        <div style="font-size:16px; font-weight:800; color:${color}; min-width:54px;">${g.value}/${g.max}</div>
        <div style="flex:1; min-width:0;">
          <div style="font-size:13px; font-weight:600;">${escapeHtml(g.name||'(sans titre)')}</div>
          <div style="font-size:11px; color:var(--textSec);">Coef ${g.coef} · ${g.date ? new Date(g.date).toLocaleDateString('fr-FR') : ''}</div>
        </div>
      `;
      row.onclick = () => openGradeModal(g);
      lEl.appendChild(row);
    }
    el.appendChild(sec);
  }
}

async function openGradeModal(grade) {
  _editingGrade = grade;
  document.getElementById('grade-modal-title').textContent = grade ? 'Modifier' : 'Nouvelle note';
  document.getElementById('grade-subject-input').value = grade ? grade.subject : '';
  document.getElementById('grade-name-input').value = grade ? (grade.name||'') : '';
  document.getElementById('grade-value-input').value = grade ? grade.value : '';
  document.getElementById('grade-max-input').value = grade ? grade.max : 20;
  document.getElementById('grade-coef-input').value = grade ? grade.coef : 1;
  document.getElementById('grade-date-input').value = grade ? grade.date : new Date().toISOString().split('T')[0];
  document.getElementById('grade-del-btn').style.display = grade ? 'inline-flex' : 'none';
  // Refresh datalist
  const grades = await dbAll('grades');
  const subjects = [...new Set(grades.map(g => g.subject).filter(Boolean))];
  document.getElementById('grade-subjects-dl').innerHTML = subjects.map(s => `<option value="${escapeHtml(s)}">`).join('');
  openModal('modal-grade');
}

async function saveGrade() {
  const subject = document.getElementById('grade-subject-input').value.trim();
  const name = document.getElementById('grade-name-input').value.trim();
  const value = parseFloat(document.getElementById('grade-value-input').value);
  const max = parseFloat(document.getElementById('grade-max-input').value) || 20;
  const coef = parseFloat(document.getElementById('grade-coef-input').value) || 1;
  const date = document.getElementById('grade-date-input').value;
  if (!subject || isNaN(value)) { alert('Renseigne au moins matière + note.'); return; }
  if (_editingGrade) await dbPut('grades', { ..._editingGrade, subject, name, value, max, coef, date });
  else await dbAdd('grades', { subject, name, value, max, coef, date, created_at: new Date().toISOString() });
  closeModal('modal-grade');
  renderGrades();
}

async function deleteGradeNow() {
  if (!confirm('Supprimer cette note ?')) return;
  await dbDel('grades', _editingGrade.id);
  closeModal('modal-grade');
  renderGrades();
}

// ============================================================
// HOMEWORK
// ============================================================
let _editingHw = null;
let _hwFilter = 'todo';

async function renderHw() {
  const hw = await dbAll('homework');
  const subjects = [...new Set(hw.map(h => h.subject).filter(Boolean))];
  document.getElementById('hw-subjects-dl').innerHTML = subjects.map(s => `<option value="${escapeHtml(s)}">`).join('');
  // Chips
  const chips = document.getElementById('hw-chips');
  chips.innerHTML = '';
  const todoCount = hw.filter(h => !h.done).length;
  const doneCount = hw.filter(h => h.done).length;
  chips.appendChild(createChip(`À faire (${todoCount})`, '📝', null, _hwFilter==='todo', () => { _hwFilter='todo'; renderHw(); }));
  chips.appendChild(createChip(`Terminés (${doneCount})`, '✅', null, _hwFilter==='done', () => { _hwFilter='done'; renderHw(); }));
  chips.appendChild(createChip(`Tous (${hw.length})`, '✨', null, _hwFilter==='all', () => { _hwFilter='all'; renderHw(); }));
  // Filter & sort
  let list = hw;
  if (_hwFilter === 'todo') list = list.filter(h => !h.done);
  else if (_hwFilter === 'done') list = list.filter(h => h.done);
  list.sort((a,b) => (a.due||'9999').localeCompare(b.due||'9999'));
  const el = document.getElementById('hw-list');
  el.innerHTML = '';
  if (list.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">📝</div><h3>Aucun devoir</h3><p>Ajoute tes devoirs avec leur date butoir.</p></div>`;
    return;
  }
  const today = new Date().toISOString().split('T')[0];
  for (const h of list) {
    const overdue = h.due && h.due < today && !h.done;
    const dueLabel = h.due ? new Date(h.due).toLocaleDateString('fr-FR', {weekday:'short', day:'numeric', month:'short'}) : '';
    const prioColor = h.priority === 'high' ? 'var(--danger)' : h.priority === 'low' ? 'var(--success)' : '#FFD166';
    const prioIcon = h.priority === 'high' ? '🔴' : h.priority === 'low' ? '🟢' : '🟡';
    const row = document.createElement('div');
    row.style.cssText = `display:flex; align-items:center; gap:10px; padding:12px; background:var(--surface); border-radius:14px; margin-bottom:6px; ${overdue?'border-left:3px solid var(--danger);':''}`;
    row.innerHTML = `
      <button class="todo-check ${h.done?'checked':''}" data-act="check" style="width:26px; height:26px;">${h.done?'✓':''}</button>
      <div style="flex:1; min-width:0;">
        <div style="font-size:14px; font-weight:600; ${h.done?'text-decoration:line-through; opacity:0.5;':''}">${escapeHtml(h.name)}</div>
        <div style="font-size:11px; color:var(--textSec);">${prioIcon} ${escapeHtml(h.subject||'')} ${dueLabel?'· 📅 '+dueLabel:''} ${overdue?'⚠️ en retard':''}</div>
      </div>
      <button data-act="edit" style="font-size:18px; padding:4px 8px; background:transparent;">⋯</button>
    `;
    row.querySelector('[data-act="check"]').onclick = async () => {
      h.done = !h.done;
      await dbPut('homework', h);
      renderHw();
    };
    row.querySelector('[data-act="edit"]').onclick = () => openHwModal(h);
    el.appendChild(row);
  }
}

async function openHwModal(hw) {
  _editingHw = hw;
  document.getElementById('hw-modal-title').textContent = hw ? 'Modifier' : 'Nouveau devoir';
  document.getElementById('hw-name-input').value = hw ? hw.name : '';
  document.getElementById('hw-subject-input').value = hw ? (hw.subject||'') : '';
  document.getElementById('hw-due-input').value = hw ? (hw.due||'') : '';
  document.getElementById('hw-priority-input').value = hw ? hw.priority : 'med';
  document.getElementById('hw-note-input').value = hw ? (hw.note||'') : '';
  document.getElementById('hw-del-btn').style.display = hw ? 'inline-flex' : 'none';
  const all = await dbAll('homework');
  const subjects = [...new Set(all.map(h => h.subject).filter(Boolean))];
  document.getElementById('hw-subjects-dl').innerHTML = subjects.map(s => `<option value="${escapeHtml(s)}">`).join('');
  openModal('modal-hw');
}

async function saveHw() {
  const name = document.getElementById('hw-name-input').value.trim();
  const subject = document.getElementById('hw-subject-input').value.trim();
  const due = document.getElementById('hw-due-input').value;
  const priority = document.getElementById('hw-priority-input').value;
  const note = document.getElementById('hw-note-input').value.trim();
  if (!name) { alert('Donne un titre.'); return; }
  if (_editingHw) await dbPut('homework', { ..._editingHw, name, subject, due, priority, note });
  else await dbAdd('homework', { name, subject, due, priority, note, done: false, created_at: new Date().toISOString() });
  closeModal('modal-hw');
  renderHw();
}

async function deleteHwNow() {
  if (!confirm('Supprimer ce devoir ?')) return;
  await dbDel('homework', _editingHw.id);
  closeModal('modal-hw');
  renderHw();
}

// ============================================================
// SCHEDULE
// ============================================================
let _editingClass = null;
let _classColor = '#FF6FA3';
let _scheduleDay = new Date().getDay() || 7; // sunday=0 -> 7 (we use mon=1)
if (_scheduleDay === 0) _scheduleDay = 1;
if (_scheduleDay > 6) _scheduleDay = 1;
const DAY_NAMES = ['','Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi'];

async function renderSchedule() {
  const classes = await dbAll('classes');
  const subjects = [...new Set(classes.map(c => c.subject).filter(Boolean))];
  document.getElementById('class-subjects-dl').innerHTML = subjects.map(s => `<option value="${escapeHtml(s)}">`).join('');
  // Chips for days
  const chips = document.getElementById('schedule-chips');
  chips.innerHTML = '';
  for (let d=1; d<=6; d++) {
    chips.appendChild(createChip(DAY_NAMES[d], null, null, _scheduleDay===d, () => { _scheduleDay=d; renderSchedule(); }));
  }
  // List for selected day
  const list = classes.filter(c => c.day === _scheduleDay).sort((a,b) => (a.start||'').localeCompare(b.start||''));
  const el = document.getElementById('schedule-list');
  el.innerHTML = '';
  if (list.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">🗓️</div><h3>Aucun cours</h3><p>Tape sur + pour ajouter un cours pour ${DAY_NAMES[_scheduleDay]}.</p></div>`;
    return;
  }
  // Highlight current class
  const now = new Date();
  const todayDay = now.getDay() === 0 ? 7 : now.getDay();
  const nowTime = String(now.getHours()).padStart(2,'0') + ':' + String(now.getMinutes()).padStart(2,'0');
  for (const c of list) {
    const isCurrent = todayDay === c.day && c.start <= nowTime && nowTime < c.end;
    const row = document.createElement('button');
    row.style.cssText = `display:flex; gap:12px; padding:12px; background:var(--surface); border-radius:14px; margin-bottom:6px; width:100%; text-align:left; border-left:5px solid ${c.color}; ${isCurrent?'box-shadow:0 0 0 2px var(--primary);':''}`;
    row.innerHTML = `
      <div style="text-align:center; min-width:64px;">
        <div style="font-size:14px; font-weight:700;">${c.start}</div>
        <div style="font-size:11px; color:var(--textSec);">${c.end}</div>
      </div>
      <div style="flex:1; min-width:0;">
        <div style="font-size:15px; font-weight:600;">${escapeHtml(c.subject)} ${isCurrent?'<span style="background:var(--primary); color:white; font-size:10px; padding:2px 6px; border-radius:8px; margin-left:6px;">EN COURS</span>':''}</div>
        <div style="font-size:12px; color:var(--textSec);">${c.room?'📍 '+escapeHtml(c.room):''} ${c.teacher?'· '+escapeHtml(c.teacher):''}</div>
      </div>
    `;
    row.onclick = () => openClassModal(c, _scheduleDay);
    el.appendChild(row);
  }
}

function openClassModal(cls, day) {
  _editingClass = cls;
  document.getElementById('class-modal-title').textContent = cls ? 'Modifier' : 'Nouveau cours';
  document.getElementById('class-subject-input').value = cls ? cls.subject : '';
  document.getElementById('class-day-input').value = cls ? cls.day : (day || _scheduleDay);
  document.getElementById('class-start-input').value = cls ? cls.start : '08:00';
  document.getElementById('class-end-input').value = cls ? cls.end : '09:00';
  document.getElementById('class-room-input').value = cls ? (cls.room||'') : '';
  document.getElementById('class-teacher-input').value = cls ? (cls.teacher||'') : '';
  _classColor = cls ? cls.color : '#FF6FA3';
  document.getElementById('class-del-btn').style.display = cls ? 'inline-flex' : 'none';
  const palette = ['#FF6FA3','#FFB6D9','#C77DFF','#9D4EDD','#7B61FF','#5DD6E5','#5DD68F','#FFD166','#FF8C42','#FF6B7A','#A78BFA','#06FFA5'];
  const sw = document.getElementById('class-swatches');
  sw.innerHTML = '';
  for (const c of palette) {
    const b = document.createElement('button');
    b.className = 'swatch' + (c===_classColor?' selected':'');
    b.style.background = c;
    b.textContent = c===_classColor ? '✓' : '';
    b.onclick = () => { _classColor = c; openClassModal(cls, day); };
    sw.appendChild(b);
  }
  openModal('modal-class');
}

async function saveClass() {
  const subject = document.getElementById('class-subject-input').value.trim();
  const day = parseInt(document.getElementById('class-day-input').value);
  const start = document.getElementById('class-start-input').value;
  const end = document.getElementById('class-end-input').value;
  const room = document.getElementById('class-room-input').value.trim();
  const teacher = document.getElementById('class-teacher-input').value.trim();
  if (!subject || !start || !end) { alert('Remplis matière + horaires.'); return; }
  if (_editingClass) await dbPut('classes', { ..._editingClass, subject, day, start, end, room, teacher, color: _classColor });
  else await dbAdd('classes', { subject, day, start, end, room, teacher, color: _classColor, created_at: new Date().toISOString() });
  closeModal('modal-class');
  _scheduleDay = day;
  renderSchedule();
}

async function deleteClassNow() {
  if (!confirm('Supprimer ce cours ?')) return;
  await dbDel('classes', _editingClass.id);
  closeModal('modal-class');
  renderSchedule();
}

// ============================================================
// FLASHCARDS
// ============================================================
let _editingDeck = null;
let _currentDeck = null;
let _editingCard = null;
let _reviewCards = [];
let _reviewIndex = 0;
let _reviewFlipped = false;

async function renderDecks() {
  const decks = await dbAll('decks');
  const cards = await dbAll('cards');
  const el = document.getElementById('decks-list');
  el.innerHTML = '';
  if (decks.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">🃏</div><h3>Aucun deck</h3><p>Crée des decks de flashcards (vocabulaire, formules, dates...).</p></div>`;
    return;
  }
  for (const d of decks) {
    const count = cards.filter(c => c.deck_id === d.id).length;
    const due = cards.filter(c => c.deck_id === d.id && (!c.next_due || c.next_due <= new Date().toISOString().split('T')[0])).length;
    const row = document.createElement('button');
    row.className = 'list-row';
    row.innerHTML = `
      <div style="width:42px; height:42px; border-radius:10px; background:linear-gradient(135deg, var(--primary), var(--accent)); display:flex; align-items:center; justify-content:center; font-size:20px; color:white;">🃏</div>
      <div class="info">
        <div class="name">${escapeHtml(d.name)}</div>
        <div class="sub">${count} carte${count>1?'s':''}${due>0?' · '+due+' à réviser':''}${d.description?' · '+escapeHtml(d.description):''}</div>
      </div>
