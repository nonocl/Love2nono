const SKIN_DEFAULT_AM = [
  {ico:'💦', name:'Nettoyant doux', desc:'À l\'eau tiède'},
  {ico:'🌿', name:'Tonique', desc:'Sur coton ou tapotements'},
  {ico:'💧', name:'Sérum hydratant', desc:'Acide hyaluronique idéal'},
  {ico:'🧴', name:'Crème hydratante', desc:''},
  {ico:'☀️', name:'Crème solaire SPF50', desc:'Étape la plus importante !'}
];
const SKIN_DEFAULT_PM = [
  {ico:'💄', name:'Démaquillant huile', desc:'Si maquillage'},
  {ico:'💦', name:'Nettoyant', desc:'Double cleansing'},
  {ico:'🍃', name:'Exfoliant', desc:'2-3× par semaine seulement'},
  {ico:'🧪', name:'Sérum traitant', desc:'Rétinol, vitamine C, niacinamide'},
  {ico:'👁', name:'Contour des yeux', desc:''},
  {ico:'🌙', name:'Crème de nuit riche', desc:''}
];
function getSkin() { 
  let s; try { s = JSON.parse(localStorage.getItem('nw_skin') || 'null'); } catch { s = null; }
  if (!s) s = { am: SKIN_DEFAULT_AM, pm: SKIN_DEFAULT_PM, log: {} };
  return s;
}
function saveSkin(s) { localStorage.setItem('nw_skin', JSON.stringify(s)); }
function renderSkincare() {
  const s = getSkin();
  const today = todayKey();
  const log = s.log[today] || { am: [], pm: [] };
  
  let html = `<div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">
    <div style="background:linear-gradient(135deg, #FFD166, #FF8C42); color:white; padding:14px; border-radius:14px; text-align:center;">
      <div style="font-size:24px;">🌅</div>
      <div style="font-size:13px; font-weight:700; margin-top:4px;">Matin</div>
      <div style="font-size:18px; font-weight:900;">${log.am.length}/${s.am.length}</div>
    </div>
    <div style="background:linear-gradient(135deg, #5DADE2, #A78BFA); color:white; padding:14px; border-radius:14px; text-align:center;">
      <div style="font-size:24px;">🌙</div>
      <div style="font-size:13px; font-weight:700; margin-top:4px;">Soir</div>
      <div style="font-size:18px; font-weight:900;">${log.pm.length}/${s.pm.length}</div>
    </div>
  </div>`;
  
  ['am', 'pm'].forEach(period => {
    const items = s[period];
    const done = log[period];
    html += `<h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-top:18px;">${period === 'am' ? '🌅 Routine matin' : '🌙 Routine soir'}</h3>`;
    items.forEach((it, idx) => {
      const checked = done.includes(idx);
      html += `<div onclick="skinToggle('${period}', ${idx})" style="background:var(--surface); padding:12px 14px; border-radius:12px; margin-bottom:6px; display:flex; gap:10px; align-items:center; cursor:pointer; ${checked ? 'opacity:0.6;' : ''}">
        <div style="font-size:24px;">${it.ico || '✨'}</div>
        <div style="flex:1;">
          <div style="font-size:13px; font-weight:700; ${checked ? 'text-decoration:line-through;' : ''}">${escapeHtml(it.name)}</div>
          ${it.desc ? `<div style="font-size:11px; color:var(--textSec);">${escapeHtml(it.desc)}</div>` : ''}
        </div>
        <div style="width:24px; height:24px; border-radius:50%; background:${checked ? 'var(--success)' : 'transparent'}; border:2px solid ${checked ? 'var(--success)' : 'var(--border)'}; display:flex; align-items:center; justify-content:center; color:white; font-size:14px;">${checked ? '✓' : ''}</div>
      </div>`;
    });
  });
  
  document.getElementById('skin-content').innerHTML = html;
}
function skinToggle(period, idx) {
  const s = getSkin();
  const today = todayKey();
  if (!s.log[today]) s.log[today] = { am:[], pm:[] };
  const arr = s.log[today][period];
  if (arr.includes(idx)) s.log[today][period] = arr.filter(x => x !== idx);
  else arr.push(idx);
  saveSkin(s);
  renderSkincare();
}
function skinEdit() { goTo('skincare-edit'); }
function renderSkinEdit() {
  const s = getSkin();
  ['am', 'pm'].forEach(period => {
    const wrap = document.getElementById('skin-' + period);
    wrap.innerHTML = s[period].map((it, i) => `<div style="background:var(--surface); padding:10px; border-radius:10px; margin-bottom:6px; display:flex; gap:8px; align-items:center;">
      <div style="font-size:20px;">${it.ico || '✨'}</div>
      <div style="flex:1;">
        <input type="text" value="${escapeHtml(it.name)}" onchange="skinEditField('${period}', ${i}, 'name', this.value)" style="background:transparent; border:none; color:var(--text); font-weight:700; font-size:13px; width:100%; outline:none;">
        <input type="text" value="${escapeHtml(it.desc || '')}" onchange="skinEditField('${period}', ${i}, 'desc', this.value)" placeholder="Note (optionnel)" style="background:transparent; border:none; color:var(--textSec); font-size:11px; width:100%; outline:none; margin-top:2px;">
      </div>
      <button onclick="skinDel('${period}', ${i})" style="background:none; border:none; color:var(--danger); font-size:18px; cursor:pointer;">🗑</button>
    </div>`).join('');
  });
}
function skinEditField(period, i, field, val) {
  const s = getSkin(); s[period][i][field] = val; saveSkin(s);
}
function skinDel(period, i) {
  if (!confirm('Supprimer cette étape ?')) return;
  const s = getSkin(); s[period].splice(i, 1); saveSkin(s); renderSkinEdit();
}
function skinAdd(period) {
  const name = prompt('Nom de l\'étape ?');
  if (!name) return;
  const s = getSkin();
  s[period].push({ ico:'✨', name, desc:'' });
  saveSkin(s); renderSkinEdit();
}

// === GARDE-ROBE ===
const WARD_CATS = [
  {id:'all', name:'Tout', emoji:'👗'},
  {id:'haut', name:'Hauts', emoji:'👕'},
  {id:'bas', name:'Bas', emoji:'👖'},
  {id:'robe', name:'Robes', emoji:'👗'},
  {id:'manteau', name:'Manteaux', emoji:'🧥'},
  {id:'chaussure', name:'Chaussures', emoji:'👟'},
  {id:'acc', name:'Accessoires', emoji:'👜'},
  {id:'bijou', name:'Bijoux', emoji:'💍'},
  {id:'lingerie', name:'Lingerie', emoji:'🩱'}
];
let _wardFilter = 'all';
let _wardPhotoData = null;

async function renderWardrobe() {
  // Tabs
  const tabs = document.getElementById('ward-cats');
  tabs.innerHTML = WARD_CATS.map(c =>
    `<button onclick="_wardFilter='${c.id}'; renderWardrobe();" class="btn ${_wardFilter === c.id ? 'primary' : 'alt'}" style="font-size:11px; padding:6px 10px; flex-shrink:0;">${c.emoji} ${c.name}</button>`
  ).join('');
  
  let items = await dbAll('wardrobe');
  if (!items) items = [];
  if (_wardFilter !== 'all') items = items.filter(i => i.cat === _wardFilter);
  
  const grid = document.getElementById('ward-grid');
  if (!items.length) {
    grid.innerHTML = '<div style="grid-column:1/-1; text-align:center; padding:30px; color:var(--textSec);">Aucun vêtement. Tap + pour en ajouter.</div>';
    return;
  }
  grid.innerHTML = items.map(it => `<div onclick="wardOpen(${it.id})" style="background:var(--surface); border-radius:14px; overflow:hidden; cursor:pointer;">
    ${it.photo ? `<img src="${it.photo}" style="width:100%; aspect-ratio:1; object-fit:cover;">` : `<div style="aspect-ratio:1; background:var(--surfaceAlt); display:flex; align-items:center; justify-content:center; font-size:40px;">${WARD_CATS.find(c=>c.id===it.cat)?.emoji || '👕'}</div>`}
    <div style="padding:8px;">
      <div style="font-size:12px; font-weight:700; line-height:1.2;">${escapeHtml(it.name || 'Sans nom')}</div>
      ${it.color ? `<div style="font-size:10px; color:var(--textSec); margin-top:2px;">${escapeHtml(it.color)}</div>` : ''}
    </div>
  </div>`).join('');
}
function wardAddNew() {
  _wardPhotoData = null;
  document.getElementById('ward-preview').innerHTML = '📷 Tap pour photo';
  document.getElementById('ward-name').value = '';
  document.getElementById('ward-color').value = '';
  document.getElementById('ward-notes').value = '';
  goTo('wardrobe-add');
}
function wardLoadPhoto(input) {
  const f = (input.files || [])[0]; if (!f) return;
  const r = new FileReader();
  r.onload = e => {
    const img = new Image();
    img.onload = () => {
      // Resize 600px max
      const c = document.createElement('canvas');
      const max = 600;
      const ratio = Math.min(max / img.width, max / img.height, 1);
      c.width = img.width * ratio; c.height = img.height * ratio;
      c.getContext('2d').drawImage(img, 0, 0, c.width, c.height);
      _wardPhotoData = c.toDataURL('image/jpeg', 0.85);
      document.getElementById('ward-preview').innerHTML = `<img src="${_wardPhotoData}" style="width:100%; height:100%; object-fit:cover; border-radius:14px;">`;
    };
    img.src = e.target.result;
  };
  r.readAsDataURL(f);
}
async function wardSave() {
  const item = {
    cat: document.getElementById('ward-cat').value,
    name: document.getElementById('ward-name').value.trim() || 'Sans nom',
    color: document.getElementById('ward-color').value.trim(),
    season: document.getElementById('ward-season').value,
    notes: document.getElementById('ward-notes').value.trim(),
    photo: _wardPhotoData,
    created: Date.now()
  };
  await dbAdd('wardrobe', item);
  toast('👗 Ajouté à la garde-robe !');
  goTo('wardrobe');
}
async function wardOpen(id) {
  const it = (await dbAll('wardrobe')).find(x => x.id === id);
  if (!it) return;
  if (confirm(`${it.name}\n${it.color || ''}\n\n${it.notes || ''}\n\nSupprimer ?`)) {
    await dbDel('wardrobe', id);
    toast('🗑 Supprimé');
    renderWardrobe();
  }
}

// === BEAUTY BOX ===
function getBeauty() { try { return JSON.parse(localStorage.getItem('nw_beauty') || '[]'); } catch { return []; } }
function saveBeauty(d) { localStorage.setItem('nw_beauty', JSON.stringify(d)); }
function beautyAdd() {
  document.getElementById('bty-name').value = '';
  document.getElementById('bty-brand').value = '';
  document.getElementById('bty-opened').value = todayKey();
  goTo('beauty-add');
}
function beautySave() {
  const name = document.getElementById('bty-name').value.trim();
  if (!name) return toast('Nom requis');
  const item = {
    id: 'b_' + Date.now(),
    type: document.getElementById('bty-type').value,
    name,
    brand: document.getElementById('bty-brand').value.trim(),
    opened: document.getElementById('bty-opened').value,
    pao: parseInt(document.getElementById('bty-pao').value),
    rating: parseInt(document.getElementById('bty-rating').value)
  };
  const d = getBeauty(); d.push(item); saveBeauty(d);
  toast('💄 Ajouté');
  goTo('beauty');
}
function renderBeauty() {
  const d = getBeauty();
  if (!d.length) {
    document.getElementById('beauty-list').innerHTML = '<p style="text-align:center; color:var(--textSec); padding:30px;">Beauty box vide. Tap + pour ajouter.</p>';
    return;
  }
  // Trier par expiration la plus proche
  const today = new Date();
  d.forEach(it => {
    if (it.opened) {
      const exp = new Date(it.opened);
      exp.setMonth(exp.getMonth() + (it.pao || 12));
      it._exp = exp;
      it._daysLeft = Math.floor((exp - today) / 86400000);
    }
  });
  d.sort((a,b) => (a._daysLeft || 9999) - (b._daysLeft || 9999));
  const types = {skincare:'✨', makeup:'💄', parfum:'🌸', cheveux:'💇', ongles:'💅', corps:'🧴'};
  document.getElementById('beauty-list').innerHTML = d.map(it => {
    let warn = '', col = 'var(--success)';
    if (it._daysLeft != null) {
      if (it._daysLeft < 0) { warn = '⚠️ EXPIRÉ'; col = 'var(--danger)'; }
      else if (it._daysLeft < 30) { warn = `⚠️ Expire dans ${it._daysLeft} jours`; col = '#FF8C42'; }
      else { warn = `${Math.floor(it._daysLeft/30)} mois restants`; col = 'var(--success)'; }
    }
    return `<div style="background:var(--surface); padding:12px 14px; border-radius:12px; margin-bottom:6px; border-left:4px solid ${col};">
      <div style="display:flex; gap:10px; align-items:center;">
        <div style="font-size:28px;">${types[it.type] || '💄'}</div>
        <div style="flex:1;">
          <div style="font-size:13px; font-weight:700;">${escapeHtml(it.name)}</div>
          ${it.brand ? `<div style="font-size:11px; color:var(--textSec);">${escapeHtml(it.brand)}</div>` : ''}
          <div style="font-size:11px; color:${col}; margin-top:2px; font-weight:700;">${warn}</div>
          ${it.rating > 0 ? `<div style="font-size:11px;">${'⭐'.repeat(it.rating)}</div>` : ''}
        </div>
        <button onclick="beautyDel('${it.id}')" style="background:none; border:none; color:var(--danger); font-size:18px;">🗑</button>
      </div>
    </div>`;
  }).join('');
}
function beautyDel(id) {
  if (!confirm('Supprimer ?')) return;
  saveBeauty(getBeauty().filter(x => x.id !== id));
  renderBeauty();
}

