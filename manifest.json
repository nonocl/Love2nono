function calcUpdate() {
  document.getElementById('calc-display').textContent = state.calcCurrent;
  document.getElementById('calc-history-line').innerHTML = state.calcPrevious !== null ? `${state.calcPrevious} ${displayOp(state.calcOp)}` : '&nbsp;';
}
function displayOp(o) { return {'+':'+','-':'−','*':'×','/':'÷','%':'%'}[o] || ''; }
function calcDigit(d) {
  if (state.calcShouldReset) { state.calcCurrent = '0'; state.calcShouldReset = false; }
  if (d === '.' && state.calcCurrent.includes('.')) return;
  state.calcCurrent = state.calcCurrent === '0' && d !== '.' ? d : state.calcCurrent + d;
  calcUpdate();
}
function calcOp(op) {
  if (state.calcOp && !state.calcShouldReset) calcEquals();
  state.calcPrevious = parseFloat(state.calcCurrent);
  state.calcOp = op;
  state.calcShouldReset = true;
  calcUpdate();
}
function calcEquals() {
  if (state.calcOp === null) return;
  const a = state.calcPrevious, b = parseFloat(state.calcCurrent);
  let r = 0;
  switch (state.calcOp) {
    case '+': r = a+b; break;
    case '-': r = a-b; break;
    case '*': r = a*b; break;
    case '/': r = b===0 ? NaN : a/b; break;
    case '%': r = a*b/100; break;
  }
  const expr = `${a} ${displayOp(state.calcOp)} ${b} = ${r}`;
  state.calcHistoryList.unshift(expr);
  state.calcHistoryList = state.calcHistoryList.slice(0, 50);
  localStorage.setItem('nw_calc_history', JSON.stringify(state.calcHistoryList));
  state.calcCurrent = String(r);
  state.calcPrevious = null;
  state.calcOp = null;
  state.calcShouldReset = true;
  calcUpdate();
  renderCalcHistory();
}
function calcClear() { state.calcCurrent='0'; state.calcPrevious=null; state.calcOp=null; calcUpdate(); }
function calcBack() { state.calcCurrent = state.calcCurrent.slice(0,-1) || '0'; calcUpdate(); }
function renderCalcHistory() {
  const el = document.getElementById('calc-history-list');
  el.innerHTML = state.calcHistoryList.length === 0 ? '<p style="color:var(--textSec); text-align:center; padding:20px;">Vide</p>' :
    state.calcHistoryList.map(e => `<div style="padding:10px; border-bottom:1px solid var(--border); font-size:14px;">${escapeHtml(e)}</div>`).join('');
}
function clearCalcHistory() {
  state.calcHistoryList = [];
  localStorage.setItem('nw_calc_history', '[]');
  renderCalcHistory();
}

// ============================================================
// CONVERTER
// ============================================================
const CONV_UNITS = {
  length: { m:1, km:1000, cm:0.01, mm:0.001, mi:1609.34, yd:0.9144, ft:0.3048, in:0.0254 },
  weight: { kg:1, g:0.001, mg:0.000001, lb:0.453592, oz:0.0283495 },
  vol: { l:1, ml:0.001, gal:3.78541, 'fl oz':0.0295735, cup:0.236588 },
};
function setupConv() {
  const cat = document.getElementById('conv-cat').value;
  const from = document.getElementById('conv-from-unit');
  const to = document.getElementById('conv-to-unit');
  if (cat === 'temp') {
    from.innerHTML = to.innerHTML = '<option>°C</option><option>°F</option><option>K</option>';
    to.value = '°F';
  } else {
    const units = Object.keys(CONV_UNITS[cat]);
    from.innerHTML = units.map(u => `<option>${u}</option>`).join('');
    to.innerHTML = units.map(u => `<option>${u}</option>`).join('');
    to.value = units[1] || units[0];
  }
  doConv();
}
function doConv() {
  const cat = document.getElementById('conv-cat').value;
  const fromU = document.getElementById('conv-from-unit').value;
  const toU = document.getElementById('conv-to-unit').value;
  const v = parseFloat(document.getElementById('conv-from-val').value) || 0;
  let result;
  if (cat === 'temp') {
    let kelvin;
    if (fromU === '°C') kelvin = v + 273.15;
    else if (fromU === '°F') kelvin = (v - 32) * 5/9 + 273.15;
    else kelvin = v;
    if (toU === '°C') result = kelvin - 273.15;
    else if (toU === '°F') result = (kelvin - 273.15) * 9/5 + 32;
    else result = kelvin;
  } else {
    const meters = v * CONV_UNITS[cat][fromU];
    result = meters / CONV_UNITS[cat][toU];
  }
  document.getElementById('conv-to-val').value = parseFloat(result.toFixed(6));
}

