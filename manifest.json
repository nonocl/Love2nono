// ============================================================
// COUNTDOWNS
// ============================================================
async function renderCountdowns() {
  const list = await dbAll('countdowns');
  const el = document.getElementById('countdown-list');
  el.innerHTML = '';
  if (list.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">⏳</div><h3>Aucun compte à rebours</h3><p>Suivi de deadlines, événements à venir...</p></div>`;
    return;
  }
  const now = new Date();
  for (const c of list) {
    const target = new Date(c.date);
    const diff = target - now;
    const days = Math.floor(diff/(1000*60*60*24));
    const hours = Math.floor((diff%(1000*60*60*24))/(1000*60*60));
    const mins = Math.floor((diff%(1000*60*60))/(1000*60));
    const card = document.createElement('div');
    card.className = 'counter-card';
    let display;
    if (diff < 0) display = '<div class="counter-value">Passé</div>';
    else if (days > 0) display = `<div class="counter-value">${days}<span style="font-size:24px;">j ${hours}h</span></div>`;
    else display = `<div class="counter-value">${hours}<span style="font-size:24px;">h ${mins}m</span></div>`;
    card.innerHTML = `
      <button class="del-btn" data-id="${c.id}">×</button>
      <div class="counter-name">${escapeHtml(c.name)}</div>
      ${display}
      <div class="counter-date">${target.toLocaleString('fr-FR')}</div>
    `;
    card.querySelector('.del-btn').onclick = async (e) => {
      e.stopPropagation();
      if (confirm('Supprimer ?')) { await dbDel('countdowns', c.id); renderCountdowns(); }
    };
    el.appendChild(card);
  }
}

function openCountdownModal() {
  document.getElementById('cd-name-input').value = '';
