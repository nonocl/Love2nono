  {id:'libido', name:'Libido +', emoji:'🔥'},
  {id:'discharge', name:'Pertes', emoji:'💧'},
  {id:'sleep', name:'Insomnie', emoji:'🌙'}
];
const CYC_MOODS = [
  {id:'happy', emoji:'😊', name:'Bien'},
  {id:'sad', emoji:'😢', name:'Triste'},
  {id:'angry', emoji:'😡', name:'Énervée'},
