// ============================================================
// WATCHLIST (animes / séries / films)
// ============================================================

// Type config
const WATCH_TYPES = {
  anime: { label: 'Animes', single: 'anime', icon: '🌸', empty: 'Aucun anime' },
  series: { label: 'Séries', single: 'série', icon: '📺', empty: 'Aucune série' },
  film: { label: 'Films', single: 'film', icon: '🎬', empty: 'Aucun film' },
  game: { label: 'Jeux', single: 'jeu', icon: '🎮', empty: 'Aucun jeu' },
  book: { label: 'Manga / Livres', single: 'livre', icon: '📚', empty: 'Aucun livre' },
};

const WATCH_STATUS = {
  plan: { label: '📌 Prévu', color: '#9B7AC9' },
  watching: { label: '▶ En cours', color: '#5B8DEF' },
  done: { label: '✅ Terminé', color: '#7BC47F' },
  dropped: { label: '⏸ Abandonné', color: '#E14D6B' },
};

let _curWatchType = 'anime';   // current page filter
let _curWatch = null;            // detail item
let _editingWatch = null;        // modal editing
let _watchStatusFilter = 'all';
let _watchPosterData = null;     // dataURL pending in modal
let _watchSeasons = [];          // [{name, total_eps, watched_eps}]

function goToWatch(type) {
  _curWatchType = type;
  _watchStatusFilter = 'all';
  goTo('watch');
}

async function renderWatch() {
  const cfg = WATCH_TYPES[_curWatchType];
  document.getElementById('watch-title').textContent = cfg.label;
  document.getElementById('watch-empty-icon').textContent = cfg.icon;
  document.getElementById('watch-empty-title').textContent = cfg.empty;

  const all = await dbAll('watchlist');
  const list = all.filter(w => w.type === _curWatchType);

  // Chips
  const chips = document.getElementById('watch-chips');
  chips.innerHTML = '';
  chips.appendChild(createChip(`Tous (${list.length})`, '✨', null, _watchStatusFilter==='all', () => { _watchStatusFilter='all'; renderWatch(); }));
  for (const [k, v] of Object.entries(WATCH_STATUS)) {
    const count = list.filter(w => w.status === k).length;
    chips.appendChild(createChip(`${v.label} (${count})`, null, v.color, _watchStatusFilter===k, () => { _watchStatusFilter=k; renderWatch(); }));
  }

  let filtered = list;
  if (_watchStatusFilter !== 'all') filtered = filtered.filter(w => w.status === _watchStatusFilter);
  // Sort: watching first, then plan, done, dropped
  const order = { watching: 0, plan: 1, done: 2, dropped: 3 };
  filtered.sort((a,b) => (order[a.status]??99) - (order[b.status]??99) || (a.name||'').localeCompare(b.name||''));

  const grid = document.getElementById('watch-grid');
  grid.innerHTML = '';
  document.getElementById('watch-empty').style.display = filtered.length === 0 ? 'block' : 'none';

  for (const w of filtered) {
    const card = document.createElement('button');
    card.className = 'watch-card';
    const status = WATCH_STATUS[w.status] || WATCH_STATUS.plan;
    const sub = watchSubtitle(w);
    const progress = watchProgressPct(w);
    card.innerHTML = `
      <div class="watch-poster" ${w.poster ? `style="background-image:url('${w.poster}')"` : ''}>${w.poster ? '' : (WATCH_TYPES[w.type].icon)}</div>
      <span class="watch-status-badge ${w.status}">${status.label}</span>
      ${progress > 0 && progress < 100 ? `<div class="watch-progress" style="bottom: 50%;"><div class="watch-progress-fill" style="width:${progress}%;"></div></div>` : ''}
      <div class="watch-info">
        <div class="watch-name">${escapeHtml(w.name)}</div>
        <div class="watch-sub">${escapeHtml(sub)}</div>
      </div>
    `;
    card.onclick = () => openWatchDetail(w);
    grid.appendChild(card);
  }
}

function watchSubtitle(w) {
  if (w.type === 'film') {
    const parts = [];
    if (w.year) parts.push(w.year);
    if (w.duration_min) parts.push(`${w.duration_min} min`);
    return parts.join(' · ') || ' ';
  }
  if (w.type === 'game') {
    const parts = [];
    if (w.platform) parts.push(w.platform);
    if (w.hours_played) parts.push(`${w.hours_played}h`);
    return parts.join(' · ') || ' ';
  }
  // anime/série/book
  if (!w.seasons || w.seasons.length === 0) return ' ';
  const totalEps = w.seasons.reduce((s,x)=>s+(x.total_eps||0), 0);
  const watchedEps = w.seasons.reduce((s,x)=>s+(x.watched_eps||0), 0);
  const unitWord = w.type === 'book' ? 'ch' : 'ép';
  if (w.seasons.length === 1) {
    return totalEps > 0 ? `${watchedEps}/${totalEps} ${unitWord}` : `${watchedEps} ${unitWord}`;
  }
  const tomeWord = w.type === 'book' ? 'T' : 'S';
  return `${tomeWord}${w.seasons.length} · ${watchedEps}/${totalEps || '?'} ${unitWord}`;
}

function watchProgressPct(w) {
  if (w.type === 'film' || w.type === 'game') return w.status === 'done' ? 100 : 0;
  if (!w.seasons || w.seasons.length === 0) return 0;
  const totalEps = w.seasons.reduce((s,x)=>s+(x.total_eps||0), 0);
  const watchedEps = w.seasons.reduce((s,x)=>s+(x.watched_eps||0), 0);
  if (totalEps === 0) return 0;
  return Math.round((watchedEps / totalEps) * 100);
}

async function openWatchDetail(w) {
  _curWatch = w;
  document.getElementById('watch-detail-title').textContent = w.name;
  const sub = watchSubtitle(w);
  const status = WATCH_STATUS[w.status] || WATCH_STATUS.plan;
  document.getElementById('watch-detail-sub').textContent = `${status.label} · ${sub}`;
  const hero = document.getElementById('watch-hero');
  if (w.poster) {
    hero.style.backgroundImage = `url('${w.poster}')`;
  } else {
    hero.style.backgroundImage = '';
  }
  // Genres
  const gEl = document.getElementById('watch-detail-genres');
  gEl.innerHTML = '';
  if (w.genres && w.genres.length) {
    for (const g of w.genres) {
      const c = document.createElement('span');
      c.className = 'genre-chip';
      c.textContent = g;
      gEl.appendChild(c);
    }
  }
  // Status buttons highlight
  document.querySelectorAll('[data-st]').forEach(b => {
    if (b.dataset.st === w.status) { b.classList.remove('alt'); b.classList.add('primary'); }
    else { b.classList.add('alt'); b.classList.remove('primary'); }
  });
  // Progress (films vs episodes)
  const pEl = document.getElementById('watch-detail-progress');
  pEl.innerHTML = '';
  if (w.type !== 'film' && w.type !== 'game' && w.seasons && w.seasons.length) {
    for (let i=0; i<w.seasons.length; i++) {
      const s = w.seasons[i];
      const pct = s.total_eps > 0 ? Math.round((s.watched_eps / s.total_eps) * 100) : 0;
      const row = document.createElement('div');
      row.className = 'season-row';
      row.style.flexWrap = 'wrap';
      const stepperLabel = s.total_eps > 0 ? `${s.watched_eps} / ${s.total_eps}` : `${s.watched_eps}`;
      const defaultName = (w.type === 'book' ? 'Tome ' : 'Saison ') + (i+1);
      row.innerHTML = `
        <div style="flex:1; min-width:0;">
          <div class="season-name">${escapeHtml(s.name || defaultName)}</div>
          <div class="season-progress">${pct}%</div>
          <div class="season-bar"><div class="season-bar-fill" style="width:${pct}%;"></div></div>
        </div>
        <div class="ep-stepper">
          <button data-act="dec">−</button>
          <span class="val">${stepperLabel}</span>
          <button data-act="inc">+</button>
        </div>
      `;
      row.querySelector('[data-act="dec"]').onclick = (e) => { e.stopPropagation(); changeEp(i, -1); };
      row.querySelector('[data-act="inc"]').onclick = (e) => { e.stopPropagation(); changeEp(i, +1); };
      pEl.appendChild(row);
    }
  } else if (w.type === 'film') {
    // film : nothing to show beyond status
    const info = document.createElement('div');
    info.style.cssText = 'background:var(--surfaceAlt); padding:12px; border-radius:12px; font-size:13px; color:var(--textSec);';
    let line = '';
    if (w.year) line += `Année : ${w.year}<br>`;
    if (w.duration_min) line += `Durée : ${w.duration_min} min<br>`;
    info.innerHTML = line || 'Aucune info supplémentaire';
    pEl.appendChild(info);
  } else if (w.type === 'game') {
    const info = document.createElement('div');
    info.style.cssText = 'background:var(--surfaceAlt); padding:12px; border-radius:12px; font-size:13px; color:var(--textSec);';
    let line = '';
    if (w.platform) line += `Plateforme : ${w.platform}<br>`;
    if (w.hours_played) line += `Temps de jeu : ${w.hours_played}h<br>`;
    info.innerHTML = line || 'Aucune info supplémentaire';
    pEl.appendChild(info);
  }
  // Note
  const nEl = document.getElementById('watch-detail-note-wrap');
  nEl.innerHTML = '';
  if (w.note) {
    nEl.innerHTML = `<div style="background:var(--surfaceAlt); padding:12px; border-radius:12px; font-size:13px; line-height:1.5; white-space:pre-wrap;"><strong style="display:block; margin-bottom:6px;">📝 Note</strong>${escapeHtml(w.note)}</div>`;
  }
  goTo('watch-detail');
}

async function changeEp(seasonIndex, delta) {
  const w = await dbGet('watchlist', _curWatch.id);
  const s = w.seasons[seasonIndex];
  let v = (s.watched_eps || 0) + delta;
  if (v < 0) v = 0;
  if (s.total_eps > 0 && v > s.total_eps) v = s.total_eps;
  s.watched_eps = v;
  // Auto status
  const totalEps = w.seasons.reduce((sum,x)=>sum+(x.total_eps||0), 0);
  const watchedEps = w.seasons.reduce((sum,x)=>sum+(x.watched_eps||0), 0);
  if (totalEps > 0 && watchedEps >= totalEps) w.status = 'done';
  else if (watchedEps > 0 && w.status === 'plan') w.status = 'watching';
  await dbPut('watchlist', w);
  _curWatch = w;
  openWatchDetail(w);
}

async function setWatchStatus(status) {
  const w = await dbGet('watchlist', _curWatch.id);
  w.status = status;
  // If marking done, fill all watched eps
  if (status === 'done' && w.seasons) {
    for (const s of w.seasons) if (s.total_eps > 0) s.watched_eps = s.total_eps;
  }
  await dbPut('watchlist', w);
  _curWatch = w;
  openWatchDetail(w);
  toast('Statut mis à jour');
}

// ----- Modal add/edit -----
function openWatchModal(item) {
  _editingWatch = item;
  _watchPosterData = item ? (item.poster || null) : null;
  _watchSeasons = item && item.seasons ? JSON.parse(JSON.stringify(item.seasons)) : [];

  const type = item ? item.type : _curWatchType;
  document.getElementById('watch-modal-title').textContent = item ? `Modifier ${WATCH_TYPES[type].single}` : `Nouveau ${WATCH_TYPES[type].single}`;
  document.getElementById('watch-name-input').value = item ? item.name : '';
  document.getElementById('watch-status-input').value = item ? item.status : 'plan';
  document.getElementById('watch-genres-input').value = item && item.genres ? item.genres.join(', ') : '';
  document.getElementById('watch-note-input').value = item ? (item.note || '') : '';
  document.getElementById('watch-duration-input').value = item ? (item.duration_min || '') : '';
  document.getElementById('watch-year-input').value = item ? (item.year || '') : '';
  document.getElementById('watch-platform-input').value = item ? (item.platform || '') : '';
  document.getElementById('watch-hours-input').value = item ? (item.hours_played || '') : '';
  document.getElementById('watch-del-btn').style.display = item ? 'inline-flex' : 'none';

  // Show fields by type
  document.getElementById('watch-multi-fields').style.display = (type === 'film' || type === 'game') ? 'none' : 'block';
  document.getElementById('watch-film-fields').style.display = type === 'film' ? 'block' : 'none';
  document.getElementById('watch-game-fields').style.display = type === 'game' ? 'block' : 'none';

  // Adapt labels for books
  if (type === 'book') {
    document.getElementById('watch-multi-label').textContent = 'Tomes';
    document.getElementById('watch-add-season-label').textContent = 'Ajouter un tome';
  } else {
    document.getElementById('watch-multi-label').textContent = 'Saisons';
    document.getElementById('watch-add-season-label').textContent = 'Ajouter une saison';
  }

  updateWatchPosterPreview();

  if (type !== 'film' && type !== 'game') {
    if (_watchSeasons.length === 0) {
      const defaultName = type === 'book' ? 'Tome 1' : 'Saison 1';
      _watchSeasons.push({ name: defaultName, total_eps: 0, watched_eps: 0 });
    }
    renderSeasonsFields();
  }

  openModal('modal-watch');
}

function renderSeasonsFields() {
  const el = document.getElementById('watch-seasons-list');
  el.innerHTML = '';
  for (let i=0; i<_watchSeasons.length; i++) {
    const s = _watchSeasons[i];
    const row = document.createElement('div');
    row.style.cssText = 'background:var(--surfaceAlt); padding:10px; border-radius:12px; margin-bottom:6px;';
    row.innerHTML = `
      <div style="display:flex; gap:6px; align-items:center; margin-bottom:6px;">
        <input type="text" class="input" value="${escapeHtml(s.name || ('Saison '+(i+1)))}" data-i="${i}" data-f="name" style="flex:1; padding:7px 10px; font-size:13px;">
        ${_watchSeasons.length > 1 ? `<button class="btn ghost" data-rm="${i}" style="padding:6px 10px; color:var(--danger);">×</button>` : ''}
      </div>
      <div style="display:flex; gap:6px;">
        <div style="flex:1;">
          <div style="font-size:11px; color:var(--textSec); margin-bottom:2px;">Vu</div>
          <input type="number" class="input" value="${s.watched_eps||0}" data-i="${i}" data-f="watched_eps" min="0" style="padding:7px 10px; font-size:13px;">
        </div>
        <div style="font-size:18px; align-self:flex-end; padding:8px 0;">/</div>
        <div style="flex:1;">
          <div style="font-size:11px; color:var(--textSec); margin-bottom:2px;">Total ép</div>
          <input type="number" class="input" value="${s.total_eps||''}" data-i="${i}" data-f="total_eps" min="0" placeholder="?" style="padding:7px 10px; font-size:13px;">
        </div>
      </div>
    `;
    el.appendChild(row);
  }
  // listeners
  el.querySelectorAll('input').forEach(inp => {
    inp.addEventListener('input', () => {
      const i = parseInt(inp.dataset.i);
      const f = inp.dataset.f;
      if (f === 'name') _watchSeasons[i].name = inp.value;
      else _watchSeasons[i][f] = parseInt(inp.value) || 0;
    });
  });
  el.querySelectorAll('[data-rm]').forEach(btn => {
    btn.onclick = () => {
      _watchSeasons.splice(parseInt(btn.dataset.rm), 1);
      renderSeasonsFields();
    };
  });
}

function addSeasonField() {
  const type = _editingWatch ? _editingWatch.type : _curWatchType;
  const prefix = type === 'book' ? 'Tome ' : 'Saison ';
  _watchSeasons.push({ name: prefix + (_watchSeasons.length + 1), total_eps: 0, watched_eps: 0 });
  renderSeasonsFields();
}

function updateWatchPosterPreview() {
  const el = document.getElementById('watch-poster-preview');
  const clr = document.getElementById('watch-poster-clear');
  if (_watchPosterData) {
    el.style.backgroundImage = `url('${_watchPosterData}')`;
    el.textContent = '';
    clr.style.display = 'block';
  } else {
    el.style.backgroundImage = '';
    el.textContent = '🖼️';
    clr.style.display = 'none';
  }
}

document.getElementById('watch-poster-input').addEventListener('change', async (e) => {
  const f = e.target.files?.[0]; if (!f) return;
  // Resize to ~600px max width
  const dataUrl = await new Promise(res => {
    const r = new FileReader();
    r.onload = () => res(r.result);
    r.readAsDataURL(f);
  });
  const img = new Image();
  img.onload = () => {
    const maxW = 600;
    const scale = Math.min(1, maxW / img.naturalWidth);
    const c = document.createElement('canvas');
    c.width = img.naturalWidth * scale;
    c.height = img.naturalHeight * scale;
    c.getContext('2d').drawImage(img, 0, 0, c.width, c.height);
    _watchPosterData = c.toDataURL('image/jpeg', 0.85);
    updateWatchPosterPreview();
  };
  img.src = dataUrl;
  e.target.value = '';
});

function clearWatchPoster() {
  _watchPosterData = null;
  updateWatchPosterPreview();
}

async function saveWatch() {
  const name = document.getElementById('watch-name-input').value.trim();
  if (!name) { alert('Donne un titre.'); return; }
  const status = document.getElementById('watch-status-input').value;
  const genresStr = document.getElementById('watch-genres-input').value.trim();
  const genres = genresStr ? genresStr.split(',').map(g => g.trim()).filter(Boolean) : [];
  const note = document.getElementById('watch-note-input').value.trim();
  const type = _editingWatch ? _editingWatch.type : _curWatchType;

  const data = {
    type, name, status, genres, note,
    poster: _watchPosterData,
    updated_at: new Date().toISOString(),
  };

  if (type === 'film') {
    data.duration_min = parseInt(document.getElementById('watch-duration-input').value) || null;
    data.year = parseInt(document.getElementById('watch-year-input').value) || null;
  } else if (type === 'game') {
    data.platform = document.getElementById('watch-platform-input').value.trim() || null;
    data.hours_played = parseFloat(document.getElementById('watch-hours-input').value) || null;
  } else {
    data.seasons = _watchSeasons.map(s => ({
      name: s.name || (type === 'book' ? 'Tome' : 'Saison'),
      total_eps: parseInt(s.total_eps) || 0,
      watched_eps: parseInt(s.watched_eps) || 0,
    }));
  }

  if (_editingWatch) {
    await dbPut('watchlist', { ...(_editingWatch), ...data });
    if (_curWatch && _curWatch.id === _editingWatch.id) {
      _curWatch = await dbGet('watchlist', _editingWatch.id);
      openWatchDetail(_curWatch);
    }
  } else {
    data.created_at = new Date().toISOString();
    await dbAdd('watchlist', data);
  }
  closeModal('modal-watch');
  if (state.page === 'watch') renderWatch();
  toast('Enregistré ✨');
}

async function deleteWatchNow() {
  if (!confirm(`Supprimer "${_editingWatch.name}" ?`)) return;
  await dbDel('watchlist', _editingWatch.id);
  closeModal('modal-watch');
  if (_curWatch && _curWatch.id === _editingWatch.id) {
    _curWatch = null;
    goTo('watch');
  } else if (state.page === 'watch') {
    renderWatch();
  }
  toast('Supprimé');
}

