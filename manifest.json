// === 17. RIMES FR (basique) ===
function getEnding(word, n) {
  word = word.toLowerCase().replace(/[^a-zàâäéèêëîïôöùûüÿñç]/g, '');
  return word.slice(-n);
}
const RHYME_DICT_HINT = "Tape un mot, je te trouve des mots qui finissent par les mêmes 2-3 lettres.";
const RHYME_BASE = ['amour','toujours','contour','tour','autour','retour','jour','court','vautour','plomb','lourd','sourd','court','bonjour','séjour','discours','parcours','secours','recours','humour','velours','four','pour','sur','cœur','peur','sœur','heure','demeure','meurt','pleurer','tendreté','pleur','pleurer','douceur','majeur','rougeur','noirceur','grandeur','pâleur','bonheur','malheur','chaleur','douleur','rancœur','vapeur','horreur','terreur','ardeur','splendeur','candeur','rideur','liseur','lecteur','acteur','docteur','moteur','réacteur','protecteur','seigneur','honneur','déshonneur','rigueur','vigueur','sécheur','blancheur','fraîcheur','vie','envie','folie','jolie','infinie','endormie','partie','sortie','garantie','sympathie','poésie','jalousie','frénésie','amitié','pitié','liberté','beauté','fierté','vérité','éternité','divinité','intimité','clarté','autorité','priorité','légèreté','dureté','tendresse','jeunesse','sagesse','adresse','déesse','princesse','tristesse','faiblesse','richesse','baisse','laisse','caresse','presse','nuit','bruit','fruit','suit','cuit','pluie','minuit','ennui','autrui','soir','noir','espoir','miroir','espoir','devoir','savoir','recevoir','dormir','partir','sortir','venir','retenir','convenir','souvenir','plaisir','désir','choisir','réussir','prison','saison','raison','horizon','poison','blason','façon','garçon','soupçon','frisson','passion','émotion','attention','intention','création','admiration','satisfaction','perfection','collection','attention','rébellion','musique','magique','classique','dynamique','fantastique','romantique','authentique','politique','éthique','tactique','tragique','antique','rythme','synonyme','prénom','nom','renom','dénonce','annonce','onze','mois','toi','moi','foi','émoi','soi','bois','rois','lois','cas','pas','bras','soldat','combat','débat','combat','vacances','danse','silence','nuance','distance','espérance','souvenance','souffrance','soufrance','exigence','imprudence'];
function findRhymes(word) {
  if (!word || word.length < 2) return [];
  const e2 = getEnding(word, 2);
  const e3 = getEnding(word, 3);
  const e4 = getEnding(word, 4);
  const matches = { four: [], three: [], two: [] };
  RHYME_BASE.forEach(w => {
    if (w === word.toLowerCase()) return;
    if (getEnding(w, 4) === e4 && e4.length === 4) matches.four.push(w);
    else if (getEnding(w, 3) === e3 && e3.length === 3) matches.three.push(w);
    else if (getEnding(w, 2) === e2) matches.two.push(w);
  });
  return matches;
}
function renderRhyme() {
  let html = `<div style="background:linear-gradient(135deg,#FF8C42,#9B59B6); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🎤</div>
