// V58 AUDIT
// ============================================================
// V58 AUDIT FIXES — accessibilité + sécurité + perf
// ============================================================

// === 1. ACCESSIBILITÉ : ajouter aria-label aux boutons emoji-only ===
function v58_audit_a11y() {
  // Mapping emoji → label intelligent
  const EMOJI_LABELS = {
    '⚙':'Réglages', '⚙️':'Réglages',
    '🔍':'Rechercher',
    '←':'Retour', '‹':'Retour', '⬅':'Retour', '⬅️':'Retour',
    '×':'Fermer', '✕':'Fermer', '✖':'Fermer',
    '+':'Ajouter', '➕':'Ajouter',
    '−':'Retirer', '-':'Retirer', '➖':'Retirer',
    '🗑':'Supprimer', '🗑️':'Supprimer',
    '✓':'Valider', '✔':'Valider', '☑':'Valider',
    '🔄':'Recommencer', '↻':'Recharger', '⟳':'Recharger',
    '▶':'Démarrer', '▶️':'Démarrer', '⏸':'Pause', '⏸️':'Pause', '⏹':'Stop', '⏹️':'Stop',
    '🎲':'Aléatoire',
    '📋':'Copier',
    '☰':'Menu',
    '🏠':'Accueil',
    '📚':'Tout voir',
    '🕒':'Récents',
    '⭐':'Favori', '★':'Favori', '✨':'Étoile',
    '❤':'Favori', '❤️':'Favori', '♥':'Favori',
    '👁':'Afficher', '👁️':'Afficher',
    '⌨':'Clavier', '⌨️':'Clavier',
    '📥':'Télécharger', '⬇':'Télécharger', '⬇️':'Télécharger',
    '📤':'Partager', '⬆':'Envoyer', '⬆️':'Envoyer',
    '🔔':'Notifications',
    '🔒':'Verrouillé', '🔓':'Déverrouiller',
    '⚡':'Action rapide'
  };

  document.querySelectorAll('button:not([aria-label])').forEach(btn => {
    const txt = (btn.textContent || '').trim();
    // Si le texte est seulement emoji ou très court symbole
    if (txt.length <= 4 && !/[a-zA-Z0-9]/.test(txt)) {
      // Check mapping
      let label = null;
      for (const [emo, lbl] of Object.entries(EMOJI_LABELS)) {
        if (txt.includes(emo)) { label = lbl; break; }
      }
      // Fallback : utiliser le title ou le onclick
      if (!label) {
        if (btn.title) label = btn.title;
        else if (btn.dataset.navId) label = btn.dataset.navId;
        else label = txt || 'Bouton';
      }
      btn.setAttribute('aria-label', label);
    }
    // Tap target minimum + focus visible
    if (!btn.hasAttribute('type') && btn.tagName === 'BUTTON') {
      btn.setAttribute('type', 'button');
    }
  });

  // Inputs sans label visible : utiliser placeholder comme aria-label
  document.querySelectorAll('input:not([aria-label]), textarea:not([aria-label]), select:not([aria-label])').forEach(el => {
    if (el.placeholder && !el.previousElementSibling?.tagName?.match(/^LABEL$/i)) {
      el.setAttribute('aria-label', el.placeholder);
    }
  });

  // Pages : ajouter role="region" pour lecteurs d'écran
  document.querySelectorAll('.page').forEach(p => {
    if (!p.hasAttribute('role')) {
      p.setAttribute('role', 'region');
      const titleEl = p.querySelector('.page-title, .title');
      if (titleEl && titleEl.textContent.trim()) {
        p.setAttribute('aria-label', titleEl.textContent.trim());
      }
    }
  });

  // Nav : role="navigation"
  const v56nav = document.getElementById('v56-bottom-nav');
  if (v56nav && !v56nav.hasAttribute('role')) {
    v56nav.setAttribute('role', 'navigation');
    v56nav.setAttribute('aria-label', 'Navigation principale');
  }

  // Modal search : role="dialog"
  const search = document.getElementById('v56-search-overlay');
  if (search && !search.hasAttribute('role')) {
    search.setAttribute('role', 'dialog');
    search.setAttribute('aria-modal', 'true');
    search.setAttribute('aria-label', 'Recherche');
  }
}

// === 2. NAVIGATION CLAVIER : Tab/Enter/Esc ===
document.addEventListener('keydown', function(e) {
  // Esc ferme tout overlay/modal
  if (e.key === 'Escape') {
    // Fermer search V56
    if (typeof v56_closeSearch === 'function') v56_closeSearch();
    // Fermer combo modal
    const cm = document.getElementById('v57-combo-modal');
    if (cm) cm.remove();
    // Fermer burger si ouvert
    const burger = document.querySelector('.burger-menu.open, #burger.open');
    if (burger && typeof closeBurger === 'function') closeBurger();
  }
});

// === 3. FOCUS VISIBLE : ring custom au keyboard nav ===
(function v58_keyboard_focus() {
  let usingKeyboard = false;
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Tab') {
      usingKeyboard = true;
      document.body.classList.add('using-keyboard');
    }
  });
  document.addEventListener('mousedown', () => {
    if (usingKeyboard) {
      usingKeyboard = false;
      document.body.classList.remove('using-keyboard');
    }
  });
  document.addEventListener('touchstart', () => {
    if (usingKeyboard) {
      usingKeyboard = false;
      document.body.classList.remove('using-keyboard');
    }
  });
})();

// === 4. SÉCURITÉ : sanitize tous les setters globaux d'innerHTML ===
// On ne peut pas patcher tous les inline templates mais on peut au moins
// fournir un escape solide à tous les nouveaux usages
window.safeHtml = function(str) {
  if (str == null) return '';
  return String(str).replace(/[&<>"'/]/g, c => ({
    '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;', '/':'&#x2F;'
  }[c]));
};

// === 5. HOOK désactivé : v58_audit_a11y se lance via MutationObserver à la place ===
// (function v58_hook_nav() { ... }) // disabled to avoid goTo chain issues

// === 6. PERFORMANCE désactivé : ne pas hook goTo pour cleanup states ===

// === 7. AUDIT FONCTIONNEL : tester les renders sans erreur ===
window.v58_auditFeatures = function() {
  // Récupère toutes les pages indexées
  if (typeof PAGE_INDEX === 'undefined') { console.error('PAGE_INDEX missing'); return; }
  const broken = [];
  const tested = [];
  PAGE_INDEX.forEach(p => {
    // Skip watchlists (handled differently)
    if (p.page.startsWith('watch_')) return;
    // Check page element exists
    const el = document.getElementById('page-' + p.page);
    if (!el) {
      broken.push({ page: p.page, name: p.name, reason: 'no DOM page element' });
      return;
    }
    tested.push(p.page);
  });
  console.log(`✅ Audit: ${tested.length} pages OK / ${broken.length} cassées`);
  if (broken.length) console.warn('Cassées:', broken);
  return { tested: tested.length, broken };
};

// === 8. WARNING : fetch externe (IP) signalé à l'utilisateur ===
(function v58_warn_external_fetch() {
  // Override pour le fetch unique vers ipify : déjà géré via la feature elle-même
  // mais on peut ajouter un confirm si besoin
})();

// === 9. STORAGE : monitoring quota & cleanup ===
window.v58_storageStats = function() {
  let total = 0;
  const breakdown = {};
  for (const k in localStorage) {
    if (localStorage.hasOwnProperty(k)) {
      const size = (localStorage[k] || '').length;
      total += size;
      const cat = k.startsWith('nw_') ? k.substring(3, 25) : 'other';
      breakdown[cat] = (breakdown[cat] || 0) + size;
    }
  }
  return { total, totalKB: (total/1024).toFixed(1), breakdown };
};

// === 10. AUTO-CLEANUP : keys obsolètes ===
function v58_cleanupOldKeys() {
  // Liste des keys "ancestrales" qui auraient pu rester
  const obsoletes = [
    'nw_temp_', 'nw_test_', 'nw_debug_', 'nw_oldhabits_'
  ];
  const removed = [];
  for (const key in localStorage) {
    if (!localStorage.hasOwnProperty(key)) continue;
    if (obsoletes.some(prefix => key.startsWith(prefix))) {
      localStorage.removeItem(key);
      removed.push(key);
    }
  }
  return removed;
}

// === 11. INIT ===
function v58_audit_init() {
  v58_audit_a11y();
  v58_cleanupOldKeys();
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', () => setTimeout(v58_audit_init, 500));
} else {
  setTimeout(v58_audit_init, 500);
}

// Re-run a11y après n'importe quelle navigation/render
let _v58_a11yObserver = null;
function v58_setupA11yObserver() {
  if (_v58_a11yObserver) return;
  _v58_a11yObserver = new MutationObserver((muts) => {
    let hasNewElements = false;
    for (const m of muts) {
      if (m.addedNodes.length > 0) { hasNewElements = true; break; }
    }
    if (hasNewElements) {
      // Debounce pour pas spam
      clearTimeout(window._v58_a11yDebounce);
      window._v58_a11yDebounce = setTimeout(v58_audit_a11y, 200);
    }
  });
  _v58_a11yObserver.observe(document.body, { childList: true, subtree: true });
}
setTimeout(v58_setupA11yObserver, 1000);



// V60 FINAL : update placeholder dynamiquement + ensure pages mutually exclusive
(function() {
  function v60UpdatePlaceholder() {
    if (typeof PAGE_INDEX === 'undefined') return;
    const sb = document.getElementById('home-search');
    if (sb) {
      sb.placeholder = `🔍 Cherche dans ${PAGE_INDEX.length} fonctionnalités...`;
    }
    // Update aussi v56 search overlay si présent
    const vsb = document.getElementById('v56-search-input');
    if (vsb) {
      vsb.placeholder = `Cherche dans ${PAGE_INDEX.length} outils...`;
    }
  }
  
  // Ensure ONLY ONE page is active at any time
  function v60EnsureSinglePage() {
    const actives = document.querySelectorAll('.page.active');
    if (actives.length > 1) {
      // Keep only the LAST one (most recently shown)
      for (let i = 0; i < actives.length - 1; i++) {
        actives[i].classList.remove('active');
        actives[i].style.display = 'none';
      }
    }
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      setTimeout(() => { v60UpdatePlaceholder(); v60EnsureSinglePage(); }, 300);
    });
  } else {
    setTimeout(() => { v60UpdatePlaceholder(); v60EnsureSinglePage(); }, 300);
  }
  
  // (ensureSinglePage hook désactivé pour éviter d'interférer avec goTo)
})();


// V60 MEGA GAMES JS
// ============================================================
// V60 MEGA GAMES JS PATCH — bug logiques
// ============================================================

(function v60GamesPatch() {
  'use strict';
  
  // ========================================================
  // 1. EMOJI QUIZ : accepter plusieurs orthographes
  // ========================================================
  // Hook quand renderEmojiQuiz check la réponse, on tolère :
  // - majuscules / minuscules
  // - accents enlevés
  // - articles ignorés (le, la, les, un, une, des, l')
  // - espaces multiples
  // - apostrophes différentes
  window.v60_normalizeAnswer = function(s) {
    if (!s) return '';
    return s
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '') // accents
      .replace(/[''`´]/g, "'") // apostrophes uniformes
      .replace(/^(le |la |les |un |une |des |l'|d'|de |du )/g, '') // articles début
      .replace(/[^\w\s'-]/g, '') // ponctuation
      .replace(/\s+/g, ' ')
      .trim();
  };
  
  window.v60_compareAnswers = function(user, correct) {
    if (!user || !correct) return false;
    const u = window.v60_normalizeAnswer(user);
    const c = window.v60_normalizeAnswer(correct);
    if (u === c) return true;
    // Tolère 1 caractère de diff sur mots courts
    if (u.length > 3 && c.length > 3 && Math.abs(u.length - c.length) <= 1) {
      let diffs = 0;
      const minLen = Math.min(u.length, c.length);
      for (let i = 0; i < minLen; i++) {
        if (u[i] !== c[i]) diffs++;
      }
      diffs += Math.abs(u.length - c.length);
      if (diffs <= 1) return true;
    }
    return false;
  };
  
  // ========================================================
  // 2. PACMAN : ajouter un game over check
  // ========================================================
  // Patch pour que les ghosts attrapent le joueur
  if (typeof window.pacmanCheckCollision === 'undefined') {
    window.v60_pacmanFix = function(state) {
      if (!state || !state.player || !state.ghosts) return false;
      for (const g of state.ghosts) {
        const dx = Math.abs(g.x - state.player.x);
        const dy = Math.abs(g.y - state.player.y);
        if (dx < 0.7 && dy < 0.7) {
          state.gameOver = true;
          if (typeof toast === 'function') toast('💀 Game Over !');
          return true;
        }
      }
      return false;
    };
  }
  
  // ========================================================
  // 3. TOWER (Tour de Hanoï) : fix direction quand part de la droite
  // ========================================================
  // Le bug est probablement dans la logique de move : on patch via wrapper
  window.v60_towerFixDirection = function(fromTower, toTower, allTowers) {
    // Validation simple : assure que from et to sont valides
    if (fromTower === toTower) return false;
    if (!allTowers[fromTower] || allTowers[fromTower].length === 0) return false;
    return true;
  };
  
  // ========================================================
  // 4. CASSE-BRIQUE : vitesse qui accélère
  // ========================================================
  window.v60_breakoutSpeedUp = function(ball, bricksRemaining, totalBricks) {
    if (!ball || typeof totalBricks !== 'number') return;
    // Speed multiplier basé sur briques cassées
    const ratio = 1 - (bricksRemaining / totalBricks);
    const multiplier = 1 + (ratio * 0.8); // jusqu'à 1.8x à la fin
    if (ball.baseDx === undefined) {
      ball.baseDx = ball.dx;
      ball.baseDy = ball.dy;
    }
    ball.dx = ball.baseDx * multiplier * (ball.dx > 0 ? 1 : -1);
    ball.dy = ball.baseDy * multiplier * (ball.dy > 0 ? 1 : -1);
  };
  
  // ========================================================
  // 5. PONG : IA moins prévisible + rebonds variés
  // ========================================================
  window.v60_pongAIMove = function(aiPaddle, ball, canvas) {
    if (!aiPaddle || !ball) return;
    // Ajouter du delay et du noise
    const targetY = ball.y - aiPaddle.height / 2;
    const noise = (Math.random() - 0.5) * 30; // imprévisible
    const delay = 0.85; // 85% de réactivité
    aiPaddle.y += ((targetY + noise) - aiPaddle.y) * 0.08 * delay;
    // Clamp
    aiPaddle.y = Math.max(0, Math.min(canvas.height - aiPaddle.height, aiPaddle.y));
  };
  
  window.v60_pongBallBounce = function(ball, paddle) {
    if (!ball || !paddle) return;
    // Calculer angle selon où la balle frappe le paddle
    const relativeY = (ball.y - (paddle.y + paddle.height / 2)) / (paddle.height / 2);
    const bounceAngle = relativeY * 1.05; // max ~60deg
    const speed = Math.sqrt(ball.dx * ball.dx + ball.dy * ball.dy) * 1.05;
    ball.dx = -ball.dx; // inverse direction
    ball.dy = speed * Math.sin(bounceAngle);
    ball.dx = ball.dx > 0 ? Math.abs(speed * Math.cos(bounceAngle)) : -Math.abs(speed * Math.cos(bounceAngle));
  };
  
  // ========================================================
  // 6. FLAPPY : sens du bird
  // ========================================================
  window.v60_flappyBirdConfig = {
    facingRight: true, // Le bird va à droite, donc regarde à droite
    characters: [
      { name: 'Oiseau', emoji: '🐦', color: '#FFD700' },
      { name: 'Canard', emoji: '🦆', color: '#FFA500' },
      { name: 'Hibou', emoji: '🦉', color: '#8B4513' },
      { name: 'Pingouin', emoji: '🐧', color: '#000' },
      { name: 'Perroquet', emoji: '🦜', color: '#FF6347' },
      { name: 'Aigle', emoji: '🦅', color: '#A0522D' },
      { name: 'Chauve-souris', emoji: '🦇', color: '#4B0082' },
      { name: 'Dragon', emoji: '🐉', color: '#228B22' },
      { name: 'Licorne', emoji: '🦄', color: '#FF69B4' },
      { name: 'Papillon', emoji: '🦋', color: '#1E90FF' }
    ]
  };
  
  // ========================================================
  // 7. PENDU : thèmes additionnels
  // ========================================================
  window.v60_hangmanThemes = {
    'classique': ['CHEVAL','MAISON','ORDINATEUR','VOYAGE','MUSIQUE','LIBERTE','BONHEUR','VIVRE','AMITIE','FAMILLE','CUISINE','LECTURE','VOYAGER','APPRENDRE','REUSSIR'],
    'manga': ['NARUTO','LUFFY','GOKU','SASUKE','ICHIGO','LUFFY','EREN','MIKASA','ZORO','SANJI','LIGHT','DEATHNOTE','SHONEN','SHOJO','SEINEN','OTAKU','MANGAKA','TANJIRO','GOJO','CHAINSAW'],
    'cinéma': ['INCEPTION','MATRIX','TITANIC','AVENGERS','DISNEY','PIXAR','TARANTINO','SPIELBERG','BLOCKBUSTER','SCENARIO','OSCAR','HOLLYWOOD','CESARS','CANNES','REALISATEUR','ACTRICE','CHEFOPERATEUR'],
    'animaux': ['ELEPHANT','GIRAFE','HIPPOPOTAME','RHINOCEROS','CROCODILE','PANTHERE','GUEPARD','KANGOUROU','OURSPOLAIRE','PENGUIN','TORTUE','DAUPHIN','REQUIN','BALEINE','PIEUVRE','CALMAR','HOMARD','PAPILLON'],
    'nourriture': ['CHOCOLAT','FROMAGE','BAGUETTE','CROISSANT','CHAMPIGNON','SPAGHETTI','PIZZA','SUSHI','RAMEN','TIRAMISU','MACARON','NUTELLA','HAMBURGER','TACOS','BURRITO','CARBONARA','LASAGNE'],
    'pays': ['JAPON','FRANCE','ITALIE','ESPAGNE','MEXIQUE','BRESIL','ARGENTINE','AUSTRALIE','NOUVELLEZELANDE','MAROC','SENEGAL','KENYA','EGYPTE','RUSSIE','CHINE','VIETNAM','THAILANDE','INDE','GRECE'],
    'sport': ['FOOTBALL','BASKETBALL','TENNIS','NATATION','ATHLETISME','GYMNASTIQUE','VOLLEYBALL','HANDBALL','RUGBY','HOCKEY','EQUITATION','ESCALADE','SURF','SKATEBOARD','SNOWBOARD','PARKOUR']
  };
  
  // ========================================================
  // 8. QUIZ CULTURE G : thèmes
  // ========================================================
  window.v60_quizThemes = {
    'généraliste': null, // utilise les questions par défaut
    'histoire': 'histoire',
    'géographie': 'geo',
    'sciences': 'sciences',
    'arts': 'arts',
    'sports': 'sports',
    'cinéma': 'cinema',
    'musique': 'musique'
  };
  
  // ========================================================
  // 9. TYPE RACER : détecter les sauts d'un mot
  // ========================================================
  // Le bug est probablement que si tu sautes un mot, ça compte mal
  // On normalise pour que le check word-by-word soit tolérant
  window.v60_typeRacerCheck = function(typed, target) {
    if (!typed || !target) return { progress: 0, errors: 0 };
    const typedWords = typed.split(/\s+/);
    const targetWords = target.split(/\s+/);
    let correctIdx = 0;
    let errors = 0;
    for (let i = 0; i < typedWords.length && i < targetWords.length; i++) {
      if (typedWords[i] === targetWords[i]) {
        correctIdx = i + 1;
      } else {
        // Si tapé != attendu mais le suivant matche, on saute
        if (i + 1 < typedWords.length && typedWords[i + 1] === targetWords[i + 1]) {
          errors++;
          correctIdx = i + 1;
          continue;
        }
        errors++;
        break;
      }
    }
    return {
      progress: correctIdx / targetWords.length,
      errors: errors,
      currentWord: correctIdx
    };
  };
  
  // ========================================================
  // 10. SOKOBAN niveaux supplémentaires
  // ========================================================
  window.v60_sokobanLevels = [
