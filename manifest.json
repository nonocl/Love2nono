}

/* === EASTER EGG #15 : ROSE GARDEN GLASS ===
   theme rosegarden + vibe-glass = serre romantique */
body[data-theme="rosegarden"].vibe-glass {
  background: linear-gradient(160deg, #FF6FA3 0%, #FF1493 40%, #5D2E8C 100%) fixed !important;
}
body[data-theme="rosegarden"].vibe-glass .v56-greeting::before,
body[data-theme="rosegarden"].vibe-glass .v56-card::before {
  content: '🌹';
