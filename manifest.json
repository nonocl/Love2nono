// === PRIX AU KILO ===
function renderPricePerKg() {
  let html = `<p style="font-size:11px; color:var(--textSec);">Compare jusqu'à 4 produits. Le moins cher au kilo gagne.</p>`;
  for (let i = 1; i <= 4; i++) {
    html += `<div style="background:var(--surface); padding:12px; border-radius:12px; margin-top:8px;">
      <div style="font-size:12px; font-weight:700; color:var(--primary);">🏷 Produit ${i}</div>
      <input type="text" class="input" id="ppk-name-${i}" placeholder="Nom (optionnel)..." oninput="ppkCalc()" style="margin-top:6px;">
      <div style="display:flex; gap:6px; margin-top:6px;">
        <input type="number" class="input" id="ppk-price-${i}" placeholder="Prix €" oninput="ppkCalc()" step="0.01" style="flex:1;">
        <input type="number" class="input" id="ppk-weight-${i}" placeholder="Poids/qté" oninput="ppkCalc()" step="1" style="flex:1;">
        <select class="input" id="ppk-unit-${i}" onchange="ppkCalc()" style="flex:1;">
          <option value="g">g</option>
          <option value="kg">kg</option>
          <option value="ml">ml</option>
          <option value="l">l</option>
          <option value="u">unités</option>
        </select>
      </div>
      <div id="ppk-result-${i}" style="font-size:13px; margin-top:6px; font-weight:700;"></div>
    </div>`;
  }
  html += `<div id="ppk-winner" style="margin-top:14px;"></div>`;
  document.getElementById('priceperkg-content').innerHTML = html;
}
function ppkCalc() {
  const results = [];
  for (let i = 1; i <= 4; i++) {
    const p = parseFloat(document.getElementById('ppk-price-'+i).value);
    const w = parseFloat(document.getElementById('ppk-weight-'+i).value);
    const u = document.getElementById('ppk-unit-'+i).value;
    const name = document.getElementById('ppk-name-'+i).value || `Produit ${i}`;
    const resultEl = document.getElementById('ppk-result-'+i);
    if (isNaN(p) || isNaN(w) || w === 0) { resultEl.innerHTML = ''; continue; }
    let pricePerStandard, label;
    if (u === 'g') { pricePerStandard = p / (w / 1000); label = '€/kg'; }
    else if (u === 'kg') { pricePerStandard = p / w; label = '€/kg'; }
    else if (u === 'ml') { pricePerStandard = p / (w / 1000); label = '€/L'; }
    else if (u === 'l') { pricePerStandard = p / w; label = '€/L'; }
    else { pricePerStandard = p / w; label = '€/u'; }
    resultEl.innerHTML = `<span style="color:var(--primary);">${pricePerStandard.toFixed(2)} ${label}</span>`;
    results.push({ i, name, price: pricePerStandard, label });
  }
  if (results.length >= 2) {
    results.sort((a,b) => a.price - b.price);
    const winner = results[0];
    const worst = results[results.length-1];
    const savings = ((worst.price - winner.price) / worst.price * 100).toFixed(0);
    document.getElementById('ppk-winner').innerHTML = `<div style="background:linear-gradient(135deg,#5DD68F,#06FFA5); color:white; padding:14px; border-radius:14px; text-align:center;">
      <div style="font-size:32px;">🏆</div>
      <div style="font-size:14px; font-weight:800;">Le moins cher : ${escapeHtml(winner.name)}</div>
      <div style="font-size:12px; opacity:0.9; margin-top:4px;">${winner.price.toFixed(2)} ${winner.label} · économie ${savings}%</div>
    </div>`;
  } else {
    document.getElementById('ppk-winner').innerHTML = '';
  }
}

// === ABONNEMENTS ===
function getSubs() { try { return JSON.parse(localStorage.getItem('nw_subs') || '[]'); } catch { return []; } }
function saveSubs(d) { localStorage.setItem('nw_subs', JSON.stringify(d)); }
function renderSubs() {
  const subs = getSubs();
  const monthly = subs.reduce((s,x) => s + (x.cycle === 'monthly' ? x.price : x.cycle === 'yearly' ? x.price/12 : x.price*4), 0);
  const yearly = monthly * 12;
  let html = `<div style="background:linear-gradient(135deg,#FF1493,#9B59B6); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">💳</div>
    <div style="font-size:11px; opacity:0.9;">Total mensuel</div>
    <div style="font-size:32px; font-weight:900;">${monthly.toFixed(2)} €</div>
    <div style="font-size:12px; opacity:0.9; margin-top:2px;">${yearly.toFixed(0)} € / an</div>
  </div>`;
  if (!subs.length) html += '<p style="text-align:center; color:var(--textSec); padding:30px;">Aucun abonnement. Tap +.</p>';
  
  // Sort by next renewal
  const now = Date.now();
  subs.forEach(s => {
    s.nextRenewMs = computeNextRenew(s);
  });
  subs.sort((a,b) => a.nextRenewMs - b.nextRenewMs);
  
  subs.forEach(s => {
    const daysLeft = Math.ceil((s.nextRenewMs - now) / (24*60*60*1000));
    const soon = daysLeft <= 7;
    const cycleLabel = s.cycle === 'monthly' ? '/ mois' : s.cycle === 'yearly' ? '/ an' : '/ semaine';
    html += `<div style="background:var(--surface); padding:12px; border-radius:12px; margin-top:6px; ${soon ? 'border-left:3px solid var(--danger);' : ''}">
      <div style="display:flex; justify-content:space-between;">
        <div style="flex:1;">
          <div style="font-size:14px; font-weight:700;">${escapeHtml(s.icon || '💳')} ${escapeHtml(s.name)}</div>
          <div style="font-size:11px; color:var(--textSec); margin-top:2px;">${s.price.toFixed(2)} € ${cycleLabel}</div>
          <div style="font-size:11px; ${soon?'color:var(--danger);':'color:var(--textSec);'} font-weight:${soon?'700':'400'}; margin-top:2px;">📅 ${soon ? `Renouvellement dans ${daysLeft}j !` : `Prochain : ${new Date(s.nextRenewMs).toLocaleDateString('fr-FR')}`}</div>
        </div>
        <button onclick="subDel('${s.id}')" style="background:none; border:none; color:var(--danger); font-size:18px;">✗</button>
      </div>
    </div>`;
  });
  document.getElementById('subs-content').innerHTML = html;
}
function computeNextRenew(s) {
  let next = new Date(s.startDate);
  const now = new Date();
  while (next <= now) {
    if (s.cycle === 'monthly') next.setMonth(next.getMonth() + 1);
    else if (s.cycle === 'yearly') next.setFullYear(next.getFullYear() + 1);
    else next.setDate(next.getDate() + 7);
  }
  return next.getTime();
}
function subAdd() {
  const presets = ['Spotify','Netflix','Disney+','Amazon Prime','Crunchyroll','Apple Music','YouTube Premium','Steam','Custom'];
  const ch = prompt(`Choisis :\n\n${presets.map((p,i) => `${i+1}. ${p}`).join('\n')}\n\n0. Annuler`);
  if (!ch) return;
  const idx = parseInt(ch) - 1;
  let name = presets[idx] || prompt('Nom :');
  if (!name || name === 'Custom') name = prompt('Nom :');
  if (!name) return;
  const price = parseFloat(prompt('Prix (€) :')) || 0;
  const cycle = prompt('Cycle : 1=Mensuel, 2=Annuel, 3=Hebdo', '1');
  const cycleMap = {'1':'monthly','2':'yearly','3':'weekly'};
  const startDate = prompt('Date début abonnement (YYYY-MM-DD) :', new Date().toISOString().slice(0,10));
  const subs = getSubs();
  subs.push({ id:'sb_'+Date.now(), name, price, cycle: cycleMap[cycle] || 'monthly', startDate, icon: idx >= 0 ? '🎵' : '💳' });
  saveSubs(subs); renderSubs();
}
function subDel(id) { if(!confirm('Supprimer ?'))return; saveSubs(getSubs().filter(s => s.id !== id)); renderSubs(); }

