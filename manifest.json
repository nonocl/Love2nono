    <div style="font-size:11px; opacity:0.9;">${RHYME_BASE.length} mots de base · pour rap/poésie</div>
  </div>
  <input type="text" class="input" id="rhyme-input" placeholder="Tape un mot..." oninput="rhymeUpdate()" style="margin-top:14px;" autofocus>
  <div id="rhyme-result" style="margin-top:14px;"></div>`;
  document.getElementById('rhyme-content').innerHTML = html;
}
function rhymeUpdate() {
  const w = document.getElementById('rhyme-input').value.trim();
  const r = findRhymes(w);
  if (!w) { document.getElementById('rhyme-result').innerHTML = '<p style="font-size:11px; color:var(--textSec); padding:10px;">Tape un mot ci-dessus...</p>'; return; }
  let html = '';
  if (r.four && r.four.length) html += `<h3 style="font-size:13px; font-weight:700; color:var(--success); margin-top:6px;">🔥 Rimes parfaites (4 lettres)</h3><div style="display:flex; flex-wrap:wrap; gap:6px;">${r.four.map(x => `<span onclick="copyText('${x}')" style="background:var(--surface); padding:6px 10px; border-radius:8px; font-size:13px; cursor:pointer; border:2px solid var(--success);">${escapeHtml(x)}</span>`).join('')}</div>`;
  if (r.three && r.three.length) html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">✨ Rimes très bonnes (3 lettres)</h3><div style="display:flex; flex-wrap:wrap; gap:6px;">${r.three.map(x => `<span onclick="copyText('${x}')" style="background:var(--surface); padding:6px 10px; border-radius:8px; font-size:13px; cursor:pointer;">${escapeHtml(x)}</span>`).join('')}</div>`;
  if (r.two && r.two.length) html += `<h3 style="font-size:13px; font-weight:700; color:var(--textSec); margin-top:14px;">💫 Rimes faibles (2 lettres)</h3><div style="display:flex; flex-wrap:wrap; gap:6px;">${r.two.slice(0, 30).map(x => `<span onclick="copyText('${x}')" style="background:var(--surface); padding:6px 10px; border-radius:8px; font-size:12px; cursor:pointer; opacity:0.7;">${escapeHtml(x)}</span>`).join('')}</div>`;
  if (!r.four.length && !r.three.length && !r.two.length) html += '<p style="text-align:center; color:var(--textSec); padding:20px;">Aucune rime trouvée 😔</p>';
  document.getElementById('rhyme-result').innerHTML = html;
}

// === 18. ANAGRAM SOLVER ===
function findAnagrams(word) {
  word = word.toLowerCase().replace(/[^a-z]/g, '');
  if (word.length < 3 || word.length > 9) return [];
  const sorted = word.split('').sort().join('');
  // Use base of common french words
  return ANAGRAM_BASE.filter(w => w !== word && w.length === word.length && w.split('').sort().join('') === sorted);
}
const ANAGRAM_BASE = ['rats','arts','star','tars','tsar','rose','sore','eros','ores','rite','tier','tire','time','mite','emit','item','live','evil','vile','veil','cite','tice','ice','laser','reals','rales','seals','ales','sale','seal','ales','last','rats','star','arts','same','seam','mesa','team','meat','mate','tame','tear','rate','tare','eath','heat','hate','thea','race','care','acre','atlas','meal','male','lame','dish','hids','salt','last','slat','tals','luce','clue','star','tars','rats','arts','tsar','dame','made','mead','mare','ream','marie','aimer','émir','émirs','remis','mires','arme','rame','mer','rem','ré','ré','fous','sous','ours','rugi','iris','iris','sortie','tories','ratio','riota','sirop','prios','rouet','outre','route','tueur','maire','aimer','marie'];
