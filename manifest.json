function tarotDraw(n) {
  const used = new Set();
  const cards = [];
  while (cards.length < n) {
    const idx = Math.floor(Math.random() * v51_TAROT_CARDS.length);
    if (used.has(idx)) continue;
    used.add(idx);
    cards.push({ ...v51_TAROT_CARDS[idx], reversed: Math.random() < 0.3 });
  }
  const labels = n === 1 ? ['Carte du jour'] : ['Passé', 'Présent', 'Futur'];
  let html = `<div style="display:grid; grid-template-columns:repeat(${n},1fr); gap:8px;">`;
  cards.forEach((c, i) => {
    html += `<div style="background:linear-gradient(135deg,#9B59B6,#000); color:white; padding:18px; border-radius:14px; text-align:center; ${c.reversed ? 'transform:rotate(180deg);' : ''}">
      <div style="font-size:11px; opacity:0.7;">${labels[i] || ''}</div>
      <div style="font-size:48px; margin:8px 0;">${c.e}</div>
      <div style="font-size:13px; font-weight:900;">${c.n}</div>
      ${c.reversed ? '<div style="font-size:9px; opacity:0.7; margin-top:4px;">RENVERSÉE</div>' : ''}
    </div>`;
  });
  html += `</div>`;
  cards.forEach((c, i) => {
    html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:8px;">
      <div style="font-size:11px; color:var(--primary); font-weight:700;">${labels[i] || c.n} ${c.e}</div>
      <div style="font-size:13px; margin-top:4px;">${escapeHtml(c.m)}${c.reversed ? ' (énergie inversée ou bloquée)' : ''}</div>
    </div>`;
  });
  document.getElementById('tarot-result').innerHTML = html;
  if (navigator.vibrate) navigator.vibrate([10, 50, 10]);
}

