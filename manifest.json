let _capMode = 'list', _capQuiz = null;
function capMode(m) {
  _capMode = m;
  document.getElementById('cap-mode-list').className = m==='list' ? 'btn primary' : 'btn alt';
  document.getElementById('cap-mode-quiz').className = m==='quiz' ? 'btn primary' : 'btn alt';
  if (m === 'quiz') newCapQuiz(); else renderCapList();
}
function renderCapList() {
  if (_capMode !== 'list') return;
  const search = (document.getElementById('cap-search').value || '').toLowerCase();
  const list = CAPITALES.filter(c => !search || c[0].toLowerCase().includes(search) || c[1].toLowerCase().includes(search));
  document.getElementById('cap-content').innerHTML = list.map(c => `
    <div style="display:flex; padding:8px 12px; background:var(--surface); border-radius:8px; margin-bottom:3px;">
