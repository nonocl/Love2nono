      <div style="margin-top:8px; font-size:10px; color:var(--textSec);">Combos débloquées : <strong>${seen.length} / ${V57_EASTER_EGGS.length}</strong></div>`;
  } else {
    html = `<div style="font-size:11px; color:var(--textSec); font-weight:700;">🎁 COMBOS SECRÈTES</div>
      <div style="margin-top:6px; font-size:10px; line-height:1.5;">Mélange thème + design + vibe pour débloquer des combinaisons surprises !</div>
