function generateQRSVG(text) {
  try {
    const q = qrcode(0, 'M');
    q.addData(text);
    q.make();
    const n = q.getModuleCount();
    let svg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${n} ${n}" shape-rendering="crispEdges" style="width:100%; max-width:280px; height:auto; background:white;">`;
    svg += `<rect width="${n}" height="${n}" fill="white"/>`;
    for (let r=0; r<n; r++) {
      for (let c=0; c<n; c++) {
        if (q.isDark(r, c)) svg += `<rect x="${c}" y="${r}" width="1" height="1" fill="black"/>`;
      }
    }
    svg += '</svg>';
    return svg;
  } catch (e) {
    console.error('QR err:', e);
    return '<p style="color:var(--danger);">⚠️ Texte trop long pour un QR code (max ~1000 caractères)</p>';
  }
}

function renderQR() {
  const text = document.getElementById('qr-input').value;
  const out = document.getElementById('qr-output');
  if (!text.trim()) { out.innerHTML = '<p style="color:var(--textSec); padding:30px;">Tape ton texte pour générer le QR code</p>'; document.getElementById('qr-dl-btn').style.display='none'; return; }
  out.innerHTML = generateQRSVG(text);
  document.getElementById('qr-dl-btn').style.display = 'block';
}

function downloadQR() {
  const svg = document.getElementById('qr-output').querySelector('svg');
  if (!svg) return;
  const data = new XMLSerializer().serializeToString(svg);
  const blob = new Blob([data], { type: 'image/svg+xml' });
  const url = URL.createObjectURL(blob);
  // Convert to PNG via canvas
  const img = new Image();
  img.onload = () => {
    const c = document.createElement('canvas');
    c.width = 600; c.height = 600;
    const ctx = c.getContext('2d');
    ctx.fillStyle = 'white';
    ctx.fillRect(0,0,600,600);
    ctx.drawImage(img, 0, 0, 600, 600);
    c.toBlob(b => {
      const a = document.createElement('a');
      a.href = URL.createObjectURL(b);
      a.download = `qr_${Date.now()}.png`;
      document.body.appendChild(a); a.click(); a.remove();
    }, 'image/png');
  };
  img.src = url;
}

// ============================================================
// PASSWORD GENERATOR
// ============================================================
function generatePw() {
  const len = parseInt(document.getElementById('pw-len').value);
  const upper = document.getElementById('pw-upper').checked;
  const lower = document.getElementById('pw-lower').checked;
  const digits = document.getElementById('pw-digits').checked;
  const special = document.getElementById('pw-special').checked;
  let charset = '';
  if (upper) charset += 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  if (lower) charset += 'abcdefghijklmnopqrstuvwxyz';
  if (digits) charset += '0123456789';
  if (special) charset += '!@#$%^&*()_+-=[]{}|;:,.<>?';
  if (!charset) { alert('Coche au moins un type de caractère.'); return; }
  let pw = '';
  const arr = new Uint32Array(len);
  crypto.getRandomValues(arr);
  for (let i=0; i<len; i++) pw += charset[arr[i] % charset.length];
  document.getElementById('pw-output').textContent = pw;
}

function copyPw() {
  const pw = document.getElementById('pw-output').textContent;
  if (pw === 'cliquez générer') return;
  navigator.clipboard?.writeText(pw);
  toast('Copié ✨');
}

// ============================================================
// BASE CONVERTER
// ============================================================
function updateBase(from) {
  const elDec = document.getElementById('bc-dec');
  const elBin = document.getElementById('bc-bin');
  const elOct = document.getElementById('bc-oct');
  const elHex = document.getElementById('bc-hex');
  let n = NaN;
  try {
    if (from === 'dec') n = parseInt(elDec.value);
    else if (from === 'bin') n = parseInt(elBin.value, 2);
    else if (from === 'oct') n = parseInt(elOct.value, 8);
    else if (from === 'hex') n = parseInt(elHex.value, 16);
  } catch (e) {}
  if (isNaN(n)) {
    if (from !== 'dec') elDec.value = '';
    if (from !== 'bin') elBin.value = '';
    if (from !== 'oct') elOct.value = '';
    if (from !== 'hex') elHex.value = '';
    return;
  }
  if (from !== 'dec') elDec.value = n.toString(10);
  if (from !== 'bin') elBin.value = n.toString(2);
  if (from !== 'oct') elOct.value = n.toString(8);
  if (from !== 'hex') elHex.value = n.toString(16).toUpperCase();
}


// ============================================================
// VAULT (gestionnaire mots de passe local)
// ============================================================
const VAULT_CATS = {
  social: { label: '💬 Réseaux sociaux', color: '#7B61FF' },
  email: { label: '📧 Email', color: '#5B8DEF' },
  game: { label: '🎮 Jeu', color: '#FF8C42' },
  school: { label: '🎓 École', color: '#5DD68F' },
  bank: { label: '🏦 Banque', color: '#FFD166' },
  shop: { label: '🛒 Shopping', color: '#FF6FA3' },
  streaming: { label: '📺 Streaming', color: '#C77DFF' },
  dev: { label: '💻 Dev', color: '#5DD6E5' },
  other: { label: '📦 Autre', color: '#9CA3AF' },
};
let _editingVault = null;
let _viewingVault = null;

async function renderVault() {
  const items = await dbAll('vault');
  const q = (document.getElementById('vault-search')?.value || '').trim().toLowerCase();
  const filtered = q
    ? items.filter(v => [v.app, v.username, v.email, v.num, v.url, v.notes].some(x => x && String(x).toLowerCase().includes(q)))
    : items;
  filtered.sort((a,b) => (a.app||'').localeCompare(b.app||''));
  const el = document.getElementById('vault-list');
  el.innerHTML = '';
  if (items.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">🔐</div><h3>Aucun compte</h3><p>Note tes mots de passe en sécurité, sur ton tel uniquement.</p></div>`;
    return;
  }
  if (filtered.length === 0) {
    el.innerHTML = `<p style="color:var(--textSec); text-align:center; padding:30px; font-size:13px;">Aucun résultat pour "${escapeHtml(q)}"</p>`;
    return;
  }
  for (const v of filtered) {
    const meta = VAULT_CATS[v.cat] || VAULT_CATS.other;
    const row = document.createElement('button');
    row.className = 'list-row';
    const sub = [v.username, v.email].filter(Boolean).join(' · ') || meta.label;
    row.innerHTML = `
      <div style="width:42px; height:42px; border-radius:10px; background:${meta.color}; display:flex; align-items:center; justify-content:center; font-size:18px;">${meta.label.split(' ')[0]}</div>
      <div class="info">
        <div class="name">${escapeHtml(v.app)} ${v.twofa ? '<span style="font-size:10px; background:var(--success); color:white; padding:2px 6px; border-radius:8px; margin-left:4px;">A2F</span>' : ''}</div>
        <div class="sub">${escapeHtml(sub)}</div>
      </div>
      <span style="color:var(--textSec); font-size:20px;">›</span>
    `;
    row.onclick = () => openVaultView(v);
    el.appendChild(row);
  }
}

function openVaultView(v) {
  _viewingVault = v;
  const meta = VAULT_CATS[v.cat] || VAULT_CATS.other;
  document.getElementById('vault-view-title').textContent = v.app;
  const safe = (s) => escapeHtml(s || '');
  const fieldRow = (label, value, copy=true, mono=false) => {
    if (!value) return '';
    return `
      <div style="background:var(--surfaceAlt); padding:10px 12px; border-radius:10px; margin-bottom:6px;">
        <div style="font-size:11px; color:var(--textSec); margin-bottom:2px;">${label}</div>
        <div style="display:flex; align-items:center; gap:8px;">
          <div style="flex:1; min-width:0; word-break:break-all; ${mono?'font-family:monospace;':''}">${safe(value)}</div>
          ${copy ? `<button class="btn alt" style="padding:4px 10px; font-size:12px;" onclick="copyVaultField(${JSON.stringify(value).replace(/"/g, '&quot;')})">📋</button>` : ''}
        </div>
      </div>`;
  };
  const pwdRow = `
      <div style="background:var(--surfaceAlt); padding:10px 12px; border-radius:10px; margin-bottom:6px;">
        <div style="font-size:11px; color:var(--textSec); margin-bottom:2px;">Mot de passe</div>
        <div style="display:flex; align-items:center; gap:8px;">
          <div id="vault-view-pwd" style="flex:1; min-width:0; word-break:break-all; font-family:monospace;">${'•'.repeat(Math.min(v.password?.length || 8, 16))}</div>
          <button class="btn alt" style="padding:4px 10px; font-size:12px;" onclick="toggleViewPwd()" id="vault-view-eye">👁</button>
          <button class="btn alt" style="padding:4px 10px; font-size:12px;" onclick="copyVaultField(${JSON.stringify(v.password||'').replace(/"/g, '&quot;')})">📋</button>
        </div>
      </div>`;
  let twofaInfo = '';
  if (v.twofa) {
    const methods = { app: '📱 App authenticator', sms: '💬 SMS', email: '📧 Email', key: '🔑 Clé physique', backup: '🗝️ Codes de secours', other: '❓ Autre' };
    twofaInfo = `<div style="background:var(--success); color:white; padding:10px 12px; border-radius:10px; margin-bottom:6px; font-size:13px;">🛡️ A2F activée — ${methods[v.twofa_method]||'?'}</div>`;
  }
  const urlOpen = v.url ? `<button class="btn primary full" style="margin-top:10px;" onclick="openVaultUrl('${(v.url||'').replace(/'/g,'')}')">🌐 Ouvrir le site</button>` : '';
  document.getElementById('vault-view-body').innerHTML = `
    <div style="background:${meta.color}; color:white; padding:14px; border-radius:14px; margin-bottom:10px; text-align:center;">
      <div style="font-size:13px; opacity:0.9;">${meta.label}</div>
    </div>
    ${twofaInfo}
    ${fieldRow('Identifiant', v.username)}
    ${fieldRow('Email', v.email)}
    ${fieldRow('Numéro', v.num)}
    ${pwdRow}
    ${fieldRow('URL', v.url)}
    ${v.notes ? `<div style="background:var(--surfaceAlt); padding:10px 12px; border-radius:10px; margin-bottom:6px; white-space:pre-wrap;"><div style="font-size:11px; color:var(--textSec); margin-bottom:4px;">Notes</div>${safe(v.notes)}</div>` : ''}
    ${urlOpen}
  `;
  openModal('modal-vault-view');
}

function toggleViewPwd() {
  const el = document.getElementById('vault-view-pwd');
  const eye = document.getElementById('vault-view-eye');
  if (!_viewingVault) return;
  if (eye.textContent === '👁') {
    el.textContent = _viewingVault.password || '';
    eye.textContent = '🙈';
  } else {
    el.textContent = '•'.repeat(Math.min(_viewingVault.password?.length || 8, 16));
    eye.textContent = '👁';
  }
}

function copyVaultField(value) {
  navigator.clipboard?.writeText(value);
  toast('Copié ✨');
}

function openVaultUrl(url) {
  if (!url) return;
  if (!url.startsWith('http')) url = 'https://' + url;
  window.open(url, '_blank');
}

function editCurrentVault() {
  closeModal('modal-vault-view');
  setTimeout(() => openVaultModal(_viewingVault), 50);
}

function openVaultModal(v) {
  _editingVault = v;
  document.getElementById('vault-modal-title').textContent = v ? 'Modifier' : 'Nouveau compte';
  document.getElementById('vault-app-input').value = v ? v.app : '';
  document.getElementById('vault-cat-input').value = v ? v.cat : 'social';
  document.getElementById('vault-user-input').value = v ? (v.username || '') : '';
  document.getElementById('vault-email-input').value = v ? (v.email || '') : '';
  document.getElementById('vault-num-input').value = v ? (v.num || '') : '';
  document.getElementById('vault-pwd-input').value = v ? (v.password || '') : '';
  document.getElementById('vault-pwd-input').type = 'password';
  document.getElementById('vault-pwd-toggle').textContent = '👁';
  document.getElementById('vault-2fa-input').checked = v ? !!v.twofa : false;
  document.getElementById('vault-2fa-method').value = v && v.twofa_method ? v.twofa_method : 'app';
  document.getElementById('vault-2fa-method-wrap').style.display = (v && v.twofa) ? 'block' : 'none';
  document.getElementById('vault-url-input').value = v ? (v.url || '') : '';
  document.getElementById('vault-notes-input').value = v ? (v.notes || '') : '';
  document.getElementById('vault-del-btn').style.display = v ? 'inline-flex' : 'none';
  openModal('modal-vault');
}

function toggleVaultPwd() {
  const el = document.getElementById('vault-pwd-input');
  const btn = document.getElementById('vault-pwd-toggle');
  if (el.type === 'password') { el.type = 'text'; btn.textContent = '🙈'; }
  else { el.type = 'password'; btn.textContent = '👁'; }
}

function toggle2faMethod() {
  document.getElementById('vault-2fa-method-wrap').style.display = document.getElementById('vault-2fa-input').checked ? 'block' : 'none';
}

function genVaultPwd() {
  const charset = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*';
  const arr = new Uint32Array(16);
  crypto.getRandomValues(arr);
  let pw = '';
  for (let i=0; i<16; i++) pw += charset[arr[i] % charset.length];
  document.getElementById('vault-pwd-input').value = pw;
  document.getElementById('vault-pwd-input').type = 'text';
  document.getElementById('vault-pwd-toggle').textContent = '🙈';
  toast('Mot de passe généré 🎲');
}

async function saveVault() {
  const app = document.getElementById('vault-app-input').value.trim();
  const password = document.getElementById('vault-pwd-input').value;
  if (!app || !password) { alert('App + mot de passe sont obligatoires.'); return; }
  const data = {
    app,
    cat: document.getElementById('vault-cat-input').value,
    username: document.getElementById('vault-user-input').value.trim(),
    email: document.getElementById('vault-email-input').value.trim(),
    num: document.getElementById('vault-num-input').value.trim(),
    password,
    twofa: document.getElementById('vault-2fa-input').checked,
    twofa_method: document.getElementById('vault-2fa-method').value,
    url: document.getElementById('vault-url-input').value.trim(),
    notes: document.getElementById('vault-notes-input').value.trim(),
  };
  if (_editingVault) await dbPut('vault', { ..._editingVault, ...data, updated_at: new Date().toISOString() });
  else await dbAdd('vault', { ...data, created_at: new Date().toISOString() });
  closeModal('modal-vault');
  renderVault();
}

async function deleteVaultNow() {
  if (!confirm(`Supprimer "${_editingVault.app}" ?`)) return;
  await dbDel('vault', _editingVault.id);
  closeModal('modal-vault');
  renderVault();
}

