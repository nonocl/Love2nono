    <button class="btn pwgen-mode primary" data-mode="strong" onclick="pwgenSetMode('strong')">⚡ Fort</button>
    <button class="btn pwgen-mode alt" data-mode="speak" onclick="pwgenSetMode('speak')">🗣 Prononçable</button>
    <button class="btn pwgen-mode alt" data-mode="phrase" onclick="pwgenSetMode('phrase')">📝 Phrase-passe</button>
