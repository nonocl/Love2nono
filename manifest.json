function compShare(idx) {
  const txt = COMPLIMENTS[idx];
  if (navigator.share) {
    navigator.share({ text: txt + '\n\n💕' }).catch(() => {});
  } else {
    navigator.clipboard?.writeText(txt);
    toast('📋 Copié, partage-le !');
  }
}

