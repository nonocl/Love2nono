let _invCurId = null;
let _invFilter = 'Tous';
let _invPhoto = null;
function getInv() { try { return JSON.parse(localStorage.getItem('nw_inv') || '[]'); } catch { return []; } }
function saveInv(d) { localStorage.setItem('nw_inv', JSON.stringify(d)); }
function invNew() {
  _invCurId = null;
  _invPhoto = null;
  document.getElementById('inv-name').value = '';
  document.getElementById('inv-cat').value = 'Électronique';
  document.getElementById('inv-value').value = '';
  document.getElementById('inv-date').value = '';
  document.getElementById('inv-notes').value = '';
  document.getElementById('inv-photo-prev').innerHTML = '';
  goTo('invent-edit');
}
function invOpen(id) {
  const it = getInv().find(x => x.id === id); if (!it) return;
  _invCurId = id;
  _invPhoto = it.photo;
  document.getElementById('inv-name').value = it.name || '';
  document.getElementById('inv-cat').value = it.cat || 'Autre';
  document.getElementById('inv-value').value = it.value || '';
  document.getElementById('inv-date').value = it.date || '';
  document.getElementById('inv-notes').value = it.notes || '';
  document.getElementById('inv-photo-prev').innerHTML = it.photo ? `<img src="${it.photo}" style="width:100%; max-height:200px; object-fit:cover; border-radius:10px;">` : '';
  goTo('invent-edit');
}
function invLoadPhoto(input) {
  const f = (input.files || [])[0]; if (!f) return;
  const r = new FileReader();
  r.onload = e => {
    const img = new Image();
    img.onload = () => {
      const max = 800;
      let w = img.width, h = img.height;
      if (w > max || h > max) { const r = Math.min(max/w, max/h); w *= r; h *= r; }
      const c = document.createElement('canvas'); c.width = w; c.height = h;
      const ctx = c.getContext('2d');
      ctx.fillStyle = '#fff'; ctx.fillRect(0,0,w,h);
      ctx.drawImage(img, 0, 0, w, h);
      _invPhoto = c.toDataURL('image/jpeg', 0.8);
      document.getElementById('inv-photo-prev').innerHTML = `<img src="${_invPhoto}" style="width:100%; max-height:200px; object-fit:cover; border-radius:10px;">`;
    };
    img.src = e.target.result;
  };
  r.readAsDataURL(f);
}
function invSave() {
  const name = document.getElementById('inv-name').value.trim();
  if (!name) return toast('Donne un nom');
  const data = {
    name,
    cat: document.getElementById('inv-cat').value,
    value: parseFloat(document.getElementById('inv-value').value) || 0,
    date: document.getElementById('inv-date').value,
    notes: document.getElementById('inv-notes').value,
    photo: _invPhoto,
  };
  const inv = getInv();
  if (_invCurId) {
    const idx = inv.findIndex(x => x.id === _invCurId);
    if (idx >= 0) inv[idx] = { ...inv[idx], ...data };
  } else {
    inv.push({ id:'i_'+Date.now(), ...data });
  }
  saveInv(inv);
  toast('💾 Sauvé');
  goTo('invent');
}
function invDel() {
  if (!_invCurId) return goTo('invent');
  if (!confirm('Supprimer cet objet ?')) return;
  saveInv(getInv().filter(x => x.id !== _invCurId));
  goTo('invent');
}
function renderInv() {
  const inv = getInv();
  const cats = ['Tous', ...new Set(inv.map(x => x.cat))];
  document.getElementById('inv-cats').innerHTML = cats.map(c => 
    `<div class="home-tab ${_invFilter === c ? 'active' : ''}" onclick="invFilter('${c}')">${c} (${c === 'Tous' ? inv.length : inv.filter(x => x.cat === c).length})</div>`
  ).join('');
  let visible = inv;
  if (_invFilter !== 'Tous') visible = visible.filter(x => x.cat === _invFilter);
  const search = (document.getElementById('inv-search').value || '').toLowerCase();
  if (search) visible = visible.filter(x => (x.name||'').toLowerCase().includes(search) || (x.notes||'').toLowerCase().includes(search));
  if (!visible.length) {
    document.getElementById('inv-list').innerHTML = '<p style="text-align:center; color:var(--textSec); padding:30px;">Aucun objet. Tap + pour commencer 📦</p>';
    return;
  }
  const totalValue = inv.reduce((s, x) => s + (x.value || 0), 0);
  document.getElementById('inv-list').innerHTML = `<p style="text-align:right; font-size:11px; color:var(--textSec); margin-bottom:8px;">💰 Valeur totale : <strong>${totalValue.toFixed(0)}€</strong></p>` + visible.map(it => `
    <div onclick="invOpen('${it.id}')" style="display:flex; gap:10px; align-items:center; padding:10px; background:var(--surface); border-radius:10px; margin-bottom:6px; cursor:pointer;">
      ${it.photo ? `<img src="${it.photo}" style="width:50px; height:50px; object-fit:cover; border-radius:8px;">` : `<div style="width:50px; height:50px; background:var(--surfaceAlt); border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:24px;">📦</div>`}
      <div style="flex:1; min-width:0;">
        <div style="font-weight:700; font-size:14px;">${escapeHtml(it.name)}</div>
        <div style="font-size:11px; color:var(--textSec);">${escapeHtml(it.cat)}${it.value ? ' · ' + it.value + '€' : ''}</div>
      </div>
    </div>
  `).join('');
}
function invFilter(c) { _invFilter = c; renderInv(); }




