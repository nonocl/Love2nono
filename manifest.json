/* === VIBE 4: AESTHETIC (default, gardé du style actuel) === */
/* Pas de styles override, utilise le système existant */

/* ============================================================
   V56 NEW BOTTOM NAV — Pill style flottante
   ============================================================ */
.v56-bottom-nav {
  position: fixed;
  bottom: 14px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 4px;
  padding: 8px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 28px;
  box-shadow: 0 12px 40px rgba(0,0,0,0.18), 0 4px 12px rgba(0,0,0,0.08);
  z-index: 1000;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  max-width: calc(100vw - 28px);
}
.v56-bottom-nav-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  padding: 8px 14px;
  background: transparent;
  border: none;
  cursor: pointer;
  color: var(--textSec);
  border-radius: 20px;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  font-size: 10px;
  font-weight: 700;
  min-width: 56px;
  position: relative;
}
.v56-bottom-nav-btn .v56-nav-ico {
  font-size: 22px;
  line-height: 1;
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}
.v56-bottom-nav-btn .v56-nav-label {
  font-size: 10px;
  letter-spacing: 0.3px;
  opacity: 0.85;
}
.v56-bottom-nav-btn:hover .v56-nav-ico { transform: scale(1.1); }
.v56-bottom-nav-btn.active {
  background: linear-gradient(135deg, var(--primary), var(--accent));
  color: white !important;
}
.v56-bottom-nav-btn.active .v56-nav-ico {
  transform: scale(1.05);
  filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
}
.v56-bottom-nav-btn.active .v56-nav-label { opacity: 1; font-weight: 900; }
@media (max-width: 380px) {
  .v56-bottom-nav-btn { padding: 8px 10px; min-width: 50px; }
  .v56-bottom-nav-btn .v56-nav-ico { font-size: 20px; }
}

/* Hide ancienne nav quand v56 active */
body.v56-active .bottom-nav { display: none !important; }
body.v56-active .fab-quick { bottom: 88px !important; }

/* Padding bottom des pages pour éviter overlap */
body.v56-active .page { padding-bottom: 90px; }

/* ============================================================
   V56 NEW HOME DASHBOARD
   ============================================================ */
.v56-home-bg {
  background: var(--bg);
  min-height: 100vh;
  position: relative;
}
.v56-home-bg::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; height: 240px;
  background: linear-gradient(180deg, rgba(255,111,163,0.18) 0%, transparent 100%);
  pointer-events: none;
  z-index: 0;
}
body.dark .v56-home-bg::before {
  background: linear-gradient(180deg, rgba(155,89,182,0.22) 0%, transparent 100%);
}

.v56-home-content { position: relative; z-index: 1; padding: 14px 16px 100px; }

.v56-greeting {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 24px;
  padding: 18px 20px;
  margin-bottom: 16px;
  position: relative;
  overflow: hidden;
}
.v56-greeting::before {
  content: '';
  position: absolute;
  top: -40%; right: -20%;
  width: 200px; height: 200px;
  background: radial-gradient(circle, var(--primary) 0%, transparent 70%);
  opacity: 0.15;
  pointer-events: none;
}
.v56-greeting-time {
  font-size: 11px;
  color: var(--textSec);
  font-weight: 700;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  margin-bottom: 4px;
}
.v56-greeting-text {
  font-size: 24px;
  font-weight: 900;
  line-height: 1.2;
  letter-spacing: -0.5px;
  color: var(--text);
}
.v56-greeting-name { color: var(--primary); }
.v56-greeting-sub {
  font-size: 13px;
  color: var(--textSec);
  margin-top: 6px;
  font-weight: 500;
}

/* Stats hero */
.v56-stats-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8px;
  margin-bottom: 16px;
}
.v56-stat {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 12px;
  text-align: center;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
}
.v56-stat:active { transform: scale(0.96); }
.v56-stat-emoji { font-size: 22px; margin-bottom: 4px; }
.v56-stat-value {
  font-size: 20px;
  font-weight: 900;
  color: var(--primary);
  line-height: 1;
}
.v56-stat-label {
  font-size: 10px;
  color: var(--textSec);
  font-weight: 700;
  margin-top: 4px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

/* Section titre style */
.v56-section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 22px 0 10px;
}
.v56-section-title h3 {
  font-size: 11px;
  font-weight: 900;
  color: var(--textSec);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin: 0;
}
.v56-section-title .v56-see-all {
  font-size: 11px;
  font-weight: 700;
  color: var(--primary);
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px 8px;
  border-radius: 10px;
  transition: background 0.2s;
}
.v56-section-title .v56-see-all:hover { background: var(--surfaceAlt); }

/* Hero card "Tout" */
.v56-hero-card {
  background: linear-gradient(135deg, var(--primary), var(--accent));
  color: white;
  border-radius: 24px;
  padding: 22px;
  margin-bottom: 16px;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  gap: 16px;
  box-shadow: 0 8px 28px rgba(0,0,0,0.15);
  transition: transform 0.2s;
}
.v56-hero-card:active { transform: scale(0.98); }
.v56-hero-card::after {
  content: '';
  position: absolute;
  top: -30%; right: -20%;
  width: 200px; height: 200px;
  background: radial-gradient(circle, rgba(255,255,255,0.3) 0%, transparent 70%);
  pointer-events: none;
}
.v56-hero-emoji { font-size: 44px; flex-shrink: 0; }
.v56-hero-info { flex: 1; }
.v56-hero-title { font-size: 18px; font-weight: 900; letter-spacing: -0.3px; }
.v56-hero-sub { font-size: 12px; opacity: 0.9; margin-top: 4px; font-weight: 500; }
.v56-hero-arrow { font-size: 28px; opacity: 0.8; }

/* Carrousel catégories horizontal */
.v56-cat-scroll {
  display: flex;
  gap: 10px;
  overflow-x: auto;
  padding: 4px 16px 14px;
  margin: 0 -16px 16px;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.v56-cat-scroll::-webkit-scrollbar { display: none; }
.v56-cat-card {
  flex: 0 0 auto;
  width: 130px;
  height: 150px;
  border-radius: 20px;
  padding: 14px;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  scroll-snap-align: start;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  color: white;
  box-shadow: 0 6px 20px rgba(0,0,0,0.12);
  transition: transform 0.2s;
}
.v56-cat-card:active { transform: scale(0.95); }
.v56-cat-emoji { font-size: 38px; }
.v56-cat-name { font-size: 14px; font-weight: 900; letter-spacing: -0.3px; line-height: 1.2; }
.v56-cat-count { font-size: 10px; opacity: 0.85; font-weight: 700; margin-top: 2px; }

/* Quick action grid */
.v56-quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  margin-bottom: 16px;
}
.v56-quick-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 12px 6px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  cursor: pointer;
  transition: transform 0.2s;
  text-align: center;
}
.v56-quick-card:active { transform: scale(0.94); }
.v56-quick-emoji { font-size: 24px; }
.v56-quick-name { font-size: 10px; font-weight: 700; line-height: 1.2; color: var(--text); }

/* Inspire card */
.v56-inspire {
  background: linear-gradient(135deg, #FF6FA3 0%, #FFD166 100%);
  color: white;
  border-radius: 22px;
  padding: 22px;
  margin-bottom: 16px;
  position: relative;
  overflow: hidden;
}
.v56-inspire::before {
  content: '"';
  position: absolute;
  top: -10px; left: 12px;
  font-size: 80px;
  opacity: 0.2;
  font-family: Georgia, serif;
  line-height: 1;
}
.v56-inspire-text {
  font-size: 14px;
  font-style: italic;
  font-weight: 600;
  line-height: 1.5;
  position: relative;
}
.v56-inspire-author {
  font-size: 11px;
  opacity: 0.85;
  margin-top: 8px;
  font-weight: 700;
}

/* Recent featured tile */
.v56-recent-list {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding: 4px 16px 8px;
  margin: 0 -16px;
  scrollbar-width: none;
}
.v56-recent-list::-webkit-scrollbar { display: none; }
.v56-recent-card {
  flex: 0 0 auto;
  width: 100px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 14px 8px;
  text-align: center;
  cursor: pointer;
  transition: transform 0.2s;
}
.v56-recent-card:active { transform: scale(0.94); }
.v56-recent-emoji { font-size: 28px; }
.v56-recent-name { font-size: 10px; font-weight: 700; margin-top: 6px; line-height: 1.2; color: var(--text); }

/* Mood weather widget */
.v56-mood-card {
  background: linear-gradient(135deg, #5DADE2 0%, #9B59B6 100%);
  color: white;
  border-radius: 22px;
  padding: 18px 20px;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 14px;
  cursor: pointer;
}
.v56-mood-emoji { font-size: 44px; }
.v56-mood-text { flex: 1; }
.v56-mood-title { font-size: 14px; font-weight: 900; }
.v56-mood-sub { font-size: 11px; opacity: 0.9; margin-top: 4px; font-weight: 500; }

/* === V56 CARD GENERIC === */
.v56-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 16px;
  margin-bottom: 12px;
}

/* === V56 SEARCH OVERLAY === */
.v56-search-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  z-index: 9998;
  display: none;
  flex-direction: column;
  padding: 20px 16px;
}
.v56-search-overlay.active { display: flex; }
.v56-search-input-wrap {
  position: relative;
  background: var(--surface);
  border-radius: 20px;
  display: flex;
  align-items: center;
  padding: 4px 4px 4px 18px;
  gap: 10px;
  box-shadow: 0 12px 40px rgba(0,0,0,0.3);
}
.v56-search-input-wrap input {
  flex: 1;
  border: none;
  background: transparent;
  padding: 18px 0;
  font-size: 16px;
  font-weight: 600;
  color: var(--text);
  outline: none;
}
.v56-search-close {
  background: var(--surfaceAlt);
  border: none;
  width: 40px; height: 40px;
  border-radius: 50%;
  font-size: 20px;
  cursor: pointer;
  color: var(--text);
}
.v56-search-results {
  flex: 1;
  margin-top: 14px;
  overflow-y: auto;
  background: var(--surface);
  border-radius: 20px;
  padding: 8px;
}
.v56-search-result {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 12px 14px;
  border-radius: 14px;
  cursor: pointer;
  transition: background 0.2s;
}
.v56-search-result:hover, .v56-search-result:active { background: var(--surfaceAlt); }
.v56-search-result-ico {
  width: 44px; height: 44px;
  background: var(--surfaceAlt);
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px;
  flex-shrink: 0;
}
.v56-search-result-info { flex: 1; }
.v56-search-result-name { font-size: 14px; font-weight: 700; color: var(--text); }
.v56-search-result-cat { font-size: 11px; color: var(--textSec); margin-top: 2px; }
.v56-search-result-arrow { font-size: 20px; color: var(--textSec); }

/* Quick suggestions in search */
.v56-search-chips {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  padding: 14px 4px 0;
}
.v56-search-chip {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 8px 14px;
  font-size: 12px;
  font-weight: 700;
  color: var(--text);
  cursor: pointer;
}
.v56-search-chip:hover { background: var(--surfaceAlt); }

/* === V56 PAGE TRANSITIONS === */
.page.v56-anim-in { animation: v56SlideIn 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
@keyframes v56SlideIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

/* === V56 SETTINGS PANEL FOR VIBES === */
.v56-vibe-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-top: 10px;
}
.v56-vibe-option {
  border: 2px solid var(--border);
  border-radius: 18px;
  padding: 16px 12px;
  cursor: pointer;
  text-align: center;
  background: var(--surface);
  transition: all 0.2s;
  position: relative;
  overflow: hidden;
}
.v56-vibe-option:active { transform: scale(0.96); }
.v56-vibe-option.active {
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(255, 111, 163, 0.2);
}
.v56-vibe-option .v56-vibe-preview {
  height: 60px;
  border-radius: 12px;
  margin-bottom: 8px;
}
.v56-vibe-option[data-vibe="aesthetic"] .v56-vibe-preview {
  background: linear-gradient(135deg, #FF6FA3, #FFD166);
}
.v56-vibe-option[data-vibe="glass"] .v56-vibe-preview {
  background: linear-gradient(135deg, #FFE0EC 0%, #E0E7FF 50%, #FCE7F3 100%);
  position: relative;
}
.v56-vibe-option[data-vibe="glass"] .v56-vibe-preview::after {
  content: '';
  position: absolute;
  inset: 12px;
  background: rgba(255,255,255,0.5);
  backdrop-filter: blur(8px);
  border-radius: 8px;
  border: 1px solid rgba(255,255,255,0.7);
}
.v56-vibe-option[data-vibe="neuo"] .v56-vibe-preview {
  background: #E6E9EF;
  position: relative;
}
.v56-vibe-option[data-vibe="neuo"] .v56-vibe-preview::after {
  content: '';
  position: absolute;
  inset: 12px;
  background: #E6E9EF;
  border-radius: 8px;
  box-shadow: 4px 4px 8px #C5C9D1, -4px -4px 8px #FFFFFF;
}
.v56-vibe-option[data-vibe="brut"] .v56-vibe-preview {
  background: #F7F3EE;
  position: relative;
}
.v56-vibe-option[data-vibe="brut"] .v56-vibe-preview::after {
  content: '';
  position: absolute;
  inset: 12px;
  background: #FFFFFF;
  border: 3px solid #000;
  box-shadow: 4px 4px 0 #000;
  border-radius: 0;
}
.v56-vibe-name { font-size: 13px; font-weight: 900; color: var(--text); }
.v56-vibe-desc { font-size: 10px; color: var(--textSec); margin-top: 2px; font-weight: 500; }

/* === Dot indicator on bottom nav === */
.v56-bottom-nav-btn .v56-dot {
  position: absolute;
  top: 6px; right: 12px;
  width: 6px; height: 6px;
  background: var(--primary);
  border-radius: 50%;
  display: none;
}
.v56-bottom-nav-btn[data-has-update="1"] .v56-dot { display: block; }

/* === SMOOTH SCROLL === */
html { scroll-behavior: smooth; }

/* === ICON BTN MAJ === */
body.v56-active .icon-btn {
  width: 40px; height: 40px;
  border-radius: 50%;
  background: var(--surfaceAlt);
  border: none;
  font-size: 18px;
}



/* ============================================================ V57 COMBO SYSTEM ============================================================ */
/* ============================================================
   V57 COMBO SYSTEM
   - Fixes pour les combinaisons clashantes
   - 12 easter eggs sur des combos magiques
   ============================================================ */

/* ============================================================
   PARTIE 1 : FIXES DE COMBOS
   ============================================================ */

/* Fix : Vibe Brut + design qui a déjà des bordures lourdes
   → on respecte la priorité du design choisi car c'est le plus "fort" visuellement */
body.vibe-brut.design-terminal .v56-greeting,
body.vibe-brut.design-terminal .v56-card,
body.vibe-brut.design-terminal .v56-stat,
body.vibe-brut.design-terminal .home-tile,
body.vibe-brut.design-terminal .v56-quick-card {
  background: #000 !important;
  border: 2px solid #00FF41 !important;
  box-shadow: 0 0 12px rgba(0,255,65,0.4) !important;
  color: #00FF41 !important;
}

body.vibe-brut.design-cyberpunk .v56-greeting,
body.vibe-brut.design-cyberpunk .v56-card {
  background: #0A001E !important;
  border: 3px solid #FF00FF !important;
  box-shadow: 6px 6px 0 #00FFFF !important;
}

body.vibe-brut.design-paper .v56-greeting,
body.vibe-brut.design-paper .v56-card {
  background: #EFE5C7 !important;
  border: 3px solid #5C4A2A !important;
  box-shadow: 4px 4px 0 #5C4A2A !important;
}

/* Fix : Vibe Glass + thèmes ayant déjà gradient → on garde le gradient du thème mais on rend les surfaces translucides */
body.vibe-glass.has-gradient {
  background: var(--gradient, linear-gradient(135deg, #FFE0EC, #E0E7FF)) fixed !important;
}
body.vibe-glass.has-gradient .v56-greeting,
body.vibe-glass.has-gradient .v56-card,
body.vibe-glass.has-gradient .home-tile {
  background: rgba(255,255,255,0.18) !important;
  backdrop-filter: blur(24px) saturate(180%) !important;
  -webkit-backdrop-filter: blur(24px) saturate(180%) !important;
  border: 1px solid rgba(255,255,255,0.3) !important;
}

/* Fix : Vibe Neuo + dark mode → ne pas écraser les ombres */
body.vibe-neuo.dark .v56-greeting,
body.vibe-neuo.dark .v56-card,
body.vibe-neuo.dark .home-tile {
  background: var(--surface, #1F2937) !important;
  box-shadow: 8px 8px 16px rgba(0,0,0,0.4), -6px -6px 14px rgba(255,255,255,0.05) !important;
}

/* Fix : Vibe Brut + thème galaxy/aurora/y2k → garder le gradient mais bordures noires */
body.vibe-brut[class*="theme-"].has-gradient {
  background: var(--gradient) fixed !important;
}
body.vibe-brut.has-gradient .v56-greeting,
body.vibe-brut.has-gradient .v56-card {
  background: rgba(0,0,0,0.4) !important;
  border: 3px solid #FFFFFF !important;
  box-shadow: 6px 6px 0 #FFFFFF !important;
  color: #FFFFFF !important;
}

/* Fix : Vibe Glass + Brut → impossible donc Glass gagne (clean) */
body.vibe-glass.vibe-brut { /* impossible mais au cas où */
  background: linear-gradient(135deg, #FFE0EC, #E0E7FF) fixed !important;
}

/* Fix : design-glass (déjà existant) + vibe-glass (V56) → on prend le V56 qui est plus moderne */
body.design-glass.vibe-glass .v56-card { background: rgba(255,255,255,0.6) !important; }

/* Fix : layout-compact + vibe-brut → réduire les ombres énormes */
body.layout-compact.vibe-brut .home-tile {
  box-shadow: 3px 3px 0 #000 !important;
}
body.layout-compact.vibe-brut.dark .home-tile {
  box-shadow: 3px 3px 0 #FF6B6B !important;
}

/* Fix : preset-minimal + vibe-glass → keep minimal, lighter blur */
body.preset-minimal.vibe-glass .v56-card,
body.preset-minimal.vibe-glass .v56-greeting {
  backdrop-filter: blur(12px) !important;
  -webkit-backdrop-filter: blur(12px) !important;
  border: 1px solid rgba(255,255,255,0.4) !important;
  box-shadow: none !important;
}

/* ============================================================
   PARTIE 2 : EASTER EGGS — 12 COMBOS MAGIQUES
   ============================================================ */

/* === EASTER EGG #1 : NEON DREAM ===
   preset-neon + vibe-glass = aura néon flottante */
body.preset-neon.vibe-glass .v56-greeting,
body.preset-neon.vibe-glass .v56-card,
body.preset-neon.vibe-glass .home-tile {
  background: rgba(255,255,255,0.08) !important;
  backdrop-filter: blur(20px) !important;
  -webkit-backdrop-filter: blur(20px) !important;
  border: 1px solid rgba(255,20,147,0.4) !important;
  box-shadow: 0 0 30px rgba(255,20,147,0.4), 0 0 60px rgba(0,255,255,0.2), inset 0 0 20px rgba(255,20,147,0.1) !important;
  animation: v57_neonPulse 3s ease-in-out infinite;
}
@keyframes v57_neonPulse {
  0%,100% { box-shadow: 0 0 30px rgba(255,20,147,0.4), 0 0 60px rgba(0,255,255,0.2); }
  50% { box-shadow: 0 0 50px rgba(0,255,255,0.5), 0 0 80px rgba(255,20,147,0.3); }
}

/* === EASTER EGG #2 : MATRIX MODE ===
   design-terminal + vibe-brut = mode hacker brutaliste */
body.design-terminal.vibe-brut {
  background: #000 !important;
  font-family: 'Courier New', monospace !important;
}
body.design-terminal.vibe-brut .v56-greeting,
body.design-terminal.vibe-brut .v56-card,
body.design-terminal.vibe-brut .home-tile,
body.design-terminal.vibe-brut .v56-quick-card,
body.design-terminal.vibe-brut .v56-stat {
  background: #000 !important;
  border: 2px solid #00FF41 !important;
  box-shadow: 0 0 0 2px #00FF41, 4px 4px 0 #00FF41 !important;
  color: #00FF41 !important;
  text-shadow: 0 0 8px #00FF41 !important;
  font-family: 'Courier New', monospace !important;
}
body.design-terminal.vibe-brut .v56-greeting-text,
body.design-terminal.vibe-brut .v56-greeting-name,
body.design-terminal.vibe-brut .v56-greeting-time,
body.design-terminal.vibe-brut .v56-stat-value,
body.design-terminal.vibe-brut .v56-stat-label {
  color: #00FF41 !important;
  text-shadow: 0 0 12px #00FF41 !important;
}
body.design-terminal.vibe-brut .v56-greeting-time::before {
  content: '> ';
}
body.design-terminal.vibe-brut .v56-greeting-text::after {
  content: ' █';
  animation: v57_matrixCursor 1s step-end infinite;
}
@keyframes v57_matrixCursor {
  0%,50% { opacity: 1; }
  51%,100% { opacity: 0; }
}

/* === EASTER EGG #3 : Y2K BLISS ===
   design-y2k + vibe-glass + theme y2k = explosion de couleurs holographiques */
body.design-y2k.vibe-glass {
  background: linear-gradient(135deg, #FF1493 0%, #00FFFF 35%, #9D00FF 70%, #FFD700 100%) fixed !important;
}
body.design-y2k.vibe-glass .v56-greeting,
body.design-y2k.vibe-glass .v56-card,
body.design-y2k.vibe-glass .home-tile {
  background: rgba(255,255,255,0.25) !important;
  backdrop-filter: blur(30px) saturate(200%) !important;
  -webkit-backdrop-filter: blur(30px) saturate(200%) !important;
  border: 2px solid rgba(255,255,255,0.6) !important;
  box-shadow: 0 8px 32px rgba(255,20,147,0.4), inset 0 0 20px rgba(0,255,255,0.2) !important;
  animation: v57_y2kShine 6s ease-in-out infinite;
}
@keyframes v57_y2kShine {
  0%,100% { filter: hue-rotate(0deg); }
  50% { filter: hue-rotate(45deg); }
}

/* === EASTER EGG #4 : KAWAII KINGDOM ===
   design-hellokitty + preset-kawaii = explosion sucrée maxi */
body.design-hellokitty.preset-kawaii {
  background: radial-gradient(circle at 20% 20%, #FFE4EC 0%, #FFC1D9 30%, #FF8FB1 70%) fixed !important;
}
body.design-hellokitty.preset-kawaii .v56-greeting,
body.design-hellokitty.preset-kawaii .v56-card,
body.design-hellokitty.preset-kawaii .home-tile {
  background: #FFFFFF !important;
  border: 3px solid #FF6FA3 !important;
  border-radius: 28px !important;
  box-shadow: 0 6px 0 rgba(255,111,163,0.5), 0 12px 24px rgba(255,111,163,0.3) !important;
  position: relative;
}
body.design-hellokitty.preset-kawaii .v56-greeting::after,
body.design-hellokitty.preset-kawaii .v56-card::after {
  content: '🎀';
  position: absolute;
  top: -8px; right: 12px;
  font-size: 20px;
  filter: drop-shadow(0 2px 4px rgba(255,111,163,0.5));
  animation: v57_bowWiggle 4s ease-in-out infinite;
}
@keyframes v57_bowWiggle {
  0%,100% { transform: rotate(-8deg); }
  50% { transform: rotate(8deg); }
}

/* === EASTER EGG #5 : RETRO ARCADE ===
   design-gameboy + vibe-brut = console rétro pixel-art */
body.design-gameboy.vibe-brut {
  background: #0F380F !important;
  font-family: 'Courier New', monospace !important;
}
body.design-gameboy.vibe-brut .v56-greeting,
body.design-gameboy.vibe-brut .v56-card,
body.design-gameboy.vibe-brut .home-tile,
body.design-gameboy.vibe-brut .v56-stat,
body.design-gameboy.vibe-brut .v56-quick-card {
  background: #8BAC0F !important;
  border: 4px solid #0F380F !important;
  border-radius: 0 !important;
  box-shadow: 4px 4px 0 #0F380F, 8px 8px 0 #306230 !important;
  color: #0F380F !important;
  font-family: 'Courier New', monospace !important;
  image-rendering: pixelated !important;
}
body.design-gameboy.vibe-brut .v56-greeting-name { color: #0F380F !important; }
body.design-gameboy.vibe-brut .v56-bottom-nav-btn.active {
  background: #0F380F !important;
  color: #8BAC0F !important;
  text-shadow: 1px 1px 0 #306230;
}

/* === EASTER EGG #6 : DARK ACADEMIA LIBRARY ===
   theme-darkacademia + vibe-neuo = bibliothèque cosy */
body.theme-darkacademia.vibe-neuo,
body[data-theme="darkacademia"].vibe-neuo {
  background: #1A0E08 !important;
  background-image: 
    radial-gradient(ellipse at 30% 20%, rgba(201,168,124,0.08) 0%, transparent 50%),
    radial-gradient(ellipse at 70% 80%, rgba(201,168,124,0.06) 0%, transparent 50%) !important;
}
body.theme-darkacademia.vibe-neuo .v56-greeting,
body.theme-darkacademia.vibe-neuo .v56-card,
body[data-theme="darkacademia"].vibe-neuo .v56-greeting,
body[data-theme="darkacademia"].vibe-neuo .v56-card {
  background: #2C1810 !important;
  border: 1px solid #5C4033 !important;
