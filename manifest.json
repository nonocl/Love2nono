  <div id="mir-flip" style="background:var(--surface); padding:12px; border-radius:10px; cursor:pointer; word-break:break-word;" onclick="copyText(document.getElementById('mir-flip').textContent)"></div>
  
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">🪞 Effet miroir vertical</h3>
  <div id="mir-mirror" style="background:var(--surface); padding:12px; border-radius:10px; cursor:pointer; word-break:break-word;" onclick="copyText(document.getElementById('mir-mirror').textContent)"></div>
  
  <p style="font-size:11px; color:var(--textSec); margin-top:10px; text-align:center;">Tap pour copier 📋</p>`;
  document.getElementById('mirrortext-content').innerHTML = html;
  mirrorUpdate();
}
