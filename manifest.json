// JEU: PUISSANCE 4
// ============================================================
let _c4 = null;
const C4_ROWS = 6, C4_COLS = 7;
function newC4() {
  _c4 = {
    grid: Array.from({length:C4_ROWS}, () => Array(C4_COLS).fill(0)),
    turn: 1, // 1 = player rouge, 2 = AI jaune
    over: false
  };
  document.getElementById('c4-status').textContent = 'À ton tour 🔴';
  renderC4();
}
function renderC4() {
  const board = document.getElementById('c4-board');
  board.innerHTML = '';
  for (let r=0; r<C4_ROWS; r++) for (let c=0; c<C4_COLS; c++) {
    const cell = document.createElement('button');
    const v = _c4.grid[r][c];
    const bg = v === 1 ? '#FF6B7A' : (v === 2 ? '#FFD166' : 'white');
    cell.style.cssText = `width:40px; height:40px; border-radius:50%; background:${bg}; border:none; padding:0; cursor:pointer;`;
    cell.disabled = v !== 0 || _c4.over || _c4.turn !== 1;
    cell.onclick = () => c4Drop(c);
    board.appendChild(cell);
  }
}
function c4Drop(col) {
  // Find lowest empty
  let row = -1;
  for (let r=C4_ROWS-1; r>=0; r--) if (!_c4.grid[r][col]) { row = r; break; }
  if (row < 0) return;
  _c4.grid[row][col] = _c4.turn;
  // Check win
  if (c4CheckWin(row, col, _c4.turn)) {
    _c4.over = true;
    document.getElementById('c4-status').innerHTML = _c4.turn === 1 ? '🎉 Tu gagnes !' : '😬 IA gagne';
    renderC4();
    return;
  }
  // Draw
  if (_c4.grid.every(r => r.every(v => v))) {
    _c4.over = true;
    document.getElementById('c4-status').textContent = 'Match nul';
    renderC4();
    return;
  }
  _c4.turn = _c4.turn === 1 ? 2 : 1;
  document.getElementById('c4-status').textContent = _c4.turn === 1 ? 'À ton tour 🔴' : '🤖 IA réfléchit...';
  renderC4();
  if (_c4.turn === 2) setTimeout(c4AiMove, 600);
}
function c4CheckWin(r, c, p) {
  const dirs = [[0,1],[1,0],[1,1],[1,-1]];
  for (const [dr,dc] of dirs) {
    let count = 1;
    for (let i=1; i<4; i++) { const nr=r+dr*i, nc=c+dc*i; if (nr<0||nr>=C4_ROWS||nc<0||nc>=C4_COLS||_c4.grid[nr][nc]!==p) break; count++; }
    for (let i=1; i<4; i++) { const nr=r-dr*i, nc=c-dc*i; if (nr<0||nr>=C4_ROWS||nc<0||nc>=C4_COLS||_c4.grid[nr][nc]!==p) break; count++; }
    if (count >= 4) return true;
  }
  return false;
}
function c4AiMove() {
  // Simple AI: try to win, then block, then random
  for (let c=0; c<C4_COLS; c++) {
    let row = -1;
    for (let r=C4_ROWS-1; r>=0; r--) if (!_c4.grid[r][c]) { row = r; break; }
    if (row < 0) continue;
    _c4.grid[row][c] = 2;
    if (c4CheckWin(row, c, 2)) {
      // Win!
      if (c4CheckWin(row, c, 2)) {
        _c4.over = true;
        document.getElementById('c4-status').innerHTML = '😬 IA gagne';
        renderC4();
        return;
      }
    }
    _c4.grid[row][c] = 0;
  }
  // Block player
  for (let c=0; c<C4_COLS; c++) {
    let row = -1;
    for (let r=C4_ROWS-1; r>=0; r--) if (!_c4.grid[r][c]) { row = r; break; }
    if (row < 0) continue;
    _c4.grid[row][c] = 1;
    if (c4CheckWin(row, c, 1)) {
      _c4.grid[row][c] = 2;
      _c4.turn = 1;
      document.getElementById('c4-status').textContent = 'À ton tour 🔴';
      renderC4();
      return;
    }
    _c4.grid[row][c] = 0;
  }
  // Random valid
  const validCols = [];
  for (let c=0; c<C4_COLS; c++) if (!_c4.grid[0][c]) validCols.push(c);
  const col = validCols[Math.floor(Math.random()*validCols.length)];
  let row = -1;
  for (let r=C4_ROWS-1; r>=0; r--) if (!_c4.grid[r][col]) { row = r; break; }
  _c4.grid[row][col] = 2;
  if (c4CheckWin(row, col, 2)) {
    _c4.over = true;
    document.getElementById('c4-status').innerHTML = '😬 IA gagne';
    renderC4();
    return;
  }
  _c4.turn = 1;
  document.getElementById('c4-status').textContent = 'À ton tour 🔴';
  renderC4();
}

