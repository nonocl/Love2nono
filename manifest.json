// MÉTRONOME
// ============================================================
let _met = { running: false, bpm: 120, beat: 0, interval: null, taps: [] };
function metSet(bpm) {
  _met.bpm = parseInt(bpm);
  document.getElementById('met-bpm').textContent = _met.bpm;
  document.getElementById('met-slider').value = _met.bpm;
  if (_met.running) { metStop(); metStart(); }
}
function metToggle() { _met.running ? metStop() : metStart(); }
function metStart() {
  _met.running = true;
  _met.beat = 0;
  document.getElementById('met-btn').textContent = '■ Arrêter';
  const interval = 60000 / _met.bpm;
  const tick = () => {
    if (!_met.running) return;
    const time = parseInt(document.getElementById('met-time').value);
    const isAccent = _met.beat % time === 0;
    playTone(isAccent ? 1200 : 800, 0.05, 'sine', isAccent ? 0.5 : 0.3);
    const pulse = document.getElementById('met-pulse');
    pulse.style.transform = 'scale(1.3)';
    pulse.style.background = isAccent ? 'var(--primary)' : 'var(--surface)';
    setTimeout(() => pulse.style.transform = 'scale(1)', 100);
    _met.beat++;
  };
  tick();
  _met.interval = setInterval(tick, interval);
}
function metStop() {
  _met.running = false;
  if (_met.interval) clearInterval(_met.interval);
  document.getElementById('met-btn').textContent = '▶ Démarrer';
}
function metTapTempo() {
  const now = Date.now();
  _met.taps.push(now);
  // Keep only last 8 taps and within 3s
  _met.taps = _met.taps.filter(t => now - t < 3000).slice(-8);
  if (_met.taps.length < 2) {
    document.getElementById('met-tap-result').textContent = 'Tap au moins 2 fois...';
    return;
  }
  const intervals = [];
  for (let i = 1; i < _met.taps.length; i++) intervals.push(_met.taps[i] - _met.taps[i-1]);
  const avg = intervals.reduce((a,b)=>a+b) / intervals.length;
  const bpm = Math.round(60000 / avg);
  document.getElementById('met-tap-result').innerHTML = `≈ <strong>${bpm}</strong> BPM <button class="btn primary" style="padding:4px 10px; font-size:11px;" onclick="metSet(${bpm})">Appliquer</button>`;
}

