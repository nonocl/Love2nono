    </div>
    <div style="background:var(--surface); padding:10px 6px; border-radius:8px; text-align:center;">
      <div style="font-size:9px; color:var(--textSec);">ENTROPIE</div>
      <div style="font-size:18px; font-weight:900;">${a.entropy.toFixed(0)}</div>
    </div>
    <div style="background:var(--surface); padding:10px 6px; border-radius:8px; text-align:center;">
      <div style="font-size:9px; color:var(--textSec);">SCORE</div>
      <div style="font-size:18px; font-weight:900;">${a.score}</div>
    </div>
  </div>`;
  
  if (breachData) {
    if (breachData.count > 0) {
      html += `<div style="background:#E14D6B; color:white; padding:14px; border-radius:12px; margin-top:10px;">
        <div style="font-size:14px; font-weight:900;">🚨 BREACH DÉTECTÉ</div>
        <div style="font-size:12px; margin-top:4px;">Ce mot de passe apparaît <strong>${breachData.count.toLocaleString('fr-FR')} fois</strong> dans des fuites publiques. Change-le immédiatement.</div>
      </div>`;
    } else {
      html += `<div style="background:#5DD68F; color:white; padding:14px; border-radius:12px; margin-top:10px;">
        <div style="font-size:14px; font-weight:900;">✅ Pas trouvé dans les breaches connues</div>
        <div style="font-size:12px; margin-top:4px;">Source : HaveIBeenPwned (k-anonymity, ton mdp n'a pas été envoyé en clair)</div>
      </div>`;
    }
  }
  
  if (a.flags.length > 0) {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">🚩 Faiblesses</h3>`;
    a.flags.forEach(f => {
      const c = f.sev === 'high' ? '#E14D6B' : f.sev === 'med' ? '#FFC542' : '#5DADE2';
      html += `<div style="background:var(--surface); padding:8px 12px; border-radius:8px; margin-top:4px; border-left:3px solid ${c}; font-size:12px;">${escapeHtml(f.msg)}</div>`;
    });
  }
  if (a.wins.length > 0) {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">✅ Points forts</h3>`;
    a.wins.forEach(w => {
      html += `<div style="background:var(--surface); padding:8px 12px; border-radius:8px; margin-top:4px; font-size:12px;">${escapeHtml(w)}</div>`;
    });
  }
  
  document.getElementById('pwa-result').innerHTML = html;
}
async function pwAuditFullCheck() {
  const pw = document.getElementById('pwa-input').value;
  if (!pw) { toast('Tape un mot de passe'); return; }
  
  // Show loading
  pwAuditRender(pw, null);
  const r = document.getElementById('pwa-result');
  r.insertAdjacentHTML('beforeend', `<div id="pwa-loading" style="background:var(--surface); padding:14px; border-radius:12px; margin-top:10px; text-align:center; font-size:12px;"><div style="display:inline-block; width:14px; height:14px; border-radius:50%; background:var(--primary); animation:pulse-soft 1s infinite; margin-right:8px;"></div> Vérification HIBP en cours...</div>`);
  
  try {
    // SHA-1 hash
    const enc = new TextEncoder();
    const buf = await crypto.subtle.digest('SHA-1', enc.encode(pw));
    const hash = Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('').toUpperCase();
    const prefix = hash.slice(0, 5);
    const suffix = hash.slice(5);
    
    // Query HIBP (k-anonymity)
    const ctrl = new AbortController();
    setTimeout(() => ctrl.abort(), 8000);
    const res = await fetch(`https://api.pwnedpasswords.com/range/${prefix}`, { signal: ctrl.signal });
    if (!res.ok) throw new Error('HIBP error');
    const text = await res.text();
    const lines = text.split('\n');
    let count = 0;
    for (const line of lines) {
      const [s, c] = line.trim().split(':');
      if (s === suffix) { count = parseInt(c, 10); break; }
    }
    pwAuditRender(pw, { count });
  } catch (e) {
    document.getElementById('pwa-loading').outerHTML = `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:10px; font-size:12px; color:var(--textSec); text-align:center;">⚠️ Vérification breach impossible (besoin internet ou API indisponible). L'analyse locale reste valide.</div>`;
  }
}

