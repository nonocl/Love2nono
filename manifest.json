      </div>
      <div id="aq-feedback" style="margin-top:14px; font-weight:700; min-height:24px;"></div>
    </div>
  `;
}
function aqAnswer(opt) {
  const item = _aqState.deck[_aqState.q];
  const fb = document.getElementById('aq-feedback');
  if (opt === item.ans) {
    _aqState.correct++;
    fb.innerHTML = `<span style="color:var(--success);">✅ Bravo ! ${item.ans} ${item.word}</span>`;
  } else {
    fb.innerHTML = `<span style="color:var(--danger);">❌ C'était : ${item.ans} ${item.word}</span>`;
  }
  setTimeout(() => { _aqState.q++; showArticleQuiz(); }, 1200);
}

