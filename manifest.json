let _gpCat = 'edgy';
function gpSet(c) {
  _gpCat = c;
  Object.keys(GAMING_PARTS).forEach(x => {
    const el = document.getElementById('gp-'+x);
    if (el) el.className = x === c ? 'btn primary' : 'btn alt';
  });
  gpGen();
}
function gpGen() {
  const p = GAMING_PARTS[_gpCat];
  let html = '';
  for (let i = 0; i < 10; i++) {
    const a = p.adj[Math.floor(Math.random() * p.adj.length)];
    const n = p.noun[Math.floor(Math.random() * p.noun.length)];
    const num = Math.floor(Math.random() * 999);
    const styles = [
      `${a}${n}`,
      `${a}_${n}`,
      `${a}${n}${num}`,
      `xX${a}${n}Xx`,
      `${a.toLowerCase()}.${n.toLowerCase()}`,
      `${a}${n}_${num}`,
      `Mr${a}${n}`,
      `${a}${n}YT`,
    ];
    const pick = styles[Math.floor(Math.random() * styles.length)];
    const safe = pick.replace(/'/g, "\\'");
    html += `<div style="background:var(--surface); padding:12px 14px; border-radius:10px; margin-top:5px; display:flex; justify-content:space-between; align-items:center; cursor:pointer;" onclick="copyText('${safe}', '📋')">
      <span style="font-size:14px; font-weight:700; font-family:monospace;">${escapeHtml(pick)}</span>
      <span style="font-size:11px; color:var(--textSec);">📋</span>
    </div>`;
  }
  document.getElementById('gp-list').innerHTML = html;
}

