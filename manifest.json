// Build reverse indexes for fast lookup
const DICT_INDEX = { fr: {}, it: {}, en: {}, es: {} };
const LANG_IDX = { fr: 0, it: 1, en: 2, es: 3 };
for (let i = 0; i < DICT.length; i++) {
  for (const lang of ['fr','it','en','es']) {
    const word = DICT[i][LANG_IDX[lang]].toLowerCase().trim();
    if (!DICT_INDEX[lang][word]) DICT_INDEX[lang][word] = [];
    DICT_INDEX[lang][word].push(i);
  }
}


// ============================================================
// TRANSLATOR
// ============================================================
const LANG_FLAGS = { fr: '🇫🇷', it: '🇮🇹', en: '🇬🇧', es: '🇪🇸' };
const LANG_NAMES = { fr: 'Français', it: 'Italien', en: 'Anglais', es: 'Espagnol' };

function swapTrLang() {
  const a = document.getElementById('tr-from');
  const b = document.getElementById('tr-to');
  const tmp = a.value;
  a.value = b.value;
  b.value = tmp;
  // Also swap input/output
  const out = document.getElementById('tr-output').dataset.translation;
  const inp = document.getElementById('tr-input');
  if (out) inp.value = out;
  doTranslate();
}

function doTranslate() {
  const from = document.getElementById('tr-from').value;
  const to = document.getElementById('tr-to').value;
  const text = document.getElementById('tr-input').value.trim().toLowerCase();
  const out = document.getElementById('tr-output');
  if (!text) {
    out.innerHTML = '';
    delete out.dataset.translation;
    return;
  }
  if (from === to) {
    out.innerHTML = `<div style="background:var(--surfaceAlt); padding:14px; border-radius:12px;">${escapeHtml(text)}</div>`;
    return;
  }

  // Try exact match first (whole text)
  const exactIds = DICT_INDEX[from][text];
  if (exactIds && exactIds.length > 0) {
    const translations = [...new Set(exactIds.map(i => DICT[i][LANG_IDX[to]]))];
    out.innerHTML = renderTranslations(text, translations, from, to, true);
    out.dataset.translation = translations[0];
    return;
  }

  // Word-by-word translation for sentences
  const words = text.split(/\s+/);
  if (words.length > 1) {
    const translatedWords = [];
    let foundAny = false;
    for (const w of words) {
      const cleaned = w.replace(/[.,;:!?¿¡()«»"']/g, '').toLowerCase();
      const ids = DICT_INDEX[from][cleaned];
      if (ids && ids.length > 0) {
        translatedWords.push(DICT[ids[0]][LANG_IDX[to]]);
        foundAny = true;
      } else {
        translatedWords.push('[' + w + ']');
      }
    }
    if (foundAny) {
      const result = translatedWords.join(' ');
      out.innerHTML = `
        <div style="background:var(--surfaceAlt); padding:14px; border-radius:12px;">
          <div style="font-size:11px; color:var(--textSec); margin-bottom:6px;">${LANG_FLAGS[to]} Traduction mot à mot (les mots inconnus sont entre crochets) :</div>
          <div style="font-size:16px;">${escapeHtml(result)}</div>
          <button class="btn alt" style="margin-top:8px; font-size:12px; padding:6px 10px;" onclick="addTrFav('${escapeJs(text)}','${escapeJs(result)}','${from}','${to}')">⭐ Favori</button>
          <button class="btn alt" style="margin-top:8px; font-size:12px; padding:6px 10px; margin-left:6px;" onclick="copyVaultField('${escapeJs(result)}')">📋</button>
        </div>
      `;
      out.dataset.translation = result;
      return;
    }
  }

  // Try partial match (word starts with)
  const partial = [];
  for (const word in DICT_INDEX[from]) {
    if (word.startsWith(text)) {
      const ids = DICT_INDEX[from][word];
      for (const id of ids) {
        partial.push({ word, translation: DICT[id][LANG_IDX[to]] });
      }
      if (partial.length >= 5) break;
    }
  }
  if (partial.length > 0) {
    let html = `<div style="background:var(--surfaceAlt); padding:14px; border-radius:12px;">
      <div style="font-size:11px; color:var(--textSec); margin-bottom:6px;">Suggestions ${LANG_FLAGS[from]} → ${LANG_FLAGS[to]} :</div>`;
    for (const p of partial) {
      html += `<div style="display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-bottom:1px solid var(--border);">
        <div><span style="color:var(--textSec); font-size:13px;">${escapeHtml(p.word)}</span> → <span style="font-weight:600;">${escapeHtml(p.translation)}</span></div>
        <button class="btn alt" style="font-size:11px; padding:4px 8px;" onclick="addTrFav('${escapeJs(p.word)}','${escapeJs(p.translation)}','${from}','${to}')">⭐</button>
      </div>`;
    }
    html += '</div>';
    out.innerHTML = html;
    return;
  }

  // Fallback API Wiktionary (besoin internet)
  out.innerHTML = `<div style="background:var(--surfaceAlt); padding:14px; border-radius:12px; color:var(--textSec); font-size:13px;">
    <div style="display:flex; align-items:center; gap:8px;">
      <div style="width:10px; height:10px; border-radius:50%; background:var(--primary); animation:pulse-soft 1s infinite;"></div>
      <span>Recherche dans Wiktionnaire en ligne...</span>
    </div>
  </div>`;
  fetchWiktionary(text, from, to, out);
}

// Fallback API Wiktionary (online) — utilise l'API REST officielle de Wiktionary
async function fetchWiktionary(word, from, to, outEl) {
  const wiktLang = { fr: 'fr', it: 'it', en: 'en', es: 'es' }[from] || 'fr';
  try {
    const url = `https://${wiktLang}.wiktionary.org/api/rest_v1/page/definition/${encodeURIComponent(word)}`;
    const ctrl = new AbortController();
    setTimeout(() => ctrl.abort(), 6000);
    const res = await fetch(url, { signal: ctrl.signal });
    if (!res.ok) throw new Error('not found');
    const data = await res.json();
    const langKey = Object.keys(data)[0];
    const defs = data[langKey] || [];
    
    let html = `<div style="background:var(--surfaceAlt); padding:14px; border-radius:12px;">
      <div style="font-size:11px; color:var(--textSec); margin-bottom:8px;">${LANG_FLAGS[from]} <strong style="color:var(--text); font-size:14px;">${escapeHtml(word)}</strong> · 🌐 via Wiktionnaire</div>`;
    
    let foundAny = false;
    for (const section of defs.slice(0, 3)) {
      if (!section.definitions || section.definitions.length === 0) continue;
      foundAny = true;
      html += `<div style="margin-top:6px; padding:10px; background:var(--surface); border-radius:8px;">`;
      if (section.partOfSpeech) {
        html += `<div style="font-size:10px; color:var(--primary); font-weight:700; text-transform:uppercase; margin-bottom:4px;">${escapeHtml(section.partOfSpeech)}</div>`;
      }
      for (const def of section.definitions.slice(0, 3)) {
        const cleanDef = (def.definition || '').replace(/<[^>]+>/g, '').slice(0, 220);
        if (cleanDef) html += `<div style="font-size:13px; margin-top:4px; line-height:1.4;">• ${escapeHtml(cleanDef)}</div>`;
      }
      html += `</div>`;
    }
    if (!foundAny) throw new Error('no defs');
    html += `<div style="font-size:10px; color:var(--textSec); margin-top:10px;">💡 Pour la traduction directe FR↔IT/EN/ES, le mot doit être dans le dico offline (~3945 mots).</div></div>`;
    outEl.innerHTML = html;
    outEl.dataset.translation = word;
  } catch (e) {
    outEl.innerHTML = `<div style="background:var(--surfaceAlt); padding:14px; border-radius:12px; color:var(--textSec); font-size:13px;">
      ❌ Aucune traduction trouvée pour "<strong style="color:var(--text);">${escapeHtml(word)}</strong>".<br>
      <span style="font-size:11px;">Mot absent du dico offline (~3945 mots). ${e.name === 'AbortError' ? 'Wiktionnaire trop lent.' : 'Wiktionnaire indisponible (besoin internet).'}</span>
    </div>`;
    delete outEl.dataset.translation;
  }
}

function renderTranslations(source, translations, from, to, exact) {
  const main = translations[0];
  let html = `<div style="background:var(--surfaceAlt); padding:14px; border-radius:12px;">
    <div style="font-size:11px; color:var(--textSec); margin-bottom:6px;">${LANG_FLAGS[from]} → ${LANG_FLAGS[to]}${exact?'':' (suggestion)'}</div>
    <div style="font-size:22px; font-weight:600;">${escapeHtml(main)}</div>`;
  if (translations.length > 1) {
    html += `<div style="margin-top:8px; font-size:13px; color:var(--textSec);">Autres : ${translations.slice(1).map(t=>escapeHtml(t)).join(', ')}</div>`;
  }
  html += `<div style="margin-top:10px; display:flex; gap:6px;">
    <button class="btn alt" style="font-size:12px; padding:6px 10px;" onclick="addTrFav('${escapeJs(source)}','${escapeJs(main)}','${from}','${to}')">⭐ Favori</button>
    <button class="btn alt" style="font-size:12px; padding:6px 10px;" onclick="copyVaultField('${escapeJs(main)}')">📋 Copier</button>
  </div></div>`;
  return html;
}

function escapeJs(s) {
  return String(s).replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/\n/g,'\\n');
}

// Favorites stored in localStorage
function getTrFavs() {
  try { return JSON.parse(localStorage.getItem('nw_tr_favs') || '[]'); } catch (e) { return []; }
}

function addTrFav(source, target, from, to) {
  const favs = getTrFavs();
  // Prevent duplicates
  if (favs.some(f => f.source === source && f.from === from && f.to === to)) {
    toast('Déjà dans tes favoris');
    return;
  }
  favs.unshift({ source, target, from, to, ts: Date.now() });
  if (favs.length > 100) favs.length = 100;
  localStorage.setItem('nw_tr_favs', JSON.stringify(favs));
  toast('⭐ Ajouté aux favoris');
  renderTrFavs();
}

function removeTrFav(idx) {
  const favs = getTrFavs();
  favs.splice(idx, 1);
  localStorage.setItem('nw_tr_favs', JSON.stringify(favs));
  renderTrFavs();
}

function clearTrFavs() {
  if (!confirm('Supprimer tous tes favoris ?')) return;
  localStorage.removeItem('nw_tr_favs');
  renderTrFavs();
}

function renderTrFavs() {
  const favs = getTrFavs();
  const el = document.getElementById('tr-favs');
  if (!el) return;
  if (favs.length === 0) {
    el.innerHTML = '<p style="color:var(--textSec); font-size:13px; text-align:center; padding:20px 0;">Tap sur ⭐ pour sauvegarder une traduction</p>';
    return;
  }
  el.innerHTML = '';
  for (let i = 0; i < favs.length; i++) {
    const f = favs[i];
    const row = document.createElement('div');
    row.style.cssText = 'display:flex; align-items:center; gap:8px; background:var(--surfaceAlt); padding:10px 12px; border-radius:10px; margin-bottom:4px;';
    row.innerHTML = `
      <div style="flex:1; min-width:0;">
        <div style="font-size:12px; color:var(--textSec);">${LANG_FLAGS[f.from]} ${escapeHtml(f.source)}</div>
        <div style="font-size:14px; font-weight:600;">${LANG_FLAGS[f.to]} ${escapeHtml(f.target)}</div>
      </div>
      <button class="btn alt" style="padding:4px 8px; font-size:12px;" onclick="copyVaultField('${escapeJs(f.target)}')">📋</button>
      <button class="btn ghost" style="padding:4px 8px; font-size:14px; color:var(--danger);" onclick="removeTrFav(${i})">✕</button>
    `;
    el.appendChild(row);
  }
}

// Phrasebook (catégorisé)
let _pbCat = 'greet';
function renderPhrasebook() {
  const lang = document.getElementById('pb-lang').value;
  const fromIdx = LANG_IDX.fr;
  const toIdx = LANG_IDX[lang];
  // Chips
  const chips = document.getElementById('pb-chips');
  chips.innerHTML = '';
  for (const [key, cat] of Object.entries(PHRASEBOOK_CATS)) {
    chips.appendChild(createChip(cat.label, null, null, _pbCat===key, () => { _pbCat=key; renderPhrasebook(); }));
  }
  // List
  const cat = PHRASEBOOK_CATS[_pbCat];
  const el = document.getElementById('pb-list');
  el.innerHTML = '';
  for (let i = cat.range[0]; i < cat.range[1] && i < DICT.length; i++) {
    const entry = DICT[i];
    const row = document.createElement('div');
    row.style.cssText = 'background:var(--surfaceAlt); padding:10px 12px; border-radius:10px; margin-bottom:4px; display:flex; align-items:center; gap:8px;';
    row.innerHTML = `
      <div style="flex:1; min-width:0;">
        <div style="font-size:12px; color:var(--textSec);">🇫🇷 ${escapeHtml(entry[fromIdx])}</div>
        <div style="font-size:15px; font-weight:600;">${LANG_FLAGS[lang]} ${escapeHtml(entry[toIdx])}</div>
      </div>
      <button class="btn alt" style="padding:4px 8px; font-size:12px;" onclick="copyVaultField('${escapeJs(entry[toIdx])}')">📋</button>
      <button class="btn alt" style="padding:4px 8px; font-size:12px;" onclick="addTrFav('${escapeJs(entry[fromIdx])}','${escapeJs(entry[toIdx])}','fr','${lang}')">⭐</button>
    `;
    el.appendChild(row);
  }
}


// ============================================================
// VIDEOS
// ============================================================
let _videoBlobUrls = new Map();
let _currentVideo = null;

async function handleVideoUpload(event) {
  const files = Array.from(event.target.files);
  if (files.length === 0) return;
  toast(`Import de ${files.length} vidéo${files.length>1?'s':''}...`, 3000);
  for (const file of files) {
    try {
      // Generate thumbnail from first frame
      const blob = file;
      const thumbnail = await generateVideoThumbnail(file);
      const duration = await getVideoDuration(file);
      await dbAdd('videos', {
        name: file.name.replace(/\.[^/.]+$/, ''),
        type: file.type,
        size: file.size,
        duration: duration,
        blob: blob,
        thumbnail: thumbnail,
        fav: false,
        created_at: new Date().toISOString(),
      });
    } catch (e) {
      console.error('Erreur import vidéo:', e);
      toast('Erreur sur ' + file.name);
    }
  }
  event.target.value = '';
  toast('✓ Vidéos importées');
  renderVideos();
}

function generateVideoThumbnail(file) {
  return new Promise((resolve) => {
    const url = URL.createObjectURL(file);
    const video = document.createElement('video');
    video.src = url;
    video.muted = true;
    video.playsInline = true;
    video.currentTime = 1;
    video.onloadeddata = () => {
      const canvas = document.createElement('canvas');
      const w = 320, h = Math.round(320 * (video.videoHeight / video.videoWidth) || 180);
      canvas.width = w;
      canvas.height = h;
      const ctx = canvas.getContext('2d');
      try {
        ctx.drawImage(video, 0, 0, w, h);
        canvas.toBlob((blob) => {
          URL.revokeObjectURL(url);
          resolve(blob);
        }, 'image/jpeg', 0.7);
      } catch (e) {
        URL.revokeObjectURL(url);
        resolve(null);
      }
    };
    video.onerror = () => { URL.revokeObjectURL(url); resolve(null); };
    setTimeout(() => { URL.revokeObjectURL(url); resolve(null); }, 5000);
  });
}

function getVideoDuration(file) {
  return new Promise((resolve) => {
    const url = URL.createObjectURL(file);
    const video = document.createElement('video');
    video.src = url;
    video.onloadedmetadata = () => {
      URL.revokeObjectURL(url);
      resolve(video.duration || 0);
    };
    video.onerror = () => { URL.revokeObjectURL(url); resolve(0); };
    setTimeout(() => { URL.revokeObjectURL(url); resolve(0); }, 3000);
  });
}

async function renderVideos() {
  const videos = await dbAll('videos');
  // Free old thumbnail URLs
  for (const url of _videoBlobUrls.values()) URL.revokeObjectURL(url);
  _videoBlobUrls.clear();
  const el = document.getElementById('videos-list');
  el.innerHTML = '';
  if (videos.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">🎥</div><h3>Aucune vidéo</h3><p>Tape sur + pour importer des vidéos depuis ton tel.</p></div>`;
    return;
  }
  // Quota info
  const totalSize = videos.reduce((s,v)=>s+(v.size||0), 0);
  const sizeMB = (totalSize / (1024*1024)).toFixed(1);
  document.getElementById('video-quota').textContent = `${videos.length} vidéo${videos.length>1?'s':''} · ${sizeMB} Mo au total`;
  // Sort by date desc
  videos.sort((a,b) => (b.created_at||'').localeCompare(a.created_at||''));
  // Grid layout
  const grid = document.createElement('div');
  grid.style.cssText = 'display:grid; grid-template-columns:1fr 1fr; gap:8px;';
  for (const v of videos) {
    const card = document.createElement('button');
    card.style.cssText = 'background:var(--surface); border-radius:14px; overflow:hidden; padding:0; text-align:left; display:flex; flex-direction:column;';
    let thumbHtml = '<div style="aspect-ratio:16/9; background:var(--surfaceAlt); display:flex; align-items:center; justify-content:center; font-size:32px;">🎥</div>';
    if (v.thumbnail) {
      const url = URL.createObjectURL(v.thumbnail);
      _videoBlobUrls.set(v.id, url);
      thumbHtml = `<div style="aspect-ratio:16/9; background:black; position:relative;">
        <img src="${url}" style="width:100%; height:100%; object-fit:cover;">
        <div style="position:absolute; right:6px; bottom:6px; background:rgba(0,0,0,0.75); color:white; padding:2px 6px; border-radius:6px; font-size:10px;">${formatVideoTime(v.duration||0)}</div>
        ${v.fav ? '<div style="position:absolute; left:6px; top:6px; font-size:18px;">❤️</div>' : ''}
      </div>`;
    }
    card.innerHTML = `${thumbHtml}
      <div style="padding:8px 10px;">
        <div style="font-size:12px; font-weight:600; line-height:1.2; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${escapeHtml(v.name)}</div>
        <div style="font-size:10px; color:var(--textSec); margin-top:2px;">${(v.size/(1024*1024)).toFixed(1)} Mo</div>
      </div>
    `;
    card.onclick = () => openVideo(v);
    grid.appendChild(card);
  }
  el.appendChild(grid);
}

function formatVideoTime(s) {
  if (!s || isNaN(s)) return '0:00';
  s = Math.floor(s);
  const m = Math.floor(s / 60);
  const sec = s % 60;
  if (m >= 60) {
    const h = Math.floor(m / 60);
    const mm = m % 60;
    return `${h}:${String(mm).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
  }
  return `${m}:${String(sec).padStart(2,'0')}`;
}

async function openVideo(v) {
  _currentVideo = v;
  document.getElementById('vp-title').textContent = v.name;
  const video = document.getElementById('vp-video');
  // Free previous URL
  if (video.dataset.curUrl) URL.revokeObjectURL(video.dataset.curUrl);
  const url = URL.createObjectURL(v.blob);
  video.src = url;
  video.dataset.curUrl = url;
  video.playbackRate = 1;
  document.getElementById('vp-speed').textContent = '1×';
  document.getElementById('vp-fav-btn').textContent = v.fav ? '❤️' : '♡';
  document.getElementById('vp-meta').innerHTML = `
    <div style="display:flex; justify-content:space-between; padding:4px 0; border-bottom:1px solid var(--border);"><span style="color:var(--textSec);">Durée</span><span>${formatVideoTime(v.duration||0)}</span></div>
    <div style="display:flex; justify-content:space-between; padding:4px 0; border-bottom:1px solid var(--border);"><span style="color:var(--textSec);">Taille</span><span>${(v.size/(1024*1024)).toFixed(1)} Mo</span></div>
    <div style="display:flex; justify-content:space-between; padding:4px 0; border-bottom:1px solid var(--border);"><span style="color:var(--textSec);">Format</span><span>${v.type||'?'}</span></div>
    <div style="display:flex; justify-content:space-between; padding:4px 0;"><span style="color:var(--textSec);">Importée</span><span>${v.created_at ? new Date(v.created_at).toLocaleDateString('fr-FR') : ''}</span></div>
  `;
  goTo('video-player');
  setTimeout(() => video.play().catch(()=>{}), 100);
}

function closeVideo() {
  const video = document.getElementById('vp-video');
  video.pause();
  if (video.dataset.curUrl) {
    URL.revokeObjectURL(video.dataset.curUrl);
    delete video.dataset.curUrl;
  }
  video.src = '';
  goTo('videos');
}

function changeVideoSpeed(delta) {
  const video = document.getElementById('vp-video');
  let newSpeed = Math.max(0.25, Math.min(3, video.playbackRate + delta));
  newSpeed = Math.round(newSpeed * 100) / 100;
  video.playbackRate = newSpeed;
  document.getElementById('vp-speed').textContent = newSpeed + '×';
}

async function toggleFavVideo() {
  if (!_currentVideo) return;
  _currentVideo.fav = !_currentVideo.fav;
  await dbPut('videos', _currentVideo);
  document.getElementById('vp-fav-btn').textContent = _currentVideo.fav ? '❤️' : '♡';
}

async function deleteCurrentVideo() {
  if (!_currentVideo) return;
  if (!confirm(`Supprimer "${_currentVideo.name}" ?`)) return;
  await dbDel('videos', _currentVideo.id);
  closeVideo();
  renderVideos();
}


// ============================================================
// WALLET (solde / portefeuille)
// ============================================================
const WALLET_CATS_IN = {
  pocket: { label: '💵 Argent de poche', color: '#5DD68F' },
  gift: { label: '🎁 Cadeau', color: '#C77DFF' },
  job: { label: '💼 Petit boulot', color: '#5B8DEF' },
  refund: { label: '↩️ Remboursement', color: '#FFD166' },
  sale: { label: '🏷️ Vente', color: '#FF8C42' },
  other_in: { label: '✨ Autre', color: '#9CA3AF' },
};
const WALLET_CATS_OUT = {
  food: { label: '🍔 Nourriture', color: '#FF8C42' },
  fun: { label: '🎮 Loisirs', color: '#7B61FF' },
  clothes: { label: '👕 Vêtements', color: '#FF6FA3' },
  transport: { label: '🚌 Transport', color: '#5B8DEF' },
  school: { label: '📚 Scolaire', color: '#5DD68F' },
  gift_out: { label: '🎁 Cadeau offert', color: '#C77DFF' },
  saving: { label: '🏦 Épargne', color: '#06FFA5' },
  other_out: { label: '💼 Autre', color: '#9CA3AF' },
};
let _editingWtx = null;
let _walletFilter = 'all';

function getWalletInit() { return parseFloat(localStorage.getItem('nw_wallet_init') || '0'); }
function setWalletInit(v) { localStorage.setItem('nw_wallet_init', String(v)); }

async function renderWallet() {
  const txs = await dbAll('wallet_tx');
  // Calc balance
  let balance = getWalletInit();
  for (const t of txs) {
    balance += t.kind === 'in' ? t.amount : -t.amount;
  }
  document.getElementById('wallet-balance').textContent = balance.toFixed(2).replace('.', ',') + ' €';
  document.getElementById('wallet-balance').style.color = balance < 0 ? 'var(--danger)' : 'var(--primary)';
  // Month stats
  const now = new Date();
  const yyyy = now.getFullYear(), mm = now.getMonth();
  let monthIn = 0, monthOut = 0;
  for (const t of txs) {
    const d = new Date(t.date);
    if (d.getFullYear() === yyyy && d.getMonth() === mm) {
      if (t.kind === 'in') monthIn += t.amount;
      else monthOut += t.amount;
    }
  }
  document.getElementById('wallet-month-in').textContent = '+' + monthIn.toFixed(2).replace('.',',') + ' €';
  document.getElementById('wallet-month-out').textContent = '−' + monthOut.toFixed(2).replace('.',',') + ' €';
  // Chips
  const chips = document.getElementById('wallet-chips');
  chips.innerHTML = '';
  chips.appendChild(createChip(`Tout (${txs.length})`, '✨', null, _walletFilter==='all', () => { _walletFilter='all'; renderWallet(); }));
  const inCount = txs.filter(t=>t.kind==='in').length;
  const outCount = txs.filter(t=>t.kind==='out').length;
  chips.appendChild(createChip(`Entrées (${inCount})`, '↗', null, _walletFilter==='in', () => { _walletFilter='in'; renderWallet(); }));
  chips.appendChild(createChip(`Sorties (${outCount})`, '↘', null, _walletFilter==='out', () => { _walletFilter='out'; renderWallet(); }));
  // Filter & sort
  let list = txs;
  if (_walletFilter !== 'all') list = list.filter(t => t.kind === _walletFilter);
  list.sort((a,b) => (b.date||'').localeCompare(a.date||'') || (b.id - a.id));
  // Render
  const el = document.getElementById('wallet-list');
  el.innerHTML = '';
  if (txs.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">💵</div><h3>Aucune transaction</h3><p>Note tes rentrées et sorties pour suivre ton solde.</p></div>`;
    return;
  }
  // Group by date
  let curDate = '';
  for (const t of list) {
    if (t.date !== curDate) {
      curDate = t.date;
      const sep = document.createElement('div');
      sep.style.cssText = 'font-size:11px; color:var(--textSec); margin:14px 0 6px; text-transform:uppercase; letter-spacing:0.5px;';
      sep.textContent = formatTxDate(t.date);
      el.appendChild(sep);
    }
    const cats = t.kind === 'in' ? WALLET_CATS_IN : WALLET_CATS_OUT;
    const meta = cats[t.cat] || cats[t.kind === 'in' ? 'other_in' : 'other_out'];
    const sign = t.kind === 'in' ? '+' : '−';
    const color = t.kind === 'in' ? 'var(--success)' : 'var(--danger)';
    const row = document.createElement('button');
    row.style.cssText = 'display:flex; align-items:center; gap:10px; padding:12px; background:var(--surface); border-radius:14px; margin-bottom:4px; width:100%; text-align:left;';
    row.innerHTML = `
      <div style="width:40px; height:40px; border-radius:20px; background:${meta.color}; display:flex; align-items:center; justify-content:center; font-size:18px;">${meta.label.split(' ')[0]}</div>
      <div style="flex:1; min-width:0;">
        <div style="font-size:14px; font-weight:600;">${escapeHtml(t.name||'(sans nom)')}</div>
        <div style="font-size:11px; color:var(--textSec);">${meta.label.split(' ').slice(1).join(' ')}${t.note?' · '+escapeHtml(t.note.slice(0,40)):''}</div>
      </div>
      <div style="font-size:16px; font-weight:800; color:${color};">${sign}${t.amount.toFixed(2).replace('.',',')} €</div>
    `;
    row.onclick = () => openWalletTxModal(t.kind, t);
    el.appendChild(row);
  }
}

function formatTxDate(s) {
  if (!s) return 'Sans date';
  const d = new Date(s);
  const today = new Date(); today.setHours(0,0,0,0);
  const yesterday = new Date(today); yesterday.setDate(today.getDate()-1);
  if (d.toDateString() === today.toDateString()) return "Aujourd'hui";
  if (d.toDateString() === yesterday.toDateString()) return "Hier";
  return d.toLocaleDateString('fr-FR', {weekday:'long', day:'numeric', month:'long'});
}

function openWalletTxModal(kind, tx) {
  _editingWtx = tx ? {...tx} : { kind };
  const k = tx ? tx.kind : kind;
  const isIn = k === 'in';
  document.getElementById('wtx-modal-title').textContent = tx ? (isIn?'Modifier rentrée':'Modifier sortie') : (isIn?'Nouvelle rentrée':'Nouvelle sortie');
  document.getElementById('wtx-amount-input').value = tx ? tx.amount : '';
  document.getElementById('wtx-name-input').value = tx ? (tx.name||'') : '';
  document.getElementById('wtx-date-input').value = tx ? tx.date : new Date().toISOString().split('T')[0];
  document.getElementById('wtx-note-input').value = tx ? (tx.note||'') : '';
  // Populate categories based on kind
  const sel = document.getElementById('wtx-cat-input');
  sel.innerHTML = '';
  const cats = isIn ? WALLET_CATS_IN : WALLET_CATS_OUT;
  for (const [key, c] of Object.entries(cats)) {
    const opt = document.createElement('option');
    opt.value = key;
    opt.textContent = c.label;
    sel.appendChild(opt);
  }
  sel.value = tx ? tx.cat : (isIn ? 'pocket' : 'food');
  document.getElementById('wtx-del-btn').style.display = tx ? 'inline-flex' : 'none';
  openModal('modal-wallet-tx');
}

async function saveWalletTx() {
  const amount = parseFloat(document.getElementById('wtx-amount-input').value);
  const name = document.getElementById('wtx-name-input').value.trim();
  const cat = document.getElementById('wtx-cat-input').value;
  const date = document.getElementById('wtx-date-input').value;
  const note = document.getElementById('wtx-note-input').value.trim();
  if (isNaN(amount) || amount <= 0) { alert('Montant invalide.'); return; }
  if (!name) { alert('Donne une description.'); return; }
  const data = { amount, name, cat, date, note, kind: _editingWtx.kind };
  if (_editingWtx.id) {
    await dbPut('wallet_tx', { ..._editingWtx, ...data });
  } else {
    await dbAdd('wallet_tx', { ...data, created_at: new Date().toISOString() });
  }
  closeModal('modal-wallet-tx');
  renderWallet();
}

async function deleteWalletTxNow() {
  if (!confirm('Supprimer cette transaction ?')) return;
  await dbDel('wallet_tx', _editingWtx.id);
  closeModal('modal-wallet-tx');
  renderWallet();
}

function openWalletSettings() {
  document.getElementById('wallet-init-input').value = getWalletInit();
  openModal('modal-wallet-settings');
}

function saveWalletInit() {
  const v = parseFloat(document.getElementById('wallet-init-input').value) || 0;
  setWalletInit(v);
  closeModal('modal-wallet-settings');
  renderWallet();
}

async function resetWallet() {
  if (!confirm('⚠️ Effacer toutes les transactions et le solde initial ?')) return;
  await dbClear('wallet_tx');
  localStorage.removeItem('nw_wallet_init');
  closeModal('modal-wallet-settings');
  renderWallet();
}

// ============================================================
// THEME FAB (sélecteur flottant)
// ============================================================
function toggleThemeFab() {
  const panel = document.getElementById('theme-fab-panel');
  if (panel.classList.contains('show')) {
    panel.classList.remove('show');
  } else {
    renderThemeFabList();
    panel.classList.add('show');
  }
}

function renderThemeFabList() {
  const el = document.getElementById('theme-fab-list');
  el.innerHTML = '';
  const order = ['nono','nonowall','girly','dark','light','cream','sage','cloud','peach','butterfly','midnight','amethyst','sunset','cat','pinkdream','oceanic','twilight','aurora','fire','galaxy'];
  for (const key of order) {
    const t = THEMES[key];
    if (!t) continue;
    const btn = document.createElement('button');
    btn.className = 'theme-fab-item' + (state.themeName === key ? ' active' : '');
    const swatchBg = t.gradient || `linear-gradient(135deg, ${t.primary}, ${t.accent})`;
    btn.innerHTML = `
      <div class="swatch" style="background:${swatchBg};"></div>
      <span class="name">${escapeHtml(t.name)}</span>
      ${state.themeName === key ? '<span class="check">✓</span>' : ''}
    `;
    btn.onclick = () => {
      setTheme(key);
      renderThemeFabList();
      // Rafraîchir la grille de thèmes dans Settings si on y est
      if (state.page === 'settings') renderThemeGrid();
    };
    el.appendChild(btn);
  }
  // Custom theme si existant
  if (state.customTheme) {
    const btn = document.createElement('button');
    btn.className = 'theme-fab-item' + (state.themeName === 'custom' ? ' active' : '');
    const t = state.customTheme;
    const swatchBg = t.gradient || `linear-gradient(135deg, ${t.primary}, ${t.accent})`;
    btn.innerHTML = `
      <div class="swatch" style="background:${swatchBg};"></div>
      <span class="name">⚡ Mon thème custom</span>
      ${state.themeName === 'custom' ? '<span class="check">✓</span>' : ''}
    `;
    btn.onclick = () => {
      setTheme('custom');
      renderThemeFabList();
      if (state.page === 'settings') renderThemeGrid();
    };
    el.appendChild(btn);
  }
}

// Fermer le panneau si on tap ailleurs
document.addEventListener('click', (e) => {
  const panel = document.getElementById('theme-fab-panel');
  const fab = document.getElementById('theme-fab');
  if (!panel.classList.contains('show')) return;
  if (panel.contains(e.target) || fab.contains(e.target)) return;
  panel.classList.remove('show');
});

// Cacher le FAB sur certaines pages où il gênerait (lecteur vidéo, jeux plein écran, modales)
function updateThemeFabVisibility() {
  const fab = document.getElementById('theme-fab');
  if (!fab) return;
  // Cache si une modale est ouverte
  const modalOpen = document.querySelector('.modal-bg.show, .modal-bg[style*="display: flex"], .modal-bg[style*="display:flex"]');
  // Cache pendant la lecture vidéo en plein écran
  const onVideoPage = state.page === 'video-player';
  fab.classList.toggle('hidden', !!modalOpen || onVideoPage);
}

// Hook dans goTo pour cacher/montrer
const _origGoTo = goTo;
goTo = function(page) {
  _origGoTo(page);
  updateThemeFabVisibility();
  // Fermer le panneau quand on change de page
  document.getElementById('theme-fab-panel')?.classList.remove('show');
};

// Aussi quand on ouvre/ferme une modale
const _origOpenModal = openModal;
openModal = function(id) {
  _origOpenModal(id);
  updateThemeFabVisibility();
  document.getElementById('theme-fab-panel')?.classList.remove('show');
};
const _origCloseModal = closeModal;
closeModal = function(id) {
  _origCloseModal(id);
  setTimeout(updateThemeFabVisibility, 50);
};



// ============================================================
// CALENDRIER (1900 → 2222)
// ============================================================
const MONTH_NAMES = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
const DAY_SHORT = ['L','M','M','J','V','S','D'];
let _calYear = new Date().getFullYear();
let _calMonth = new Date().getMonth();
let _calSelectedDate = null;

async function renderCalendar() {
  if (!_calSelectedDate) _calSelectedDate = new Date().toISOString().split('T')[0];
  document.getElementById('cal-title').textContent = `${MONTH_NAMES[_calMonth]} ${_calYear}`;
  // Get all events for this month
  const allEvents = await dbAll('events');
  const monthEvents = allEvents.filter(e => {
    const d = new Date(e.date);
    return d.getFullYear() === _calYear && d.getMonth() === _calMonth;
  });
  const eventsByDay = {};
  for (const e of monthEvents) {
    const d = new Date(e.date).getDate();
    if (!eventsByDay[d]) eventsByDay[d] = [];
    eventsByDay[d].push(e);
  }
  // Build grid
  const grid = document.getElementById('cal-grid');
  grid.innerHTML = '';
  // Header (days)
  const header = document.createElement('div');
  header.style.cssText = 'display:grid; grid-template-columns:repeat(7,1fr); gap:2px; margin-bottom:4px;';
  for (const d of DAY_SHORT) {
    const c = document.createElement('div');
    c.style.cssText = 'text-align:center; font-size:11px; font-weight:700; color:var(--textSec); padding:4px;';
    c.textContent = d;
    header.appendChild(c);
  }
  grid.appendChild(header);
  // Days grid
  const daysGrid = document.createElement('div');
  daysGrid.style.cssText = 'display:grid; grid-template-columns:repeat(7,1fr); gap:3px;';
  // First day of month (0=Sunday, 1=Monday...). We want Monday-first.
  const firstDay = new Date(_calYear, _calMonth, 1).getDay();
  const offset = firstDay === 0 ? 6 : firstDay - 1;
  const daysInMonth = new Date(_calYear, _calMonth + 1, 0).getDate();
  const todayStr = new Date().toISOString().split('T')[0];
  for (let i = 0; i < offset; i++) {
    const empty = document.createElement('div');
    daysGrid.appendChild(empty);
  }
  for (let day = 1; day <= daysInMonth; day++) {
    const dateStr = `${_calYear}-${String(_calMonth+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
    const isToday = dateStr === todayStr;
    const isSelected = dateStr === _calSelectedDate;
    const events = eventsByDay[day] || [];
    const cell = document.createElement('button');
    cell.style.cssText = `
      aspect-ratio:1; padding:4px 2px; font-size:13px; border-radius:8px;
      background:${isSelected ? 'var(--primary)' : (isToday ? 'var(--surfaceAlt)' : 'transparent')};
      color:${isSelected ? 'white' : 'var(--text)'};
      border:${isToday && !isSelected ? '2px solid var(--primary)' : 'none'};
      display:flex; flex-direction:column; align-items:center; justify-content:center; gap:2px;
      cursor:pointer; font-weight:${isToday?'700':'500'};
    `;
    cell.innerHTML = `<span>${day}</span>`;
    if (events.length > 0) {
      const dotsWrap = document.createElement('div');
      dotsWrap.style.cssText = 'display:flex; gap:2px; flex-wrap:wrap; justify-content:center;';
      for (const e of events.slice(0, 3)) {
        const dot = document.createElement('span');
        dot.style.cssText = `width:4px; height:4px; border-radius:2px; background:${e.color || 'var(--primary)'};`;
        dotsWrap.appendChild(dot);
      }
      cell.appendChild(dotsWrap);
    }
    cell.onclick = () => { _calSelectedDate = dateStr; renderCalendar(); };
    daysGrid.appendChild(cell);
  }
  grid.appendChild(daysGrid);
  // Render selected day events
  await renderCalDayEvents();
}

async function renderCalDayEvents() {
  const list = document.getElementById('cal-events-list');
  const titleEl = document.getElementById('cal-day-title');
  if (!_calSelectedDate) return;
  const d = new Date(_calSelectedDate);
  titleEl.textContent = d.toLocaleDateString('fr-FR', { weekday:'long', day:'numeric', month:'long', year:'numeric' });
  const events = (await dbAll('events')).filter(e => e.date === _calSelectedDate);
  events.sort((a,b) => (a.time||'').localeCompare(b.time||''));
  list.innerHTML = '';
  if (events.length === 0) {
    list.innerHTML = '<p style="color:var(--textSec); font-size:13px; text-align:center; padding:14px;">Aucun événement</p>';
    return;
  }
  for (const e of events) {
    const row = document.createElement('button');
    row.style.cssText = 'display:flex; gap:10px; padding:10px 12px; background:var(--surfaceAlt); border-radius:10px; margin-bottom:4px; width:100%; text-align:left; align-items:center;';
    row.innerHTML = `
      <div style="width:6px; height:36px; background:${e.color}; border-radius:3px;"></div>
      <div style="flex:1; min-width:0;">
        <div style="font-size:14px; font-weight:600;">${escapeHtml(e.name)}</div>
        <div style="font-size:11px; color:var(--textSec);">${e.time||''} ${e.note?'· '+escapeHtml(e.note.slice(0,40)):''}</div>
      </div>
    `;
    row.onclick = () => openCalEventModal(e);
    list.appendChild(row);
  }
}

function calNav(deltaMonths) {
  const d = new Date(_calYear, _calMonth + deltaMonths, 1);
  if (d.getFullYear() < 1900) { _calYear = 1900; _calMonth = 0; }
  else if (d.getFullYear() > 2222) { _calYear = 2222; _calMonth = 11; }
  else { _calYear = d.getFullYear(); _calMonth = d.getMonth(); }
  renderCalendar();
}

function calToday() {
  const t = new Date();
  _calYear = t.getFullYear(); _calMonth = t.getMonth();
  _calSelectedDate = t.toISOString().split('T')[0];
  renderCalendar();
}

function openCalJump() {
  document.getElementById('cal-jump-year').value = _calYear;
  document.getElementById('cal-jump-month').value = _calMonth;
  openModal('modal-cal-jump');
}

function doCalJump() {
  let y = parseInt(document.getElementById('cal-jump-year').value);
  if (y < 1900) y = 1900; if (y > 2222) y = 2222;
  _calYear = y;
  _calMonth = parseInt(document.getElementById('cal-jump-month').value);
  closeModal('modal-cal-jump');
  renderCalendar();
}

let _editingCalEv = null;
function openCalEventModal(ev) {
  _editingCalEv = ev;
  document.getElementById('cal-ev-title').textContent = ev ? 'Modifier' : 'Nouvel événement';
  document.getElementById('cal-ev-name').value = ev ? ev.name : '';
  document.getElementById('cal-ev-date').value = ev ? ev.date : (_calSelectedDate || new Date().toISOString().split('T')[0]);
  document.getElementById('cal-ev-time').value = ev ? (ev.time||'') : '';
  document.getElementById('cal-ev-color').value = ev ? ev.color : '#FF6FA3';
  document.getElementById('cal-ev-note').value = ev ? (ev.note||'') : '';
  document.getElementById('cal-ev-del').style.display = ev ? 'inline-flex' : 'none';
  openModal('modal-cal-event');
}

async function saveCalEvent() {
  const name = document.getElementById('cal-ev-name').value.trim();
  const date = document.getElementById('cal-ev-date').value;
  const time = document.getElementById('cal-ev-time').value;
  const color = document.getElementById('cal-ev-color').value;
  const note = document.getElementById('cal-ev-note').value.trim();
  if (!name || !date) { alert('Titre + date requis.'); return; }
  if (_editingCalEv) await dbPut('events', { ..._editingCalEv, name, date, time, color, note });
  else await dbAdd('events', { name, date, time, color, note, created_at: new Date().toISOString() });
  closeModal('modal-cal-event');
  // If date moved to another month, navigate
  const d = new Date(date);
  _calYear = d.getFullYear(); _calMonth = d.getMonth(); _calSelectedDate = date;
  renderCalendar();
}

async function deleteCalEvent() {
  if (!confirm('Supprimer cet événement ?')) return;
  await dbDel('events', _editingCalEv.id);
  closeModal('modal-cal-event');
  renderCalendar();
}

