// MODE ORAL
// ============================================================
let _moQs = [];
let _moIdx = 0;
function moRefreshList() {
  const src = document.getElementById('mo-source').value;
  document.getElementById('mo-custom').style.display = src === 'custom' ? '' : 'none';
}
async function moStart() {
  const src = document.getElementById('mo-source').value;
  if (src === 'flashcards') {
    const cards = await dbAll('cards');
    _moQs = cards.map(c => ({ q: c.front, a: c.back }));
  } else {
    const lines = document.getElementById('mo-list').value.trim().split('\n');
    _moQs = lines.map(l => {
      const [q, a] = l.split('|').map(s => s?.trim());
      return q && a ? { q, a } : null;
    }).filter(Boolean);
  }
  if (!_moQs.length) return toast('Aucune question disponible');
  _moQs.sort(() => Math.random() - 0.5);
  _moIdx = 0;
  moNext();
}
function moNext() {
  if (_moIdx >= _moQs.length) {
    document.getElementById('mo-game').innerHTML = `<div style="text-align:center; padding:30px;"><div style="font-size:64px;">🎉</div><h3 style="margin-top:14px;">Session terminée !</h3><p style="color:var(--textSec);">${_moQs.length} questions parcourues</p><button class="btn primary full" onclick="moStart()" style="margin-top:14px;">↻ Recommencer</button></div>`;
    return;
  }
  const q = _moQs[_moIdx];
  document.getElementById('mo-game').innerHTML = `
    <div style="background:var(--surface); padding:20px; border-radius:14px;">
      <div style="font-size:11px; color:var(--textSec); margin-bottom:6px;">Question ${_moIdx + 1}/${_moQs.length}</div>
      <div style="font-size:18px; font-weight:600; line-height:1.4;">${escapeHtml(q.q)}</div>
      <button class="btn primary full" onclick="moSpeak()" style="margin-top:14px;">🔊 Réécouter</button>
      <button class="btn alt full" onclick="moReveal()" style="margin-top:6px;">👁 Révéler la réponse</button>
      <div id="mo-answer" style="display:none; margin-top:14px; padding:14px; background:linear-gradient(135deg, var(--primary), var(--accent)); color:white; border-radius:10px;">
        <div style="font-size:11px; opacity:0.85;">Réponse :</div>
        <div style="font-size:16px; font-weight:600; margin-top:4px;">${escapeHtml(q.a)}</div>
      </div>
      <div id="mo-actions" style="display:none; gap:6px; margin-top:10px;">
        <button class="btn alt" onclick="moAnswer(false)" style="flex:1;">❌ Pas su</button>
        <button class="btn primary" onclick="moAnswer(true)" style="flex:1;">✅ Su</button>
      </div>
    </div>
  `;
  setTimeout(moSpeak, 300);
}
function moSpeak() {
  if (!('speechSynthesis' in window)) return toast('TTS non supporté');
  const q = _moQs[_moIdx];
  const u = new SpeechSynthesisUtterance(q.q);
  u.lang = 'fr-FR';
  u.rate = parseFloat(document.getElementById('mo-speed').value);
  speechSynthesis.cancel();
  speechSynthesis.speak(u);
}
function moReveal() {
  document.getElementById('mo-answer').style.display = '';
  document.getElementById('mo-actions').style.display = 'flex';
}
function moAnswer(ok) {
  _moIdx++;
  moNext();
}

