// === 1. CONJUGUEUR ANGLAIS ===
const V53_EN_IRREG = {
  'be': { present:['am','are','is','are','are','are'], past:['was','were','was','were','were','were'], pp:'been', ing:'being' },
  'have': { present:['have','have','has','have','have','have'], past:['had','had','had','had','had','had'], pp:'had', ing:'having' },
  'do': { present:['do','do','does','do','do','do'], past:['did','did','did','did','did','did'], pp:'done', ing:'doing' },
  'go': { present:['go','go','goes','go','go','go'], past:['went','went','went','went','went','went'], pp:'gone', ing:'going' },
  'see': { present:['see','see','sees','see','see','see'], past:['saw','saw','saw','saw','saw','saw'], pp:'seen', ing:'seeing' },
  'eat': { present:['eat','eat','eats','eat','eat','eat'], past:['ate','ate','ate','ate','ate','ate'], pp:'eaten', ing:'eating' },
  'come': { present:['come','come','comes','come','come','come'], past:['came','came','came','came','came','came'], pp:'come', ing:'coming' },
  'take': { present:['take','take','takes','take','take','take'], past:['took','took','took','took','took','took'], pp:'taken', ing:'taking' },
  'make': { present:['make','make','makes','make','make','make'], past:['made','made','made','made','made','made'], pp:'made', ing:'making' },
  'know': { present:['know','know','knows','know','know','know'], past:['knew','knew','knew','knew','knew','knew'], pp:'known', ing:'knowing' },
  'get': { present:['get','get','gets','get','get','get'], past:['got','got','got','got','got','got'], pp:'gotten', ing:'getting' },
  'give': { present:['give','give','gives','give','give','give'], past:['gave','gave','gave','gave','gave','gave'], pp:'given', ing:'giving' }
};
const V53_EN_PRONOUNS = ['I','you','he/she/it','we','you (pl)','they'];
function renderConjugEn() {
  let html = `<div style="background:linear-gradient(135deg,#5DADE2,#9B59B6); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🇬🇧</div><div style="font-size:16px; font-weight:800;">English conjugator</div>
  </div>
  <input type="text" id="cen-verb" class="input" placeholder="Verb (work, eat, be, have, go...)" oninput="cenConj()" style="margin-top:14px;" autocomplete="off">
  <div id="cen-result" style="margin-top:14px;"></div>
  <p style="font-size:10px; color:var(--textSec); margin-top:14px;">💡 Irréguliers : be, have, do, go, see, eat, come, take, make, know, get, give. Autres = règle régulière.</p>`;
  document.getElementById('conjugen-content').innerHTML = html;
}
function cenConj() {
  const v = document.getElementById('cen-verb').value.trim().toLowerCase();
  if (!v) { document.getElementById('cen-result').innerHTML = ''; return; }
  let conj;
  if (V53_EN_IRREG[v]) { conj = V53_EN_IRREG[v]; }
  else {
    // Régulier
    let past = v + 'ed';
    if (v.endsWith('e')) past = v + 'd';
    else if (/[bcdfghjklmnpqrstvwxz][aeiou][bcdfghjklmnpqrstvwxz]$/.test(v) && !v.endsWith('w') && !v.endsWith('y')) past = v + v.slice(-1) + 'ed';
    else if (v.endsWith('y') && !/[aeiou]y$/.test(v)) past = v.slice(0,-1) + 'ied';
    let ing = v + 'ing';
    if (v.endsWith('e') && !v.endsWith('ee') && !v.endsWith('ye')) ing = v.slice(0,-1) + 'ing';
    let third = v + 's';
    if (/(ch|sh|ss|x|z|o)$/.test(v)) third = v + 'es';
    else if (v.endsWith('y') && !/[aeiou]y$/.test(v)) third = v.slice(0,-1) + 'ies';
    conj = {
      present: [v,v,third,v,v,v],
      past: [past,past,past,past,past,past],
      pp: past, ing: ing
    };
  }
  let html = '';
  html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px;">
    <div style="font-size:11px; font-weight:700; color:var(--primary); margin-bottom:4px;">Present simple</div>`;
  for (let i = 0; i < 6; i++) html += `<div style="font-size:13px; display:flex; gap:8px; margin-top:2px;"><span style="color:var(--textSec); min-width:90px;">${V53_EN_PRONOUNS[i]}</span><strong>${escapeHtml(conj.present[i])}</strong></div>`;
  html += '</div>';
  html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px;">
    <div style="font-size:11px; font-weight:700; color:var(--primary); margin-bottom:4px;">Past simple</div>`;
  for (let i = 0; i < 6; i++) html += `<div style="font-size:13px; display:flex; gap:8px; margin-top:2px;"><span style="color:var(--textSec); min-width:90px;">${V53_EN_PRONOUNS[i]}</span><strong>${escapeHtml(conj.past[i])}</strong></div>`;
  html += '</div>';
  html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px;">
    <div style="font-size:11px; font-weight:700; color:var(--primary); margin-bottom:4px;">Other forms</div>
    <div style="font-size:13px; margin-top:2px;"><span style="color:var(--textSec);">Past participle (-ed/3e forme):</span> <strong>${escapeHtml(conj.pp)}</strong></div>
    <div style="font-size:13px; margin-top:2px;"><span style="color:var(--textSec);">Present participle (-ing):</span> <strong>${escapeHtml(conj.ing)}</strong></div>
    <div style="font-size:13px; margin-top:2px;"><span style="color:var(--textSec);">Future:</span> <strong>will ${escapeHtml(v)}</strong></div>
    <div style="font-size:13px; margin-top:2px;"><span style="color:var(--textSec);">Conditional:</span> <strong>would ${escapeHtml(v)}</strong></div>
  </div>`;
  document.getElementById('cen-result').innerHTML = html;
}

