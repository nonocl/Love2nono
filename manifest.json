// === PLANNING MÉNAGE ===
const CLEAN_DEFAULT = {
  daily: ['Faire le lit', 'Vaisselle', 'Sortir poubelle si pleine'],
  weekly: ['Aspirateur', 'Serpillère', 'Salle de bain', 'WC', 'Changer draps', 'Lessive', 'Frigo (jeter périmés)'],
  monthly: ['Frigo nettoyer', 'Four', 'Vitres', 'Plinthes', 'Dépoussiérer luminaires']
};
function getClean() {
  let c;
  try { c = JSON.parse(localStorage.getItem('nw_clean') || 'null'); } catch { c = null; }
  if (!c) {
    c = {
      daily: CLEAN_DEFAULT.daily.map(t => ({ text:t, done:false })),
      weekly: CLEAN_DEFAULT.weekly.map(t => ({ text:t, done:false, lastDone:null })),
      monthly: CLEAN_DEFAULT.monthly.map(t => ({ text:t, done:false, lastDone:null })),
      lastReset: new Date().toISOString().slice(0,10)
    };
    localStorage.setItem('nw_clean', JSON.stringify(c));
  }
  // Auto reset daily
  const today = new Date().toISOString().slice(0,10);
  if (c.lastReset !== today) {
    c.daily.forEach(i => i.done = false);
    c.lastReset = today;
    localStorage.setItem('nw_clean', JSON.stringify(c));
  }
  return c;
}
function saveClean(c) { localStorage.setItem('nw_clean', JSON.stringify(c)); }
function renderCleaning() {
  const c = getClean();
  let html = `<div style="background:linear-gradient(135deg,#5DD68F,#06FFA5); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🧹</div>
    <div style="font-size:16px; font-weight:800;">Planning ménage</div>
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📅 Quotidien</h3>`;
  c.daily.forEach((it, i) => {
    html += `<div onclick="cleanCheck('daily',${i})" style="background:var(--surface); padding:10px 14px; border-radius:10px; margin-top:4px; display:flex; gap:10px; cursor:pointer; ${it.done?'opacity:0.6;':''}">
      <span style="width:20px; height:20px; border-radius:5px; border:2px solid var(--primary); background:${it.done?'var(--primary)':'transparent'}; color:white; display:inline-flex; align-items:center; justify-content:center; font-size:12px;">${it.done?'✓':''}</span>
      <span style="flex:1; ${it.done?'text-decoration:line-through;':''}">${escapeHtml(it.text)}</span>
    </div>`;
  });
  html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📆 Hebdo</h3>`;
  c.weekly.forEach((it, i) => {
    const days = it.lastDone ? Math.floor((Date.now() - it.lastDone) / (24*60*60*1000)) : null;
    const due = days === null || days >= 7;
    html += `<div onclick="cleanCheck('weekly',${i})" style="background:var(--surface); padding:10px 14px; border-radius:10px; margin-top:4px; display:flex; gap:10px; cursor:pointer; ${!due?'opacity:0.5;':''}">
      <span style="width:20px; height:20px; border-radius:5px; border:2px solid ${due?'var(--primary)':'var(--border)'}; background:${!due?'var(--primary)':'transparent'}; color:white; display:inline-flex; align-items:center; justify-content:center; font-size:12px;">${!due?'✓':''}</span>
      <span style="flex:1;">${escapeHtml(it.text)} ${days !== null ? `<span style="font-size:10px; color:var(--textSec);">(il y a ${days}j)</span>` : ''}</span>
    </div>`;
  });
  html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📅 Mensuel</h3>`;
  c.monthly.forEach((it, i) => {
    const days = it.lastDone ? Math.floor((Date.now() - it.lastDone) / (24*60*60*1000)) : null;
    const due = days === null || days >= 30;
    html += `<div onclick="cleanCheck('monthly',${i})" style="background:var(--surface); padding:10px 14px; border-radius:10px; margin-top:4px; display:flex; gap:10px; cursor:pointer; ${!due?'opacity:0.5;':''}">
      <span style="width:20px; height:20px; border-radius:5px; border:2px solid ${due?'var(--primary)':'var(--border)'}; background:${!due?'var(--primary)':'transparent'}; color:white; display:inline-flex; align-items:center; justify-content:center; font-size:12px;">${!due?'✓':''}</span>
      <span style="flex:1;">${escapeHtml(it.text)} ${days !== null ? `<span style="font-size:10px; color:var(--textSec);">(il y a ${days}j)</span>` : ''}</span>
    </div>`;
  });
  document.getElementById('cleaning-content').innerHTML = html;
}
function cleanCheck(type, i) {
  const c = getClean();
  if (type === 'daily') {
    c.daily[i].done = !c.daily[i].done;
  } else {
    c[type][i].lastDone = Date.now();
  }
  saveClean(c); renderCleaning();
}

