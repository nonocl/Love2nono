// ============================================================
// SLEEP TRACKER
// ============================================================
let _editingSleep = null;
let _sleepQuality = 3;

function setSleepQ(q) {
  _sleepQuality = q;
  document.querySelectorAll('.slp-q').forEach(b => {
    b.classList.toggle('primary', parseInt(b.dataset.q) === q);
    b.classList.toggle('alt', parseInt(b.dataset.q) !== q);
  });
}

async function renderSleep() {
  const logs = await dbAll('sleep_log');
  // Avg 7 days
  const now = new Date();
  const cutoff = new Date(now); cutoff.setDate(cutoff.getDate()-7);
  const recent = logs.filter(l => new Date(l.date) >= cutoff);
  if (recent.length > 0) {
    let totalMin = 0, totalQ = 0;
    for (const l of recent) {
      totalMin += sleepDurationMin(l);
      totalQ += l.quality || 3;
    }
    const avgH = (totalMin / recent.length / 60).toFixed(1);
    const avgQ = (totalQ / recent.length).toFixed(1);
    document.getElementById('sleep-avg').textContent = avgH + ' h';
    document.getElementById('sleep-quality-avg').textContent = `Qualité moyenne : ${avgQ}/5`;
  } else {
    document.getElementById('sleep-avg').textContent = '— h';
    document.getElementById('sleep-quality-avg').textContent = 'Pas de données';
  }
  // List
  const el = document.getElementById('sleep-list');
  el.innerHTML = '';
  if (logs.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">😴</div><h3>Aucune nuit</h3><p>Enregistre tes nuits pour suivre ton sommeil.</p></div>`;
    return;
  }
  logs.sort((a,b) => (b.date||'').localeCompare(a.date||''));
  for (const l of logs.slice(0, 30)) {
    const min = sleepDurationMin(l);
    const h = Math.floor(min/60), m = min%60;
    const qIcon = ['', '😩','😕','😐','🙂','😴'][l.quality||3];
    const row = document.createElement('button');
    row.style.cssText = 'display:flex; align-items:center; gap:10px; padding:12px; background:var(--surface); border-radius:14px; margin-bottom:4px; width:100%; text-align:left;';
    row.innerHTML = `
      <div style="font-size:28px;">${qIcon}</div>
      <div style="flex:1; min-width:0;">
        <div style="font-size:14px; font-weight:600;">${new Date(l.date).toLocaleDateString('fr-FR', {weekday:'long', day:'numeric', month:'short'})}</div>
        <div style="font-size:11px; color:var(--textSec);">${l.bed} → ${l.wake} · ${l.note?escapeHtml(l.note.slice(0,30)):''}</div>
      </div>
      <div style="font-size:18px; font-weight:800; color:var(--primary);">${h}h${m>0?String(m).padStart(2,'0'):''}</div>
    `;
    row.onclick = () => openSleepModal(l);
    el.appendChild(row);
  }
}

function sleepDurationMin(l) {
  if (!l.bed || !l.wake) return 0;
  const [bh, bm] = l.bed.split(':').map(Number);
  const [wh, wm] = l.wake.split(':').map(Number);
  let bedMin = bh*60 + bm;
  let wakeMin = wh*60 + wm;
  // Si bed > wake, c'est qu'on a passé minuit
  if (bedMin > wakeMin) wakeMin += 24*60;
  return wakeMin - bedMin;
}

function openSleepModal(l) {
  _editingSleep = l;
  document.getElementById('slp-modal-title').textContent = l ? 'Modifier' : 'Nouvelle nuit';
  document.getElementById('slp-date-input').value = l ? l.date : new Date().toISOString().split('T')[0];
  document.getElementById('slp-bed-input').value = l ? l.bed : '23:00';
  document.getElementById('slp-wake-input').value = l ? l.wake : '07:00';
  document.getElementById('slp-note-input').value = l ? (l.note||'') : '';
  setSleepQ(l ? (l.quality||3) : 3);
  document.getElementById('slp-del-btn').style.display = l ? 'inline-flex' : 'none';
  openModal('modal-sleep');
}

async function saveSleep() {
  const date = document.getElementById('slp-date-input').value;
  const bed = document.getElementById('slp-bed-input').value;
  const wake = document.getElementById('slp-wake-input').value;
  const note = document.getElementById('slp-note-input').value.trim();
  if (!date || !bed || !wake) { alert('Date + horaires requis.'); return; }
  const data = { date, bed, wake, quality: _sleepQuality, note };
  if (_editingSleep) await dbPut('sleep_log', { ..._editingSleep, ...data });
  else await dbAdd('sleep_log', { ...data, created_at: new Date().toISOString() });
  closeModal('modal-sleep');
  renderSleep();
}

async function deleteSleepNow() {
  if (!confirm('Supprimer cette nuit ?')) return;
  await dbDel('sleep_log', _editingSleep.id);
  closeModal('modal-sleep');
  renderSleep();
}

