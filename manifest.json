let _p2iFile = null;
function p2iLoad(input) {
  _p2iFile = (input.files || [])[0];
  document.getElementById('p2i-btn').disabled = !_p2iFile;
  document.getElementById('p2i-results').innerHTML = '';
  if (_p2iFile) setStatus('p2i-status', `📄 ${_p2iFile.name} (${(_p2iFile.size/1024).toFixed(1)} Ko)`, 'info');
}
async function p2iConvert() {
  if (!_p2iFile) return;
  setStatus('p2i-status', 'Chargement de la lib PDF.js...', 'loading');
  try {
    const pdfjs = await ensurePdfJs();
    const buf = await _p2iFile.arrayBuffer();
    const pdf = await pdfjs.getDocument({ data: buf }).promise;
    const scale = parseFloat(document.getElementById('p2i-quality').value);
    const out = document.getElementById('p2i-results');
    out.innerHTML = '';
    for (let i=1; i<=pdf.numPages; i++) {
      setStatus('p2i-status', `Page ${i}/${pdf.numPages}...`, 'loading');
      const page = await pdf.getPage(i);
      const viewport = page.getViewport({ scale });
      const c = document.createElement('canvas');
      c.width = viewport.width; c.height = viewport.height;
      await page.render({ canvasContext: c.getContext('2d'), viewport }).promise;
      const blob = await new Promise(r => c.toBlob(r, 'image/png'));
      const url = URL.createObjectURL(blob);
      const card = document.createElement('div');
      card.style.cssText = 'background:var(--surface); padding:10px; border-radius:10px; margin-bottom:6px; display:flex; gap:10px; align-items:center;';
      card.innerHTML = `<img src="${url}" style="width:60px; height:80px; object-fit:cover; border-radius:6px;"><div style="flex:1;"><strong>Page ${i}</strong><div style="font-size:11px; color:var(--textSec);">${viewport.width.toFixed(0)}×${viewport.height.toFixed(0)}</div></div><button class="btn primary" style="padding:6px 10px; font-size:12px;" onclick="(function(){const a=document.createElement('a');a.href='${url}';a.download='page-${i}.png';a.click();})()">⬇</button>`;
      out.appendChild(card);
    }
    setStatus('p2i-status', `✅ ${pdf.numPages} page${pdf.numPages>1?'s':''} extraite${pdf.numPages>1?'s':''} !`, 'success');
  } catch (e) {
    console.error(e); setStatus('p2i-status', '❌ ' + e.message, 'error');
  }
}

