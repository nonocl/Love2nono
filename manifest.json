function getTodaySeed() {
  const d = new Date();
  return d.getFullYear() * 10000 + (d.getMonth()+1) * 100 + d.getDate();
}
function seededRandom(seed) {
  const x = Math.sin(seed) * 10000;
  return x - Math.floor(x);
}
function renderTarot() {
  const seed = getTodaySeed();
  const idx = Math.floor(seededRandom(seed) * TAROT_CARDS.length);
  const reversed = seededRandom(seed + 1) > 0.7;
  const card = TAROT_CARDS[idx];
  
  let html = `<div style="background:linear-gradient(135deg,#5D2E8C,#1A1A2E,#0F3460); color:white; padding:20px; border-radius:18px; text-align:center; box-shadow:0 8px 24px rgba(93,46,140,0.3);">
    <div style="font-size:11px; opacity:0.7; letter-spacing:2px;">CARTE DU JOUR</div>
    <div style="font-size:80px; margin:14px 0; ${reversed?'transform:rotate(180deg);':''}">${card.emoji}</div>
    <div style="font-size:22px; font-weight:900; letter-spacing:1px;">${escapeHtml(card.name)}</div>
    <div style="font-size:11px; opacity:0.7; margin-top:4px;">${reversed?'⇣ INVERSÉE':'⇡ DROITE'}</div>
    <div style="background:rgba(255,255,255,0.1); padding:14px; border-radius:12px; margin-top:14px; font-size:13px; line-height:1.5; font-style:italic;">
      ${escapeHtml(reversed ? card.down : card.up)}
    </div>
  </div>
  <p style="font-size:11px; color:var(--textSec); text-align:center; margin-top:14px;">✨ Une nouvelle carte chaque jour à minuit</p>
  
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:18px;">🔮 Tirage 3 cartes (passé · présent · futur)</h3>
  <button class="btn primary full" onclick="tarotThree()" style="margin-top:6px;">🃏 Tirer 3 cartes</button>
  <div id="tarot-three" style="margin-top:12px;"></div>
  
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:18px;">🎴 Tirer une carte au hasard</h3>
  <button class="btn alt full" onclick="tarotRandom()" style="margin-top:6px;">🎲 Carte aléatoire</button>
  <div id="tarot-random" style="margin-top:12px;"></div>`;
  document.getElementById('tarot-content').innerHTML = html;
}
function renderTarotCard(card, reversed, label) {
  return `<div style="background:linear-gradient(135deg,#5D2E8C,#1A1A2E); color:white; padding:14px; border-radius:14px; text-align:center; margin-top:6px;">
    ${label?`<div style="font-size:10px; opacity:0.7; letter-spacing:1px;">${escapeHtml(label)}</div>`:''}
    <div style="font-size:48px; margin:6px 0; ${reversed?'transform:rotate(180deg);':''}">${card.emoji}</div>
    <div style="font-size:15px; font-weight:800;">${escapeHtml(card.name)} ${reversed?'⇣':''}</div>
    <div style="font-size:11px; opacity:0.85; margin-top:6px; line-height:1.4;">${escapeHtml(reversed?card.down:card.up)}</div>
  </div>`;
}
function tarotThree() {
  const labels = ['🌙 PASSÉ', '☀️ PRÉSENT', '⭐ FUTUR'];
  let html = '';
  for (let i = 0; i < 3; i++) {
    const card = TAROT_CARDS[Math.floor(Math.random() * TAROT_CARDS.length)];
    const rev = Math.random() > 0.7;
    html += renderTarotCard(card, rev, labels[i]);
  }
  document.getElementById('tarot-three').innerHTML = html;
}
function tarotRandom() {
  const card = TAROT_CARDS[Math.floor(Math.random() * TAROT_CARDS.length)];
  const rev = Math.random() > 0.7;
  document.getElementById('tarot-random').innerHTML = renderTarotCard(card, rev);
}

