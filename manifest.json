    await dbPut('music_cats', { ..._editingMusicCat, name, color: _musicCatColor, icon: _musicCatIcon || null });
  } else {
    await dbAdd('music_cats', { name, color: _musicCatColor, icon: _musicCatIcon || null, created_at: new Date().toISOString() });
  }
  closeModal('modal-music-cat');
  renderMusicCats();
}

async function deleteMusicCatNow() {
  if (!confirm(`Supprimer "${_editingMusicCat.name}" ?`)) return;
  const links = await dbAll('track_cats');
  for (const l of links.filter(x => x.cat_id === _editingMusicCat.id)) await dbDel('track_cats', l.key);
  await dbDel('music_cats', _editingMusicCat.id);
  if (player.filter === 'cat:'+_editingMusicCat.id) player.filter = 'all';
  closeModal('modal-music-cat');
