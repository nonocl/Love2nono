  filtered.forEach(t => { if (!cats[t.c]) cats[t.c] = []; cats[t.c].push(t); });
  let html = '';
  Object.keys(cats).forEach(c => {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">${escapeHtml(c)}</h3>`;
