// JEU: MOTS MELES
// ============================================================
const WS_THEMES = {
  animals: ['CHAT','CHIEN','LION','TIGRE','OURS','POULE','CHEVAL','LAPIN'],
  school: ['LIVRE','STYLO','CAHIER','REGLE','GOMME','SAC','TABLE','CRAYON'],
  food: ['PAIN','PIZZA','PATES','RIZ','SUSHI','SALADE','POMME','BANANE'],
  italian: ['CIAO','GRAZIE','AMORE','SOLE','CASA','LIBRO','GATTO','SCUOLA'],
  colors: ['ROUGE','BLEU','VERT','JAUNE','NOIR','BLANC','ROSE','ORANGE'],
};
let _ws = null;
let _wsSelectStart = null;

function newWordSearch() {
  const theme = document.getElementById('ws-theme').value;
  const words = WS_THEMES[theme].map(w => w.toUpperCase());
  const size = 12;
  const grid = Array.from({length:size}, () => Array(size).fill(''));
  const placed = [];
  for (const word of words) {
    let tries = 0, ok = false;
    while (tries < 50 && !ok) {
      tries++;
      const dir = Math.floor(Math.random()*3); // 0=h, 1=v, 2=diag
      const r = Math.floor(Math.random()*size), c = Math.floor(Math.random()*size);
      const dr = dir === 1 ? 1 : (dir === 2 ? 1 : 0);
      const dc = dir === 0 ? 1 : (dir === 2 ? 1 : 0);
      const er = r + dr*(word.length-1), ec = c + dc*(word.length-1);
      if (er >= size || ec >= size) continue;
      let conflict = false;
      for (let i=0; i<word.length; i++) {
        const nc = grid[r+dr*i][c+dc*i];
        if (nc && nc !== word[i]) { conflict = true; break; }
      }
      if (!conflict) {
        for (let i=0; i<word.length; i++) grid[r+dr*i][c+dc*i] = word[i];
        placed.push({word, r, c, dr, dc});
        ok = true;
      }
    }
  }
  // Fill empty
  for (let r=0; r<size; r++) for (let c=0; c<size; c++) {
    if (!grid[r][c]) grid[r][c] = String.fromCharCode(65 + Math.floor(Math.random()*26));
  }
  _ws = { grid, words: placed, found: [], size, selecting: null };
  renderWordSearch();
}

function renderWordSearch() {
  const board = document.getElementById('ws-board');
  board.style.gridTemplateColumns = `repeat(${_ws.size}, 24px)`;
  board.innerHTML = '';
  for (let r=0; r<_ws.size; r++) for (let c=0; c<_ws.size; c++) {
    const cell = document.createElement('div');
    const isFound = _ws.found.some(p => isCellInWord(r, c, p));
    cell.style.cssText = `width:24px; height:24px; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:700; background:${isFound?'#5DD68F':'var(--surface)'}; color:${isFound?'white':'var(--text)'}; cursor:pointer; user-select:none;`;
    cell.textContent = _ws.grid[r][c];
    cell.dataset.r = r; cell.dataset.c = c;
    cell.onclick = () => wsClickCell(r, c);
    board.appendChild(cell);
  }
  const wEl = document.getElementById('ws-words');
  wEl.innerHTML = '';
  for (const p of _ws.words) {
    const found = _ws.found.includes(p);
    wEl.insertAdjacentHTML('beforeend', `<span style="padding:4px 8px; background:${found?'#5DD68F':'var(--surfaceAlt)'}; color:${found?'white':'var(--text)'}; border-radius:6px; font-size:12px; ${found?'text-decoration:line-through;':''}">${p.word}</span>`);
  }
  document.getElementById('ws-status').textContent = `${_ws.found.length}/${_ws.words.length} trouvés`;
  if (_ws.found.length === _ws.words.length) {
    setTimeout(() => alert('🎉 Tous les mots trouvés !'), 200);
  }
}

function isCellInWord(r, c, p) {
  for (let i=0; i<p.word.length; i++) {
    if (p.r + p.dr*i === r && p.c + p.dc*i === c) return true;
  }
  return false;
}

function wsClickCell(r, c) {
  if (!_wsSelectStart) {
    _wsSelectStart = [r, c];
    toast(`Premier "${_ws.grid[r][c]}" sélectionné. Tap sur le dernier.`);
    return;
  }
  // Check if a word matches between start and (r,c)
  const [sr, sc] = _wsSelectStart;
  const dr = Math.sign(r - sr), dc = Math.sign(c - sc);
  // Build the word
  let word = '';
  let cr = sr, cc = sc;
  while (true) {
    if (cr < 0 || cc < 0 || cr >= _ws.size || cc >= _ws.size) { word = ''; break; }
    word += _ws.grid[cr][cc];
    if (cr === r && cc === c) break;
    cr += dr; cc += dc;
    if (word.length > 15) { word = ''; break; }
  }
  // Check forwards or reversed
  for (const p of _ws.words) {
    if (_ws.found.includes(p)) continue;
    if (p.word === word || p.word === word.split('').reverse().join('')) {
      _ws.found.push(p);
      _wsSelectStart = null;
      renderWordSearch();
      return;
    }
  }
  _wsSelectStart = null;
  renderWordSearch();
}


