// WATER
// ============================================================
function getWaterGoal() { return parseInt(localStorage.getItem('nw_water_goal') || '2000'); }
function getWaterToday() {
  const today = new Date().toISOString().split('T')[0];
  return parseInt(localStorage.getItem('nw_water_' + today) || '0');
}
function setWaterToday(v) {
  const today = new Date().toISOString().split('T')[0];
  if (v < 0) v = 0;
  localStorage.setItem('nw_water_' + today, v);
}

function renderWater() {
  const goal = getWaterGoal();
  const cur = getWaterToday();
  document.getElementById('water-current').textContent = cur + ' ml';
  document.getElementById('water-goal-info').textContent = 'objectif : ' + goal + ' ml';
  document.getElementById('water-bar').style.width = Math.min(100, (cur/goal)*100) + '%';
  // History 7 last days
  const hist = document.getElementById('water-history');
  hist.innerHTML = '';
  for (let i=6; i>=0; i--) {
    const d = new Date(); d.setDate(d.getDate()-i);
    const ds = d.toISOString().split('T')[0];
    const v = parseInt(localStorage.getItem('nw_water_' + ds) || '0');
    const pct = Math.min(100, (v/goal)*100);
    const label = i===0 ? 'Aujourd\'hui' : d.toLocaleDateString('fr-FR', {weekday:'short', day:'numeric'});
    const row = document.createElement('div');
    row.style.cssText = 'display:flex; align-items:center; gap:10px; margin-bottom:6px;';
    row.innerHTML = `
      <span style="font-size:12px; min-width:80px;">${label}</span>
      <div style="flex:1; height:18px; background:var(--surfaceAlt); border-radius:9px; overflow:hidden;">
        <div style="background:linear-gradient(90deg, #5DD6E5, #5B8DEF); height:100%; width:${pct}%;"></div>
      </div>
      <span style="font-size:11px; color:var(--textSec); min-width:60px; text-align:right;">${v} ml</span>
    `;
    hist.appendChild(row);
  }
}

function addWater(amount) {
  setWaterToday(getWaterToday() + amount);
  renderWater();
  if (amount > 0 && getWaterToday() >= getWaterGoal() && (getWaterToday() - amount) < getWaterGoal()) {
    toast('🎉 Objectif atteint !', 3000);
  }
}

function openWaterSettings() {
  document.getElementById('water-goal-input').value = getWaterGoal();
  openModal('modal-water-settings');
}

function saveWaterGoal() {
  const v = parseInt(document.getElementById('water-goal-input').value) || 2000;
  localStorage.setItem('nw_water_goal', v);
  closeModal('modal-water-settings');
  renderWater();
}

