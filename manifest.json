}

async function renderSavedPalettes() {
  const palettes = await dbAll('palettes');
  const sec = document.getElementById('saved-palettes-section');
  const list = document.getElementById('saved-palettes-list');
  if (palettes.length === 0) { sec.style.display = 'none'; return; }
  sec.style.display = 'block';
  list.innerHTML = '';
  for (const p of palettes.sort((a,b)=>(b.created_at||'').localeCompare(a.created_at||''))) {
    const row = document.createElement('div');
    row.style.cssText = 'display:flex; gap:4px; margin-bottom:8px; align-items:center;';
    const colors = document.createElement('div');
    colors.style.cssText = 'display:flex; flex:1; height:30px; border-radius:8px; overflow:hidden;';
    for (const c of p.colors) {
      const d = document.createElement('div');
      d.style.cssText = `flex:1; background:${c};`;
      d.title = c;
      d.onclick = () => { navigator.clipboard?.writeText(c); toast(`${c} copié`); };
      colors.appendChild(d);
    }
    const del = document.createElement('button');
    del.textContent = '×'; del.style.cssText = 'background:var(--surfaceAlt); width:30px; height:30px; border-radius:15px;';
    del.onclick = async () => { await dbDel('palettes', p.id); renderSavedPalettes(); };
    row.appendChild(colors); row.appendChild(del);
    list.appendChild(row);
  }
}

// ============================================================
// COLOR CONVERTER
// ============================================================
function updateColorConv() {
  const hex = document.getElementById('cc-input').value;
  const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
  // RGB to HSL
  const rN = r/255, gN = g/255, bN = b/255;
  const max = Math.max(rN,gN,bN), min = Math.min(rN,gN,bN);
  let h, s, l = (max+min)/2;
  if (max === min) { h = s = 0; }
  else {
    const d = max - min;
    s = l > 0.5 ? d/(2-max-min) : d/(max+min);
    switch (max) {
      case rN: h = ((gN-bN)/d + (gN<bN?6:0)); break;
      case gN: h = ((bN-rN)/d + 2); break;
      case bN: h = ((rN-gN)/d + 4); break;
    }
    h /= 6;
  }
  const hsl = `hsl(${Math.round(h*360)}, ${Math.round(s*100)}%, ${Math.round(l*100)}%)`;
  const rgb = `rgb(${r}, ${g}, ${b})`;
  const el = document.getElementById('cc-results');
  el.innerHTML = `
    <div style="background:${hex}; height:60px; border-radius:12px; margin-bottom:14px;"></div>
    ${ccRow('HEX', hex)}
    ${ccRow('RGB', rgb)}
    ${ccRow('HSL', hsl)}
  `;
  el.querySelectorAll('[data-copy]').forEach(b => b.onclick = () => { navigator.clipboard?.writeText(b.dataset.copy); toast('Copié'); });
}
function ccRow(label, val) {
  return `<div style="display:flex; align-items:center; gap:8px; padding:10px 12px; background:var(--surfaceAlt); border-radius:10px; margin-bottom:6px;">
    <strong style="width:50px;">${label}</strong>
    <code style="flex:1; font-size:13px;">${val}</code>
    <button class="btn primary" style="padding:4px 8px; font-size:11px;" data-copy="${val}">Copier</button>
  </div>`;
}

