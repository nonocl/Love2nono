// ============================================================
const MINE_SIZE = 9, MINE_COUNT = 10;
let _mines = null;
let _mineFlagMode = false;

function initMines() {
  _mines = { grid: [], revealed: [], flagged: [], over: false, won: false, flagsLeft: MINE_COUNT };
  for (let r=0; r<MINE_SIZE; r++) {
    _mines.grid.push(new Array(MINE_SIZE).fill(0));
    _mines.revealed.push(new Array(MINE_SIZE).fill(false));
    _mines.flagged.push(new Array(MINE_SIZE).fill(false));
  }
  // Place mines
  let placed = 0;
  while (placed < MINE_COUNT) {
    const r = Math.floor(Math.random()*MINE_SIZE), c = Math.floor(Math.random()*MINE_SIZE);
    if (_mines.grid[r][c] === 'M') continue;
    _mines.grid[r][c] = 'M';
    placed++;
  }
  // Calculate numbers
  for (let r=0; r<MINE_SIZE; r++) for (let c=0; c<MINE_SIZE; c++) {
    if (_mines.grid[r][c] === 'M') continue;
    let n = 0;
    for (let dr=-1; dr<=1; dr++) for (let dc=-1; dc<=1; dc++) {
      const nr = r+dr, nc = c+dc;
      if (nr>=0 && nr<MINE_SIZE && nc>=0 && nc<MINE_SIZE && _mines.grid[nr][nc]==='M') n++;
    }
    _mines.grid[r][c] = n;
  }
  _mineFlagMode = false;
  renderMines();
}

function toggleMineFlag() {
  _mineFlagMode = !_mineFlagMode;
  document.getElementById('mine-flag-btn').textContent = _mineFlagMode ? '✓ Mode drapeau' : '🚩 Drapeau';
  document.getElementById('mine-flag-btn').style.background = _mineFlagMode ? 'var(--primary)' : '';
  document.getElementById('mine-flag-btn').style.color = _mineFlagMode ? 'white' : '';
}

function renderMines() {
  const board = document.getElementById('mines-board');
  board.style.gridTemplateColumns = `repeat(${MINE_SIZE}, 32px)`;
  board.innerHTML = '';
  for (let r=0; r<MINE_SIZE; r++) for (let c=0; c<MINE_SIZE; c++) {
    const cell = document.createElement('button');
    const isRev = _mines.revealed[r][c];
    const isFlag = _mines.flagged[r][c];
    cell.style.cssText = `width:32px; height:32px; padding:0; border-radius:4px; font-size:14px; font-weight:700; background:${isRev?'var(--surface)':'var(--border)'}; cursor:pointer; border:none;`;
    if (isFlag) { cell.textContent = '🚩'; }
    else if (isRev) {
      const v = _mines.grid[r][c];
      if (v === 'M') { cell.textContent = '💣'; cell.style.background = 'var(--danger)'; }
      else if (v > 0) {
        cell.textContent = v;
        const colors = ['','#5B8DEF','#5DD68F','#FF6B7A','#7B61FF','#FF8C42','#5DD6E5','#000','#888'];
        cell.style.color = colors[v];
      }
    }
    cell.onclick = () => clickMine(r, c);
    board.appendChild(cell);
  }
  document.getElementById('mines-count').textContent = _mines.flagsLeft;
}

function clickMine(r, c) {
  if (_mines.over) return;
  if (_mineFlagMode) {
    if (_mines.revealed[r][c]) return;
    _mines.flagged[r][c] = !_mines.flagged[r][c];
    _mines.flagsLeft += _mines.flagged[r][c] ? -1 : 1;
    renderMines();
    return;
  }
  if (_mines.flagged[r][c] || _mines.revealed[r][c]) return;
  if (_mines.grid[r][c] === 'M') {
    _mines.over = true;
    for (let r=0; r<MINE_SIZE; r++) for (let c=0; c<MINE_SIZE; c++) if (_mines.grid[r][c]==='M') _mines.revealed[r][c]=true;
    renderMines();
    setTimeout(() => alert('💥 Boom ! Game Over'), 200);
    return;
  }
  revealMineCell(r, c);
  // Check win
  let unrev = 0;
  for (let r=0; r<MINE_SIZE; r++) for (let c=0; c<MINE_SIZE; c++) if (!_mines.revealed[r][c] && _mines.grid[r][c]!=='M') unrev++;
  if (unrev === 0) {
    _mines.over = true; _mines.won = true;
    setTimeout(() => alert('🎉 Démineur ! Bravo !'), 200);
  }
  renderMines();
}

function revealMineCell(r, c) {
  if (r<0||r>=MINE_SIZE||c<0||c>=MINE_SIZE||_mines.revealed[r][c]||_mines.flagged[r][c]) return;
  _mines.revealed[r][c] = true;
  if (_mines.grid[r][c] === 0) {
    for (let dr=-1; dr<=1; dr++) for (let dc=-1; dc<=1; dc++) revealMineCell(r+dr, c+dc);
  }
}

