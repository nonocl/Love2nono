// LOREM IPSUM
// ============================================================
const LOREM_WORDS = 'lorem ipsum dolor sit amet consectetur adipiscing elit sed do eiusmod tempor incididunt ut labore et dolore magna aliqua enim ad minim veniam quis nostrud exercitation ullamco laboris nisi aliquip ex ea commodo consequat duis aute irure dolor in reprehenderit voluptate velit esse cillum eu fugiat nulla pariatur excepteur sint occaecat cupidatat non proident sunt culpa qui officia deserunt mollit anim id est laborum'.split(' ');
function renderLorem() {
  const type = document.getElementById('lor-type').value;
  const count = parseInt(document.getElementById('lor-count').value);
  document.getElementById('lor-count-label').textContent = count;
  let result = '';
  if (type === 'words') {
    result = Array(count).fill(0).map(() => LOREM_WORDS[Math.floor(Math.random()*LOREM_WORDS.length)]).join(' ');
    result = result.charAt(0).toUpperCase() + result.slice(1) + '.';
  } else if (type === 'sentences') {
    const sents = [];
    for (let i=0; i<count; i++) {
      const len = 8 + Math.floor(Math.random()*12);
      let s = Array(len).fill(0).map(() => LOREM_WORDS[Math.floor(Math.random()*LOREM_WORDS.length)]).join(' ');
      sents.push(s.charAt(0).toUpperCase() + s.slice(1) + '.');
    }
    result = sents.join(' ');
  } else {
    const paras = [];
    for (let i=0; i<count; i++) {
      const sCount = 3 + Math.floor(Math.random()*3);
      const sents = [];
      for (let j=0; j<sCount; j++) {
        const len = 8 + Math.floor(Math.random()*12);
        let s = Array(len).fill(0).map(() => LOREM_WORDS[Math.floor(Math.random()*LOREM_WORDS.length)]).join(' ');
        sents.push(s.charAt(0).toUpperCase() + s.slice(1) + '.');
      }
      paras.push(sents.join(' '));
    }
    result = paras.join('\n\n');
  }
  document.getElementById('lor-output').textContent = result;
}
function copyLorem() {
  navigator.clipboard.writeText(document.getElementById('lor-output').textContent).then(() => toast('📋 Copié !'));
}

