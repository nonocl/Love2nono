const TS_SUP = {'a':'ᵃ','b':'ᵇ','c':'ᶜ','d':'ᵈ','e':'ᵉ','f':'ᶠ','g':'ᵍ','h':'ʰ','i':'ⁱ','j':'ʲ','k':'ᵏ','l':'ˡ','m':'ᵐ','n':'ⁿ','o':'ᵒ','p':'ᵖ','r':'ʳ','s':'ˢ','t':'ᵗ','u':'ᵘ','v':'ᵛ','w':'ʷ','x':'ˣ','y':'ʸ','z':'ᶻ','0':'⁰','1':'¹','2':'²','3':'³','4':'⁴','5':'⁵','6':'⁶','7':'⁷','8':'⁸','9':'⁹','+':'⁺','-':'⁻','=':'⁼','(':'⁽',')':'⁾',' ':' '};
const TS_SUB = {'a':'ₐ','e':'ₑ','h':'ₕ','i':'ᵢ','j':'ⱼ','k':'ₖ','l':'ₗ','m':'ₘ','n':'ₙ','o':'ₒ','p':'ₚ','r':'ᵣ','s':'ₛ','t':'ₜ','u':'ᵤ','v':'ᵥ','x':'ₓ','0':'₀','1':'₁','2':'₂','3':'₃','4':'₄','5':'₅','6':'₆','7':'₇','8':'₈','9':'₉','+':'₊','-':'₋','=':'₌',' ':' '};
const TS_SQR = {'a':'🄰','b':'🄱','c':'🄲','d':'🄳','e':'🄴','f':'🄵','g':'🄶','h':'🄷','i':'🄸','j':'🄹','k':'🄺','l':'🄻','m':'🄼','n':'🄽','o':'🄾','p':'🄿','q':'🅀','r':'🅁','s':'🅂','t':'🅃','u':'🅄','v':'🅅','w':'🅆','x':'🅇','y':'🅈','z':'🅉'};
const TS_SQR_NEG = {'a':'🅰','b':'🅱','c':'🅲','d':'🅳','e':'🅴','f':'🅵','g':'🅶','h':'🅷','i':'🅸','j':'🅹','k':'🅺','l':'🅻','m':'🅼','n':'🅽','o':'🅾','p':'🅿','q':'🆀','r':'🆁','s':'🆂','t':'🆃','u':'🆄','v':'🆅','w':'🆆','x':'🆇','y':'🆈','z':'🆉'};
const TS_BUB_NEG = {'a':'🅐','b':'🅑','c':'🅒','d':'🅓','e':'🅔','f':'🅕','g':'🅖','h':'🅗','i':'🅘','j':'🅙','k':'🅚','l':'🅛','m':'🅜','n':'🅝','o':'🅞','p':'🅟','q':'🅠','r':'🅡','s':'🅢','t':'🅣','u':'🅤','v':'🅥','w':'🅦','x':'🅧','y':'🅨','z':'🅩'};
const TS_INV = {'a':'ɐ','b':'q','c':'ɔ','d':'p','e':'ǝ','f':'ɟ','g':'ƃ','h':'ɥ','i':'ᴉ','j':'ɾ','k':'ʞ','l':'l','m':'ɯ','n':'u','o':'o','p':'d','q':'b','r':'ɹ','s':'s','t':'ʇ','u':'n','v':'ʌ','w':'ʍ','x':'x','y':'ʎ','z':'z',' ':' ','.':'˙',',':'\'','?':'¿','!':'¡','\'':',','"':',,','(':')',')':'('};

function tsApplyMap(text, map, lower) {
  return Array.from(text).map(c => {
    const k = lower ? c.toLowerCase() : c;
    return map[k] || c;
  }).join('');
}
function tsSuperscript(text) { return tsApplyMap(text, TS_SUP, true); }
function tsSubscript(text) { return tsApplyMap(text, TS_SUB, true); }
function tsStrike(text) { return Array.from(text).map(c => c + '\u0336').join(''); }
function tsUnderline(text) { return Array.from(text).map(c => c + '\u0332').join(''); }
function tsSquared(text) { return tsApplyMap(text, TS_SQR, true); }
function tsSquaredNeg(text) { return tsApplyMap(text, TS_SQR_NEG, true); }
function tsBubbleNeg(text) { return tsApplyMap(text, TS_BUB_NEG, true); }
function tsInverted(text) {
  return Array.from(text.toLowerCase()).reverse().map(c => TS_INV[c] || c).join('');
}
function tsFullwidth(text) {
  return Array.from(text).map(c => {
    const code = c.charCodeAt(0);
    if (code >= 33 && code <= 126) return String.fromCharCode(code + 0xFEE0);
    if (c === ' ') return '　';
    return c;
  }).join('');
}
function tsSurround(text, sym) {
  return Array.from(text).filter(c => c !== ' ').join(sym) + (text.includes(' ') ? ' ' + text : '');
}
function tsHeartsAround(text) {
  return text.split(' ').map(w => '♡' + w + '♡').join(' ');
}
function tsStarsAround(text) {
  return text.split(' ').map(w => '✧' + w + '✧').join(' ');
}
function tsVaporwave(text) {
  return tsFullwidth(text).split('').join(' ');
}
function tsGlitch(text) {
  const glitchChars = ['̷','̸','̴','̶'];
  return Array.from(text).map(c => c + glitchChars[Math.floor(Math.random()*glitchChars.length)]).join('');
}
function tsZalgo(text) {
  const zalgoUp = ['̍','̎','̄','̅','̿','̑','̆','̐','͒','͗','͑','̇','̈','̊','͂','̓','̈́','͊','͋','͌','̃','̂','̌','͐','̀','́'];
  const zalgoDown = ['̖','̗','̘','̙','̜','̝','̞','̟','̠','̤','̥','̦','̩','̪','̫','̬','̭','̮','̯','̰','̱','̲','̳','̹','̺','̻','̼','ͅ'];
  return Array.from(text).map(c => {
    let r = c;
    for (let i=0; i<3; i++) r += zalgoUp[Math.floor(Math.random()*zalgoUp.length)];
    for (let i=0; i<2; i++) r += zalgoDown[Math.floor(Math.random()*zalgoDown.length)];
    return r;
  }).join('');
}

