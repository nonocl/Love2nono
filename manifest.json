    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:18px;">📚 Historique</h3>`;
    g.slice().reverse().slice(0, 30).forEach(e => {
      const d = new Date(e.date).toLocaleDateString('fr-FR', { weekday:'long', day:'numeric', month:'long' });
      html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px;">
