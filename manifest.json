// ============================================================
// THEME ENGINE
// ============================================================
function applyTheme() {
  const t = state.themeName === 'custom' && state.customTheme ? state.customTheme : THEMES[state.themeName] || THEMES.nono;
  const root = document.documentElement;
  root.style.setProperty('--bg', t.bg);
  root.style.setProperty('--surface', t.surface);
  root.style.setProperty('--surfaceAlt', t.surfaceAlt);
  root.style.setProperty('--primary', t.primary);
  root.style.setProperty('--accent', t.accent);
  root.style.setProperty('--text', t.text);
  root.style.setProperty('--textSec', t.textSec);
  root.style.setProperty('--border', t.border);
  root.style.setProperty('--shadow', t.shadow);
  root.style.setProperty('--danger', t.danger);
  root.style.setProperty('--success', t.success);
  // Apply gradient as body background-image if present
  if (t.gradient) {
    document.body.style.backgroundImage = t.gradient;
    document.body.style.backgroundAttachment = 'fixed';
    document.body.classList.add('has-gradient');
  } else {
    document.body.style.backgroundImage = '';
    document.body.style.backgroundAttachment = '';
    document.body.classList.remove('has-gradient');
  }
  // Pattern overlay (paws, nono...)
  const patternEl = document.getElementById('theme-pattern');
  if (t.pattern) {
    if (patternEl) patternEl.remove();
    const div = document.createElement('div');
    div.id = 'theme-pattern';
    div.style.cssText = 'position:fixed; inset:0; pointer-events:none; z-index:0; opacity:0.10;';
    if (t.pattern === 'paws') {
      const svg = `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 80 80' width='80' height='80'><g fill='${encodeURIComponent('#3D2817')}'><circle cx='20' cy='35' r='6'/><circle cx='12' cy='22' r='3.5'/><circle cx='20' cy='15' r='3.5'/><circle cx='28' cy='22' r='3.5'/><circle cx='60' cy='65' r='6'/><circle cx='52' cy='52' r='3.5'/><circle cx='60' cy='45' r='3.5'/><circle cx='68' cy='52' r='3.5'/></g></svg>`;
      div.style.backgroundImage = `url("data:image/svg+xml;utf8,${svg.replace(/#/g,'%23')}")`;
      div.style.backgroundSize = '80px 80px';
    } else if (t.pattern === 'nono') {
      // Nono text repeated as pattern
      const svg = `<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 100' width='200' height='100'><text x='10' y='40' font-family='Arial Black, sans-serif' font-size='28' font-weight='900' fill='${encodeURIComponent('#FFFFFF')}' transform='rotate(-15 100 50)'>nono ✨</text><text x='90' y='85' font-family='Arial Black, sans-serif' font-size='28' font-weight='900' fill='${encodeURIComponent('#FFFFFF')}' transform='rotate(-15 100 50)'>nono 💖</text></svg>`;
      div.style.backgroundImage = `url("data:image/svg+xml;utf8,${svg.replace(/#/g,'%23')}")`;
      div.style.backgroundSize = '200px 100px';
    }
    document.body.appendChild(div);
  } else {
    if (patternEl) patternEl.remove();
  }
  document.getElementById('theme-meta').setAttribute('content', t.bg);
}

function setTheme(name) {
  state.themeName = name;
  localStorage.setItem('nw_theme', name);
  applyTheme();
  if (state.page === 'settings') renderThemeGrid();
}

function resetTheme() {
  if (!confirm('Réinitialiser le thème par défaut ?')) return;
  state.themeName = 'nono';
  localStorage.setItem('nw_theme', 'nono');
  applyTheme();
  renderThemeGrid();
  toast('Thème réinitialisé');
}

function renderThemeGrid() {
  const el = document.getElementById('theme-grid');
  el.innerHTML = '';
  const order = ['light','dark','nono','nonowall','girly','softgirl','cottagecore','darkacademia','cream','sage','cloud','peach','butterfly','cat','rosegarden','moonlight','goldenhour','y2k','vaporwave','forestwitch','oceandream','midnight','amethyst','sunset','pinkdream','oceanic','twilight','aurora','fire','galaxy'];
  for (const k of order) {
    const t = THEMES[k];
    if (!t) continue;
    const card = document.createElement('button');
    card.className = 'theme-card' + (state.themeName === k ? ' selected' : '');
    // If gradient theme, show gradient as background; otherwise the surface color
    if (t.gradient) {
      card.style.background = t.gradient;
      card.style.color = '#FFFFFF';
    } else {
      card.style.background = t.surface;
      card.style.color = t.text;
    }
    card.innerHTML = `
      <div class="check">✓</div>
      <div class="preview-row">
        <div class="preview-dot" style="background:${t.bg}"></div>
        <div class="preview-dot" style="background:${t.primary}"></div>
        <div class="preview-dot" style="background:${t.accent}"></div>
      </div>
      <div class="name">${t.name}</div>
    `;
    card.onclick = () => setTheme(k);
    el.appendChild(card);
  }
  // Custom card
  if (state.customTheme) {
    const card = document.createElement('button');
    card.className = 'theme-card' + (state.themeName === 'custom' ? ' selected' : '');
    if (state.customTheme.gradient) {
      card.style.background = state.customTheme.gradient;
      card.style.color = '#FFFFFF';
    } else {
      card.style.background = state.customTheme.surface;
      card.style.color = state.customTheme.text;
    }
    card.innerHTML = `
      <div class="check">✓</div>
      <div class="preview-row">
        <div class="preview-dot" style="background:${state.customTheme.bg}"></div>
        <div class="preview-dot" style="background:${state.customTheme.primary}"></div>
        <div class="preview-dot" style="background:${state.customTheme.accent}"></div>
      </div>
      <div class="name">✨ Mon thème</div>
    `;
    card.onclick = () => setTheme('custom');
    el.appendChild(card);
  }
}

// Custom theme editor
function renderCustomThemeEditor() {
  const base = state.customTheme || { ...THEMES.girly };
  if (!state.customTheme) state.customTheme = { ...base };
  // Default to "solid" mode if no gradient
  const isGradient = !!base.gradient;
  // Initialize gradient stops if not present
  if (!state.customTheme._gradStops) {
    state.customTheme._gradStops = isGradient
      ? parseGradient(base.gradient)
      : [{ color: '#FF6FA3', pos: 0 }, { color: '#9B4EDD', pos: 50 }, { color: '#2A0F3A', pos: 100 }];
  }
  if (state.customTheme._gradAngle === undefined) {
    state.customTheme._gradAngle = isGradient ? extractAngle(base.gradient) : 160;
  }

  const el = document.getElementById('custom-theme-pickers');
  el.innerHTML = '';

  // Mode toggle
  const modeRow = document.createElement('div');
  modeRow.style.cssText = 'display:flex; gap:6px; margin-bottom:14px; background:var(--surfaceAlt); padding:4px; border-radius:12px;';
  modeRow.innerHTML = `
    <button class="btn ${!isGradient?'primary':'ghost'} full" data-mode="solid" style="font-size:13px;">🎨 Couleur unie</button>
    <button class="btn ${isGradient?'primary':'ghost'} full" data-mode="gradient" style="font-size:13px;">🌈 Dégradé</button>
  `;
  modeRow.querySelector('[data-mode="solid"]').onclick = () => switchCustomMode('solid');
  modeRow.querySelector('[data-mode="gradient"]').onclick = () => switchCustomMode('gradient');
  el.appendChild(modeRow);

  if (isGradient) {
    // Gradient editor
    const sec = document.createElement('div');
    sec.innerHTML = `
      <div style="font-size:13px; font-weight:700; color:var(--textSec); margin-bottom:8px;">DÉGRADÉ</div>
      <div id="grad-stops"></div>
      <div style="display:flex; gap:8px; margin-top:8px;">
        <button class="btn alt" id="grad-add" style="flex:1; font-size:13px;">+ Ajouter une couleur</button>
      </div>
      <div class="input-row" style="margin-top:14px;">
        <label>Angle</label>
        <input type="range" id="grad-angle" min="0" max="360" value="${state.customTheme._gradAngle}">
        <span class="value" id="grad-angle-val">${state.customTheme._gradAngle}°</span>
      </div>
      <div style="font-size:11px; color:var(--textSec); margin-top:4px;">0° = haut → bas, 90° = gauche → droite, 180° = bas → haut</div>
    `;
    el.appendChild(sec);
    sec.querySelector('#grad-add').onclick = () => {
      state.customTheme._gradStops.push({ color: '#FFFFFF', pos: 100 });
      applyCustomGradient();
      renderCustomThemeEditor();
    };
    sec.querySelector('#grad-angle').oninput = (e) => {
      state.customTheme._gradAngle = parseInt(e.target.value);
      document.getElementById('grad-angle-val').textContent = e.target.value + '°';
      applyCustomGradient();
    };
    renderGradStops();
  }

  // Common color fields (always shown)
  const sectionTitle = document.createElement('div');
  sectionTitle.style.cssText = 'font-size:13px; font-weight:700; color:var(--textSec); margin:18px 0 8px;';
  sectionTitle.textContent = isGradient ? 'COULEURS DU CONTENU' : 'COULEURS';
  el.appendChild(sectionTitle);

  const fields = isGradient
    ? [
        { key:'primary', label:'Couleur principale' },
        { key:'accent', label:'Accent' },
        { key:'text', label:'Texte' },
        { key:'textSec', label:'Texte secondaire' },
      ]
    : [
        { key:'bg', label:'Fond' },
        { key:'surface', label:'Cartes' },
        { key:'surfaceAlt', label:'Cartes (alt)' },
        { key:'primary', label:'Couleur principale' },
        { key:'accent', label:'Accent' },
        { key:'text', label:'Texte' },
        { key:'textSec', label:'Texte secondaire' },
        { key:'border', label:'Bordures' },
      ];
  for (const f of fields) {
    const row = document.createElement('div');
    row.className = 'input-row';
    row.innerHTML = `
      <label>${f.label}</label>
      <input type="color" data-key="${f.key}" value="${base[f.key]||'#000000'}" oninput="liveCustomTheme(this)">
      <span class="value" data-val="${f.key}">${base[f.key]||'#000000'}</span>
    `;
    el.appendChild(row);
  }
}

function renderGradStops() {
  const c = document.getElementById('grad-stops');
  if (!c) return;
  c.innerHTML = '';
  for (let i=0; i<state.customTheme._gradStops.length; i++) {
    const s = state.customTheme._gradStops[i];
    const row = document.createElement('div');
    row.style.cssText = 'display:flex; gap:8px; align-items:center; padding:6px; background:var(--surfaceAlt); border-radius:10px; margin-bottom:6px;';
    row.innerHTML = `
      <input type="color" value="${s.color}" data-stop-i="${i}" data-stop-f="color" style="flex-shrink:0;">
      <span style="font-size:12px; color:var(--textSec); min-width:40px;">Pos.</span>
      <input type="range" min="0" max="100" value="${s.pos}" data-stop-i="${i}" data-stop-f="pos" style="flex:1;">
      <span style="font-size:12px; min-width:30px; text-align:right;">${s.pos}%</span>
      ${state.customTheme._gradStops.length > 2 ? `<button data-rm="${i}" style="background:transparent; color:var(--danger); font-size:18px; padding:4px 8px;">×</button>` : ''}
    `;
    c.appendChild(row);
  }
  c.querySelectorAll('input').forEach(inp => {
    inp.addEventListener('input', () => {
      const i = parseInt(inp.dataset.stopI);
      const f = inp.dataset.stopF;
      if (f === 'pos') state.customTheme._gradStops[i].pos = parseInt(inp.value);
      else state.customTheme._gradStops[i][f] = inp.value;
      applyCustomGradient();
      // Update visible labels
      if (f === 'pos') {
        inp.parentElement.querySelector('span:last-of-type, span:nth-of-type(3)').textContent = inp.value + '%';
      }
    });
  });
  c.querySelectorAll('[data-rm]').forEach(btn => {
    btn.onclick = () => {
      state.customTheme._gradStops.splice(parseInt(btn.dataset.rm), 1);
      applyCustomGradient();
      renderCustomThemeEditor();
    };
  });
}

function applyCustomGradient() {
  if (!state.customTheme) return;
  const stops = state.customTheme._gradStops.slice().sort((a,b)=>a.pos-b.pos);
  const angle = state.customTheme._gradAngle;
  const grad = `linear-gradient(${angle}deg, ${stops.map(s => `${s.color} ${s.pos}%`).join(', ')})`;
  state.customTheme.gradient = grad;
  // Pick darkest color for solid bg fallback (theme-color meta + fallback)
  state.customTheme.bg = stops[stops.length-1].color;
  // Use translucent surfaces for glassmorphism
  state.customTheme.surface = 'rgba(0,0,0,0.35)';
  state.customTheme.surfaceAlt = 'rgba(0,0,0,0.5)';
  state.customTheme.border = 'rgba(255,255,255,0.18)';
  state.themeName = 'custom';
  applyTheme();
}

function switchCustomMode(mode) {
  if (!state.customTheme) state.customTheme = { ...THEMES.girly };
  if (mode === 'gradient') {
    if (!state.customTheme._gradStops) {
      state.customTheme._gradStops = [{ color: '#FF6FA3', pos: 0 }, { color: '#9B4EDD', pos: 50 }, { color: '#2A0F3A', pos: 100 }];
      state.customTheme._gradAngle = 160;
    }
    // Set defaults for content colors if user hasn't customised them
    if (!state.customTheme.text || state.customTheme.text === THEMES.girly.text) state.customTheme.text = '#FFFFFF';
    if (!state.customTheme.textSec || state.customTheme.textSec === THEMES.girly.textSec) state.customTheme.textSec = '#D4B8E0';
    applyCustomGradient();
  } else {
    delete state.customTheme.gradient;
    // Reset surfaces to opaque defaults
    state.customTheme.bg = THEMES.girly.bg;
    state.customTheme.surface = THEMES.girly.surface;
    state.customTheme.surfaceAlt = THEMES.girly.surfaceAlt;
    state.customTheme.border = THEMES.girly.border;
    state.themeName = 'custom';
    applyTheme();
  }
  renderCustomThemeEditor();
}

// Parse a linear-gradient(...) string back to {stops, angle}
function parseGradient(g) {
  try {
    const inner = g.match(/linear-gradient\((.*)\)/i);
    if (!inner) return [{color:'#FF6FA3',pos:0},{color:'#9B4EDD',pos:100}];
    const parts = inner[1].split(',').map(s=>s.trim());
    parts.shift(); // angle
    const stops = [];
    for (const p of parts) {
      const m = p.match(/(#[0-9a-f]{3,8}|rgba?\([^)]+\))\s*(\d+)?%?/i);
      if (m) stops.push({ color: m[1], pos: m[2] !== undefined ? parseInt(m[2]) : 50 });
    }
    return stops.length >= 2 ? stops : [{color:'#FF6FA3',pos:0},{color:'#9B4EDD',pos:100}];
  } catch (e) { return [{color:'#FF6FA3',pos:0},{color:'#9B4EDD',pos:100}]; }
}

function extractAngle(g) {
  const m = g.match(/linear-gradient\(\s*(\d+)deg/i);
  return m ? parseInt(m[1]) : 160;
}

function liveCustomTheme(input) {
  const key = input.dataset.key;
  const val = input.value;
  if (!state.customTheme) state.customTheme = { ...THEMES.girly };
  state.customTheme[key] = val;
  // Update label
  const lbl = document.querySelector(`[data-val="${key}"]`);
  if (lbl) lbl.textContent = val;
  // Apply live
  state.themeName = 'custom';
  applyTheme();
}

function saveCustomTheme() {
  if (!state.customTheme) return;
  // Add danger/success/shadow defaults if missing
  const base = THEMES.girly;
  for (const k of ['danger','success','shadow']) {
    if (!state.customTheme[k]) state.customTheme[k] = base[k];
  }
  // Strip internal helpers (_gradStops, _gradAngle) — they'd bloat storage but keep for re-edit
  // Actually keep them so user can re-edit easily
  localStorage.setItem('nw_custom_theme', JSON.stringify(state.customTheme));
  localStorage.setItem('nw_theme', 'custom');
  state.themeName = 'custom';
  applyTheme();
  toast('Thème sauvegardé ✨');
  goTo('settings');
}

// ============================================================
// WALLPAPER
// ============================================================
function applyWallpaper() {
  const root = document.documentElement;
  
  // V60 : protection contre crash sur grosses images (>2Mo)
  // Si on a déjà appliqué le même wallpaper, on saute pour éviter les renders inutiles
  const currentBg = root.style.getPropertyValue('--bgImage');
  
  try {
    if (state.wallpaper) {
      document.body.classList.add('has-wallpaper');
      // N'applique le wallpaper que si différent du précédent (évite les freezes)
      const newBg = `url(${state.wallpaper})`;
      if (currentBg !== newBg) {
        root.style.setProperty('--bgImage', newBg);
      }
      root.style.setProperty('--bgOpacity', state.wallpaperOpacity / 100);
      root.style.setProperty('--bgBlur', state.wallpaperBlur + 'px');
      
      // Update controls UI seulement si présents (page settings ouverte)
      const ctrl = document.getElementById('wallpaper-controls');
      if (ctrl) ctrl.style.display = 'block';
      const op = document.getElementById('wallpaper-opacity');
      if (op) op.value = state.wallpaperOpacity;
      const bl = document.getElementById('wallpaper-blur');
      if (bl) bl.value = state.wallpaperBlur;
      const opv = document.getElementById('wallpaper-op-val');
      if (opv) opv.textContent = state.wallpaperOpacity + '%';
      const blv = document.getElementById('wallpaper-bl-val');
      if (blv) blv.textContent = state.wallpaperBlur + 'px';
    } else {
      document.body.classList.remove('has-wallpaper');
      if (currentBg !== 'none') {
        root.style.setProperty('--bgImage', 'none');
      }
      const ctrl = document.getElementById('wallpaper-controls');
      if (ctrl) ctrl.style.display = 'none';
    }
  } catch(e) {
    console.warn('applyWallpaper error:', e);
  }
}

document.getElementById('wallpaper-input').addEventListener('change', async (e) => {
  const f = e.target.files?.[0];
  if (!f) return;
  const reader = new FileReader();
  reader.onload = async () => {
    state.wallpaper = reader.result;
    try { localStorage.setItem('nw_wallpaper', reader.result); } catch (err) {
      // localStorage trop petit, utiliser IndexedDB pour wallpaper
      await setKV('wallpaper', reader.result);
      localStorage.setItem('nw_wallpaper', '__indexed__');
    }
    applyWallpaper();
    toast('Fond d\'écran appliqué ✨');
  };
  reader.readAsDataURL(f);
  e.target.value = '';
});

function updateWallpaper() {
  state.wallpaperOpacity = parseInt(document.getElementById('wallpaper-opacity').value);
  state.wallpaperBlur = parseInt(document.getElementById('wallpaper-blur').value);
  localStorage.setItem('nw_wp_op', state.wallpaperOpacity);
  localStorage.setItem('nw_wp_bl', state.wallpaperBlur);
  applyWallpaper();
}

function removeWallpaper() {
  if (!confirm('Enlever le fond d\'écran ?')) return;
  state.wallpaper = null;
  localStorage.removeItem('nw_wallpaper');
  delKV('wallpaper').catch(()=>{});
  applyWallpaper();
  toast('Fond d\'écran enlevé');
}

// ============================================================
// INDEXEDDB
// ============================================================
let db;
function openDB() {
  return new Promise((res, rej) => {
    const req = indexedDB.open('nonosworld', 13);
    req.onupgradeneeded = (e) => {
      const d = e.target.result;
      const stores = ['pfps','categories','albums','pfp_cats','pfp_albums','counters','countdowns','bdays','habits','habit_logs','wishes','quotes','moods','notes','palettes','tracks','playlists','playlist_tracks','watchlist','music_cats','track_cats','grades','homework','classes','decks','cards','friends','expenses','vault','videos','wallet_tx','events','game_scores','sobriety','sleep_log','weight_log','wheels','wallet_tx','kv',
        // === NOUVEAUX STORES v12 ===
        'files','file_folders','note_cats','drawings',
        // === NOUVEAU STORE v13 (Pack Girly) ===
        'wardrobe'];
      for (const name of stores) {
        if (!d.objectStoreNames.contains(name)) {
          if (name === 'kv') d.createObjectStore(name, { keyPath: 'key' });
          else if (name.includes('_') && !['file_folders','note_cats'].includes(name)) d.createObjectStore(name, { keyPath: 'key' });
          else d.createObjectStore(name, { keyPath: 'id', autoIncrement: true });
        }
      }
    };
    req.onsuccess = () => { db = req.result; res(db); };
    req.onerror = () => rej(req.error);
  });
}
function tx(stores, mode='readonly') { return db.transaction(stores, mode); }
function p(req) { return new Promise((res, rej) => { req.onsuccess = () => res(req.result); req.onerror = () => rej(req.error); }); }

async function dbAdd(store, obj) { return p(tx([store],'readwrite').objectStore(store).add(obj)); }
async function dbPut(store, obj) { return p(tx([store],'readwrite').objectStore(store).put(obj)); }
async function dbGet(store, id) { return p(tx([store]).objectStore(store).get(id)); }
async function dbAll(store) { return p(tx([store]).objectStore(store).getAll()); }
async function dbDel(store, id) { return p(tx([store],'readwrite').objectStore(store).delete(id)); }
async function dbClear(store) { return p(tx([store],'readwrite').objectStore(store).clear()); }

async function setKV(key, value) { return dbPut('kv', { key, value }); }
async function getKV(key) { const r = await dbGet('kv', key); return r?.value; }
async function delKV(key) { return dbDel('kv', key); }

