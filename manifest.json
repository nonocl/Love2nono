// JEU: MASTERMIND
// ============================================================
const MASTER_COLORS = ['#FF6B7A','#FFD166','#5DD68F','#5DD6E5','#C77DFF','#FF8C42'];
let _master = null;
function newMaster() {
  _master = {
    secret: [], guess: [], history: [], over: false, max: 10
  };
  for (let i=0; i<4; i++) _master.secret.push(Math.floor(Math.random()*MASTER_COLORS.length));
  document.getElementById('master-result').textContent = '';
  renderMaster();
}
function renderMaster() {
  // History
  const h = document.getElementById('master-history');
  h.innerHTML = '';
  _master.history.forEach((entry, i) => {
    const row = document.createElement('div');
    row.style.cssText = 'display:flex; gap:8px; align-items:center; padding:4px 0;';
    let html = `<div style="font-size:11px; color:var(--textSec); width:24px;">${i+1}</div><div style="display:flex; gap:4px;">`;
    entry.guess.forEach(c => html += `<div style="width:24px; height:24px; border-radius:50%; background:${MASTER_COLORS[c]};"></div>`);
    html += `</div><div style="margin-left:auto; display:flex; gap:2px;">`;
    for (let i=0; i<entry.black; i++) html += `<div style="width:10px; height:10px; border-radius:50%; background:#000; border:1px solid #888;"></div>`;
    for (let i=0; i<entry.white; i++) html += `<div style="width:10px; height:10px; border-radius:50%; background:#fff; border:1px solid #888;"></div>`;
    html += `</div>`;
    row.innerHTML = html;
    h.appendChild(row);
  });
  // Current guess
  const cur = document.getElementById('master-current');
  cur.innerHTML = '';
  for (let i=0; i<4; i++) {
    const slot = document.createElement('div');
    const c = _master.guess[i];
    slot.style.cssText = `width:36px; height:36px; border-radius:50%; background:${c !== undefined ? MASTER_COLORS[c] : 'var(--surfaceAlt)'}; border:2px solid var(--border); cursor:pointer;`;
    slot.onclick = () => { _master.guess.splice(i, 1); renderMaster(); };
    cur.appendChild(slot);
  }
  // Palette
  const pal = document.getElementById('master-palette');
  pal.innerHTML = '';
  MASTER_COLORS.forEach((c, idx) => {
    const btn = document.createElement('button');
    btn.style.cssText = `width:36px; height:36px; border-radius:50%; background:${c}; border:none; cursor:pointer;`;
    btn.disabled = _master.over || _master.guess.length >= 4;
    btn.onclick = () => {
      if (_master.guess.length < 4) { _master.guess.push(idx); renderMaster(); }
    };
    pal.appendChild(btn);
  });
  document.getElementById('master-submit-btn').disabled = _master.guess.length !== 4 || _master.over;
}
function masterSubmit() {
  if (_master.guess.length !== 4 || _master.over) return;
  let black = 0, white = 0;
  const usedSecret = [false,false,false,false];
  const usedGuess = [false,false,false,false];
  for (let i=0; i<4; i++) {
    if (_master.guess[i] === _master.secret[i]) { black++; usedSecret[i] = true; usedGuess[i] = true; }
  }
  for (let i=0; i<4; i++) {
    if (usedGuess[i]) continue;
    for (let j=0; j<4; j++) {
      if (!usedSecret[j] && _master.guess[i] === _master.secret[j]) { white++; usedSecret[j] = true; break; }
    }
  }
  _master.history.push({ guess: _master.guess.slice(), black, white });
  if (black === 4) {
    _master.over = true;
    document.getElementById('master-result').innerHTML = `<span style="color:var(--success);">🎉 Trouvé en ${_master.history.length} essais !</span>`;
  } else if (_master.history.length >= _master.max) {
    _master.over = true;
    let html = '<div style="color:var(--danger);">😬 Perdu. Combinaison :</div><div style="display:flex; gap:4px; justify-content:center; margin-top:6px;">';
    _master.secret.forEach(c => html += `<div style="width:24px; height:24px; border-radius:50%; background:${MASTER_COLORS[c]};"></div>`);
    html += '</div>';
    document.getElementById('master-result').innerHTML = html;
  }
  _master.guess = [];
  renderMaster();
}

