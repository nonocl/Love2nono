}
function cpDraw() {
  const c = RANDOM_COUNTRIES[Math.floor(Math.random() * RANDOM_COUNTRIES.length)];
  document.getElementById('cp-result').innerHTML = `<div style="background:linear-gradient(135deg,#5DADE2,#06FFA5); color:white; padding:24px; border-radius:18px; text-align:center; animation:bounce-in 0.4s;">
