body[data-theme="goldenhour"].vibe-neuo {
  background: linear-gradient(165deg, #FF8C42 0%, #FFD166 40%, #FF6FA3 100%) fixed !important;
}
body[data-theme="goldenhour"].vibe-neuo .v56-greeting,
body[data-theme="goldenhour"].vibe-neuo .v56-card {
  background: rgba(255, 209, 102, 0.25) !important;
  box-shadow: 8px 8px 24px rgba(255, 140, 66, 0.4), -4px -4px 16px rgba(255, 255, 255, 0.3) !important;
  border: none !important;
  border-radius: 24px !important;
}

/* === EASTER EGG #11 : OCEAN DEEPS ===
   theme oceandream + vibe-glass = sous-marin */
body[data-theme="oceandream"].vibe-glass {
  background: linear-gradient(160deg, #021E73 0%, #5DADE2 40%, #06FFA5 80%, #1F4287 100%) fixed !important;
}
body[data-theme="oceandream"].vibe-glass .v56-greeting,
body[data-theme="oceandream"].vibe-glass .v56-card {
  background: rgba(2, 30, 115, 0.3) !important;
  backdrop-filter: blur(20px) hue-rotate(-10deg) !important;
  -webkit-backdrop-filter: blur(20px) hue-rotate(-10deg) !important;
  border: 1px solid rgba(6, 255, 165, 0.3) !important;
  box-shadow: 0 8px 28px rgba(2, 30, 115, 0.6), inset 0 0 20px rgba(6, 255, 165, 0.1) !important;
  position: relative;
  overflow: hidden;
}
body[data-theme="oceandream"].vibe-glass .v56-greeting::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 0%, rgba(6,255,165,0.1) 100%);
