// === 8. EXPORT CHIFFRÉ ===
async function deriveKey(passphrase, salt) {
  const enc = new TextEncoder();
  const km = await crypto.subtle.importKey('raw', enc.encode(passphrase), 'PBKDF2', false, ['deriveKey']);
  return crypto.subtle.deriveKey({ name:'PBKDF2', salt, iterations:100000, hash:'SHA-256' }, km, { name:'AES-GCM', length:256 }, false, ['encrypt', 'decrypt']);
}
async function encryptText(text, passphrase) {
  const salt = crypto.getRandomValues(new Uint8Array(16));
  const iv = crypto.getRandomValues(new Uint8Array(12));
  const key = await deriveKey(passphrase, salt);
  const enc = new TextEncoder().encode(text);
  const cipher = await crypto.subtle.encrypt({ name:'AES-GCM', iv }, key, enc);
  const out = new Uint8Array(salt.length + iv.length + cipher.byteLength);
  out.set(salt, 0); out.set(iv, salt.length); out.set(new Uint8Array(cipher), salt.length + iv.length);
  return btoa(String.fromCharCode(...out));
}
async function decryptText(b64, passphrase) {
  const data = Uint8Array.from(atob(b64), c => c.charCodeAt(0));
  const salt = data.slice(0, 16);
  const iv = data.slice(16, 28);
  const cipher = data.slice(28);
  const key = await deriveKey(passphrase, salt);
  const dec = await crypto.subtle.decrypt({ name:'AES-GCM', iv }, key, cipher);
  return new TextDecoder().decode(dec);
}
function renderEncExport() {
  let html = `<div style="background:linear-gradient(135deg,#9B59B6,#FF1493); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🔐</div>
    <div style="font-size:16px; font-weight:800; margin-top:6px;">Export chiffré AES-256</div>
    <div style="font-size:11px; opacity:0.9; margin-top:4px;">Sauvegarde toutes tes données avec passphrase</div>
  </div>
  <p style="font-size:12px; color:var(--textSec); margin-top:14px;">Choisis une <strong>phrase de passe</strong> longue et complexe. Sans elle, impossible de déchiffrer. Garde-la précieusement.</p>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📤 Exporter</h3>
  <input type="text" class="input" id="enc-pass-export" placeholder="Phrase de passe (min 8 chars)..." autocomplete="off">
  <button class="btn primary full" onclick="encExport()" style="margin-top:8px;">🔐 Chiffrer & exporter</button>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:18px;">📥 Importer</h3>
  <textarea class="input" id="enc-text-import" rows="4" placeholder="Colle ici le contenu chiffré..."></textarea>
  <input type="text" class="input" id="enc-pass-import" placeholder="Phrase de passe..." autocomplete="off" style="margin-top:6px;">
  <button class="btn alt full" onclick="encImport()" style="margin-top:8px; color:var(--danger);">⚠️ Déchiffrer & remplacer</button>
  <p style="font-size:11px; color:var(--textSec); margin-top:8px;">⚠️ L'import écrase toutes les données actuelles.</p>`;
  document.getElementById('encexport-content').innerHTML = html;
}
async function encExport() {
  const pass = document.getElementById('enc-pass-export').value;
  if (pass.length < 8) { toast('Phrase trop courte (8 chars min)'); return; }
  const data = {};
  for (let i = 0; i < localStorage.length; i++) {
    const k = localStorage.key(i);
    if (k && k.startsWith('nw_')) data[k] = localStorage.getItem(k);
  }
  const json = JSON.stringify(data);
  const cipher = await encryptText(json, pass);
  const blob = new Blob([cipher], { type: 'text/plain' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `love2nono-backup-${new Date().toISOString().slice(0,10)}.enc`;
  a.click();
  URL.revokeObjectURL(url);
  toast('✅ Export chiffré téléchargé');
}
async function encImport() {
  const txt = document.getElementById('enc-text-import').value.trim();
  const pass = document.getElementById('enc-pass-import').value;
  if (!txt || !pass) { toast('Remplis les 2 champs'); return; }
  if (!confirm('⚠️ ÉCRASER toutes les données actuelles ?')) return;
  try {
    const json = await decryptText(txt, pass);
    const data = JSON.parse(json);
    Object.keys(data).forEach(k => localStorage.setItem(k, data[k]));
    toast('✅ Import réussi · Recharge l\'app');
    setTimeout(() => location.reload(), 1500);
  } catch (e) {
    toast('❌ Échec : phrase incorrecte ou fichier corrompu');
  }
}

