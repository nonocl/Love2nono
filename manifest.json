    </div>`;
  (b.todaySubjects || []).forEach((s, i) => {
    html += `<div onclick="bagCheck('todaySubjects',${i})" style="background:var(--surface); padding:10px 14px; border-radius:10px; margin-top:4px; display:flex; gap:10px; align-items:center; cursor:pointer; ${s.done?'opacity:0.6;':''}">
      <span style="width:20px; height:20px; border-radius:5px; border:2px solid var(--primary); background:${s.done?'var(--primary)':'transparent'}; color:white; display:inline-flex; align-items:center; justify-content:center; font-size:12px;">${s.done?'✓':''}</span>
      <span style="flex:1; ${s.done?'text-decoration:line-through;':''}">📖 Affaires de ${escapeHtml(s.name)}</span>
      <button onclick="event.stopPropagation(); bagRemoveSubject(${i})" style="background:none; border:none; color:var(--danger); font-size:14px;">✗</button>
    </div>`;
  });
  document.getElementById('bagprep-content').innerHTML = html;
}
function bagCheck(key, i) { const b=getBag(); b[key][i].done = !b[key][i].done; saveBag(b); renderBag(); }
function bagToggleSubject(s) {
  const b = getBag();
  b.todaySubjects = b.todaySubjects || [];
  if (b.todaySubjects.find(x => x.name === s)) return;
  b.todaySubjects.push({ name:s, done:false });
  saveBag(b); renderBag();
}
function bagRemoveSubject(i) { const b=getBag(); b.todaySubjects.splice(i,1); saveBag(b); renderBag(); }
function bagReset() { if(!confirm('Décocher tout ?'))return; const b=getBag(); b.base.forEach(i=>i.done=false); (b.todaySubjects||[]).forEach(s=>s.done=false); saveBag(b); renderBag(); }

