  {id:'energy', emoji:'⚡', name:'Énergique'}
];
function getCycLogs() { try { return JSON.parse(localStorage.getItem('nw_cycle_logs') || '[]'); } catch { return []; } }
function saveCycLogs(d) { localStorage.setItem('nw_cycle_logs', JSON.stringify(d)); }

function renderCycle() {
  const logs = getCycLogs().sort((a,b) => b.date.localeCompare(a.date));
  const periodDays = logs.filter(l => l.flow && l.flow !== '');
  
  // Calcul prédiction
  let cycleLength = 28, periodLength = 5, lastPeriod = null, nextPeriod = null, dayInCycle = null, phase = '';
  
  // Trouve les débuts de règles (jours avec flow et le précédent jour soit pas de flow soit absent)
  const periodStarts = [];
  const sortedLogs = [...logs].sort((a,b) => a.date.localeCompare(b.date));
  for (let i = 0; i < sortedLogs.length; i++) {
    if (sortedLogs[i].flow) {
      const prev = i > 0 ? sortedLogs[i-1] : null;
      const dayBefore = new Date(sortedLogs[i].date); dayBefore.setDate(dayBefore.getDate()-1);
      const prevHadFlow = prev && prev.date === dayBefore.toISOString().slice(0,10) && prev.flow;
      if (!prevHadFlow) periodStarts.push(sortedLogs[i].date);
    }
  }
  
  if (periodStarts.length >= 2) {
    // Calcule moyenne cycle
    let sum = 0, n = 0;
    for (let i = 1; i < periodStarts.length; i++) {
      const days = Math.round((new Date(periodStarts[i]) - new Date(periodStarts[i-1])) / 86400000);
      if (days > 15 && days < 50) { sum += days; n++; }
    }
    if (n > 0) cycleLength = Math.round(sum / n);
  }
  
  if (periodStarts.length) {
    lastPeriod = new Date(periodStarts[periodStarts.length - 1]);
    const today = new Date(); today.setHours(0,0,0,0); lastPeriod.setHours(0,0,0,0);
    dayInCycle = Math.floor((today - lastPeriod) / 86400000) + 1;
    nextPeriod = new Date(lastPeriod.getTime() + cycleLength * 86400000);
    
    if (dayInCycle <= 5) phase = 'menstruelle';
    else if (dayInCycle <= 13) phase = 'folliculaire';
    else if (dayInCycle <= 16) phase = 'ovulation';
    else phase = 'lutéale';
  }
  
  const phaseInfo = {
    'menstruelle': { color:'#E74C3C', emoji:'🌹', desc:'Repos, hydratation, douceur. Évite les efforts intenses.' },
    'folliculaire': { color:'#F39C12', emoji:'🌷', desc:'Énergie qui remonte. Bon moment pour entreprendre.' },
    'ovulation': { color:'#E67E22', emoji:'🌟', desc:'Pic d\'énergie et confiance. Moment social, séduction.' },
    'lutéale': { color:'#9B59B6', emoji:'🌙', desc:'Introspection. Auto-soin, créativité, repos progressif.' }
  };
  
  const today = new Date().toISOString().slice(0,10);
  const todayLog = logs.find(l => l.date === today);
  
  let html = '';
  
  if (lastPeriod) {
    const daysToNext = Math.ceil((nextPeriod - new Date()) / 86400000);
    const pi = phaseInfo[phase] || {};
    html += `<div style="background:linear-gradient(135deg, ${pi.color || '#FF6FA3'}, ${pi.color || '#FF6FA3'}AA); color:white; padding:18px; border-radius:18px; text-align:center;">
      <div style="font-size:11px; opacity:0.85;">Phase ${phase}</div>
      <div style="font-size:42px; font-weight:900; line-height:1;">${pi.emoji || '🌸'} J${dayInCycle}</div>
      <div style="font-size:13px; margin-top:8px; line-height:1.5;">${pi.desc || ''}</div>
    </div>`;
    
    if (daysToNext > 0) {
      html += `<div style="background:var(--surface); padding:12px 14px; border-radius:14px; margin-top:10px; text-align:center;">
        <div style="font-size:11px; color:var(--textSec);">⏳ Prochaines règles dans</div>
        <div style="font-size:24px; font-weight:800; color:var(--primary);">${daysToNext} jour${daysToNext > 1 ? 's' : ''}</div>
        <div style="font-size:11px; color:var(--textSec); margin-top:2px;">≈ ${nextPeriod.toLocaleDateString('fr-FR', {day:'numeric', month:'long'})}</div>
      </div>`;
    } else if (daysToNext >= -5) {
      html += `<div style="background:#E74C3C; color:white; padding:12px 14px; border-radius:14px; margin-top:10px; text-align:center;">
        <div style="font-size:14px; font-weight:700;">🌹 Tes règles devraient être là</div>
      </div>`;
    }
    
    html += `<div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:10px;">
      <div style="background:var(--surface); padding:10px; border-radius:10px; text-align:center;">
        <div style="font-size:10px; color:var(--textSec);">Cycle moyen</div>
        <div style="font-size:18px; font-weight:800;">${cycleLength}j</div>
      </div>
      <div style="background:var(--surface); padding:10px; border-radius:10px; text-align:center;">
        <div style="font-size:10px; color:var(--textSec);">Périodes loggées</div>
        <div style="font-size:18px; font-weight:800;">${periodStarts.length}</div>
      </div>
    </div>`;
  } else {
    html += `<div style="background:linear-gradient(135deg, #FF6FA3, #FFD166); color:white; padding:18px; border-radius:18px; text-align:center;">
      <div style="font-size:48px;">🌸</div>
      <div style="font-size:16px; font-weight:800; margin-top:8px;">Bienvenue</div>
      <p style="font-size:12px; line-height:1.5; margin-top:8px; opacity:0.95;">Logge ton premier jour de règles pour activer les prédictions.</p>
    </div>`;
  }
  
  // Calendar mini
  html += `<h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-top:18px;">📅 Ce mois</h3>`;
  html += renderCycCalendar(logs);
  
  // Today
  html += `<button class="btn primary full" onclick="cycLogToday()" style="margin-top:14px;">${todayLog ? '✎ Modifier aujourd\'hui' : '+ Logger aujourd\'hui'}</button>`;
  
  document.getElementById('cycle-content').innerHTML = html;
}

function renderCycCalendar(logs) {
  const now = new Date();
  const year = now.getFullYear(), month = now.getMonth();
  const firstDay = new Date(year, month, 1);
  const lastDay = new Date(year, month + 1, 0);
  const startDay = (firstDay.getDay() + 6) % 7; // Lundi = 0
  
  let html = `<div style="background:var(--surface); padding:12px; border-radius:14px; margin-top:8px;">
    <div style="text-align:center; font-weight:700; margin-bottom:8px;">${firstDay.toLocaleDateString('fr-FR', {month:'long', year:'numeric'})}</div>
    <div style="display:grid; grid-template-columns:repeat(7,1fr); gap:3px; font-size:9px; text-align:center; color:var(--textSec);">
      <div>L</div><div>M</div><div>M</div><div>J</div><div>V</div><div>S</div><div>D</div>
    </div>
    <div style="display:grid; grid-template-columns:repeat(7,1fr); gap:3px; margin-top:4px;">`;
  
  for (let i = 0; i < startDay; i++) html += '<div></div>';
  
  for (let d = 1; d <= lastDay.getDate(); d++) {
    const dateStr = `${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const log = logs.find(l => l.date === dateStr);
    let bg = 'transparent', col = 'var(--text)';
    if (log && log.flow) {
      bg = log.flow === 'spotting' ? '#FFB3BA' : log.flow === 'light' ? '#FF6B9D' : log.flow === 'medium' ? '#E74C3C' : '#8B0000';
      col = '#FFF';
    }
    const isToday = dateStr === new Date().toISOString().slice(0,10);
    html += `<div onclick="cycEditDate('${dateStr}')" style="aspect-ratio:1; background:${bg}; color:${col}; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:11px; ${isToday ? 'border:2px solid var(--primary);' : ''} cursor:pointer;">${d}</div>`;
  }
  html += `</div>`;
  html += `<div style="display:flex; gap:10px; justify-content:center; margin-top:10px; font-size:10px; flex-wrap:wrap;">
    <span><span style="display:inline-block; width:10px; height:10px; background:#FFB3BA; border-radius:50%;"></span> Spotting</span>
    <span><span style="display:inline-block; width:10px; height:10px; background:#FF6B9D; border-radius:50%;"></span> Léger</span>
    <span><span style="display:inline-block; width:10px; height:10px; background:#E74C3C; border-radius:50%;"></span> Normal</span>
    <span><span style="display:inline-block; width:10px; height:10px; background:#8B0000; border-radius:50%;"></span> Abondant</span>
  </div></div>`;
  return html;
}

function cycLogToday() { cycEditDate(new Date().toISOString().slice(0,10)); }
function cycEditDate(dateStr) {
  document.getElementById('cyc-date').value = dateStr;
  const log = getCycLogs().find(l => l.date === dateStr) || {};
  document.getElementById('cyc-flow').value = log.flow || '';
  document.getElementById('cyc-notes').value = log.notes || '';
  // Symptômes
  const sympWrap = document.getElementById('cyc-symptoms');
  sympWrap.innerHTML = CYC_SYMPTOMS.map(s => 
    `<button onclick="this.classList.toggle('cs-on')" data-sid="${s.id}" class="${(log.symptoms || []).includes(s.id) ? 'cs-on' : ''}" style="background:var(--surface); border:1px solid var(--border); padding:8px 6px; border-radius:10px; cursor:pointer; font-size:11px; text-align:center;">
      <div style="font-size:18px;">${s.emoji}</div><div>${s.name}</div></button>`
  ).join('');
  // Style toggle
  if (!document.getElementById('cs-style-tag')) {
    const st = document.createElement('style'); st.id = 'cs-style-tag';
    st.textContent = '.cs-on { background: var(--primary) !important; color:white !important; border-color:var(--primary) !important; }';
    document.head.appendChild(st);
  }
  // Mood
  const moodWrap = document.getElementById('cyc-mood');
  moodWrap.innerHTML = CYC_MOODS.map(m =>
    `<button onclick="this.parentElement.querySelectorAll('button').forEach(b => b.classList.remove('cs-on')); this.classList.add('cs-on');" data-mid="${m.id}" class="${log.mood === m.id ? 'cs-on' : ''}" style="background:var(--surface); border:1px solid var(--border); padding:8px 10px; border-radius:10px; cursor:pointer; font-size:11px; text-align:center; flex:1; min-width:70px;">
      <div style="font-size:18px;">${m.emoji}</div><div>${m.name}</div></button>`
  ).join('');
  goTo('cycle-log');
}
function cycSave() {
  const date = document.getElementById('cyc-date').value;
  if (!date) return toast('Date requise');
  const flow = document.getElementById('cyc-flow').value;
  const notes = document.getElementById('cyc-notes').value.trim();
  const symptoms = Array.from(document.querySelectorAll('#cyc-symptoms .cs-on')).map(b => b.dataset.sid);
  const mood = document.querySelector('#cyc-mood .cs-on')?.dataset.mid || '';
  let logs = getCycLogs().filter(l => l.date !== date);
  if (flow || notes || symptoms.length || mood) {
    logs.push({ date, flow, notes, symptoms, mood });
  }
  saveCycLogs(logs);
  toast('🌸 Sauvegardé');
  goTo('cycle');
}

