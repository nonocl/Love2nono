const PEN_WORDS = [
  'ORDINATEUR','TÉLÉPHONE','MAISON','CHOCOLAT','OISEAU','VOITURE','PLAGE','MONTAGNE','MUSIQUE','GUITARE',
  'BIBLIOTHEQUE','PYRAMIDE','VACANCES','PRINTEMPS','HIVER','AUTOMNE','UNIVERS','PLANETE','GALAXIE','LUMIERE',
  'COURAGE','LIBERTE','BONHEUR','VOYAGE','DECOUVERTE','AVENTURE','PIRATE','TRESOR','LEGENDE','CHATEAU',
  'DRAGON','SORCIERE','LICORNE','SIRENE','POKEMON','CARTE','CONSOLE','MANETTE','JOYSTICK','PIXEL',
  'INTERNET','REGARD','SOURIRE','RIRE','LARMES','MEMOIRE','REVE','SOMMEIL','REVEIL','HORLOGE'
];
let _pen = null;
function penNew() {
  const word = PEN_WORDS[Math.floor(Math.random()*PEN_WORDS.length)];
  _pen = { word, found: new Set(), errors: 0, over: false };
  penRender();
}
function penRender() {
  if (!_pen) return;
  // Word display
  let display = '';
  let allFound = true;
  for (const ch of _pen.word) {
    if (ch === ' ') display += ' ';
    else if (_pen.found.has(ch) || /[^A-ZÀ-Ÿ]/.test(ch)) display += ch + ' ';
    else { display += '_ '; allFound = false; }
  }
  document.getElementById('pen-word').textContent = display.trim();
  document.getElementById('pen-errors').textContent = _pen.errors;
  // SVG pendu
  const stages = [
    '<svg width="120" height="160"><line x1="10" y1="150" x2="110" y2="150" stroke="currentColor" stroke-width="3"/></svg>',
    '<svg width="120" height="160"><line x1="10" y1="150" x2="110" y2="150" stroke="currentColor" stroke-width="3"/><line x1="30" y1="150" x2="30" y2="20" stroke="currentColor" stroke-width="3"/></svg>',
    '<svg width="120" height="160"><line x1="10" y1="150" x2="110" y2="150" stroke="currentColor" stroke-width="3"/><line x1="30" y1="150" x2="30" y2="20" stroke="currentColor" stroke-width="3"/><line x1="30" y1="20" x2="80" y2="20" stroke="currentColor" stroke-width="3"/></svg>',
    '<svg width="120" height="160"><line x1="10" y1="150" x2="110" y2="150" stroke="currentColor" stroke-width="3"/><line x1="30" y1="150" x2="30" y2="20" stroke="currentColor" stroke-width="3"/><line x1="30" y1="20" x2="80" y2="20" stroke="currentColor" stroke-width="3"/><line x1="80" y1="20" x2="80" y2="40" stroke="currentColor" stroke-width="3"/></svg>',
    '<svg width="120" height="160"><line x1="10" y1="150" x2="110" y2="150" stroke="currentColor" stroke-width="3"/><line x1="30" y1="150" x2="30" y2="20" stroke="currentColor" stroke-width="3"/><line x1="30" y1="20" x2="80" y2="20" stroke="currentColor" stroke-width="3"/><line x1="80" y1="20" x2="80" y2="40" stroke="currentColor" stroke-width="3"/><circle cx="80" cy="55" r="15" stroke="currentColor" stroke-width="3" fill="none"/></svg>',
    '<svg width="120" height="160"><line x1="10" y1="150" x2="110" y2="150" stroke="currentColor" stroke-width="3"/><line x1="30" y1="150" x2="30" y2="20" stroke="currentColor" stroke-width="3"/><line x1="30" y1="20" x2="80" y2="20" stroke="currentColor" stroke-width="3"/><line x1="80" y1="20" x2="80" y2="40" stroke="currentColor" stroke-width="3"/><circle cx="80" cy="55" r="15" stroke="currentColor" stroke-width="3" fill="none"/><line x1="80" y1="70" x2="80" y2="110" stroke="currentColor" stroke-width="3"/></svg>',
    '<svg width="120" height="160"><line x1="10" y1="150" x2="110" y2="150" stroke="currentColor" stroke-width="3"/><line x1="30" y1="150" x2="30" y2="20" stroke="currentColor" stroke-width="3"/><line x1="30" y1="20" x2="80" y2="20" stroke="currentColor" stroke-width="3"/><line x1="80" y1="20" x2="80" y2="40" stroke="currentColor" stroke-width="3"/><circle cx="80" cy="55" r="15" stroke="currentColor" stroke-width="3" fill="none"/><line x1="80" y1="70" x2="80" y2="110" stroke="currentColor" stroke-width="3"/><line x1="80" y1="80" x2="60" y2="100" stroke="currentColor" stroke-width="3"/><line x1="80" y1="80" x2="100" y2="100" stroke="currentColor" stroke-width="3"/></svg>',
    '<svg width="120" height="160"><line x1="10" y1="150" x2="110" y2="150" stroke="currentColor" stroke-width="3"/><line x1="30" y1="150" x2="30" y2="20" stroke="currentColor" stroke-width="3"/><line x1="30" y1="20" x2="80" y2="20" stroke="currentColor" stroke-width="3"/><line x1="80" y1="20" x2="80" y2="40" stroke="currentColor" stroke-width="3"/><circle cx="80" cy="55" r="15" stroke="currentColor" stroke-width="3" fill="none"/><line x1="80" y1="70" x2="80" y2="110" stroke="currentColor" stroke-width="3"/><line x1="80" y1="80" x2="60" y2="100" stroke="currentColor" stroke-width="3"/><line x1="80" y1="80" x2="100" y2="100" stroke="currentColor" stroke-width="3"/><line x1="80" y1="110" x2="60" y2="135" stroke="currentColor" stroke-width="3"/><line x1="80" y1="110" x2="100" y2="135" stroke="currentColor" stroke-width="3"/></svg>',
    '<svg width="120" height="160" style="color:#FF4757;"><line x1="10" y1="150" x2="110" y2="150" stroke="currentColor" stroke-width="3"/><line x1="30" y1="150" x2="30" y2="20" stroke="currentColor" stroke-width="3"/><line x1="30" y1="20" x2="80" y2="20" stroke="currentColor" stroke-width="3"/><line x1="80" y1="20" x2="80" y2="40" stroke="currentColor" stroke-width="3"/><circle cx="80" cy="55" r="15" stroke="currentColor" stroke-width="3" fill="none"/><text x="74" y="55" font-size="12">×</text><text x="80" y="55" font-size="12">×</text><line x1="80" y1="70" x2="80" y2="110" stroke="currentColor" stroke-width="3"/><line x1="80" y1="80" x2="60" y2="100" stroke="currentColor" stroke-width="3"/><line x1="80" y1="80" x2="100" y2="100" stroke="currentColor" stroke-width="3"/><line x1="80" y1="110" x2="60" y2="135" stroke="currentColor" stroke-width="3"/><line x1="80" y1="110" x2="100" y2="135" stroke="currentColor" stroke-width="3"/></svg>',
  ];
  document.getElementById('pen-svg').innerHTML = stages[Math.min(_pen.errors, 8)];
  // Letters keyboard
  const letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
  document.getElementById('pen-letters').innerHTML = letters.map(L => {
    const tried = _pen.found.has(L) || _pen.errors > 0 && _pen.tried?.has(L);
    const inWord = _pen.word.includes(L);
    let bg = 'var(--surfaceAlt)';
    if (tried) bg = inWord ? 'var(--success)' : 'var(--danger)';
    return `<button onclick="penGuess('${L}')" ${tried ? 'disabled' : ''} style="padding:8px 4px; background:${bg}; color:${tried ? 'white' : 'var(--text)'}; border:1px solid var(--border); border-radius:4px; font-weight:700; cursor:${tried ? 'not-allowed':'pointer'};">${L}</button>`;
  }).join('');
  // Status
  if (_pen.over) {
    if (_pen.errors >= 8) {
      document.getElementById('pen-status').innerHTML = `<span style="color:var(--danger);">💀 Perdu ! Le mot était : ${_pen.word}</span>`;
    } else {
      document.getElementById('pen-status').innerHTML = `<span style="color:var(--success);">🎉 Trouvé ! ${_pen.word}</span>`;
    }
  } else if (allFound) {
    _pen.over = true;
    document.getElementById('pen-status').innerHTML = `<span style="color:var(--success);">🎉 Bravo, mot trouvé !</span>`;
    if (typeof badgeUnlock === 'function') badgeUnlock('pendu_winner');
    if (typeof badgeIncrement === 'function') badgeIncrement('games_played', 5, 'gamer');
  }
}
function penGuess(L) {
  if (!_pen || _pen.over) return;
  if (!_pen.tried) _pen.tried = new Set();
  if (_pen.tried.has(L)) return;
  _pen.tried.add(L);
  if (_pen.word.includes(L)) {
    _pen.found.add(L);
  } else {
    _pen.errors++;
    if (_pen.errors >= 8) _pen.over = true;
  }
  penRender();
}


