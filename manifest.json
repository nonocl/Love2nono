function pcCalc() {
  const v = id => parseFloat(document.getElementById(id).value);
  const r1 = (v('pc1-x')/100) * v('pc1-y');
  document.getElementById('pc1-r').textContent = isNaN(r1) ? '—' : r1.toFixed(2);
  const r2 = (v('pc2-x')/v('pc2-y')) * 100;
  document.getElementById('pc2-r').textContent = isNaN(r2) ? '—' : r2.toFixed(2) + '%';
  const r3 = ((v('pc3-y')-v('pc3-x'))/v('pc3-x')) * 100;
  document.getElementById('pc3-r').textContent = isNaN(r3) ? '—' : (r3 >= 0 ? '+' : '') + r3.toFixed(2) + '%';
  const r4 = v('pc4-y') * (1 - v('pc4-x')/100);
  document.getElementById('pc4-r').textContent = isNaN(r4) ? '—' : r4.toFixed(2) + '€ (économie : ' + (v('pc4-y')-r4).toFixed(2) + '€)';
}

