// === 23. COMPATIBILITÉ ASTRO ===
function renderAstroCompat() {
  let html = `<div style="background:linear-gradient(135deg,#FF6FA3,#9B59B6); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">💞</div><div style="font-size:16px; font-weight:800;">Compatibilité astro</div>
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">Toi</h3>
  <select id="ac-1" class="input" oninput="acCalc()" style="margin-top:6px;">${v51_ZODIAC.map((z,i)=>`<option value="${i}">${z.e} ${z.n}</option>`).join('')}</select>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">Crush / partenaire</h3>
  <select id="ac-2" class="input" oninput="acCalc()" style="margin-top:6px;">${v51_ZODIAC.map((z,i)=>`<option value="${i}">${z.e} ${z.n}</option>`).join('')}</select>
  <div id="ac-result" style="margin-top:14px;"></div>`;
  document.getElementById('astrocompat-content').innerHTML = html;
  acCalc();
}
function acCalc() {
  const a = parseInt(document.getElementById('ac-1').value);
  const b = parseInt(document.getElementById('ac-2').value);
  // Compatibilité basée sur éléments : feu/terre/air/eau
  // Bélier(0), Lion(4), Sagittaire(8) = feu
  // Taureau(1), Vierge(5), Capricorne(9) = terre
  // Gémeaux(2), Balance(6), Verseau(10) = air
  // Cancer(3), Scorpion(7), Poissons(11) = eau
  const elt = i => ['feu','terre','air','eau'][i % 4];
  const e1 = elt(a), e2 = elt(b);
  let score, label, color, advice;
  if (a === b) { score = 75; label = 'Soulmates ou rivaux'; color = '#9B59B6'; advice = 'Vous vous comprenez à fond, mais attention aux mêmes défauts amplifiés.'; }
  else if (e1 === e2) { score = 90; label = 'Symbiose totale'; color = '#5DD68F'; advice = 'Vous parlez la même langue énergétique. Chemin facile.'; }
  else if ((e1 === 'feu' && e2 === 'air') || (e1 === 'air' && e2 === 'feu')) { score = 85; label = 'Passion vive'; color = '#FF6FA3'; advice = 'L\'air alimente le feu. Connexion électrique et créative.'; }
  else if ((e1 === 'terre' && e2 === 'eau') || (e1 === 'eau' && e2 === 'terre')) { score = 85; label = 'Croissance mutuelle'; color = '#5DADE2'; advice = 'L\'eau nourrit la terre. Stabilité et profondeur.'; }
  else if ((e1 === 'feu' && e2 === 'eau') || (e1 === 'eau' && e2 === 'feu')) { score = 50; label = 'Tension dynamique'; color = '#FFC542'; advice = 'L\'eau éteint le feu, le feu évapore l\'eau. Conflits possibles mais évolution réelle.'; }
  else if ((e1 === 'terre' && e2 === 'air') || (e1 === 'air' && e2 === 'terre')) { score = 50; label = 'Vibrations différentes'; color = '#FFC542'; advice = 'Vous fonctionnez sur des fréquences distinctes. Communication essentielle.'; }
  else { score = 65; label = 'Apprentissage'; color = '#5DADE2'; advice = 'Chacun a beaucoup à apprendre de l\'autre. Patience.'; }
  document.getElementById('ac-result').innerHTML = `<div style="background:${color}; color:white; padding:24px; border-radius:18px; text-align:center;">
    <div style="font-size:48px;">${v51_ZODIAC[a].e} 💞 ${v51_ZODIAC[b].e}</div>
    <div style="font-size:48px; font-weight:900; margin-top:10px;">${score}%</div>
    <div style="font-size:14px; font-weight:700; margin-top:4px;">${label}</div>
  </div>
  <div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:10px; font-size:13px; line-height:1.6;">${escapeHtml(advice)}</div>`;
}

// === 24. PHASES DE LA LUNE ===
function v51_renderMoonPhase() {
  // Approximation: lune nouvelle 6 janvier 2000, cycle 29.53 jours
  const today = new Date();
  const lp = 29.53058867;
  const newMoon = new Date('2000-01-06T18:14:00Z');
  const days = (today - newMoon) / 86400000;
  const phase = (days % lp + lp) % lp;
  const phasePct = phase / lp;
  let phaseName, emoji, illumination;
  if (phasePct < 0.0625) { phaseName = 'Nouvelle lune'; emoji = '🌑'; illumination = 0; }
  else if (phasePct < 0.1875) { phaseName = 'Premier croissant'; emoji = '🌒'; illumination = 25; }
  else if (phasePct < 0.3125) { phaseName = 'Premier quartier'; emoji = '🌓'; illumination = 50; }
  else if (phasePct < 0.4375) { phaseName = 'Lune gibbeuse croissante'; emoji = '🌔'; illumination = 75; }
  else if (phasePct < 0.5625) { phaseName = 'Pleine lune'; emoji = '🌕'; illumination = 100; }
  else if (phasePct < 0.6875) { phaseName = 'Lune gibbeuse décroissante'; emoji = '🌖'; illumination = 75; }
  else if (phasePct < 0.8125) { phaseName = 'Dernier quartier'; emoji = '🌗'; illumination = 50; }
  else if (phasePct < 0.9375) { phaseName = 'Dernier croissant'; emoji = '🌘'; illumination = 25; }
  else { phaseName = 'Nouvelle lune'; emoji = '🌑'; illumination = 0; }
  
  // Generate 14-day calendar
  let calendar = '<div style="display:grid; grid-template-columns:repeat(7,1fr); gap:4px; margin-top:14px;">';
  for (let i = 0; i < 14; i++) {
    const d = new Date(today);
    d.setDate(d.getDate() + i);
    const dys = (d - newMoon) / 86400000;
    const ph = (dys % lp + lp) % lp / lp;
    let em;
    if (ph < 0.0625) em = '🌑';
    else if (ph < 0.1875) em = '🌒';
    else if (ph < 0.3125) em = '🌓';
    else if (ph < 0.4375) em = '🌔';
    else if (ph < 0.5625) em = '🌕';
    else if (ph < 0.6875) em = '🌖';
    else if (ph < 0.8125) em = '🌗';
    else if (ph < 0.9375) em = '🌘';
    else em = '🌑';
    calendar += `<div style="background:var(--surface); padding:6px; border-radius:6px; text-align:center; ${i===0?'border:2px solid var(--primary);':''}">
      <div style="font-size:9px; color:var(--textSec);">${d.getDate()}/${d.getMonth()+1}</div>
      <div style="font-size:18px; margin-top:2px;">${em}</div>
    </div>`;
  }
  calendar += '</div>';
  
  let html = `<div style="background:linear-gradient(135deg,#000,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">${emoji}</div><div style="font-size:16px; font-weight:800;">Phases de la lune</div>
  </div>
  <div style="background:var(--surface); padding:24px; border-radius:18px; text-align:center; margin-top:14px;">
    <div style="font-size:96px;">${emoji}</div>
    <div style="font-size:18px; font-weight:900; color:var(--primary); margin-top:4px;">${phaseName}</div>
    <div style="font-size:12px; color:var(--textSec); margin-top:4px;">Illumination : ~${illumination}% · Cycle : jour ${Math.round(phase)} sur ${lp.toFixed(0)}</div>
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📅 14 prochains jours</h3>
  ${calendar}`;
  document.getElementById('moonphase-content').innerHTML = html;
}

