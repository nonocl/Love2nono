body.design-cat .home-tab.active { background: linear-gradient(135deg, #FF8C42, #C8956D) !important; color: #FFF8EC !important; border-color: #FFF8EC !important; }
body.design-cat .page > * { position: relative; z-index: 1; }
body.design-cat .label { color: #6B3410 !important; font-weight: 700 !important; }
body.design-cat .icon-btn { color: #FF8C42 !important; }
