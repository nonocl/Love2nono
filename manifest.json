  'Perso': ['ami','famille','copain','copine','crush','sentiment','mood','journal','dear diary','aujourd\'hui','émotion','triste','heureux','content','déçu','amoureux'],
  'Travail': ['boulot','job','manager','réunion','meeting','client','deadline','salaire','contrat','collègue'],
