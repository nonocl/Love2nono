// === 24. CALORIES TRACKER LIGHT ===
const FOOD_CAL = {
  'pomme':52,'banane':89,'orange':47,'fraise':32,'raisin':69,'avocat':160,
  'pain':265,'pâtes (cuites)':131,'riz (cuit)':130,'pomme de terre':77,
  'oeuf':155,'poulet':165,'boeuf':250,'saumon':208,'thon':132,
  'lait':42,'yaourt':59,'fromage':400,'beurre':717,
  'chocolat':546,'biscuit':480,'pizza':266,'frites':312,'burger':295,
  'salade verte':15,'tomate':18,'carotte':41,'brocoli':34,'haricots verts':31,
  'amandes':579,'noix':654,'cacahuètes':567,
  'soda':41,'jus orange':45,'café':2,'thé':1
};
function getCalLog() { try { return JSON.parse(localStorage.getItem('nw_callog') || '[]'); } catch { return []; } }
function saveCalLog(l) { localStorage.setItem('nw_callog', JSON.stringify(l)); }
function renderCalories() {
  const today = new Date().toISOString().slice(0, 10);
  const log = getCalLog();
  const todayLog = log.filter(l => l.date === today);
  const total = todayLog.reduce((s, l) => s + l.cal, 0);
  let html = `<div style="background:linear-gradient(135deg,#5DD68F,#FFD166); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🥗</div><div style="font-size:16px; font-weight:800;">Calories light</div>
    <div style="font-size:11px; opacity:0.9;">Aujourd'hui : ${total} kcal · ${todayLog.length} repas</div>
  </div>
  <p style="font-size:10px; color:var(--textSec); margin-top:8px; padding:8px; background:var(--surface); border-radius:8px;">⚠️ Outil informatif uniquement. Si tu as un trouble alimentaire, parles-en à un pro de santé.</p>
  <div style="background:var(--surface); padding:12px; border-radius:12px; margin-top:8px;">
    <input type="text" id="cl-food" class="input" placeholder="Aliment (ex: pomme, riz...)" autocomplete="off" oninput="clSuggest()">
    <div id="cl-suggest" style="margin-top:4px;"></div>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:6px;">
      <input type="number" id="cl-grams" class="input" placeholder="Grammes" min="1">
      <button class="btn primary" onclick="clAdd()">➕</button>
    </div>
  </div>`;
  if (todayLog.length > 0) {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">Aujourd'hui</h3>`;
    todayLog.forEach((l, i) => {
      const realIdx = log.indexOf(l);
      html += `<div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-top:5px; display:flex; justify-content:space-between;">
        <div>
          <div style="font-size:13px; font-weight:700;">${escapeHtml(l.food)}</div>
          <div style="font-size:11px; color:var(--textSec);">${l.grams}g</div>
        </div>
        <div style="display:flex; align-items:center; gap:8px;">
          <strong style="color:var(--primary);">${l.cal} kcal</strong>
          <button onclick="clDel(${realIdx})" style="background:none; border:none; color:var(--danger);">✗</button>
        </div>
      </div>`;
    });
  }
  document.getElementById('calories-content').innerHTML = html;
}
function clSuggest() {
  const q = document.getElementById('cl-food').value.toLowerCase();
  if (!q || q.length < 2) { document.getElementById('cl-suggest').innerHTML = ''; return; }
  const matches = Object.keys(FOOD_CAL).filter(k => k.includes(q)).slice(0, 5);
  document.getElementById('cl-suggest').innerHTML = matches.map(m => `<button onclick="document.getElementById('cl-food').value='${escapeJs(m)}'; document.getElementById('cl-suggest').innerHTML='';" style="background:var(--bg); border:1px solid var(--border); padding:4px 8px; border-radius:6px; margin:2px; font-size:11px;">${escapeHtml(m)} (${FOOD_CAL[m]})</button>`).join('');
}
function clAdd() {
  const food = document.getElementById('cl-food').value.trim().toLowerCase();
  const grams = parseFloat(document.getElementById('cl-grams').value);
  if (!food || isNaN(grams) || grams <= 0) return;
  const calPer100 = FOOD_CAL[food];
  if (!calPer100) { toast('Aliment inconnu - voir suggestions'); return; }
  const cal = Math.round(calPer100 * grams / 100);
  const log = getCalLog();
  log.push({ date: new Date().toISOString().slice(0,10), food, grams, cal });
  saveCalLog(log);
  document.getElementById('cl-food').value = ''; document.getElementById('cl-grams').value = '';
  document.getElementById('cl-suggest').innerHTML = '';
  renderCalories();
}
function clDel(i) { const l = getCalLog(); l.splice(i, 1); saveCalLog(l); renderCalories(); }

