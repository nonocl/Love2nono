async function addTodo() {
  const inp = document.getElementById('todo-input');
  const text = inp.value.trim();
  if (!text) return;
  const todos = JSON.parse(localStorage.getItem('nw_todos') || '[]');
  todos.push({ id: Date.now(), text, done: false });
  localStorage.setItem('nw_todos', JSON.stringify(todos));
  inp.value = '';
  renderTodoList();
}
function renderTodoList() {
  const todos = JSON.parse(localStorage.getItem('nw_todos') || '[]');
  const el = document.getElementById('todo-list');
  el.innerHTML = '';
  if (todos.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">✅</div><h3>Aucune tâche</h3><p>Ajoute ta première tâche !</p></div>`;
    return;
  }
  // Pending first
  todos.sort((a,b)=>a.done-b.done);
  for (const t of todos) {
    const item = document.createElement('div');
    item.className = 'todo-item' + (t.done?' done':'');
    item.innerHTML = `
      <button class="todo-check ${t.done?'checked':''}">${t.done?'✓':''}</button>
      <span class="todo-text">${escapeHtml(t.text)}</span>
      <button class="todo-del">×</button>
    `;
    item.querySelector('.todo-check').onclick = () => {
      t.done = !t.done;
      localStorage.setItem('nw_todos', JSON.stringify(todos));
      renderTodoList();
    };
    item.querySelector('.todo-del').onclick = () => {
      const filtered = todos.filter(x => x.id !== t.id);
      localStorage.setItem('nw_todos', JSON.stringify(filtered));
      renderTodoList();
    };
    el.appendChild(item);
  }
}
