// ============================================================
// CHIFFRES ROMAINS
// ============================================================
function arabicToRoman(n) {
  if (n < 1 || n > 3999) return '';
  const map = [[1000,'M'],[900,'CM'],[500,'D'],[400,'CD'],[100,'C'],[90,'XC'],[50,'L'],[40,'XL'],[10,'X'],[9,'IX'],[5,'V'],[4,'IV'],[1,'I']];
  let res = '';
  for (const [v, s] of map) while (n >= v) { res += s; n -= v; }
  return res;
}
function romanToArabic(s) {
  s = s.toUpperCase();
  const v = { I:1, V:5, X:10, L:50, C:100, D:500, M:1000 };
  let n = 0;
  for (let i=0; i<s.length; i++) {
    const c = v[s[i]], next = v[s[i+1]];
    if (next > c) { n += next - c; i++; } else n += c;
  }
  return n;
}
function convertRomanFromNum() {
  const n = parseInt(document.getElementById('roman-num').value);
  if (isNaN(n)) { document.getElementById('roman-rom').value = ''; return; }
  document.getElementById('roman-rom').value = arabicToRoman(n);
  document.getElementById('roman-output').innerHTML = `<div style="text-align:center; padding:14px; background:var(--surface); border-radius:14px; font-size:32px; font-weight:900; color:var(--primary);">${arabicToRoman(n)}</div>`;
}
function convertRomanFromRom() {
  const s = document.getElementById('roman-rom').value;
  if (!s) { document.getElementById('roman-num').value = ''; return; }
  const n = romanToArabic(s);
  document.getElementById('roman-num').value = n;
  document.getElementById('roman-output').innerHTML = `<div style="text-align:center; padding:14px; background:var(--surface); border-radius:14px; font-size:32px; font-weight:900; color:var(--primary);">${n}</div>`;
}

