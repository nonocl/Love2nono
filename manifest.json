function showQuickSwitcher() {
  let recent = [];
  try { recent = JSON.parse(localStorage.getItem('nw_recent') || '[]'); } catch {}
  if (!recent.length) return;
  
  if (navigator.vibrate) navigator.vibrate([10, 30, 10]);
  
  let qs = document.getElementById('quick-switcher');
  if (!qs) {
    qs = document.createElement('div');
    qs.id = 'quick-switcher';
    qs.className = 'quick-switcher';
    document.body.appendChild(qs);
  }
  
  const pages = (typeof PAGE_INDEX !== 'undefined') ? PAGE_INDEX : [];
  const items = recent.slice(0, 6).map(id => pages.find(p => p.page === id)).filter(Boolean);
  
  if (!items.length) return;
  
  qs.innerHTML = `
    <div class="quick-switcher-title">📂 Récemment visités</div>
    <div class="quick-switcher-items">
      ${items.map(it => `<div class="qs-item" onclick="qsGo('${it.page}')">
        <span class="qs-item-ico">${it.ico}</span>
        <span class="qs-item-name">${escapeHtml(it.name)}</span>
      </div>`).join('')}
    </div>
  `;
  qs.classList.add('open');
  
  // Auto-close on outside click
  setTimeout(() => {
    document.addEventListener('click', _qsCloseOnce, { once: true, capture: true });
  }, 100);
}

function qsGo(page) {
  document.getElementById('quick-switcher')?.classList.remove('open');
  goTo(page);
}

function _qsCloseOnce(e) {
  const qs = document.getElementById('quick-switcher');
  if (qs && !qs.contains(e.target)) {
    qs.classList.remove('open');
  }
}

// === CATEGORY CHIPS pour page-all ===
function renderCatChips() {
  const pageAll = document.getElementById('page-all');
  if (!pageAll) return;
  
  // Check if chips already exist
  let chipsBar = document.getElementById('cat-chips-bar');
  if (!chipsBar) {
    chipsBar = document.createElement('div');
    chipsBar.className = 'cat-chips-bar';
    chipsBar.id = 'cat-chips-bar';
    
    // Insert after searchbar-wrap
    const searchWrap = pageAll.querySelector('.searchbar-wrap');
    if (searchWrap && searchWrap.parentNode) {
      searchWrap.parentNode.insertBefore(chipsBar, searchWrap.nextSibling);
    }
  }
  
  // Count by category
  const pages = (typeof PAGE_INDEX !== 'undefined') ? PAGE_INDEX : [];
  const cats = {};
  pages.forEach(p => { cats[p.cat] = (cats[p.cat] || 0) + 1; });
  
  const catOrder = ['Scolaire', 'Maths & sciences', 'Langues', 'Culture & lettres', 'Galerie', 'Jeux', 'Créa & images', 'Musique', 'Réseaux sociaux', 'Aléatoire & fun', 'Productivité', 'Watchlists', 'Vie quotidienne', 'Lifestyle', 'Sport & santé', 'Documents', 'Outils & système'];
  const catIcons = {'Scolaire':'📚','Maths & sciences':'🧮','Langues':'🌐','Culture & lettres':'📜','Galerie':'📸','Jeux':'🎮','Créa & images':'🎨','Musique':'🎵','Réseaux sociaux':'📱','Aléatoire & fun':'🎲','Productivité':'✅','Watchlists':'📺','Vie quotidienne':'🏡','Lifestyle':'✨','Sport & santé':'💪','Documents':'📄','Outils & système':'🛠'};
  
  let html = `<button class="cat-chip active" data-cat="" onclick="filterCat('')">✨ Tout <span class="cat-chip-count">${pages.length}</span></button>`;
  catOrder.forEach(c => {
    if (!cats[c]) return;
    html += `<button class="cat-chip" data-cat="${c}" onclick="filterCat('${c.replace(/'/g, "\\'")}')">${catIcons[c]||''} ${escapeHtml(c)} <span class="cat-chip-count">${cats[c]}</span></button>`;
  });
  chipsBar.innerHTML = html;
}

function filterCat(cat) {
  // Update active chip
  document.querySelectorAll('.cat-chip').forEach(c => {
    c.classList.toggle('active', c.dataset.cat === cat);
  });
  
  // Show/hide sections
  const pageAll = document.getElementById('page-all');
  const sections = pageAll.querySelectorAll('.home-section');
  sections.forEach(s => {
    const titleEl = s.querySelector('.home-section-title');
    if (!titleEl) return;
    const title = titleEl.textContent.trim();
    if (!cat || title.includes(cat)) {
      s.style.display = '';
      // Animate appearance
      s.style.animation = 'fadeInUp 0.3s ease backwards';
    } else {
      s.style.display = 'none';
    }
  });
  
  // Scroll to top
  pageAll.scrollTop = 0;
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// === RECENTLY VIEWED BAR ON HOME ===
function renderRecentBar() {
  let recent = [];
  try { recent = JSON.parse(localStorage.getItem('nw_recent') || '[]'); } catch {}
  if (!recent.length) return;
  
  const pages = (typeof PAGE_INDEX !== 'undefined') ? PAGE_INDEX : [];
  const items = recent.slice(0, 8).map(id => pages.find(p => p.page === id)).filter(Boolean);
  
  let bar = document.getElementById('recent-bar');
  if (!bar) {
    bar = document.createElement('div');
    bar.id = 'recent-bar';
    bar.className = 'recent-bar';
    
    // Find where to insert: after dash-shortcuts in page-home
    const homeShortcuts = document.getElementById('dash-shortcuts');
    if (homeShortcuts && homeShortcuts.parentNode) {
      // Add a label
      const label = document.createElement('div');
      label.id = 'recent-bar-label';
      label.style.cssText = 'font-size:11px; color:var(--textSec); font-weight:700; padding:8px 16px 0; text-transform:uppercase; letter-spacing:1.5px;';
      label.textContent = '🕒 Récemment ouverts';
      homeShortcuts.parentNode.insertBefore(label, homeShortcuts.nextSibling);
      homeShortcuts.parentNode.insertBefore(bar, label.nextSibling);
