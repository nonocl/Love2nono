function emojiHint() {
  if (!_ep) return;
  _ep.hints = (_ep.hints || 0) + 1;
  const len = _ep.a.length;
  const reveal = Math.min(_ep.hints * 2, Math.floor(len/2));
  let hint = _ep.a.split('').map((c,i) => i < reveal ? c : (c === ' ' ? ' ' : '_')).join('');
  document.getElementById('emoji-puz-status').innerHTML = `<span style="color:var(--primary); font-family:monospace;">${hint}</span>`;
}
function emojiReveal() {
