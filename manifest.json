function renderQuickHide() {
  const active = isQuickHide();
  let html = `<div style="background:linear-gradient(135deg,#34495E,#1A1A1A); color:white; padding:18px; border-radius:18px; text-align:center;">
    <div style="font-size:48px;">👁️‍🗨️</div>
