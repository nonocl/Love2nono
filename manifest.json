// NUMERI ITALIENS
// ============================================================
const NUM_IT_BASE = ['zero','uno','due','tre','quattro','cinque','sei','sette','otto','nove','dieci','undici','dodici','tredici','quattordici','quindici','sedici','diciassette','diciotto','diciannove'];
const NUM_IT_TENS = ['', '', 'venti','trenta','quaranta','cinquanta','sessanta','settanta','ottanta','novanta'];
function numToItalian(n) {
  if (n < 0) return '';
  if (n === 0) return 'zero';
  if (n < 20) return NUM_IT_BASE[n];
  if (n < 100) {
    const t = Math.floor(n/10), u = n%10;
    let tens = NUM_IT_TENS[t];
    if (u === 0) return tens;
    if (u === 1 || u === 8) tens = tens.slice(0, -1); // venti -> vent + uno
    return tens + NUM_IT_BASE[u];
  }
  if (n < 1000) {
    const c = Math.floor(n/100), r = n%100;
    const cent = c === 1 ? 'cento' : NUM_IT_BASE[c]+'cento';
    return r === 0 ? cent : cent + numToItalian(r);
  }
  if (n < 10000) {
    const m = Math.floor(n/1000), r = n%1000;
    const mil = m === 1 ? 'mille' : NUM_IT_BASE[m]+'mila';
    return r === 0 ? mil : mil + numToItalian(r);
  }
  return '';
}
function renderNumIt() {
  const v = parseInt(document.getElementById('num-it-input').value);
  const out = document.getElementById('num-it-output');
  if (isNaN(v)) { out.innerHTML = ''; return; }
  const ita = numToItalian(v);
  out.innerHTML = `<div style="background:linear-gradient(135deg, var(--primary), var(--accent)); color:white; padding:20px; border-radius:14px; text-align:center;">
    <div style="font-size:48px; font-weight:900;">${v}</div>
    <div style="font-size:18px; margin-top:6px;">${ita}</div>
    <button class="btn alt" style="margin-top:10px; background:rgba(255,255,255,0.2); color:white;" onclick="ttsItalian('${ita}')">🔊 Écouter</button>
  </div>`;
}
function renderNumItList() {
