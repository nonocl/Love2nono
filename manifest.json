  { name: "✨ Mood du jour ?", items: ["Productif", "Chill", "Sportif", "Créatif", "Social", "Au lit", "Aventureux", "Concentré"] }
];
function getWheelPresets() {
  let p;
  try { p = JSON.parse(localStorage.getItem('nw_wheel_presets') || 'null'); } catch { p = null; }
  if (!p) { p = WHEEL_PRESETS_DEFAULT.slice(); localStorage.setItem('nw_wheel_presets', JSON.stringify(p)); }
  return p;
}
function saveWheelPresets(p) { localStorage.setItem('nw_wheel_presets', JSON.stringify(p)); }
let _wheelItems = [], _wheelSpinning = false, _wheelRotation = 0, _wheelHistory = [];
function getWheelHistory() { try { return JSON.parse(localStorage.getItem('nw_wheel_history') || '[]'); } catch { return []; } }
function saveWheelHistory(h) { localStorage.setItem('nw_wheel_history', JSON.stringify(h.slice(0, 20))); }

function renderWheel() {
  if (_wheelItems.length === 0) {
    const presets = getWheelPresets();
    _wheelItems = presets[0].items.slice();
  }
  _wheelHistory = getWheelHistory();
  
  const colors = ['#FF6FA3','#FFD166','#5DADE2','#06FFA5','#9B59B6','#FF8C42','#FFAFCC','#5DD68F','#A78BFA','#E14D6B','#7BB594','#FFC542'];
  
  let html = `<div style="background:linear-gradient(135deg,#FF6FA3,#FFD166,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🎲</div>
    <div style="font-size:16px; font-weight:800;">Roue de la chance</div>
    <div style="font-size:11px; opacity:0.9;">${_wheelItems.length} items · tap pour tourner</div>
  </div>
  
  <!-- Wheel SVG -->
  <div style="position:relative; max-width:340px; margin:24px auto 14px;">
    <!-- Pointer -->
    <div style="position:absolute; top:-8px; left:50%; transform:translateX(-50%); width:0; height:0; border-left:14px solid transparent; border-right:14px solid transparent; border-top:24px solid var(--text); z-index:5; filter:drop-shadow(0 2px 4px rgba(0,0,0,0.2));"></div>
    <svg id="wheel-svg" viewBox="-110 -110 220 220" style="width:100%; transition:transform 4s cubic-bezier(0.17, 0.67, 0.34, 1); transform:rotate(${_wheelRotation}deg); cursor:pointer;" onclick="wheelSpin()">`;
  
  const n = _wheelItems.length;
  const angle = 360 / n;
  for (let i = 0; i < n; i++) {
    const startA = i * angle - 90;
    const endA = (i + 1) * angle - 90;
    const startRad = startA * Math.PI / 180;
    const endRad = endA * Math.PI / 180;
    const x1 = 100 * Math.cos(startRad), y1 = 100 * Math.sin(startRad);
    const x2 = 100 * Math.cos(endRad), y2 = 100 * Math.sin(endRad);
    const largeArc = angle > 180 ? 1 : 0;
    const color = colors[i % colors.length];
    html += `<path d="M 0 0 L ${x1} ${y1} A 100 100 0 ${largeArc} 1 ${x2} ${y2} Z" fill="${color}" stroke="white" stroke-width="1.5"/>`;
    
    // Text
    const midA = (startA + endA) / 2;
    const midRad = midA * Math.PI / 180;
    const tx = 60 * Math.cos(midRad), ty = 60 * Math.sin(midRad);
    const item = _wheelItems[i];
    const displayText = item.length > 14 ? item.slice(0, 12) + '…' : item;
    html += `<text x="${tx}" y="${ty}" fill="white" font-size="9" font-weight="800" text-anchor="middle" dominant-baseline="middle" transform="rotate(${midA + 90} ${tx} ${ty})" style="pointer-events:none;">${escapeHtml(displayText)}</text>`;
  }
  // Center button
  html += `<circle cx="0" cy="0" r="22" fill="white" stroke="var(--primary)" stroke-width="3"/>
    <text x="0" y="0" fill="var(--primary)" font-size="20" text-anchor="middle" dominant-baseline="central" style="pointer-events:none;">🎲</text>
  </svg>
  </div>
  
  <button class="btn primary full" onclick="wheelSpin()" ${_wheelSpinning?'disabled':''} style="padding:18px; font-size:15px;">${_wheelSpinning?'⏳ La roue tourne...':'🎲 TOURNER LA ROUE'}</button>
  <div id="wheel-result" style="margin-top:14px; min-height:60px;"></div>
  
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:18px;">📋 Items actuels (${_wheelItems.length})</h3>
  <p style="font-size:10px; color:var(--textSec); margin-top:2px;">Tap pour supprimer · Min 2, max 12 items</p>`;
  
  _wheelItems.forEach((item, i) => {
    html += `<div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-top:5px; display:flex; justify-content:space-between; align-items:center;">
      <span style="font-size:13px;">${colors[i % colors.length] ? '<span style="display:inline-block; width:10px; height:10px; border-radius:50%; background:'+colors[i%colors.length]+'; margin-right:8px;"></span>' : ''}${escapeHtml(item)}</span>
      <button onclick="wheelRemoveItem(${i})" style="background:none; border:none; color:var(--danger); font-size:16px;">✗</button>
    </div>`;
  });
  
  html += `<div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:8px;">
    <button class="btn alt" onclick="wheelAddItem()">➕ Ajouter</button>
    <button class="btn alt" onclick="wheelClearAll()">🗑 Vider</button>
  </div>
  
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:18px;">⭐ Présets sauvegardés</h3>`;
  
  const presets = getWheelPresets();
  presets.forEach((p, i) => {
    html += `<div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-top:5px; display:flex; gap:8px; align-items:center;">
      <button onclick="wheelLoadPreset(${i})" style="flex:1; background:none; border:none; text-align:left; cursor:pointer;">
        <div style="font-size:13px; font-weight:700;">${escapeHtml(p.name)}</div>
        <div style="font-size:10px; color:var(--textSec);">${p.items.length} items · tap pour charger</div>
      </button>
      <button onclick="wheelDeletePreset(${i})" style="background:none; border:none; color:var(--danger); font-size:16px;">✗</button>
    </div>`;
  });
  
  html += `<button class="btn primary full" onclick="wheelSavePreset()" style="margin-top:8px;">💾 Sauver liste actuelle comme préset</button>`;
  
  if (_wheelHistory.length) {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:18px;">🕒 Historique récent</h3>`;
    _wheelHistory.slice(0, 10).forEach(h => {
      const d = new Date(h.t).toLocaleString('fr-FR', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' });
      html += `<div style="background:var(--surface); padding:8px 12px; border-radius:8px; margin-top:3px; display:flex; justify-content:space-between; font-size:12px;">
        <span>🎯 ${escapeHtml(h.r)}</span>
        <span style="color:var(--textSec); font-size:10px;">${d}</span>
      </div>`;
    });
  }
  
  document.getElementById('wheel-content').innerHTML = html;
}
function wheelSpin() {
  if (_wheelSpinning) return;
  if (_wheelItems.length < 2) { toast('Il faut min. 2 items'); return; }
  _wheelSpinning = true;
  const n = _wheelItems.length;
  const winnerIdx = Math.floor(Math.random() * n);
  const segmentAngle = 360 / n;
  const targetAngle = 360 - (winnerIdx * segmentAngle + segmentAngle / 2);
  const fullSpins = 5 + Math.floor(Math.random() * 3);
  _wheelRotation += fullSpins * 360 + (targetAngle - (_wheelRotation % 360));
  
  const svg = document.getElementById('wheel-svg');
  if (svg) svg.style.transform = `rotate(${_wheelRotation}deg)`;
  
  // Disable button
  const btn = document.querySelector('#wheel-content .btn.primary');
  if (btn) { btn.disabled = true; btn.textContent = '⏳ La roue tourne...'; }
  
  if (navigator.vibrate) navigator.vibrate([10, 50, 10, 50, 10]);
  
  setTimeout(() => {
    _wheelSpinning = false;
    const result = _wheelItems[winnerIdx];
    const safe = result.replace(/'/g, "\\'");
    document.getElementById('wheel-result').innerHTML = `<div style="background:linear-gradient(135deg,rgba(255,111,163,0.2),rgba(255,209,102,0.2)); padding:24px; border-radius:18px; text-align:center; border:3px solid var(--primary); animation:bounce-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);">
      <div style="font-size:11px; color:var(--textSec); letter-spacing:2px; text-transform:uppercase;">🎯 Résultat</div>
      <div style="font-size:24px; font-weight:900; margin-top:8px; color:var(--primary);">${escapeHtml(result)}</div>
    </div>`;
    
    if (navigator.vibrate) navigator.vibrate([20, 30, 50]);
    
    // Save to history
    _wheelHistory = getWheelHistory();
    _wheelHistory.unshift({ r: result, t: Date.now() });
    saveWheelHistory(_wheelHistory);
    
    // Update only history section without full re-render to keep wheel rotation
    setTimeout(() => renderWheel(), 1500);
  }, 4100);
}
function wheelAddItem() {
  if (_wheelItems.length >= 12) { toast('Max 12 items'); return; }
  const item = prompt('Nouvel item (max 30 caractères) :');
  if (!item || !item.trim()) return;
  _wheelItems.push(item.trim().slice(0, 30));
  renderWheel();
}
function wheelRemoveItem(i) {
  if (_wheelItems.length <= 2) { toast('Min 2 items requis'); return; }
  _wheelItems.splice(i, 1);
  renderWheel();
}
function wheelClearAll() {
  if (!confirm('Vider la roue ?')) return;
  _wheelItems = ['Item 1', 'Item 2'];
  renderWheel();
}
function wheelSavePreset() {
  const name = prompt('Nom du préset :');
  if (!name || !name.trim()) return;
  const presets = getWheelPresets();
  presets.push({ name: name.trim().slice(0, 40), items: _wheelItems.slice() });
  saveWheelPresets(presets);
  toast('💾 Préset sauvé');
  renderWheel();
}
function wheelLoadPreset(i) {
  const presets = getWheelPresets();
  if (!presets[i]) return;
  _wheelItems = presets[i].items.slice();
  toast('✓ Préset chargé');
  renderWheel();
}
function wheelDeletePreset(i) {
  if (!confirm('Supprimer ce préset ?')) return;
  const presets = getWheelPresets();
  presets.splice(i, 1);
  saveWheelPresets(presets);
  renderWheel();
}
function wheelManagePresets() {
  toast('Tap un préset pour le charger ✨', 1800);
}


