// EXPORT/IMPORT
// ============================================================
async function exportAll() {
  const stores = ['pfps','categories','albums','pfp_cats','pfp_albums','counters','countdowns','bdays','habits','habit_logs','wishes','quotes','moods','notes','palettes','tracks','playlists','playlist_tracks','watchlist','music_cats','track_cats','grades','homework','classes','decks','cards','friends','expenses','vault','videos','wallet_tx','events','game_scores','sobriety','sleep_log','weight_log','wheels'];
  const data = { version: 5 };
  for (const s of stores) {
    const items = await dbAll(s);
    // Convert blobs to dataURL for tracks (so JSON-serializable)
    if (s === 'tracks') {
      for (const t of items) {
        if (t.blob instanceof Blob) {
          t.blobData = await blobToDataURL(t.blob);
          t.blobType = t.blob.type;
          delete t.blob;
        }
      }
    }
    data[s] = items;
  }
  data.todos = JSON.parse(localStorage.getItem('nw_todos') || '[]');
  data.calc_history = state.calcHistoryList;
  data.theme = state.themeName;
  data.custom_theme = state.customTheme;
  toast('Génération sauvegarde... ⏳', 4000);
  const blob = new Blob([JSON.stringify(data)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `nonosworld_backup_${new Date().toISOString().slice(0,10)}.json`;
  document.body.appendChild(a); a.click(); a.remove();
  toast('Sauvegarde téléchargée ✨');
}

document.getElementById('import-input').addEventListener('change', async (e) => {
  const f = e.target.files?.[0]; if (!f) return;
  if (!confirm('Importer ? Tes données actuelles seront écrasées.')) { e.target.value=''; return; }
  try {
    const text = await f.text();
    const data = JSON.parse(text);
    const stores = ['pfps','categories','albums','pfp_cats','pfp_albums','counters','countdowns','bdays','habits','habit_logs','wishes','quotes','moods','notes','palettes','tracks','playlists','playlist_tracks','watchlist','music_cats','track_cats','grades','homework','classes','decks','cards','friends','expenses','vault','videos','wallet_tx','events','game_scores','sobriety','sleep_log','weight_log','wheels'];
    for (const s of stores) {
      await dbClear(s);
      for (const item of data[s] || []) {
        // Restore blobs for tracks
        if (s === 'tracks' && item.blobData) {
          const resp = await fetch(item.blobData);
          item.blob = await resp.blob();
          delete item.blobData;
          delete item.blobType;
        }
        await dbPut(s, item);
      }
    }
    if (data.todos) localStorage.setItem('nw_todos', JSON.stringify(data.todos));
    if (data.calc_history) localStorage.setItem('nw_calc_history', JSON.stringify(data.calc_history));
    if (data.theme) { state.themeName = data.theme; localStorage.setItem('nw_theme', data.theme); }
    if (data.custom_theme) { state.customTheme = data.custom_theme; localStorage.setItem('nw_custom_theme', JSON.stringify(data.custom_theme)); }
    applyTheme();
    toast('Importé ✨');
  } catch (err) { alert('Erreur : ' + err.message); }
  e.target.value = '';
});

async function resetAll() {
  if (!confirm('⚠️ Supprimer TOUTES tes données ? Cette action est irréversible.')) return;
  if (!confirm('Vraiment sûr ? Toutes les PFP, musiques, notes, paramètres seront perdus.')) return;
  const stores = ['pfps','categories','albums','pfp_cats','pfp_albums','counters','countdowns','bdays','habits','habit_logs','wishes','quotes','moods','notes','palettes','tracks','playlists','playlist_tracks','watchlist','music_cats','track_cats','grades','homework','classes','decks','cards','friends','expenses','vault','videos','wallet_tx','events','game_scores','sobriety','sleep_log','weight_log','wheels','kv'];
  for (const s of stores) await dbClear(s);
  localStorage.clear();
  state.themeName = 'nono';
  state.customTheme = null;
  state.wallpaper = null;
  // Stop player
  audioEl.pause(); audioEl.src = '';
  player.currentTrack = null; player.queue = []; player.index = -1;
  for (const url of player.blobUrls.values()) URL.revokeObjectURL(url);
  player.blobUrls.clear();
  document.getElementById('mini-player').classList.remove('show');
  document.body.classList.remove('has-miniplayer');
  applyTheme();
  applyWallpaper();
  toast('Tout réinitialisé');
  goTo('home');
}

