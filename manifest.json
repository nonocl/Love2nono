function getTapCount() { return parseInt(localStorage.getItem('nw_tap') || '0'); }
function setTapCount(v) { localStorage.setItem('nw_tap', String(Math.max(0, v))); document.getElementById('tap-count').textContent = getTapCount(); }
function doTap() { setTapCount(getTapCount() + 1); if ('vibrate' in navigator) navigator.vibrate(20); }
function tapBy(n) { setTapCount(getTapCount() + n); }
function resetTap() { if (confirm('Reset le compteur ?')) setTapCount(0); }

