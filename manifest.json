async function renderCategories() {
  const cats = await dbAll('categories');
  const links = await dbAll('pfp_cats');
  const el = document.getElementById('categories-list');
  el.innerHTML = '';
  if (cats.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">🏷️</div><h3>Aucune catégorie</h3><p>Crée des catégories pour organiser tes PFP par thème.</p></div>`;
    return;
  }
  for (const c of cats.sort((a,b)=>a.name.localeCompare(b.name))) {
    const count = links.filter(l => l.cat_id === c.id).length;
    const row = document.createElement('button');
    row.className = 'list-row';
    row.innerHTML = `
      <div style="width:14px; height:14px; border-radius:7px; background:${c.color};"></div>
      <div class="info">
        <div class="name">${c.icon ? c.icon+' ' : ''}${escapeHtml(c.name)}</div>
        <div class="sub">${count} PFP${count>1?'s':''}</div>
      </div>
