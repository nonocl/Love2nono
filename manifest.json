function renderPseudos() {
  const list = getPseudos();
  if (!list.length) {
    document.getElementById('ps-list').innerHTML = '<p style="text-align:center; color:var(--textSec); padding:30px;">Aucun pseudo. Tap + pour ajouter.</p>';
    return;
  }
  const PLAT_EMOJI = {
    discord:'🎮', insta:'📷', instagram:'📷', tiktok:'🎵', twitter:'🐦', x:'❌',
    snap:'👻', snapchat:'👻', steam:'🎮', riot:'🎮', epic:'🎮', xbox:'🎮',
    psn:'🎮', playstation:'🎮', nintendo:'🎮', switch:'🎮', pinterest:'📌',
    youtube:'📺', twitch:'💜', spotify:'🎧', github:'💻', linkedin:'💼',
    facebook:'👥', fb:'👥', telegram:'✈️', whatsapp:'💬', signal:'💬',
    reddit:'🤖', bereal:'📷'
  };
  document.getElementById('ps-list').innerHTML = list.map(p => {
    const em = PLAT_EMOJI[p.platform.toLowerCase()] || '🌐';
    return `<div style="background:var(--surface); padding:12px 14px; border-radius:12px; margin-bottom:6px; display:flex; gap:10px; align-items:center;">
      <div style="font-size:24px;">${em}</div>
      <div style="flex:1; min-width:0;">
        <div style="font-size:12px; color:var(--textSec); font-weight:700; text-transform:uppercase;">${escapeHtml(p.platform)}</div>
        <div style="font-size:14px; font-weight:700; word-break:break-all;">${escapeHtml(p.pseudo)}</div>
      </div>
      <button onclick="psCopy('${p.id}')" style="background:none; border:none; color:var(--primary); font-size:18px;" title="Copier">📋</button>
      <button onclick="psDel('${p.id}')" style="background:none; border:none; color:var(--danger); font-size:18px;">🗑</button>
    </div>`;
  }).join('');
}
function psCopy(id) {
  const p = getPseudos().find(x => x.id === id); if (!p) return;
  navigator.clipboard?.writeText(p.pseudo);
  toast('📋 Pseudo copié !');
}
function psDel(id) {
  if (!confirm('Supprimer ?')) return;
  savePseudos(getPseudos().filter(p => p.id !== id));
  renderPseudos();
}



