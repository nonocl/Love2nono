// ============================================================
// LIBS LOADING (lazy, mais cachées par service worker pour offline)
// ============================================================
const LIB_URLS = {
  pdfLib: 'https://cdn.jsdelivr.net/npm/pdf-lib@1.17.1/dist/pdf-lib.min.js',
  pdfJs: 'https://cdn.jsdelivr.net/npm/pdfjs-dist@3.11.174/build/pdf.min.js',
  pdfJsWorker: 'https://cdn.jsdelivr.net/npm/pdfjs-dist@3.11.174/build/pdf.worker.min.js',
  jsPdf: 'https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js',
  tesseract: 'https://cdn.jsdelivr.net/npm/tesseract.js@5.0.4/dist/tesseract.min.js',
};
const _libsLoaded = {};
function loadScript(url) {
  if (_libsLoaded[url]) return _libsLoaded[url];
  _libsLoaded[url] = new Promise((resolve, reject) => {
    const s = document.createElement('script');
    s.src = url;
    s.onload = resolve;
    s.onerror = () => { _libsLoaded[url] = null; reject(new Error('Échec chargement: ' + url)); };
    document.head.appendChild(s);
  });
  return _libsLoaded[url];
}
async function ensurePdfLib() { await loadScript(LIB_URLS.pdfLib); return PDFLib; }
async function ensurePdfJs() {
  await loadScript(LIB_URLS.pdfJs);
  if (window.pdfjsLib && !window.pdfjsLib.GlobalWorkerOptions.workerSrc) {
    window.pdfjsLib.GlobalWorkerOptions.workerSrc = LIB_URLS.pdfJsWorker;
  }
  return window.pdfjsLib;
}
async function ensureJsPdf() { await loadScript(LIB_URLS.jsPdf); return window.jspdf.jsPDF; }
async function ensureTesseract() { await loadScript(LIB_URLS.tesseract); return window.Tesseract; }

function setStatus(id, msg, type='info') {
  const el = document.getElementById(id); if (!el) return;
  const colors = { info:'var(--textSec)', success:'var(--success)', error:'var(--danger)', loading:'var(--primary)' };
  el.innerHTML = `<span style="color:${colors[type]||colors.info};">${msg}</span>`;
}
function dlBlob(blob, name) {
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = name;
  document.body.appendChild(a); a.click();
  setTimeout(() => { URL.revokeObjectURL(a.href); a.remove(); }, 100);
}

