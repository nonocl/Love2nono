function getCurrentIcon() {
  return localStorage.getItem('nw_app_icon') || 'default';
}

function setAppIcon(id) {
  // Sauvegarder le choix
  localStorage.setItem('nw_app_icon', id);
  applyAppIcon();
  // Si c'est un import perso, on ne fait pas de toast
  if (id !== 'custom') {
    const ic = APP_ICONS.find(i => i.id === id);
    if (ic) toast(`🎨 Icône changée : ${ic.name}`);
  }
  renderIconChooser();
}

function getIconUrl(iconDef) {
  if (!iconDef) return 'icon-180.png';
  if (iconDef.type === 'svg') {
    return 'data:image/svg+xml;utf8,' + iconDef.data;
  }
  return iconDef.data;
}

function applyAppIcon() {
  const id = getCurrentIcon();
  let url;
  if (id === 'custom') {
    url = localStorage.getItem('nw_app_icon_custom') || 'icon-180.png';
  } else {
    const ic = APP_ICONS.find(i => i.id === id) || APP_ICONS[0];
    url = getIconUrl(ic);
  }
  // Modifier favicon, apple-touch-icon
  ['icon', 'apple-touch-icon', 'shortcut icon'].forEach(rel => {
    let el = document.querySelector(`link[rel="${rel}"]`);
    if (!el) {
      el = document.createElement('link'); el.rel = rel; document.head.appendChild(el);
    }
    el.href = url;
  });
  // Modifier le logo dans la top-bar (img.app-logo si elle existe)
  const logo = document.querySelector('.app-logo');
  if (logo) logo.src = url;
}

function renderIconChooser() {
  const cont = document.getElementById('icon-list');
  if (!cont) return;
  const current = getCurrentIcon();
  cont.innerHTML = APP_ICONS.map(ic => {
    const url = getIconUrl(ic);
    const sel = current === ic.id;
    return `<button onclick="setAppIcon('${ic.id}')" style="background:${sel ? 'linear-gradient(135deg, var(--primary), var(--accent))' : 'var(--surface)'}; color:${sel ? 'white' : 'var(--text)'}; border:1px solid var(--border); border-radius:14px; padding:10px; text-align:center; cursor:pointer; display:flex; flex-direction:column; align-items:center; gap:6px;">
      <img src="${url}" style="width:64px; height:64px; border-radius:12px; object-fit:cover; box-shadow:0 2px 6px rgba(0,0,0,0.2);" alt="${escapeHtml(ic.name)}">
      <div style="font-weight:700; font-size:12px;">${escapeHtml(ic.name)}</div>
      <div style="font-size:10px; opacity:0.8;">${escapeHtml(ic.desc)}</div>
      ${sel ? '<div style="font-size:10px;">✓ Active</div>' : ''}
    </button>`;
  }).join('');
  // État custom
  const customWrap = document.getElementById('icon-custom-wrap');
  const customImg = localStorage.getItem('nw_app_icon_custom');
  if (customWrap) {
    if (customImg) {
      customWrap.innerHTML = `<div style="background:${current === 'custom' ? 'linear-gradient(135deg, var(--primary), var(--accent))' : 'var(--surface)'}; color:${current === 'custom' ? 'white' : 'var(--text)'}; border-radius:14px; padding:14px; text-align:center;">
        <img src="${customImg}" style="width:80px; height:80px; border-radius:14px; object-fit:cover; margin-bottom:8px;">
        <div style="font-weight:700; font-size:13px;">Icône personnalisée</div>
        <div style="display:flex; gap:6px; margin-top:8px; justify-content:center;">
          <button class="btn alt" onclick="setAppIcon('custom')" style="font-size:11px; padding:4px 10px;">${current === 'custom' ? '✓ Active' : 'Activer'}</button>
          <button class="btn alt" onclick="iconRemoveCustom()" style="font-size:11px; padding:4px 10px;">🗑 Supprimer</button>
        </div>
      </div>`;
    } else {
      customWrap.innerHTML = '';
    }
  }
}

function iconUploadCustom(input) {
  const f = (input.files || [])[0];
  if (!f) return;
  const r = new FileReader();
  r.onload = e => {
    // Resize to 192px square via canvas
    const img = new Image();
    img.onload = () => {
      const c = document.createElement('canvas');
      c.width = 192; c.height = 192;
      const ctx = c.getContext('2d');
      // Crop center square
      const s = Math.min(img.width, img.height);
      const sx = (img.width - s) / 2, sy = (img.height - s) / 2;
      ctx.drawImage(img, sx, sy, s, s, 0, 0, 192, 192);
      const dataUrl = c.toDataURL('image/jpeg', 0.85);
      localStorage.setItem('nw_app_icon_custom', dataUrl);
      setAppIcon('custom');
      toast('🎨 Icône personnelle appliquée !');
    };
    img.src = e.target.result;
  };
  r.readAsDataURL(f);
}

function iconRemoveCustom() {
  if (!confirm('Supprimer l\'icône perso ?')) return;
  localStorage.removeItem('nw_app_icon_custom');
  if (getCurrentIcon() === 'custom') setAppIcon('default');
  renderIconChooser();
}

async function iconFromPFPGallery() {
  // Liste les PFP existants depuis IndexedDB store 'pfps'
  let pfps = [];
  try { pfps = await dbAll('pfps'); } catch { return toast('Pas de galerie PFP trouvée'); }
  if (!pfps.length) return toast('Galerie PFP vide. Importe d\'abord des PFP.');
  const grid = document.getElementById('icon-pfp-grid');
  if (!grid) return;
  grid.innerHTML = pfps.slice(0, 60).map(p => {
    const url = p.dataUrl || (p.blob ? URL.createObjectURL(p.blob) : '');
    if (!url) return '';
    return `<div onclick="iconChoosePFP('${p.id || ''}', this)" style="cursor:pointer; aspect-ratio:1;">
      <img src="${url}" style="width:100%; height:100%; object-fit:cover; border-radius:8px; border:2px solid transparent;" data-url="${url}">
    </div>`;
  }).join('');
  document.getElementById('icon-pfp-section').style.display = '';
}

async function iconChoosePFP(id, el) {
  const img = el.querySelector('img');
  if (!img) return;
  // Resize via canvas
  const sourceImg = new Image();
  sourceImg.crossOrigin = 'anonymous';
  await new Promise((res, rej) => { sourceImg.onload = res; sourceImg.onerror = rej; sourceImg.src = img.src; });
  const c = document.createElement('canvas');
  c.width = 192; c.height = 192;
  const ctx = c.getContext('2d');
  const s = Math.min(sourceImg.width, sourceImg.height);
  const sx = (sourceImg.width - s) / 2, sy = (sourceImg.height - s) / 2;
  ctx.drawImage(sourceImg, sx, sy, s, s, 0, 0, 192, 192);
  const dataUrl = c.toDataURL('image/jpeg', 0.85);
  localStorage.setItem('nw_app_icon_custom', dataUrl);
  setAppIcon('custom');
  document.getElementById('icon-pfp-section').style.display = 'none';
  toast('🎨 PFP appliqué comme icône !');
}

function iconShowInstallHelp() {
  const m = document.getElementById('icon-help');
  if (m) m.style.display = m.style.display === 'none' ? '' : 'none';
}



