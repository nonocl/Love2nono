async function privUnlock() {
  const pin = prompt('PIN :');
  if (!pin) return;
  const h = await sha256(pin + '_nw_salt_v1');
  if (h !== localStorage.getItem('nw_pin_hash')) { toast('❌ PIN incorrect'); return; }
  _privUnlocked = true;
  renderPrivFolder();
}
function privFolderAdd() {
  if (!_privUnlocked) { toast('Déverrouille d\'abord'); return; }
  const name = prompt('Nom du dossier :');
  if (!name) return;
  const icon = prompt('Emoji (optionnel) :', '📁') || '📁';
  const folders = getPrivFolders();
  folders.unshift({ id: 'pf_'+Date.now(), name, icon, notes: [] });
  savePrivFolders(folders);
  renderPrivFolder();
}
function privFolderToggle(id) {
  const el = document.getElementById('pf-' + id);
  if (el) el.style.display = el.style.display === 'none' ? 'block' : 'none';
