function getDiet() { try { return JSON.parse(localStorage.getItem('nw_diet') || '{}'); } catch { return {}; } }
function saveDiet(d) { localStorage.setItem('nw_diet', JSON.stringify(d)); }
function getDietGoals() { try { return JSON.parse(localStorage.getItem('nw_diet_goals') || '{"kcal":2500,"prot":150,"carb":300,"fat":80}'); } catch { return {kcal:2500,prot:150,carb:300,fat:80}; } }
function saveDietGoals(d) { localStorage.setItem('nw_diet_goals', JSON.stringify(d)); }
function renderDiet() {
  const today = todayKey();
  const data = getDiet();
  const todayMeals = data[today] || [];
  const goals = getDietGoals();
  const totals = todayMeals.reduce((t, m) => ({
    kcal: t.kcal + (m.kcal || 0),
    prot: t.prot + (m.prot || 0),
    carb: t.carb + (m.carb || 0),
    fat: t.fat + (m.fat || 0)
  }), {kcal:0, prot:0, carb:0, fat:0});
  
  let html = `<div style="background:linear-gradient(135deg, #5DD68F, #06FFA5); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:11px; opacity:0.9;">Aujourd'hui</div>
    <div style="font-size:36px; font-weight:900;">${totals.kcal}<span style="font-size:14px; opacity:0.85;">/${goals.kcal} kcal</span></div>
    <div style="background:rgba(255,255,255,0.3); height:6px; border-radius:3px; margin-top:6px; overflow:hidden;">
      <div style="background:white; height:100%; width:${Math.min(100, (totals.kcal/goals.kcal)*100)}%;"></div>
    </div>
  </div>`;
  
  html += `<div style="display:grid; grid-template-columns:repeat(3,1fr); gap:6px; margin-top:8px;">`;
  [['prot','💪','#FF4757','Prot'],['carb','🌾','#FFD166','Glucides'],['fat','🥑','#5DADE2','Lipides']].forEach(([k, em, col, name]) => {
    const v = totals[k], g = goals[k];
    const pct = Math.min(100, (v/g)*100) || 0;
    html += `<div style="background:var(--surface); padding:10px; border-radius:10px; text-align:center;">
      <div style="font-size:18px;">${em}</div>
      <div style="font-size:10px; color:var(--textSec);">${name}</div>
      <div style="font-size:14px; font-weight:800; color:${col};">${v}<span style="font-size:10px; color:var(--textSec); font-weight:400;">/${g}g</span></div>
      <div style="background:var(--surfaceAlt); height:4px; border-radius:2px; margin-top:4px; overflow:hidden;"><div style="background:${col}; height:100%; width:${pct}%;"></div></div>
    </div>`;
  });
  html += `</div>`;
  
  html += `<button class="btn primary full" onclick="goTo('diet-add')" style="margin-top:14px;">+ Ajouter un repas</button>`;
  
  // Liste repas du jour
  if (todayMeals.length) {
    html += `<h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-top:18px;">🍽 Repas du jour</h3>`;
    todayMeals.forEach((m, i) => {
      html += `<div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-top:4px; display:flex; justify-content:space-between; align-items:center;">
        <div style="flex:1;">
          <div style="font-size:13px; font-weight:700;">${escapeHtml(m.name)}</div>
          <div style="font-size:10px; color:var(--textSec);">${m.kcal} kcal · P${m.prot}g · G${m.carb}g · L${m.fat}g</div>
        </div>
        <button onclick="dietDel(${i})" style="background:none; border:none; color:var(--danger); font-size:18px;">✗</button>
      </div>`;
    });
  }
  
  document.getElementById('diet-content').innerHTML = html;
}
function dietSave() {
  const meal = {
    name: document.getElementById('dt-name').value.trim(),
    kcal: parseFloat(document.getElementById('dt-kcal').value) || 0,
    prot: parseFloat(document.getElementById('dt-prot').value) || 0,
    carb: parseFloat(document.getElementById('dt-carb').value) || 0,
    fat: parseFloat(document.getElementById('dt-fat').value) || 0,
    time: Date.now()
  };
  if (!meal.name) return toast('Nom requis');
  const today = todayKey();
  const data = getDiet();
  if (!data[today]) data[today] = [];
  data[today].push(meal);
  saveDiet(data);
  toast('🍽 Ajouté');
  goTo('diet');
}
function dietDel(i) {
  const today = todayKey();
  const data = getDiet();
  if (!data[today]) return;
  data[today].splice(i, 1);
  saveDiet(data);
  renderDiet();
}
function dietPickPreset(i) {
  const p = DIET_PRESETS[i];
  document.getElementById('dt-name').value = p.name;
  document.getElementById('dt-kcal').value = p.kcal;
  document.getElementById('dt-prot').value = p.prot;
  document.getElementById('dt-carb').value = p.carb;
  document.getElementById('dt-fat').value = p.fat;
}
function renderDietPresets() {
  const grid = document.getElementById('dt-presets');
  grid.innerHTML = DIET_PRESETS.map((p, i) => `<button onclick="dietPickPreset(${i})" style="background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:8px; text-align:left; cursor:pointer;">
    <div style="font-size:12px; font-weight:700;">${escapeHtml(p.name)}</div>
    <div style="font-size:10px; color:var(--textSec);">${p.kcal} kcal · P${p.prot}g</div>
  </button>`).join('');
}
function dietSettings() {
  const goals = getDietGoals();
  const kcal = parseInt(prompt('Objectif kcal/jour :', goals.kcal));
  if (!kcal) return;
  const prot = parseInt(prompt('Objectif protéines/jour (g) :', goals.prot)) || goals.prot;
  const carb = parseInt(prompt('Objectif glucides/jour (g) :', goals.carb)) || goals.carb;
  const fat = parseInt(prompt('Objectif lipides/jour (g) :', goals.fat)) || goals.fat;
  saveDietGoals({kcal, prot, carb, fat});
  renderDiet();
}

