function toast(msg, dur=2200) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(t._t);
  t._t = setTimeout(() => t.classList.remove('show'), dur);
}

function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.modal-bg').forEach(m => {
  m.addEventListener('click', (e) => { if (e.target === m) m.classList.remove('open'); });
});

function escapeHtml(s) { return String(s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

// ============================================================
// PFP GALLERY
// ============================================================
async function renderGallery() {
  const [pfps, cats, albums] = await Promise.all([dbAll('pfps'), dbAll('categories'), dbAll('albums')]);
  // Chips
  const chipsEl = document.getElementById('gallery-chips');
  chipsEl.innerHTML = '';
  const allChip = createChip('Toutes', '✨', null, state.galleryFilter==='all', () => { state.galleryFilter='all'; renderGallery(); });
  chipsEl.appendChild(allChip);
  const favChip = createChip('Favoris', '♥', null, state.galleryFilter==='fav', () => { state.galleryFilter='fav'; renderGallery(); });
  chipsEl.appendChild(favChip);
  for (const c of cats.sort((a,b)=>a.name.localeCompare(b.name))) {
    chipsEl.appendChild(createChip(c.name, c.icon, c.color, state.galleryFilter==='cat:'+c.id, () => { state.galleryFilter='cat:'+c.id; renderGallery(); }));
  }
  // Filter
  let list = pfps.slice();
  if (state.galleryFilter === 'fav') list = list.filter(p => p.is_favorite);
  else if (state.galleryFilter && state.galleryFilter.startsWith('cat:')) {
    const catId = parseInt(state.galleryFilter.split(':')[1]);
    const links = await dbAll('pfp_cats');
    const ids = new Set(links.filter(l => l.cat_id === catId).map(l => l.pfp_id));
    list = list.filter(p => ids.has(p.id));
  }
  list.sort((a,b) => (b.added_at||'').localeCompare(a.added_at||''));
  // Render
  const grid = document.getElementById('pfp-grid-container');
  grid.innerHTML = '';
  document.getElementById('gallery-empty').style.display = list.length === 0 ? 'block' : 'none';
  for (const p of list) {
    const card = document.createElement('button');
    card.className = 'pfp-card';
    card.onclick = () => openPfpDetail(p.id);
    const img = document.createElement('img'); img.src = p.uri; img.loading='lazy';
    card.appendChild(img);
    if (p.is_favorite) {
      const b = document.createElement('div'); b.className = 'fav-badge'; b.innerHTML = '<span style="color:#FF6FA3;">♥</span>';
      card.appendChild(b);
    }
    grid.appendChild(card);
  }
}
function createChip(label, icon, color, active, onClick) {
  const b = document.createElement('button');
  b.className = 'chip' + (active ? ' active' : '');
  if (color && active) b.style.background = color, b.style.borderColor = color;
  if (color && !active) {
    const dot = document.createElement('span'); dot.className='dot'; dot.style.background=color;
    b.appendChild(dot);
  }
  if (icon) { const i=document.createElement('span'); i.textContent=icon; b.appendChild(i); }
  const l = document.createElement('span'); l.textContent=label; b.appendChild(l);
  b.onclick = onClick;
  return b;
}

document.getElementById('pfp-import').addEventListener('change', async (e) => {
  const files = Array.from(e.target.files || []);
  if (!files.length) return;
  let count = 0;
  for (const f of files) {
    try {
      const r = new FileReader();
      const dataUrl = await new Promise((res, rej) => { r.onload = ()=>res(r.result); r.onerror = ()=>rej(r.error); r.readAsDataURL(f); });
      await dbAdd('pfps', { uri: dataUrl, filename: f.name, title: null, is_favorite: 0, added_at: new Date().toISOString() });
      count++;
    } catch (err) { console.warn(err); }
  }
  e.target.value = '';
  if (count) { toast(`${count} PFP ajoutée${count>1?'s':''} ✨`); renderGallery(); }
});

async function openPfpDetail(id) {
  state.detailPfpId = id;
  const pfp = await dbGet('pfps', id);
  if (!pfp) return;
  document.getElementById('pfp-detail-img').src = pfp.uri;
  document.getElementById('pfp-detail-title').textContent = pfp.title || 'PFP';
  document.getElementById('pfp-fav-ico').textContent = pfp.is_favorite ? '♥' : '♡';
  // Cats
  const catLinks = await dbAll('pfp_cats');
  const allCats = await dbAll('categories');
  const myCats = allCats.filter(c => catLinks.some(l => l.pfp_id===id && l.cat_id===c.id));
  const catsEl = document.getElementById('pfp-detail-cats');
  catsEl.innerHTML = '';
  for (const c of myCats) {
    const b = document.createElement('span');
    b.style.cssText = `display:inline-flex; align-items:center; gap:4px; padding:5px 12px; border-radius:999px; color:white; font-size:12px; font-weight:600; background:${c.color};`;
    b.textContent = (c.icon ? c.icon+' ' : '') + c.name;
    catsEl.appendChild(b);
  }
  goTo('pfp-detail');
}

document.getElementById('pfp-act-fav').onclick = async () => {
  const pfp = await dbGet('pfps', state.detailPfpId);
