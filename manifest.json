const FIGURES_STYLE = [
  { f:'Métaphore', d:'Comparaison sans outil de comparaison ("Cet homme est un lion")', ex:'"L\'homme est un roseau pensant" (Pascal)' },
  { f:'Comparaison', d:'Rapprochement avec outil ("comme", "tel", "pareil à")', ex:'"Heureux qui, comme Ulysse..." (Du Bellay)' },
  { f:'Personnification', d:'Attribuer des traits humains à un objet/animal/abstrait', ex:'"La nuit chante" / "Le vent gémit"' },
  { f:'Allégorie', d:'Représenter une idée abstraite par image concrète', ex:'La justice = femme aux yeux bandés tenant balance' },
  { f:'Hyperbole', d:'Exagération pour amplifier', ex:'"Mourir de rire" / "Un million de fois"' },
  { f:'Litote', d:'Dire moins pour suggérer plus', ex:'"Va, je ne te hais point" (= je t\'aime, Corneille)' },
  { f:'Antithèse', d:'Opposition de deux idées dans la même phrase', ex:'"Je vis, je meurs" (Louise Labé)' },
  { f:'Oxymore', d:'Antithèse en un seul groupe ("obscure clarté")', ex:'"Cette obscure clarté" (Corneille) / "Soleil noir"' },
  { f:'Anaphore', d:'Répétition d\'un mot/groupe en début de phrases', ex:'"Moi président..." (Hollande, débat 2012)' },
  { f:'Énumération', d:'Liste d\'éléments accumulés', ex:'"Adieu veaux, vaches, cochons, couvée" (La Fontaine)' },
  { f:'Gradation', d:'Énumération qui monte ou descend en intensité', ex:'"Va, cours, vole, et nous venge" (Corneille)' },
  { f:'Chiasme', d:'Inversion en miroir : ABBA', ex:'"Il faut manger pour vivre, et non vivre pour manger"' },
  { f:'Parallélisme', d:'Structure répétée : ABAB', ex:'"Faire le mort, c\'est tuer le vif"' },
  { f:'Périphrase', d:'Tournure qui remplace un mot par plusieurs', ex:'"L\'astre du jour" = le soleil' },
  { f:'Métonymie', d:'Le contenant pour le contenu, partie pour tout...', ex:'"Boire un verre" / "Lire Hugo"' },
  { f:'Synecdoque', d:'Cas particulier de métonymie (partie/tout)', ex:'"Une voile" pour un bateau' },
  { f:'Euphémisme', d:'Atténuer une idée déplaisante', ex:'"Il nous a quittés" (= il est mort)' },
  { f:'Ironie', d:'Dire le contraire de ce qu\'on pense', ex:'"Quel beau temps !" (sous la pluie)' },
  { f:'Antiphrase', d:'Type d\'ironie : dire l\'inverse pour se moquer', ex:'"C\'est malin !" (à quelqu\'un qui a fait une bêtise)' },
  { f:'Allitération', d:'Répétition d\'une consonne', ex:'"Pour qui sont ces serpents qui sifflent sur vos têtes" (Racine)' },
  { f:'Assonance', d:'Répétition d\'une voyelle', ex:'"Tout m\'afflige et me nuit, et conspire à me nuire" (Racine)' },
  { f:'Hypallage', d:'Adjectif sur un mot au lieu d\'un autre', ex:'"Ce marchand accoudé sur son comptoir avide"' },
  { f:'Polysémie', d:'Mot à plusieurs sens, jeu sur ces sens', ex:'"Le coeur a ses raisons que la raison ne connaît point"' }
];
function renderBacFr() {
  let html = `<div style="background:linear-gradient(135deg,#FF6FA3,#9B59B6); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">📖</div><div style="font-size:16px; font-weight:800;">Bac Français : figures de style</div>
    <div style="font-size:11px; opacity:0.9;">${FIGURES_STYLE.length} figures · indispensable pour l'oral</div>
  </div>
  <button class="btn primary full" onclick="bfQuiz()" style="margin-top:14px;">🎯 Mode quiz</button>
  <button class="btn alt full" onclick="bfList()" style="margin-top:6px;">📚 Liste complète</button>
  <div id="bf-content" style="margin-top:14px;"></div>`;
  document.getElementById('bacfr-content').innerHTML = html;
  bfList();
}
function bfList() {
  let html = '';
  FIGURES_STYLE.forEach(f => {
    html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px;">
      <div style="font-size:13px; font-weight:700; color:var(--primary);">${escapeHtml(f.f)}</div>
      <div style="font-size:12px; margin-top:4px;">${escapeHtml(f.d)}</div>
      <div style="font-size:11px; color:var(--textSec); margin-top:4px; font-style:italic;">Ex : ${escapeHtml(f.ex)}</div>
    </div>`;
  });
  document.getElementById('bf-content').innerHTML = html;
}
function bfQuiz() {
  const correct = FIGURES_STYLE[Math.floor(Math.random() * FIGURES_STYLE.length)];
  const wrong = FIGURES_STYLE.filter(x => x.f !== correct.f).sort(() => Math.random() - 0.5).slice(0, 3);
  const opts = [...wrong, correct].sort(() => Math.random() - 0.5);
  let html = `<div style="background:var(--surface); padding:18px; border-radius:14px;">
    <div style="font-size:11px; color:var(--textSec); margin-bottom:6px;">Quel est le nom de cette figure ?</div>
    <div style="font-size:13px; margin-top:4px; line-height:1.5;">${escapeHtml(correct.d)}</div>
    <div style="font-size:11px; color:var(--textSec); margin-top:8px; font-style:italic;">Ex : ${escapeHtml(correct.ex)}</div>
  </div>
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:10px;">`;
  opts.forEach(o => {
    html += `<button class="btn alt" onclick="bfAnswer('${escapeJs(o.f)}','${escapeJs(correct.f)}')" style="padding:14px 4px;">${escapeHtml(o.f)}</button>`;
  });
  html += `</div>`;
  document.getElementById('bf-content').innerHTML = html;
}
function bfAnswer(picked, correct) {
  if (picked === correct) { toast('✓ Bravo !'); if (navigator.vibrate) navigator.vibrate(10); }
  else { toast('✗ C\'était : ' + correct); if (navigator.vibrate) navigator.vibrate([20,50,20]); }
  setTimeout(bfQuiz, 800);
}

