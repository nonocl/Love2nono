function renderInsta() {
  const d = window.simData.instagram;
  d.handle = document.getElementById('ig-handle').value;
  d.name = document.getElementById('ig-name').value;
  d.category = document.getElementById('ig-category').value;
  d.pronouns = document.getElementById('ig-pronouns').value;
  d.bio = document.getElementById('ig-bio').value;
  d.link = document.getElementById('ig-link').value;
  d.posts = document.getElementById('ig-posts').value;
  d.followers = document.getElementById('ig-followers').value;
  d.following = document.getElementById('ig-following').value;
  d.verified = document.getElementById('ig-verified').checked;
  d.private = document.getElementById('ig-private').checked;
  d.storyActive = document.getElementById('ig-story-active').checked;
  d.highlights = document.getElementById('ig-highlights').value;
  d.postsEmojis = document.getElementById('ig-posts-emojis').value;

  const initial = (d.handle || d.name || '?').slice(0,1).toUpperCase();

  const avatarRing = d.storyActive
    ? 'background:linear-gradient(135deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888);'
    : 'background:#262626;';

  const highlightTitles = (d.highlights || '').split(',').map(s => s.trim()).filter(Boolean);
  const highlightColors = ['#FF6FA3','#7B61FF','#5B8DEF','#FFD166','#5DD68F','#FF8C42','#C77DFF','#5DD6E5'];
  let highlightsHtml = '';
  if (highlightTitles.length > 0) {
    highlightsHtml = `<div style="display:flex; gap:14px; padding:14px 0 8px; overflow-x:auto; -webkit-overflow-scrolling:touch;">`;
    highlightTitles.forEach((t, i) => {
      const color = highlightColors[i % highlightColors.length];
      const emoji = ['🌍','🏖️','💜','🎮','📸','🍕','🇮🇹','✨'][i % 8];
      highlightsHtml += `
        <div style="text-align:center; flex-shrink:0;">
          <div style="width:62px; height:62px; border-radius:50%; border:1.5px solid #444; display:flex; align-items:center; justify-content:center; font-size:28px; background:linear-gradient(135deg,${color},${color}aa);">${emoji}</div>
          <div style="font-size:11px; margin-top:4px; max-width:62px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${escapeHtml(t.slice(0,12))}</div>
        </div>
      `;
    });
    highlightsHtml += '</div>';
  }

  const emojis = (d.postsEmojis || '').split('').filter(c => c.trim());
  let postsGridHtml = '';
  for (let i=0; i<9; i++) {
    const e = emojis[i] || '📷';
    const bg = ['#262626','#1a1a1a','#333','#222'][i % 4];
    postsGridHtml += `<div class="ig-post" style="background:${bg}; font-size:36px;">${e}</div>`;
  }

  const linkHtml = d.link ? `<div style="margin-top:6px; font-size:13px; color:#e0f1ff;">🔗 ${escapeHtml(d.link)}</div>` : '';
  const verifBadge = d.verified ? `<span style="display:inline-block; width:14px; height:14px; background:#0095f6; border-radius:50%; color:white; font-size:9px; font-weight:900; line-height:14px; text-align:center; vertical-align:middle; margin-left:4px;">✓</span>` : '';

  // Pronouns Insta : en gris à côté du nom complet comme la vraie app
  const pronounsHtml = d.pronouns ? `<span style="color:#a8a8a8; font-weight:400; margin-left:6px;">${escapeHtml(d.pronouns)}</span>` : '';

  document.getElementById('ig-preview').innerHTML = `
    <div class="ig-card">
      <div class="ig-header">
        <div class="ig-top">
          <div class="ig-username-h">${d.private ? '🔒 ' : ''}${escapeHtml(d.handle || 'username')}${verifBadge}<span style="margin-left:6px; font-size:10px;">▾</span></div>
          <div style="display:flex; gap:14px; font-size:18px;"><span>＋</span><span>☰</span></div>
        </div>
        <div class="ig-prof">
          <div class="ig-avatar" style="${avatarRing}">
            <div class="ig-avatar-inner">${d.avatar ? `<img src="${d.avatar}" alt="">` : `<div style="font-size:32px; color:white;">${escapeHtml(initial)}</div>`}</div>
          </div>
          <div class="ig-stats">
            <div style="text-align:center;"><div class="ig-stat-num">${escapeHtml(d.posts || '0')}</div><div class="ig-stat-lbl">posts</div></div>
            <div style="text-align:center;"><div class="ig-stat-num">${escapeHtml(d.followers || '0')}</div><div class="ig-stat-lbl">abonnés</div></div>
            <div style="text-align:center;"><div class="ig-stat-num">${escapeHtml(d.following || '0')}</div><div class="ig-stat-lbl">suivis</div></div>
          </div>
        </div>
        ${d.name ? `<div class="ig-name">${escapeHtml(d.name)}${pronounsHtml}</div>` : (pronounsHtml ? `<div class="ig-name">${pronounsHtml}</div>`:'')}
        ${d.category ? `<div style="font-size:13px; color:#a8a8a8; margin-top:1px;">${escapeHtml(d.category)}</div>` : ''}
        ${d.bio ? `<div class="ig-bio">${escapeHtml(d.bio)}</div>` : ''}
        ${linkHtml}
        <div class="ig-buttons">
          <div class="ig-btn ig-btn-primary">S'abonner</div>
          <div class="ig-btn">Message</div>
          <div class="ig-btn" style="flex:0.3;">＋</div>
        </div>
        ${highlightsHtml}
      </div>
      <div class="ig-tabs">
        <div class="ig-tab" style="border-bottom:1px solid white;">▦</div>
        <div class="ig-tab" style="opacity:0.6;">▷</div>
        <div class="ig-tab" style="opacity:0.6;">⬚</div>
      </div>
      <div class="ig-grid">${postsGridHtml}</div>
    </div>
  `;
}

