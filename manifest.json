async function renderStats() {
  const el = document.getElementById('stats-content');
  const [pfps, tracks, watchlist, notes, todos, decks, cards, grades, exps, friends, hw] = await Promise.all([
    dbAll('pfps'), dbAll('tracks'), dbAll('watchlist'), dbAll('notes'),
    Promise.resolve(JSON.parse(localStorage.getItem('nw_todos')||'[]')),
    dbAll('decks'), dbAll('cards'), dbAll('grades'), dbAll('expenses'),
    dbAll('friends'), dbAll('homework'),
  ]);
  const animes = watchlist.filter(w => w.type==='anime');
  const series = watchlist.filter(w => w.type==='series');
  const films = watchlist.filter(w => w.type==='film');
  const games = watchlist.filter(w => w.type==='game');
  const books = watchlist.filter(w => w.type==='book');
  function statBlock(icon, n, label, color='var(--primary)') {
    return `<div style="background:var(--surface); padding:14px; border-radius:14px; text-align:center;">
      <div style="font-size:24px;">${icon}</div>
      <div style="font-size:22px; font-weight:800; color:${color}; margin-top:4px;">${n}</div>
      <div style="font-size:11px; color:var(--textSec);">${label}</div>
    </div>`;
  }
  const totalEpsWatched = animes.concat(series, books).reduce((s,w) => s + (w.seasons||[]).reduce((s2,x)=>s2+(x.watched_eps||0), 0), 0);
  const animesDone = animes.filter(w => w.status === 'done').length;
  const seriesDone = series.filter(w => w.status === 'done').length;
  const filmsDone = films.filter(w => w.status === 'done').length;
  const gamesDone = games.filter(w => w.status === 'done').length;
  const booksDone = books.filter(w => w.status === 'done').length;
  let html = '<div style="display:grid; grid-template-columns:repeat(2,1fr); gap:8px;">';
  html += statBlock('📸', pfps.length, 'PFP');
  html += statBlock('🎵', tracks.length, 'Pistes');
  html += statBlock('📌', notes.length, 'Notes');
  html += statBlock('📊', grades.length, 'Notes scolaires');
  html += statBlock('🃏', cards.length, 'Flashcards');
  html += statBlock('👥', friends.length, 'Amis');
  html += statBlock('🌸', `${animesDone}/${animes.length}`, 'Animes terminés');
  html += statBlock('📺', `${seriesDone}/${series.length}`, 'Séries terminées');
  html += statBlock('🎬', `${filmsDone}/${films.length}`, 'Films vus');
  html += statBlock('🎮', `${gamesDone}/${games.length}`, 'Jeux finis');
  html += statBlock('📚', `${booksDone}/${books.length}`, 'Livres lus');
  html += statBlock('▶', totalEpsWatched, 'Épisodes/Chapitres vus');
  html += '</div>';
  // Pomodoro this week
  let pomoWeek = 0;
  for (let i=0; i<7; i++) {
    const d = new Date(); d.setDate(d.getDate()-i);
    pomoWeek += parseInt(localStorage.getItem('nw_pomo_today_' + d.toISOString().split('T')[0]) || '0');
  }
  html += `<div style="background:var(--surface); padding:16px; border-radius:14px; margin-top:14px; text-align:center;">
    <div style="font-size:12px; color:var(--textSec);">🍅 Pomodoro 7 derniers jours</div>
    <div style="font-size:28px; font-weight:800; color:var(--primary); margin-top:4px;">${pomoWeek} min</div>
    <div style="font-size:11px; color:var(--textSec);">${(pomoWeek/60).toFixed(1)} heures de focus</div>
  </div>`;
  // Wallet balance
  const wtxs = await dbAll('wallet_tx');
  if (wtxs.length > 0 || getWalletInit() !== 0) {
    let bal = getWalletInit();
    for (const t of wtxs) bal += t.kind === 'in' ? t.amount : -t.amount;
    html += `<div style="background:var(--surface); padding:16px; border-radius:14px; margin-top:8px; text-align:center;">
      <div style="font-size:12px; color:var(--textSec);">💵 Solde actuel</div>
      <div style="font-size:28px; font-weight:800; color:${bal<0?'var(--danger)':'var(--success)'}; margin-top:4px;">${bal.toFixed(2).replace('.',',')} €</div>
      <div style="font-size:11px; color:var(--textSec);">${wtxs.length} transaction${wtxs.length>1?'s':''}</div>
    </div>`;
  }
  // Grades avg
  if (grades.length > 0) {
    let sumPts=0, sumCoef=0;
    for (const g of grades) { sumPts += (g.value/g.max)*20*g.coef; sumCoef += g.coef; }
    html += `<div style="background:var(--surface); padding:16px; border-radius:14px; margin-top:8px; text-align:center;">
      <div style="font-size:12px; color:var(--textSec);">📊 Moyenne générale</div>
      <div style="font-size:28px; font-weight:800; color:var(--primary); margin-top:4px;">${(sumPts/sumCoef).toFixed(2)}/20</div>
    </div>`;
  }
  el.innerHTML = html;
}

// ============================================================
// PIXEL ART
// ============================================================
let _pxGrid = [];
let _pxSize = 16;
let _pxTool = 'paint';
let _pxIsDrawing = false;

function initPixelArt() {
  _pxSize = parseInt(document.getElementById('px-size').value);
  _pxGrid = Array.from({length: _pxSize*_pxSize}, () => null);
  renderPxGrid();
}

function renderPxGrid() {
  const wrap = document.getElementById('px-canvas-wrap');
  wrap.innerHTML = '';
  wrap.style.display = 'grid';
  wrap.style.gridTemplateColumns = `repeat(${_pxSize}, 1fr)`;
  wrap.style.gap = '0';
  for (let i=0; i<_pxSize*_pxSize; i++) {
    const cell = document.createElement('div');
    cell.style.cssText = `aspect-ratio:1/1; background:${_pxGrid[i] || 'transparent'}; border:0.5px solid rgba(128,128,128,0.15); cursor:crosshair;`;
    cell.dataset.i = i;
    cell.addEventListener('pointerdown', (e) => { e.preventDefault(); _pxIsDrawing = true; paintPx(i); });
    cell.addEventListener('pointerenter', () => { if (_pxIsDrawing) paintPx(i); });
    wrap.appendChild(cell);
  }
  document.addEventListener('pointerup', () => { _pxIsDrawing = false; });
  // Update tool buttons
  document.getElementById('px-tool-paint').classList.toggle('primary', _pxTool === 'paint');
  document.getElementById('px-tool-paint').classList.toggle('alt', _pxTool !== 'paint');
  document.getElementById('px-tool-erase').classList.toggle('primary', _pxTool === 'erase');
  document.getElementById('px-tool-erase').classList.toggle('alt', _pxTool !== 'erase');
}

function paintPx(i) {
  const color = _pxTool === 'erase' ? null : document.getElementById('px-color').value;
  _pxGrid[i] = color;
  const wrap = document.getElementById('px-canvas-wrap');
  wrap.children[i].style.background = color || 'transparent';
}

function setPxTool(t) { _pxTool = t; renderPxGrid(); }

function clearPixelArt() {
  if (!confirm('Effacer tout ?')) return;
  _pxGrid = Array.from({length: _pxSize*_pxSize}, () => null);
  renderPxGrid();
}

function downloadPixelArt() {
  const scale = 20;  // 20px per pixel
  const c = document.createElement('canvas');
  c.width = _pxSize * scale;
  c.height = _pxSize * scale;
  const ctx = c.getContext('2d');
  for (let i=0; i<_pxGrid.length; i++) {
    if (_pxGrid[i]) {
      const x = (i % _pxSize) * scale;
      const y = Math.floor(i / _pxSize) * scale;
      ctx.fillStyle = _pxGrid[i];
      ctx.fillRect(x, y, scale, scale);
    }
  }
  c.toBlob(blob => {
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `pixelart_${Date.now()}.png`;
    document.body.appendChild(a); a.click(); a.remove();
  }, 'image/png');
}

