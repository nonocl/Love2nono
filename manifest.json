    const safe = (rw.word + ' — ' + rw.def).replace(/'/g, "\\'");
    html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px; cursor:pointer;" onclick="copyText('${safe}', '📋')">
