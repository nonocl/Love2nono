// Mots fréquents avec correction (typos courantes FR)
const CORRECTOR_TYPOS = {
  // Très courantes
  'sa va': 'ça va', 'sa fait': 'ça fait', 'sa marche': 'ça marche', 'sa veut dire': 'ça veut dire',
  'malgrés': 'malgré', 'parmis': 'parmi', 'hormis ': 'hormis ',
  'dailleurs': "d'ailleurs", "au jourd'hui": "aujourd'hui", "aujourd hui": "aujourd'hui",
  'quelque soit': 'quel que soit', "quoi qu'il en soit": "quoi qu'il en soit",
  // Verbes courants mal écrits
  'je vais bien': 'je vais bien',
  'sa fais': 'ça fait',
  'jais': "j'ai",
  'tas ': "t'as ", 'ta vue': "tu as vu",
  // Contractions oubliées
  'je ai': "j'ai", 'tu es': 'tu es', 'que il': "qu'il", 'que elle': "qu'elle", 'que on': "qu'on",
  'de un': "d'un", 'de une': "d'une", 'de avoir': "d'avoir", 'de être': "d'être",
  'le ami': "l'ami", 'la amie': "l'amie", 'le école': "l'école",
  'que un': "qu'un", 'que une': "qu'une",
  'si il': "s'il", 'si ils': "s'ils",
  'me appelle': "m'appelle", 'te aime': "t'aime", 'se appelle': "s'appelle",
  // Anglicismes
  'je suis daccord': "je suis d'accord", 'pas daccord': "pas d'accord",
  // Anglais ↔ Français phonétique
  // Pluriels classiques
  'des chevaux': 'des chevaux', 'des cheveux': 'des cheveux',
  // Confusions très courantes
  'a coté': 'à côté', 'a coté de': 'à côté de', 'a cause': 'à cause',
  'a peu pres': 'à peu près', 'a peine': 'à peine', 'a part': 'à part',
  'a la': 'à la', "a l'": "à l'", 'a partir': 'à partir', 'a propos': 'à propos',
  'tres': 'très', 'apres': 'après', 'plutot': 'plutôt', 'meme': 'même',
  'theatre': 'théâtre', 'hopital': 'hôpital', 'hotel': 'hôtel',
  'foret': 'forêt', 'fete': 'fête', 'tete': 'tête', 'etre': 'être',
  'etais': 'étais', 'etait': 'était', 'etaient': 'étaient',
  'cetait': "c'était", "c etait": "c'était", "c est": "c'est", "cest": "c'est",
  'voila': 'voilà', 'deja': 'déjà', 'lui meme': 'lui-même', 'moi meme': 'moi-même',
  // Doubles consonnes oubliées ou en trop
  'aprend': 'apprend', 'aprends': 'apprends', 'aprendre': 'apprendre', 'aprenant': 'apprenant',
  'aprouver': 'approuver', 'aporter': 'apporter', 'apartement': 'appartement',
  'adresse mail': 'adresse mail', 'imediat': 'immédiat',
  // Faute pro super courante
  'au temps pour moi': 'au temps pour moi',
  // Anglicismes
  'definitivement': 'définitivement', 'eventuellement': 'éventuellement',
  // Faute typique italien-français
  'dificile': 'difficile', 'oficiel': 'officiel',
  // Mots avec accent oublié
  'ecole': 'école', 'electrique': 'électrique', 'eleve': 'élève', 'epee': 'épée',
  'cafe': 'café', 'eveille': 'éveillé', 'enerve': 'énervé',
  'ete': 'été', 'theatre': 'théâtre', 'television': 'télévision',
  'celebre': 'célèbre', 'present': 'présent', 'precis': 'précis',
  'frequence': 'fréquence', 'reference': 'référence', 'preference': 'préférence',
  // Pléonasmes courants à signaler
};

// Erreurs grammaticales avec règles complexes (regex)
const CORRECTOR_RULES = [
  // Espaces avant ponctuation française (! ? : ; %)
  { pat: /\s+\?(?!\?)/g, rep: ' ?', desc: "Espace insécable avant '?'", type: 'punctuation' },
  { pat: /\s+!(?!!)/g, rep: ' !', desc: "Espace insécable avant '!'", type: 'punctuation' },
  { pat: /\s+:(?!:)/g, rep: ' :', desc: "Espace insécable avant ':'", type: 'punctuation' },
  { pat: /\s+;(?!;)/g, rep: ' ;', desc: "Espace insécable avant ';'", type: 'punctuation' },
  
  // Pas d'espace avant virgule ou point
  { pat: /\s+,/g, rep: ',', desc: "Pas d'espace avant ','", type: 'punctuation' },
  { pat: /\s+\.(?!\.)/g, rep: '.', desc: "Pas d'espace avant '.'", type: 'punctuation' },
  
  // Espaces multiples → un seul
  { pat: /  +/g, rep: ' ', desc: "Espaces multiples", type: 'spacing' },
  
  // Espace après virgule, point, etc.
  { pat: /,([a-zA-ZàâäéèêëïîôöùûüÿçÀÂÄÉÈÊËÏÎÔÖÙÛÜŸÇ])/g, rep: ', $1', desc: "Espace après ','", type: 'spacing' },
  { pat: /\.([a-zA-ZàâäéèêëïîôöùûüÿçÀÂÄÉÈÊËÏÎÔÖÙÛÜŸÇ])/g, rep: '. $1', desc: "Espace après '.'", type: 'spacing' },
  
  // Doubles points sauf "..." 
  { pat: /(?<![.])\.\.(?!\.)/g, rep: '.', desc: "Doubles points", type: 'punctuation' },
  
  // Lettres répétées trop (3+) sauf cas valides
  { pat: /([a-zàâäéèêëïîôöùûüÿç])\1{2,}/gi, rep: '$1$1', desc: "Lettre répétée 3+ fois", type: 'typo' },
  
  // Mots dupliqués consécutifs (le le, de de, etc.)
  { pat: /\b(\w{2,})\s+\1\b/gi, rep: '$1', desc: "Mot dupliqué", type: 'duplicate' },
  
  // Apostrophes droites → courbes (typo)
  { pat: /'/g, rep: "'", desc: "Apostrophe typographique", type: 'typo' },
];

// Règles "à" vs "a", "ou" vs "où", "ça" vs "sa" — détection contextuelle
const CORRECTOR_HOMOPHONES = [
  // "à/a" - "a" est verbe avoir, "à" est préposition
  { pat: /\bil a (la |le |les |un |une |des |son |sa |ses |mon |ma |mes |ton |ta |tes |ce |cette |ces )/gi, ok: true },
  { pat: /\b(je|tu|on|elle|il|nous|vous|ils|elles) a /gi, sub: (m, p) => p === 'on' || p === 'il' || p === 'elle' ? m : m.replace(' a ', ' à '), desc: '"à" préposition après pronom (sauf il/elle/on)' },
  { pat: /\ba ([0-9])/g, rep: 'à $1', desc: '"à" devant chiffre' },
  { pat: /\ba (cause|côté|coté|cote|peu près|peine|part|propos|partir|priori|nouveau|gauche|droite|haute|paris|midi|table|pied|vélo|cheval)\b/gi, sub: (m) => m.replace(/^a /, 'à '), desc: '"à" dans expression' },
  
  // "ou/où" - "où" est interrogatif/lieu, "ou" est alternative
  { pat: /\b(c'est |c'est où |dis-moi |sais-tu |savez-vous |dis moi )ou\b/gi, sub: m => m.replace(/ou$/i, 'où'), desc: '"où" interrogatif' },
  
  // "ça/sa" - "ça" pronom démonstratif, "sa" possessif
  { pat: /\bsa (va|vient|fait|marche|m'énerve|m'agace|m'embête|me plaît|me plait|me dit|me convient|suffit|pourrait|peut|doit)\b/gi, sub: m => 'ç' + m.slice(1), desc: '"ça" pronom démonstratif' },
  
  // "et/est" - "est" verbe être, "et" conjonction
  { pat: /\b(il|elle|on|c) et /gi, sub: m => m.replace(/ et $/i, ' est '), desc: '"est" verbe être' },
  
  // "son/sont" - "son" possessif, "sont" verbe être
  { pat: /\b(ils|elles) son\b/gi, sub: m => m.replace(/son$/i, 'sont'), desc: '"sont" verbe être' },
  
  // "ces/ses" - difficile sans contexte sémantique, on skip
  
  // "leur/leurs" - "leurs" devant nom pluriel
  { pat: /\bleur ([a-zàâäéèêëïîôöùûüÿç]+s)\b/gi, sub: (m, w) => {
    // Only if word looks like plural (ends in s but not just verb)
    const exceptCommon = ['fils', 'temps', 'corps', 'cours', 'pays', 'mois', 'puis', 'jamais', 'parfois', 'autrefois', 'sens', 'plus', 'moins'];
    if (exceptCommon.includes(w.toLowerCase())) return m;
    return 'leurs ' + w;
  }, desc: '"leurs" devant pluriel' },
];

// Capitalisation après début et après point
function correctorCapitalize(text) {
  const fixes = [];
  // First letter of text
  if (text.length > 0 && /[a-zàâäéèêëïîôöùûüÿç]/.test(text[0])) {
    text = text[0].toUpperCase() + text.slice(1);
    fixes.push({ desc: 'Majuscule en début', type: 'capitalization' });
  }
  // After ". ", "! ", "? "
  text = text.replace(/([.!?]\s+)([a-zàâäéèêëïîôöùûüÿç])/g, (m, p, c) => {
    fixes.push({ desc: 'Majuscule après ' + p[0], type: 'capitalization' });
    return p + c.toUpperCase();
  });
  return { text, fixes };
}

let _correctorLastResult = null;

function renderCorrector() {
  let html = `<div style="background:linear-gradient(135deg,#5DD68F,#06FFA5,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
