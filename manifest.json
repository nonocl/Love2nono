let _puz = null;
async function initPuzzle() {
  const best = await getScore('puzzle');
  _puz = { tiles: [], moves:0, best:best?best.value:null };
  // Solved board: 1..15, 0 (empty)
  const arr = [...Array(15).keys()].map(i=>i+1).concat(0);
  // Shuffle (legal: do random valid moves from solved)
  for (let i=0; i<200; i++) {
    const empty = arr.indexOf(0);
    const er = Math.floor(empty/4), ec = empty%4;
    const moves = [];
    if (er > 0) moves.push((er-1)*4+ec);
    if (er < 3) moves.push((er+1)*4+ec);
    if (ec > 0) moves.push(er*4+ec-1);
    if (ec < 3) moves.push(er*4+ec+1);
    const m = moves[Math.floor(Math.random()*moves.length)];
    [arr[empty], arr[m]] = [arr[m], arr[empty]];
  }
  _puz.tiles = arr;
  document.getElementById('puz-best').textContent = _puz.best || '—';
  renderPuzzle();
}

function renderPuzzle() {
  const board = document.getElementById('puz-board');
  board.innerHTML = '';
  for (let i=0; i<16; i++) {
    const t = _puz.tiles[i];
    const cell = document.createElement('button');
    cell.style.cssText = `aspect-ratio:1; background:${t===0?'transparent':'var(--surface)'}; border-radius:6px; font-size:24px; font-weight:800; color:var(--primary); cursor:pointer; border:none;`;
    cell.textContent = t || '';
    cell.onclick = () => movePuzzle(i);
    board.appendChild(cell);
  }
  document.getElementById('puz-moves').textContent = _puz.moves;
}

function movePuzzle(i) {
  const empty = _puz.tiles.indexOf(0);
  const ir = Math.floor(i/4), ic = i%4, er = Math.floor(empty/4), ec = empty%4;
  if ((ir===er && Math.abs(ic-ec)===1) || (ic===ec && Math.abs(ir-er)===1)) {
    [_puz.tiles[i], _puz.tiles[empty]] = [_puz.tiles[empty], _puz.tiles[i]];
    _puz.moves++;
    renderPuzzle();
    // Check solved
    let solved = true;
    for (let j=0; j<15; j++) if (_puz.tiles[j] !== j+1) { solved = false; break; }
    if (solved) {
      setScore('puzzle', _puz.moves).then(isBest => {
        setTimeout(() => alert(`🎉 Résolu en ${_puz.moves} coups !${isBest?' 🏆 Nouveau record !':''}`), 200);
      });
    }
  }
}

