// === 27. LISTE DE COURSES SMART ===
const COURSES_RAYONS = {
  'Frais': ['lait','yaourt','beurre','fromage','crème','oeufs','jambon','saucisson','charcuterie','poisson','poulet','viande','tofu','jus','smoothie','salade','crudités','traiteur'],
  'Fruits/Légumes': ['pomme','poire','orange','banane','fraise','citron','raisin','avocat','tomate','salade','carotte','pomme de terre','courgette','aubergine','poivron','oignon','ail','champignon','brocoli','chou','poireau','fenouil','epinard','herbes','persil','basilic','menthe','gingembre'],
  'Sec / Conserves': ['pâtes','riz','quinoa','farine','sucre','sel','pain','biscottes','céréales','muesli','flocons','huile','vinaigre','sauce','soupe','conserve','thon','sardine','légumes secs','lentilles','pois chiches','haricots','tomates pelées','olives','câpres','moutarde','mayo','ketchup','miel','confiture','chocolat','biscuits','gâteaux','bonbons','noix','amandes','café','thé','vin','bière','soda','eau'],
  'Surgelés': ['glace','frites','pizza','légumes surgelés','poisson surgelé','viande surgelée'],
  'Hygiène': ['shampooing','gel douche','savon','dentifrice','brosse à dents','déodorant','crème','protections','rasoir','mouchoirs'],
  'Maison': ['liquide vaisselle','éponge','lessive','adoucissant','assouplissant','javel','papier toilette','sopalin','sac poubelle','serviette','serpillière','balai']
};
function v53_getCourses() { try { return JSON.parse(localStorage.getItem('nw_courses') || '[]'); } catch { return []; } }
function v53_saveCourses(c) { localStorage.setItem('nw_courses', JSON.stringify(c)); }
function classifyItem(name) {
  const lower = name.toLowerCase();
  for (const r in COURSES_RAYONS) {
    if (COURSES_RAYONS[r].some(w => lower.includes(w))) return r;
  }
  return 'Autres';
}
function renderCourses() {
  const items = v53_getCourses();
  // Group by rayon
  const grouped = {};
  items.forEach(it => {
    if (!grouped[it.rayon]) grouped[it.rayon] = [];
    grouped[it.rayon].push(it);
  });
  let html = `<div style="background:linear-gradient(135deg,#5DD68F,#FFD166); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🛒</div><div style="font-size:16px; font-weight:800;">Liste de courses</div>
    <div style="font-size:11px; opacity:0.9;">${items.length} articles · auto-classés par rayon</div>
  </div>
  <div style="background:var(--surface); padding:12px; border-radius:12px; margin-top:14px;">
    <div style="display:grid; grid-template-columns:3fr 1fr; gap:6px;">
      <input type="text" id="cs-name" class="input" placeholder="ex: lait demi-écrémé" autocomplete="off">
      <button class="btn primary" onclick="csAdd()">➕</button>
    </div>
  </div>`;
  if (items.length > 0) html += `<button class="btn alt full" onclick="csClear()" style="margin-top:6px; opacity:0.7; font-size:11px;">🗑 Tout vider</button>`;
  const order = ['Frais','Fruits/Légumes','Sec / Conserves','Surgelés','Hygiène','Maison','Autres'];
  order.forEach(r => {
    if (!grouped[r]) return;
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">${escapeHtml(r)} (${grouped[r].length})</h3>`;
    grouped[r].forEach(it => {
      const idx = items.indexOf(it);
      html += `<label style="display:flex; gap:10px; align-items:center; padding:10px 12px; background:var(--surface); border-radius:10px; margin-top:5px; cursor:pointer; ${it.done?'opacity:0.5;':''}">
        <input type="checkbox" ${it.done?'checked':''} onchange="csToggle(${idx})">
        <div style="flex:1; font-size:13px; ${it.done?'text-decoration:line-through;':''}">${escapeHtml(it.name)}</div>
        <button onclick="csDel(${idx})" style="background:none; border:none; color:var(--danger);">✗</button>
      </label>`;
    });
  });
  document.getElementById('coursesV53-content').innerHTML = html;
}
function csAdd() {
  const name = document.getElementById('cs-name').value.trim();
  if (!name) return;
  const items = v53_getCourses();
  items.push({ name: name.slice(0, 50), rayon: classifyItem(name), done: false });
  v53_saveCourses(items);
  document.getElementById('cs-name').value = '';
  renderCourses();
}
function csToggle(i) { const items = v53_getCourses(); items[i].done = !items[i].done; v53_saveCourses(items); renderCourses(); }
function csDel(i) { const items = v53_getCourses(); items.splice(i, 1); v53_saveCourses(items); renderCourses(); }
function csClear() { if (!confirm('Vider toute la liste ?')) return; v53_saveCourses([]); renderCourses(); }

// === 28. TRACKER DÉPENSES ===
function v53_getExpenses() { try { return JSON.parse(localStorage.getItem('nw_expenses') || '[]'); } catch { return []; } }
function v53_saveExpenses(e) { localStorage.setItem('nw_expenses', JSON.stringify(e)); }
function v53_renderExpenses() {
  const exps = v53_getExpenses();
  const today = new Date().toISOString().slice(0, 10);
  const monthStart = today.slice(0, 7);
  const thisMonth = exps.filter(e => e.date.startsWith(monthStart));
  const totalMonth = thisMonth.reduce((s, e) => s + e.amount, 0);
  const cats = {};
  thisMonth.forEach(e => { cats[e.cat] = (cats[e.cat] || 0) + e.amount; });
  let html = `<div style="background:linear-gradient(135deg,#E14D6B,#FFD166); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">💸</div><div style="font-size:16px; font-weight:800;">Tracker dépenses</div>
    <div style="font-size:11px; opacity:0.9;">Ce mois : ${totalMonth.toFixed(2)}€ sur ${thisMonth.length} dépenses</div>
  </div>
  <div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:14px;">
    <input type="text" id="ex-name" class="input" placeholder="Description" autocomplete="off">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:6px;">
      <input type="number" id="ex-amount" class="input" placeholder="Montant €" inputmode="decimal" step="0.01">
      <select id="ex-cat" class="input">
        <option>Bouffe</option><option>Sortie</option><option>Transport</option><option>Shopping</option><option>Loisirs</option><option>Logement</option><option>Santé</option><option>Études</option><option>Autre</option>
      </select>
    </div>
    <input type="date" id="ex-date" class="input" value="${today}" style="margin-top:6px;">
    <button class="btn primary full" onclick="exAdd()" style="margin-top:6px;">➕ Ajouter</button>
  </div>`;
  if (Object.keys(cats).length > 0) {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📊 Par catégorie ce mois</h3>`;
    const sorted = Object.entries(cats).sort((a,b) => b[1] - a[1]);
    const max = sorted[0][1];
    sorted.forEach(([c, v]) => {
      const pct = (v / totalMonth) * 100;
      html += `<div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-top:5px;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <div style="font-size:13px; font-weight:700;">${escapeHtml(c)}</div>
          <div style="font-size:13px; font-weight:900; color:var(--primary);">${v.toFixed(2)}€</div>
        </div>
        <div style="background:var(--bg); height:6px; border-radius:3px; margin-top:6px; overflow:hidden;">
          <div style="background:var(--primary); height:100%; width:${pct}%;"></div>
        </div>
        <div style="font-size:9px; color:var(--textSec); margin-top:2px;">${pct.toFixed(1)}%</div>
      </div>`;
    });
  }
  if (exps.length > 0) {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📜 Historique récent</h3>`;
    exps.slice().reverse().slice(0, 30).forEach((e, idx) => {
      const realIdx = exps.length - 1 - idx;
      html += `<div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-top:5px; display:flex; justify-content:space-between;">
        <div style="flex:1;">
          <div style="font-size:13px; font-weight:700;">${escapeHtml(e.name)}</div>
          <div style="font-size:10px; color:var(--textSec);">${e.cat} · ${new Date(e.date).toLocaleDateString('fr-FR')}</div>
        </div>
        <div style="display:flex; align-items:center; gap:8px;">
          <div style="font-weight:900; color:var(--primary);">${e.amount.toFixed(2)}€</div>
          <button onclick="exDel(${realIdx})" style="background:none; border:none; color:var(--danger);">✗</button>
        </div>
      </div>`;
    });
  }
  document.getElementById('expensesV53-content').innerHTML = html;
}
function exAdd() {
  const name = document.getElementById('ex-name').value.trim();
  const amount = parseFloat(document.getElementById('ex-amount').value);
  const cat = document.getElementById('ex-cat').value;
  const date = document.getElementById('ex-date').value;
  if (!name || isNaN(amount) || !date) { toast('Tous les champs requis'); return; }
  const exps = v53_getExpenses();
  exps.push({ name: name.slice(0, 50), amount, cat, date });
  v53_saveExpenses(exps);
  document.getElementById('ex-name').value = ''; document.getElementById('ex-amount').value = '';
  v53_renderExpenses();
}
function exDel(i) { const e = v53_getExpenses(); e.splice(i, 1); v53_saveExpenses(e); v53_renderExpenses(); }

// === 29. MARKDOWN EDITOR ===
function renderMarkdown() {
  let html = `<div style="background:linear-gradient(135deg,#787C7E,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">📝</div><div style="font-size:16px; font-weight:800;">Markdown editor</div>
    <div style="font-size:11px; opacity:0.9;">Tape, vois la preview live</div>
  </div>
  <textarea id="md-input" class="input" rows="10" placeholder="# Mon titre&#10;**gras** *italique*&#10;- liste&#10;[lien](https://...)" oninput="mdRender()" style="margin-top:14px; font-family:monospace; font-size:13px;"># Hello

**Markdown** ça déchire.

- Liste 1
- Liste 2

[Un lien](https://example.com)</textarea>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">👁 Preview</h3>
  <div id="md-preview" style="background:var(--surface); padding:14px; border-radius:12px; margin-top:6px;"></div>
  <button class="btn alt full" onclick="mdCopy()" style="margin-top:6px; font-size:11px;">📋 Copier markdown</button>`;
  document.getElementById('markdown-content').innerHTML = html;
  setTimeout(mdRender, 50);
}
function mdRender() {
  const t = document.getElementById('md-input').value;
  let h = escapeHtml(t);
  // Headers
  h = h.replace(/^### (.+)$/gm, '<h3 style="font-size:14px; font-weight:700; margin-top:10px;">$1</h3>');
  h = h.replace(/^## (.+)$/gm, '<h2 style="font-size:16px; font-weight:800; margin-top:12px;">$1</h2>');
  h = h.replace(/^# (.+)$/gm, '<h1 style="font-size:18px; font-weight:900; margin-top:14px;">$1</h1>');
  // Bold/Italic
  h = h.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  h = h.replace(/\*(.+?)\*/g, '<em>$1</em>');
  // Code inline
  h = h.replace(/`([^`]+)`/g, '<code style="background:var(--bg); padding:2px 6px; border-radius:4px; font-family:monospace; font-size:12px;">$1</code>');
  // Lists
  h = h.replace(/^- (.+)$/gm, '<li style="margin-left:20px;">$1</li>');
  // Links
  h = h.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" style="color:var(--primary);">$1</a>');
  // Line breaks
  h = h.replace(/\n\n/g, '<br><br>').replace(/\n/g, '<br>');
  document.getElementById('md-preview').innerHTML = `<div style="font-size:13px; line-height:1.6;">${h}</div>`;
}
function mdCopy() { navigator.clipboard.writeText(document.getElementById('md-input').value).then(() => toast('📋 Copié')); }

// === 30. REGEX TESTER ===
function renderRegex() {
  let html = `<div style="background:linear-gradient(135deg,#9B59B6,#FF6FA3); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">/.*/</div><div style="font-size:16px; font-weight:800;">Regex tester</div>
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">Pattern</h3>
  <div style="display:grid; grid-template-columns:3fr 1fr; gap:6px;">
    <input type="text" id="rx-pat" class="input" placeholder="\\d+" oninput="rxTest()" style="font-family:monospace;">
    <input type="text" id="rx-flags" class="input" value="g" placeholder="gimsy" oninput="rxTest()" style="font-family:monospace;">
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">Texte</h3>
  <textarea id="rx-text" class="input" rows="5" oninput="rxTest()" placeholder="Le 23 mars 2024 à 14h30..." style="font-family:monospace;">Le 23 mars 2024 à 14h30, j'ai vu 42 oiseaux et 7 chats.</textarea>
  <div id="rx-result" style="margin-top:14px;"></div>
  <details style="background:var(--surface); padding:12px; border-radius:10px; margin-top:14px;">
    <summary style="cursor:pointer; font-size:12px; font-weight:700;">📚 Cheatsheet</summary>
    <div style="font-size:11px; line-height:1.7; margin-top:8px; font-family:monospace;">
      \\d = chiffre · \\w = lettre/chiffre · \\s = espace<br>
      . = n'importe quoi · * = 0+ · + = 1+ · ? = 0 ou 1<br>
      [abc] = a, b ou c · [^a] = sauf a · [a-z] = plage<br>
      ^ = début · $ = fin · | = ou · () = groupe<br>
      Flags : g (global), i (insensitive), m (multiline)
    </div>
  </details>`;
  document.getElementById('regex-content').innerHTML = html;
  setTimeout(rxTest, 100);
}
function rxTest() {
  const pat = document.getElementById('rx-pat').value;
  const flags = document.getElementById('rx-flags').value;
  const text = document.getElementById('rx-text').value;
  if (!pat) { document.getElementById('rx-result').innerHTML = ''; return; }
  try {
    const r = new RegExp(pat, flags);
    let html = '';
    if (flags.includes('g')) {
      const matches = [...text.matchAll(r)];
      html = `<div style="background:#5DD68F; color:white; padding:10px 12px; border-radius:8px; font-size:12px;">✓ ${matches.length} match${matches.length>1?'es':''}</div>`;
      // Highlight in text
      let hl = escapeHtml(text);
      const sorted = matches.sort((a, b) => b.index - a.index);
      sorted.forEach(m => {
        const before = hl.slice(0, m.index);
        const match = hl.slice(m.index, m.index + m[0].length);
        const after = hl.slice(m.index + m[0].length);
        hl = before + `<mark style="background:#FFD166; padding:0 2px;">${match}</mark>` + after;
      });
      html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:8px; font-size:13px; font-family:monospace; white-space:pre-wrap; line-height:1.6;">${hl}</div>`;
      if (matches.length > 0) {
        html += `<h3 style="font-size:12px; font-weight:700; margin-top:10px;">Détails :</h3>`;
        matches.slice(0, 20).forEach((m, i) => {
          html += `<div style="background:var(--surface); padding:6px 10px; border-radius:6px; margin-top:4px; font-size:11px; font-family:monospace;">[${i}] "${escapeHtml(m[0])}" @ pos ${m.index}</div>`;
        });
      }
    } else {
      const m = text.match(r);
      if (m) {
        html = `<div style="background:#5DD68F; color:white; padding:10px 12px; border-radius:8px; font-size:12px;">✓ Match : "${escapeHtml(m[0])}"</div>`;
      } else {
        html = `<div style="background:#787C7E; color:white; padding:10px 12px; border-radius:8px; font-size:12px;">Aucun match</div>`;
      }
    }
    document.getElementById('rx-result').innerHTML = html;
  } catch (e) {
    document.getElementById('rx-result').innerHTML = `<div style="background:#E14D6B; color:white; padding:10px 12px; border-radius:8px; font-size:12px;">✗ ${escapeHtml(e.message)}</div>`;
  }
}

// === 31. IP / NETWORK INFO ===
function renderNetInfo() {
  let html = `<div style="background:linear-gradient(135deg,#5DADE2,#9B59B6); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🌐</div><div style="font-size:16px; font-weight:800;">Network info</div>
  </div>
  <button class="btn primary full" onclick="netFetch()" style="margin-top:14px;">🔍 Charger les infos</button>
  <div id="net-result" style="margin-top:14px;"></div>`;
  document.getElementById('netinfo-content').innerHTML = html;
  netLocal();
}
function netLocal() {
  let html = '<div style="background:var(--surface); padding:14px; border-radius:12px;">';
  html += '<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-bottom:8px;">📱 Navigateur (local)</h3>';
  html += `<div style="font-size:12px; line-height:1.7;">
    <div><strong>Plateforme :</strong> ${escapeHtml(navigator.platform || '?')}</div>
    <div><strong>Langue :</strong> ${escapeHtml(navigator.language || '?')}</div>
    <div><strong>Cookies :</strong> ${navigator.cookieEnabled ? 'activés' : 'désactivés'}</div>
    <div><strong>Online :</strong> ${navigator.onLine ? '🟢 oui' : '🔴 non'}</div>
    <div><strong>Écran :</strong> ${screen.width}×${screen.height}</div>
    <div><strong>Window :</strong> ${window.innerWidth}×${window.innerHeight}</div>
    <div><strong>Pixel ratio :</strong> ${window.devicePixelRatio}</div>
    <div><strong>RAM (estim.) :</strong> ${navigator.deviceMemory ? navigator.deviceMemory + ' Go' : 'inconnu'}</div>
    <div><strong>Cœurs CPU :</strong> ${navigator.hardwareConcurrency || 'inconnu'}</div>
  </div></div>`;
  if (navigator.connection) {
    html += `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:8px;">
      <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-bottom:8px;">📶 Connexion</h3>
      <div style="font-size:12px; line-height:1.7;">
        <div><strong>Type :</strong> ${navigator.connection.effectiveType || '?'}</div>
        <div><strong>Downlink :</strong> ${navigator.connection.downlink || '?'} Mb/s (estim.)</div>
        <div><strong>RTT :</strong> ${navigator.connection.rtt || '?'} ms</div>
      </div></div>`;
  }
  document.getElementById('net-result').innerHTML = html;
}
async function netFetch() {
  netLocal();
  const r = document.getElementById('net-result');
  r.insertAdjacentHTML('beforeend', '<div id="net-loading" style="background:var(--surface); padding:14px; border-radius:12px; margin-top:8px; text-align:center; font-size:12px;">⏳ Récupération IP publique...</div>');
  try {
    const ctrl = new AbortController(); setTimeout(() => ctrl.abort(), 8000);
    const res = await fetch('https://api.ipify.org?format=json', { signal: ctrl.signal });
    const data = await res.json();
    document.getElementById('net-loading').outerHTML = `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:8px;">
      <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-bottom:8px;">🌍 IP publique</h3>
      <div style="font-family:monospace; font-size:18px; font-weight:900;">${escapeHtml(data.ip)}</div>
    </div>`;
  } catch (e) {
    document.getElementById('net-loading').outerHTML = `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:8px; color:var(--textSec); font-size:12px; text-align:center;">⚠️ Impossible (besoin internet)</div>`;
  }
}


// SERVICE WORKER
// ============================================================
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('sw.js').then((reg) => {
      // Vérifier les updates au démarrage
      reg.update().catch(() => {});
      // Détecter une nouvelle version
      reg.addEventListener('updatefound', () => {
        const newWorker = reg.installing;
        if (newWorker) {
          newWorker.addEventListener('statechange', () => {
            if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
              console.log('Nouvelle version disponible');
            }
          });
        }
      });
    }).catch(e => console.warn('SW failed', e));
  });
}

// Reset complet du cache + reload (en cas de bug iOS)
async function resetAppCache() {
  if (!confirm('⚠️ Vider tout le cache de l\'app et recharger ?\n\nTes données (notes, devoirs, etc.) ne seront PAS perdues.')) return;
  try {
    if ('caches' in window) {
      const keys = await caches.keys();
      await Promise.all(keys.map(k => caches.delete(k)));
    }
    if ('serviceWorker' in navigator) {
      const regs = await navigator.serviceWorker.getRegistrations();
      await Promise.all(regs.map(r => r.unregister()));
    }
    toast('🧹 Cache vidé, rechargement...');
    setTimeout(() => location.reload(true), 800);
  } catch (e) {
    alert('Erreur: ' + e.message);
  }
}

