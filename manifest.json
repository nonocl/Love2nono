}

// === 10. TOUR DE HANOI ===
let _hanoiState = [], _hanoiSelected = -1, _hanoiMoves = 0, _hanoiDisks = 4, _hanoiDone = false;
function hanoiInit(n) {
  _hanoiDisks = n;
  _hanoiState = [[], [], []];
  for (let i = n; i >= 1; i--) _hanoiState[0].push(i);
  _hanoiSelected = -1;
  _hanoiMoves = 0;
  _hanoiDone = false;
}
function renderHanoi() {
  if (_hanoiState.length === 0) hanoiInit(4);
  const minMoves = Math.pow(2, _hanoiDisks) - 1;
  let html = `<div style="background:linear-gradient(135deg,#9B59B6,#FFD166); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🏰</div>
    <div style="font-size:16px; font-weight:800;">Tour de Hanoi</div>
    <div style="font-size:11px; opacity:0.9;">Coups : ${_hanoiMoves} · Min : ${minMoves}</div>
  </div>
  <div style="display:flex; gap:6px; margin-top:14px; justify-content:center;">
    ${[3,4,5,6,7].map(n => `<button class="btn ${_hanoiDisks===n?'primary':'alt'}" onclick="hanoiInit(${n}); renderHanoi();" style="padding:6px 12px; font-size:11px;">${n} disques</button>`).join('')}
  </div>
  <div style="display:flex; gap:8px; margin-top:18px; min-height:200px; align-items:flex-end;">`;
  for (let t = 0; t < 3; t++) {
    html += `<div onclick="hanoiTap(${t})" style="flex:1; min-height:200px; background:${_hanoiSelected===t?'var(--surfaceAlt)':'var(--surface)'}; border:2px solid ${_hanoiSelected===t?'var(--primary)':'var(--border)'}; border-radius:14px; padding:8px; cursor:pointer; display:flex; flex-direction:column-reverse; align-items:center; justify-content:flex-start;">`;
    _hanoiState[t].forEach((d, i) => {
      const widthPct = 30 + (d / _hanoiDisks) * 70;
      const colors = ['#FF6FA3','#FFD166','#5DADE2','#06FFA5','#9B59B6','#FF8C42','#A78BFA'];
      html += `<div style="width:${widthPct}%; height:24px; background:${colors[d % colors.length]}; border-radius:6px; margin-bottom:3px; display:flex; align-items:center; justify-content:center; color:white; font-weight:900; font-size:11px;">${d}</div>`;
    });
    html += `</div>`;
  }
  html += `</div>`;
  if (_hanoiDone) {
    html += `<div style="background:#5DD68F; color:white; padding:14px; border-radius:12px; text-align:center; margin-top:10px; font-weight:700;">🎉 Résolu en ${_hanoiMoves} coups ! ${_hanoiMoves === minMoves ? '⭐ PERFECT' : ''}</div>`;
  }
  html += `<button class="btn alt full" onclick="hanoiInit(${_hanoiDisks}); renderHanoi();" style="margin-top:10px;">🔄 Reset</button>`;
  document.getElementById('game-tower-content').innerHTML = html;
}
function hanoiTap(t) {
  if (_hanoiDone) return;
  if (_hanoiSelected === -1) {
    if (_hanoiState[t].length === 0) return;
    _hanoiSelected = t;
  } else {
    if (_hanoiSelected === t) {
      _hanoiSelected = -1;
      renderHanoi();
      return;
    }
    const fromTop = _hanoiState[_hanoiSelected][_hanoiState[_hanoiSelected].length - 1];
    const toTop = _hanoiState[t][_hanoiState[t].length - 1];
    if (toTop !== undefined && fromTop > toTop) {
      toast('⛔ Plus gros sur plus petit interdit');
      _hanoiSelected = -1;
      renderHanoi();
      return;
    }
    _hanoiState[t].push(_hanoiState[_hanoiSelected].pop());
    _hanoiSelected = -1;
    _hanoiMoves++;
    if (_hanoiState[2].length === _hanoiDisks) {
      _hanoiDone = true;
    }
  }
  renderHanoi();
}



// === 11. PIERRE-FEUILLE-CISEAUX ===
const RPS_OPTIONS = [{ n: 'Pierre', e: '✊' }, { n: 'Feuille', e: '✋' }, { n: 'Ciseaux', e: '✌️' }];
let _rpsLast = null;
function getRPSStats() {
  let s; try { s = JSON.parse(localStorage.getItem('nw_rps') || '{"win":0,"lose":0,"draw":0}'); } catch { s = {win:0,lose:0,draw:0}; }
  return s;
}
function renderRPS() {
  const s = getRPSStats();
  let html = `<div style="background:linear-gradient(135deg,#FF6FA3,#9B59B6); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">✊✋✌️</div>
    <div style="font-size:16px; font-weight:800;">Pierre-Feuille-Ciseaux</div>
    <div style="font-size:11px; opacity:0.9;">🏆 ${s.win} · 💔 ${s.lose} · 🤝 ${s.draw}</div>
  </div>`;
  if (_rpsLast) {
    const r = _rpsLast.result;
    const color = r === 'win' ? '#5DD68F' : r === 'lose' ? '#E14D6B' : '#FFC542';
    html += `<div style="background:${color}; color:white; padding:18px; border-radius:14px; text-align:center; margin-top:14px;">
      <div style="display:flex; gap:20px; justify-content:center; align-items:center; font-size:48px;">
        <div>${RPS_OPTIONS[_rpsLast.player].e}</div>
        <div style="font-size:18px;">VS</div>
        <div>${RPS_OPTIONS[_rpsLast.cpu].e}</div>
      </div>
      <div style="font-size:18px; font-weight:900; margin-top:8px;">${r === 'win' ? '🎉 Tu gagnes !' : r === 'lose' ? '💔 Tu perds' : '🤝 Égalité'}</div>
    </div>`;
  }
  html += `<div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; margin-top:18px;">`;
  RPS_OPTIONS.forEach((o, i) => {
    html += `<button onclick="rpsPlay(${i})" style="background:var(--surface); border:2px solid var(--border); padding:24px 8px; border-radius:18px; font-size:48px; cursor:pointer; transition:all 0.2s;">${o.e}<div style="font-size:11px; font-weight:700; color:var(--text); margin-top:4px;">${o.n}</div></button>`;
  });
  html += `</div>
  <button class="btn alt full" onclick="localStorage.removeItem('nw_rps'); _rpsLast=null; renderRPS();" style="margin-top:14px; opacity:0.6; font-size:11px;">🔄 Reset stats</button>`;
  document.getElementById('game-rps-content').innerHTML = html;
}
function rpsPlay(player) {
  const cpu = Math.floor(Math.random() * 3);
  let result;
  if (player === cpu) result = 'draw';
  else if ((player === 0 && cpu === 2) || (player === 1 && cpu === 0) || (player === 2 && cpu === 1)) result = 'win';
  else result = 'lose';
  _rpsLast = { player, cpu, result };
  const s = getRPSStats();
  s[result]++;
  localStorage.setItem('nw_rps', JSON.stringify(s));
  if (navigator.vibrate) navigator.vibrate(15);
  renderRPS();
}

