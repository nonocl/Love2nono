    r.items.forEach((it, i) => {
      const itemId = k + '_' + i;
      const checked = todayDone.includes(itemId);
      html += `<div onclick="groomingToggle('${itemId}')" style="background:var(--surface); padding:12px 14px; border-radius:12px; margin-top:6px; display:flex; gap:10px; align-items:center; cursor:pointer; ${checked ? 'opacity:0.5;' : ''}">
