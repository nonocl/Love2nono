function applyAppearance() {
  const a = getAppearance();
  const body = document.body;
  // Clean previous classes
  for (const o of LAYOUT_OPTIONS) if (o.id) body.classList.remove(o.id);
  for (const o of SECTION_STYLES) if (o.id) body.classList.remove(o.id);
  for (const o of GLOBAL_PRESETS) if (o.id) body.classList.remove(o.id);
  for (const o of FULL_DESIGNS) if (o.id) body.classList.remove(o.id);
