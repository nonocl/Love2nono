// === Section repli ===
function toggleSec(headerEl) {
  const sec = headerEl.parentElement;
  sec.classList.toggle('collapsed');
  // Save state
  const title = headerEl.querySelector('.title-txt').textContent;
  const collapsed = JSON.parse(localStorage.getItem('nw_secCollapsed') || '{}');
  collapsed[title] = sec.classList.contains('collapsed');
  localStorage.setItem('nw_secCollapsed', JSON.stringify(collapsed));
}

// Restaurer état sections au chargement
function restoreSections() {
  const collapsed = JSON.parse(localStorage.getItem('nw_secCollapsed') || '{}');
  document.querySelectorAll('.home-section').forEach(sec => {
    const title = sec.querySelector('.title-txt')?.textContent;
    if (title && collapsed[title]) sec.classList.add('collapsed');
  });
}

