function calcSplitBill() {
  const total = parseFloat(document.getElementById('sb-total').value) || 0;
  const ppl = parseInt(document.getElementById('sb-people').value) || 1;
  const tipPct = parseInt(document.getElementById('sb-tip').value) || 0;
  document.getElementById('sb-tip-label').textContent = tipPct + '%';
  const tip = total * tipPct / 100;
  const grand = total + tip;
  const each = grand / ppl;
  document.getElementById('sb-output').innerHTML = `
    <div style="background:linear-gradient(135deg, var(--primary), var(--accent)); color:white; padding:20px; border-radius:14px; text-align:center;">
      <div style="font-size:11px; opacity:0.85;">Chacun paie</div>
      <div style="font-size:48px; font-weight:900; margin:8px 0;">${each.toFixed(2)} €</div>
      <div style="font-size:13px; opacity:0.85;">Total : ${grand.toFixed(2)} € (dont ${tip.toFixed(2)} € de pourboire)</div>
    </div>
  `;
}
function setTipPct(p) {
  document.getElementById('tc-pct').value = p;
  calcTip();
}
function calcTip() {
  const total = parseFloat(document.getElementById('tc-total').value) || 0;
  const pct = parseFloat(document.getElementById('tc-pct').value) || 0;
  const tip = total * pct / 100;
  const grand = total + tip;
  document.getElementById('tc-output').innerHTML = `
    <div style="background:var(--surface); padding:18px; border-radius:14px;">
      <div style="display:flex; justify-content:space-between; margin-bottom:6px;"><span>Pourboire</span><strong style="color:var(--primary);">${tip.toFixed(2)} €</strong></div>
      <div style="display:flex; justify-content:space-between; padding-top:8px; border-top:1px solid var(--border); font-size:18px;"><strong>Total à payer</strong><strong style="color:var(--primary);">${grand.toFixed(2)} €</strong></div>
    </div>
  `;
}

// ============================================================
// RESPIRATION
// ============================================================
let _br = { running:false, pattern:[4,4,4,4], phase:0, t:0, timer:null };
function changeBrPattern() {
  const v = document.getElementById('br-pattern').value;
  if (v === '4-4-4-4') _br.pattern = [4,4,4,4];
  else if (v === '4-7-8') _br.pattern = [4,7,8,0];
  else if (v === '3-3-6') _br.pattern = [3,3,6,0];
  else if (v === '5-5') _br.pattern = [5,0,5,0];
}
function toggleBreathing() {
  _br.running = !_br.running;
  const btn = document.getElementById('br-toggle');
  if (_br.running) {
    btn.textContent = '■ Arrêter';
    _br.phase = 0; _br.t = 0; brTick();
  } else {
    btn.textContent = '▶ Démarrer';
    if (_br.timer) clearTimeout(_br.timer);
    document.getElementById('br-counter').textContent = '—';
    document.getElementById('br-circle').textContent = '—';
    document.getElementById('br-circle').style.transform = 'scale(0.6)';
  }
}
function brTick() {
  if (!_br.running) return;
  const dur = _br.pattern[_br.phase];
  if (dur === 0) { _br.phase = (_br.phase + 1) % 4; brTick(); return; }
  if (_br.t === 0) {
    const labels = ['Inspire', 'Retiens', 'Expire', 'Pause'];
    document.getElementById('br-circle').textContent = labels[_br.phase];
    const scale = _br.phase === 0 ? 1 : _br.phase === 1 ? 1 : _br.phase === 2 ? 0.6 : 0.6;
    document.getElementById('br-circle').style.transitionDuration = dur + 's';
    document.getElementById('br-circle').style.transform = `scale(${scale})`;
  }
  document.getElementById('br-counter').textContent = dur - _br.t;
  _br.t++;
  if (_br.t > dur) { _br.phase = (_br.phase + 1) % 4; _br.t = 0; }
  _br.timer = setTimeout(brTick, 1000);
}

// ============================================================
// MÉDITATION
// ============================================================
let _med = { running:false, dur:300, t:0, timer:null };
const MED_MSGS = [
  'Respire profondément. Ferme les yeux.',
  'Sens ton corps se détendre.',
  'Laisse les pensées passer comme des nuages.',
  'Concentre-toi sur ta respiration.',
  'Tu es ici, maintenant.',
  'Inspire la paix, expire la tension.',
  'Chaque souffle te ramène au présent.',
  'Tu n\'as rien à faire, juste être.',
];
function setMedDur(s) {
  _med.dur = s; _med.t = 0;
  document.getElementById('med-time').textContent = formatMed(s);
}
function formatMed(s) {
  const m = Math.floor(s/60), sec = s%60;
  return `${m}:${String(sec).padStart(2,'0')}`;
}
function toggleMed() {
  _med.running = !_med.running;
  const btn = document.getElementById('med-toggle');
  if (_med.running) {
    btn.textContent = '■ Arrêter';
    medTick();
  } else {
    btn.textContent = '▶ Démarrer';
    if (_med.timer) clearTimeout(_med.timer);
  }
}
function medTick() {
  if (!_med.running) return;
  const remaining = _med.dur - _med.t;
  if (remaining <= 0) {
    _med.running = false;
    document.getElementById('med-toggle').textContent = '▶ Démarrer';
    document.getElementById('med-msg').textContent = '🙏 Bravo. Prends un instant avant de revenir.';
    if (typeof navigator.vibrate === 'function') navigator.vibrate([200,100,200,100,400]);
    return;
  }
  document.getElementById('med-time').textContent = formatMed(remaining);
  if (_med.t % 30 === 0) {
    document.getElementById('med-msg').textContent = MED_MSGS[Math.floor(Math.random()*MED_MSGS.length)];
  }
  _med.t++;
  _med.timer = setTimeout(medTick, 1000);
}

// ============================================================
// JEU ÉCHECS (vs IA simple)
// ============================================================
const PIECES = { K:'♔', Q:'♕', R:'♖', B:'♗', N:'♘', P:'♙', k:'♚', q:'♛', r:'♜', b:'♝', n:'♞', p:'♟' };
const PIECE_VAL = { p:1, n:3, b:3, r:5, q:9, k:1000 };
let _chess = null;
function newChess() {
  _chess = {
    board: [
      ['r','n','b','q','k','b','n','r'],
      ['p','p','p','p','p','p','p','p'],
      [null,null,null,null,null,null,null,null],
      [null,null,null,null,null,null,null,null],
      [null,null,null,null,null,null,null,null],
      [null,null,null,null,null,null,null,null],
      ['P','P','P','P','P','P','P','P'],
      ['R','N','B','Q','K','B','N','R'],
    ],
    turn: 'w',
    selected: null,
    moves: [],
  };
  drawChess();
  document.getElementById('chess-status').textContent = 'Trait aux blancs';
}
function isWhite(p) { return p && p === p.toUpperCase(); }
function chessLegalMoves(board, r, c) {
  const piece = board[r][c]; if (!piece) return [];
  const isW = isWhite(piece);
  const t = piece.toLowerCase();
  const moves = [];
  const inB = (r,c) => r>=0 && r<8 && c>=0 && c<8;
  const tryAdd = (nr, nc) => {
    if (!inB(nr,nc)) return false;
    const target = board[nr][nc];
    if (!target) { moves.push([nr,nc]); return true; }
    if (isWhite(target) !== isW) { moves.push([nr,nc]); return false; }
    return false;
  };
  if (t === 'p') {
    const dir = isW ? -1 : 1;
    if (inB(r+dir, c) && !board[r+dir][c]) {
      moves.push([r+dir, c]);
      const startRow = isW ? 6 : 1;
      if (r === startRow && !board[r+2*dir][c]) moves.push([r+2*dir, c]);
    }
    for (const dc of [-1, 1]) {
      if (inB(r+dir, c+dc) && board[r+dir][c+dc] && isWhite(board[r+dir][c+dc]) !== isW) moves.push([r+dir, c+dc]);
    }
  } else if (t === 'n') {
    for (const [dr,dc] of [[-2,-1],[-2,1],[-1,-2],[-1,2],[1,-2],[1,2],[2,-1],[2,1]]) tryAdd(r+dr, c+dc);
  } else if (t === 'k') {
    for (const dr of [-1,0,1]) for (const dc of [-1,0,1]) if (dr||dc) tryAdd(r+dr, c+dc);
  } else {
    const dirs = [];
    if (t === 'r' || t === 'q') dirs.push([-1,0],[1,0],[0,-1],[0,1]);
    if (t === 'b' || t === 'q') dirs.push([-1,-1],[-1,1],[1,-1],[1,1]);
    for (const [dr,dc] of dirs) {
      let nr = r+dr, nc = c+dc;
      while (inB(nr,nc)) { if (!tryAdd(nr,nc)) break; if (board[nr][nc]) break; nr += dr; nc += dc; }
    }
  }
  return moves;
}
function drawChess() {
  const b = document.getElementById('chess-board');
  b.innerHTML = '';
  for (let r=0; r<8; r++) {
    for (let c=0; c<8; c++) {
      const cell = document.createElement('div');
      const dark = (r+c)%2 === 1;
      cell.style.cssText = `width:36px; height:36px; display:flex; align-items:center; justify-content:center; font-size:24px; cursor:pointer; background:${dark ? '#769656' : '#eeeed2'};`;
      const sel = _chess.selected;
      if (sel && sel[0] === r && sel[1] === c) cell.style.background = '#f7f769';
      if (_chess.moves.find(m => m[0]===r && m[1]===c)) cell.style.background = dark ? '#aacc70' : '#cdd26a';
      const piece = _chess.board[r][c];
      if (piece) cell.textContent = PIECES[piece];
      cell.onclick = () => chessClick(r, c);
      b.appendChild(cell);
    }
  }
}
function chessClick(r, c) {
  if (_chess.turn !== 'w') return;
  const piece = _chess.board[r][c];
  if (_chess.selected) {
    const move = _chess.moves.find(m => m[0]===r && m[1]===c);
    if (move) {
      doChessMove(_chess.selected[0], _chess.selected[1], r, c);
      _chess.selected = null; _chess.moves = [];
      drawChess();
      if (!chessKingExists('b')) { document.getElementById('chess-status').textContent = '🎉 Tu as gagné !'; return; }
      _chess.turn = 'b';
      document.getElementById('chess-status').textContent = 'IA réfléchit...';
      setTimeout(chessAI, 600);
      return;
    }
    if (piece && isWhite(piece)) {
      _chess.selected = [r,c]; _chess.moves = chessLegalMoves(_chess.board, r, c);
      drawChess(); return;
    }
    _chess.selected = null; _chess.moves = []; drawChess();
  } else if (piece && isWhite(piece)) {
    _chess.selected = [r,c]; _chess.moves = chessLegalMoves(_chess.board, r, c);
    drawChess();
  }
}
function doChessMove(r1,c1,r2,c2) {
  const piece = _chess.board[r1][c1];
  _chess.board[r2][c2] = piece;
  _chess.board[r1][c1] = null;
  // Promotion auto en dame
  if (piece === 'P' && r2 === 0) _chess.board[r2][c2] = 'Q';
  if (piece === 'p' && r2 === 7) _chess.board[r2][c2] = 'q';
}
function chessKingExists(color) {
  for (const row of _chess.board) for (const p of row) if (p && p.toLowerCase() === 'k' && (color === 'w' ? isWhite(p) : !isWhite(p))) return true;
  return false;
}
function chessEval(board) {
  let s = 0;
  for (const row of board) for (const p of row) if (p) {
    const v = PIECE_VAL[p.toLowerCase()];
    s += isWhite(p) ? -v : v;
  }
  return s;
}
function chessAI() {
  // Pick best capture or random for black
  const allMoves = [];
  for (let r=0; r<8; r++) for (let c=0; c<8; c++) {
    const p = _chess.board[r][c];
    if (p && !isWhite(p)) {
      const ms = chessLegalMoves(_chess.board, r, c);
      for (const m of ms) allMoves.push([r,c,m[0],m[1]]);
    }
  }
  if (!allMoves.length) { document.getElementById('chess-status').textContent = '🎉 Pat ! IA bloquée.'; return; }
  // Greedy : choose move maximizing material gain
  let best = -Infinity, bestM = null;
  for (const mv of allMoves) {
    const captured = _chess.board[mv[2]][mv[3]];
    const gain = captured ? PIECE_VAL[captured.toLowerCase()] : 0;
    const score = gain * 10 + Math.random();
    if (score > best) { best = score; bestM = mv; }
  }
  doChessMove(bestM[0], bestM[1], bestM[2], bestM[3]);
  drawChess();
  if (!chessKingExists('w')) { document.getElementById('chess-status').textContent = '😔 IA a gagné.'; return; }
  _chess.turn = 'w';
  document.getElementById('chess-status').textContent = 'Trait aux blancs';
}

// ============================================================
// FLAPPY BIRD
// ============================================================
let _flap = null;
function newFlappy() {
  const c = document.getElementById('flap-canvas');
  if (_flap && _flap.timer) clearInterval(_flap.timer);
  _flap = { c, ctx:c.getContext('2d'), bird:{ x:60, y:200, vy:0 }, pipes:[], score:0, dead:false, timer:null };
  c.onclick = () => { if (_flap.dead) newFlappy(); else _flap.bird.vy = -6; };
  c.ontouchstart = e => { e.preventDefault(); if (_flap.dead) newFlappy(); else _flap.bird.vy = -6; };
  _flap.timer = setInterval(flapTick, 30);
}
function flapTick() {
  if (!_flap || _flap.dead) return;
  const { c, ctx, bird } = _flap;
  bird.vy += 0.4; bird.y += bird.vy;
  if (Math.random() < 0.025) {
    const gap = 130, top = 50 + Math.random()*(c.height - 200);
    _flap.pipes.push({ x:c.width, top, gap });
  }
  for (const p of _flap.pipes) p.x -= 2;
  _flap.pipes = _flap.pipes.filter(p => p.x > -50);
  // Collision
  if (bird.y < 0 || bird.y > c.height) _flap.dead = true;
  for (const p of _flap.pipes) {
    if (bird.x > p.x && bird.x < p.x+40 && (bird.y < p.top || bird.y > p.top + p.gap)) _flap.dead = true;
    if (!p.passed && p.x + 40 < bird.x) { p.passed = true; _flap.score++; document.getElementById('flap-score').textContent = _flap.score; }
  }
  // Draw
  ctx.fillStyle = '#87CEEB'; ctx.fillRect(0,0,c.width,c.height);
  ctx.fillStyle = '#228B22';
  for (const p of _flap.pipes) {
    ctx.fillRect(p.x, 0, 40, p.top);
    ctx.fillRect(p.x, p.top+p.gap, 40, c.height - p.top - p.gap);
  }
  ctx.font = '24px sans-serif'; ctx.fillText('🐦', bird.x-12, bird.y+8);
  if (_flap.dead) {
    ctx.fillStyle = 'rgba(0,0,0,0.6)'; ctx.fillRect(0,0,c.width,c.height);
    ctx.fillStyle = 'white'; ctx.font = '24px sans-serif'; ctx.textAlign = 'center';
    ctx.fillText(`💥 Score : ${_flap.score}`, c.width/2, c.height/2);
    ctx.font = '14px sans-serif'; ctx.fillText('Tap pour rejouer', c.width/2, c.height/2 + 30);
    ctx.textAlign = 'left';
    clearInterval(_flap.timer);
  }
}

// ============================================================
// DOODLE JUMP
// ============================================================
let _doo = null;
function newDoodle() {
  const c = document.getElementById('doo-canvas');
  if (_doo && _doo.timer) clearInterval(_doo.timer);
  _doo = { c, ctx:c.getContext('2d'), p:{ x:130, y:400, vy:0, dx:0 }, plats:[], score:0, dead:false, timer:null };
  for (let i=0; i<8; i++) _doo.plats.push({ x: Math.random()*240, y: 50 + i*50, w: 60 });
  _doo.timer = setInterval(dooTick, 30);
}
function doodleMove(d) { if (_doo) _doo.p.dx = d * 4; }
function dooTick() {
  if (!_doo || _doo.dead) return;
  const { c, ctx, p } = _doo;
  p.vy += 0.3; p.y += p.vy; p.x += p.dx;
  if (p.x < 0) p.x = c.width; if (p.x > c.width) p.x = 0;
  // Collisions
  for (const pl of _doo.plats) {
    if (p.vy > 0 && p.x+15 > pl.x && p.x-15 < pl.x+pl.w && p.y+15 > pl.y && p.y+15 < pl.y+10) {
      p.vy = -10;
    }
  }
  // Scroll
  if (p.y < 200) {
    const dy = 200 - p.y;
    p.y = 200; _doo.score += dy;
    for (const pl of _doo.plats) pl.y += dy;
    _doo.plats = _doo.plats.filter(pl => pl.y < c.height);
    while (_doo.plats.length < 8) _doo.plats.push({ x: Math.random()*240, y: -20, w: 60 });
  }
  if (p.y > c.height) _doo.dead = true;
  // Draw
  ctx.fillStyle = '#fef9c3'; ctx.fillRect(0,0,c.width,c.height);
  ctx.fillStyle = '#22c55e';
  for (const pl of _doo.plats) ctx.fillRect(pl.x, pl.y, pl.w, 8);
  ctx.font = '28px sans-serif'; ctx.fillText('🦘', p.x-14, p.y+8);
  document.getElementById('doo-score').textContent = Math.floor(_doo.score);
  if (_doo.dead) {
    ctx.fillStyle = 'rgba(0,0,0,0.6)'; ctx.fillRect(0,0,c.width,c.height);
    ctx.fillStyle = 'white'; ctx.font = '24px sans-serif'; ctx.textAlign = 'center';
    ctx.fillText(`💥 Hauteur : ${Math.floor(_doo.score)}`, c.width/2, c.height/2);
    ctx.textAlign = 'left';
    clearInterval(_doo.timer);
  }
}

// ============================================================
// WHACK-A-MOLE
// ============================================================
let _mole = null;
function newMole() {
  if (_mole && _mole.timer) clearInterval(_mole.timer);
  if (_mole && _mole.spawnTimer) clearInterval(_mole.spawnTimer);
  _mole = { score:0, time:30, active:[], timer:null, spawnTimer:null, started:true };
  document.getElementById('mole-score').textContent = '0';
  document.getElementById('mole-time').textContent = '30';
  document.getElementById('mole-start').style.display = 'none';
  // Build grid
  const grid = document.getElementById('mole-grid');
  grid.innerHTML = '';
  for (let i=0; i<9; i++) {
    const cell = document.createElement('div');
    cell.style.cssText = `width:80px; height:80px; background:var(--surface); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:40px; cursor:pointer;`;
    cell.dataset.idx = i;
    cell.onclick = () => moleHit(i);
    grid.appendChild(cell);
  }
  _mole.timer = setInterval(() => {
    _mole.time--;
    document.getElementById('mole-time').textContent = _mole.time;
    if (_mole.time <= 0) endMole();
  }, 1000);
  _mole.spawnTimer = setInterval(() => {
    const free = [0,1,2,3,4,5,6,7,8].filter(i => !_mole.active.includes(i));
    if (free.length) {
      const idx = free[Math.floor(Math.random()*free.length)];
      _mole.active.push(idx);
      const cell = document.querySelector(`#mole-grid [data-idx="${idx}"]`);
      cell.textContent = '🐹';
      setTimeout(() => {
        _mole.active = _mole.active.filter(x => x !== idx);
        if (cell) cell.textContent = '';
      }, 800);
    }
  }, 700);
}
function moleHit(i) {
  if (!_mole || !_mole.active.includes(i)) return;
  _mole.score++;
  document.getElementById('mole-score').textContent = _mole.score;
  _mole.active = _mole.active.filter(x => x !== i);
  const cell = document.querySelector(`#mole-grid [data-idx="${i}"]`);
  if (cell) cell.textContent = '💥';
  setTimeout(() => { if (cell) cell.textContent = ''; }, 200);
}
function endMole() {
  if (_mole.timer) clearInterval(_mole.timer);
  if (_mole.spawnTimer) clearInterval(_mole.spawnTimer);
  document.getElementById('mole-start').style.display = '';
  document.getElementById('mole-start').textContent = `Fini ! Score : ${_mole.score} · Rejouer`;
  toast(`🎯 Score final : ${_mole.score}`);
}

// ============================================================
// PAC-MAN simplifié
// ============================================================
let _pac = null;
function newPacman() {
  // 14×14 maze. 1=wall, 0=pellet, 2=empty
  const m = [
    '11111111111111',
    '10000010000001',
    '10110010110011',
    '10000000000001',
    '10110111110101',
    '10100000000101',
    '10101111110101',
    '10100000200101',
    '10101111110101',
    '10100000000101',
    '10110111110101',
    '10000000000001',
    '10110010110011',
    '11111111111111',
  ];
  const grid = m.map(r => r.split('').map(Number));
  let total = 0;
  for (const row of grid) for (const c of row) if (c === 0) total++;
  _pac = { grid, p:{ r:1, c:1 }, ghosts:[{ r:7, c:7 }, { r:7, c:6 }], score:0, total, timer:null };
  document.getElementById('pac-total').textContent = total;
  drawPac();
  if (_pac.gtimer) clearInterval(_pac.gtimer);
  _pac.gtimer = setInterval(pacGhostMove, 600);
}
function drawPac() {
  const c = document.getElementById('pac-canvas');
  const ctx = c.getContext('2d');
  const cs = 20;
  ctx.fillStyle = '#000'; ctx.fillRect(0,0,c.width,c.height);
  for (let r=0; r<14; r++) for (let cc=0; cc<14; cc++) {
    const v = _pac.grid[r][cc];
    if (v === 1) { ctx.fillStyle = '#1d4ed8'; ctx.fillRect(cc*cs, r*cs, cs, cs); }
    else if (v === 0) { ctx.fillStyle = '#fde047'; ctx.beginPath(); ctx.arc(cc*cs+cs/2, r*cs+cs/2, 2, 0, Math.PI*2); ctx.fill(); }
  }
  // Pac
  ctx.fillStyle = '#fde047';
  ctx.beginPath(); ctx.arc(_pac.p.c*cs+cs/2, _pac.p.r*cs+cs/2, cs/2-1, 0.2*Math.PI, 1.8*Math.PI); ctx.lineTo(_pac.p.c*cs+cs/2, _pac.p.r*cs+cs/2); ctx.fill();
  // Ghosts
  for (const g of _pac.ghosts) { ctx.fillStyle = '#ef4444'; ctx.beginPath(); ctx.arc(g.c*cs+cs/2, g.r*cs+cs/2, cs/2-2, 0, Math.PI*2); ctx.fill(); }
  document.getElementById('pac-score').textContent = _pac.score;
}
function pacMove(dc, dr) {
  if (!_pac) return;
  const nr = _pac.p.r + dr, nc = _pac.p.c + dc;
  if (nr < 0 || nr >= 14 || nc < 0 || nc >= 14) return;
  if (_pac.grid[nr][nc] === 1) return;
  _pac.p.r = nr; _pac.p.c = nc;
  if (_pac.grid[nr][nc] === 0) { _pac.grid[nr][nc] = 2; _pac.score++; }
  for (const g of _pac.ghosts) if (g.r === nr && g.c === nc) return pacLose();
  drawPac();
  if (_pac.score === _pac.total) { if (_pac.gtimer) clearInterval(_pac.gtimer); toast('🎉 Tu as gagné !'); }
}
function pacGhostMove() {
  if (!_pac) return;
  for (const g of _pac.ghosts) {
    const opts = [[1,0],[-1,0],[0,1],[0,-1]].filter(([dr,dc]) => g.r+dr>=0 && g.r+dr<14 && g.c+dc>=0 && g.c+dc<14 && _pac.grid[g.r+dr][g.c+dc] !== 1);
    if (!opts.length) continue;
    // Move toward pac (simple greedy)
    opts.sort((a,b) => Math.abs(_pac.p.r-(g.r+a[0])) + Math.abs(_pac.p.c-(g.c+a[1])) - Math.abs(_pac.p.r-(g.r+b[0])) - Math.abs(_pac.p.c-(g.c+b[1])));
    const [dr, dc] = Math.random() < 0.7 ? opts[0] : opts[Math.floor(Math.random()*opts.length)];
    g.r += dr; g.c += dc;
    if (g.r === _pac.p.r && g.c === _pac.p.c) return pacLose();
  }
  drawPac();
}
function pacLose() {
  if (_pac.gtimer) clearInterval(_pac.gtimer);
  toast('😱 Game over !');
  _pac = null;
}

