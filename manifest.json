  {emoji:'🧘‍♀️', text:'Yoga / stretching 15 min', cat:'corps'},
  {emoji:'📓', text:'Journaling', cat:'mental'},
  {emoji:'🌸', text:'Mettre du parfum', cat:'beauté'},
  {emoji:'💭', text:'Méditation 10 min', cat:'mental'},
  {emoji:'🎨', text:'Faire un dessin', cat:'créatif'},
  {emoji:'🍫', text:'S\'offrir un truc gourmand', cat:'plaisir'},
  {emoji:'📞', text:'Appeler une amie', cat:'social'},
  {emoji:'🎬', text:'Film cosy + popcorn', cat:'plaisir'},
  {emoji:'🌷', text:'Acheter des fleurs', cat:'plaisir'},
  {emoji:'☕', text:'Café latte au lit', cat:'cosy'},
  {emoji:'🛍', text:'Lèche-vitrines', cat:'plaisir'},
  {emoji:'📱', text:'Détox réseaux 1h', cat:'mental'},
  {emoji:'💌', text:'Écrire à quelqu\'un qu\'on aime', cat:'social'},
  {emoji:'🌙', text:'Coucher tôt avec routine', cat:'corps'},
  {emoji:'💧', text:'Boire 2L d\'eau', cat:'corps'},
  {emoji:'🥗', text:'Cuisiner un truc healthy', cat:'corps'},
  {emoji:'🌿', text:'Tisane détente', cat:'cosy'}
];
function renderSelfcare() {
  const today = todayKey();
  // Stable seed pour 3 idées du jour
  const seed = parseInt(today.replace(/-/g,''));
  const indices = [];
  let s = seed;
  while (indices.length < 5) {
    s = (s * 9301 + 49297) % 233280;
    const idx = s % SELFCARE_IDEAS.length;
    if (!indices.includes(idx)) indices.push(idx);
  }
  const ideas = indices.map(i => SELFCARE_IDEAS[i]);
  let done; try { done = JSON.parse(localStorage.getItem('nw_selfcare_'+today) || '[]'); } catch { done = []; }
  
  let html = `<div style="background:linear-gradient(135deg, #FFB6D9, #FF6FA3); color:white; padding:16px; border-radius:16px;">
    <div style="font-size:18px; font-weight:800;">💗 Prends soin de toi</div>
    <p style="font-size:11px; opacity:0.95; margin-top:4px;">5 suggestions du jour pour te chouchouter</p>
  </div>`;
  ideas.forEach((idea, i) => {
    const isDone = done.includes(i);
    html += `<div onclick="selfcareToggle(${i})" style="background:var(--surface); padding:12px 14px; border-radius:12px; margin-top:8px; display:flex; gap:10px; align-items:center; cursor:pointer; ${isDone ? 'opacity:0.5;' : ''}">
      <div style="font-size:30px;">${idea.emoji}</div>
      <div style="flex:1; font-size:14px; ${isDone ? 'text-decoration:line-through;' : ''}">${escapeHtml(idea.text)}</div>
      <div style="width:24px; height:24px; border-radius:50%; background:${isDone ? 'var(--success)' : 'transparent'}; border:2px solid ${isDone ? 'var(--success)' : 'var(--border)'}; color:white; display:flex; align-items:center; justify-content:center;">${isDone ? '✓' : ''}</div>
    </div>`;
  });
  html += `<button class="btn alt full" onclick="renderSelfcare()" style="margin-top:14px;">🎲 Nouvelles suggestions</button>`;
  document.getElementById('selfcare-content').innerHTML = html;
}
function selfcareToggle(i) {
  const today = todayKey();
  let done; try { done = JSON.parse(localStorage.getItem('nw_selfcare_'+today) || '[]'); } catch { done = []; }
  if (done.includes(i)) done = done.filter(x => x !== i);
  else done.push(i);
  localStorage.setItem('nw_selfcare_'+today, JSON.stringify(done));
  renderSelfcare();
}



// === MANIFESTATION ===
function getManif() { try { return JSON.parse(localStorage.getItem('nw_manif') || '[]'); } catch { return []; } }
function saveManif(d) { localStorage.setItem('nw_manif', JSON.stringify(d)); }
function manifAdd() {
  const txt = prompt('✨ Ton intention :\n(Ex: J\'attire l\'amour, je vais réussir mon bac, je deviens plus confiante...)');
  if (!txt) return;
  const d = getManif();
  d.unshift({ id:'m_'+Date.now(), text:txt.trim(), created:Date.now(), reads:0, manifested:false });
  saveManif(d); renderManif();
}
function manifRead(id) {
  const d = getManif();
  const it = d.find(x => x.id === id); if (!it) return;
  it.reads = (it.reads || 0) + 1;
  it.lastRead = Date.now();
  saveManif(d); renderManif();
  toast('✨ +1 lecture');
}
function manifToggle(id) {
  const d = getManif();
  const it = d.find(x => x.id === id); if (!it) return;
  it.manifested = !it.manifested;
  if (it.manifested) it.manifestedAt = Date.now();
  saveManif(d); renderManif();
  if (it.manifested) toast('🌟 Manifesté !');
}
function manifDel(id) {
  if (!confirm('Supprimer cette intention ?')) return;
  saveManif(getManif().filter(x => x.id !== id)); renderManif();
}
function renderManif() {
  const d = getManif();
  if (!d.length) {
    document.getElementById('manif-list').innerHTML = '<p style="text-align:center; color:var(--textSec); padding:30px;">Pas d\'intention. Tap + pour ajouter ton 1er rêve.</p>';
    return;
  }
  document.getElementById('manif-list').innerHTML = d.map(it => `<div style="background:${it.manifested ? 'linear-gradient(135deg, #5DD68F, #06FFA5)' : 'var(--surface)'}; color:${it.manifested ? 'white' : 'var(--text)'}; padding:14px; border-radius:14px; margin-bottom:8px;">
    <div style="display:flex; gap:8px; align-items:flex-start;">
      <div style="font-size:24px;">${it.manifested ? '🌟' : '✨'}</div>
      <div style="flex:1; font-size:14px; line-height:1.5; font-weight:600;">${escapeHtml(it.text)}</div>
    </div>
    <div style="font-size:10px; opacity:0.8; margin-top:8px;">📖 Lu ${it.reads || 0}× · ${new Date(it.created).toLocaleDateString('fr-FR')}</div>
    <div style="display:flex; gap:4px; margin-top:8px; flex-wrap:wrap;">
      ${!it.manifested ? `<button class="btn alt" onclick="manifRead('${it.id}')" style="font-size:11px; padding:4px 10px;">📖 Relire</button>` : ''}
      <button class="btn alt" onclick="manifToggle('${it.id}')" style="font-size:11px; padding:4px 10px;">${it.manifested ? '✗ Annuler' : '🌟 Manifesté !'}</button>
      <button class="btn alt" onclick="manifDel('${it.id}')" style="font-size:11px; padding:4px 10px; color:var(--danger);">🗑</button>
    </div>
  </div>`).join('');
}

