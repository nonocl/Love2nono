          <button onclick="serNextS(${i})" style="background:var(--surfaceAlt); color:var(--text); border:1px solid var(--border); padding:6px 12px; border-radius:8px; font-size:11px;">+1 S</button>
          <button onclick="serDel(${i})" style="background:none; border:none; color:var(--danger);">✗</button>
