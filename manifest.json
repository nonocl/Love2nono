// === VIBE SYSTEM ===
const V56_VIBES = ['aesthetic', 'glass', 'neuo', 'brut'];

function v56_applyVibe(vibe) {
  if (!V56_VIBES.includes(vibe)) vibe = 'aesthetic';
  V56_VIBES.forEach(v => document.body.classList.remove('vibe-' + v));
  if (vibe !== 'aesthetic') document.body.classList.add('vibe-' + vibe);
  localStorage.setItem('nw_vibe', vibe);
  document.querySelectorAll('.v56-vibe-option').forEach(el => {
    el.classList.toggle('active', el.dataset.vibe === vibe);
  });
  if (typeof toast === 'function') toast('🎨 ' + ({aesthetic:'Aesthetic',glass:'Glass',neuo:'Neuo',brut:'Brutalist'}[vibe]));
}

function v56_initVibe() {
  const v = localStorage.getItem('nw_vibe') || 'aesthetic';
  v56_applyVibe(v);
}

// === ENABLE V56 GLOBALLY ===
function v56_enable() {
  document.body.classList.add('v56-active');
  v56_buildBottomNav();
  v56_initVibe();
  v56_renderDashboard();
}

// === NEW BOTTOM NAV ===
function v56_buildBottomNav() {
  // Remove old nav
  const old = document.getElementById('bottom-nav');
  if (old) old.style.display = 'none';
  // Build new
  let nav = document.getElementById('v56-bottom-nav');
  if (nav) nav.remove();
  nav = document.createElement('nav');
  nav.id = 'v56-bottom-nav';
  nav.className = 'v56-bottom-nav';
  const items = [
    { id: 'home', ico: '🏠', label: 'Home', action: () => v56_navTo('home') },
    { id: 'all', ico: '📚', label: 'Tout', action: () => v56_navTo('all') },
    { id: 'search', ico: '🔍', label: 'Search', action: () => v56_openSearch() },
    { id: 'recent', ico: '🕒', label: 'Récents', action: () => v56_navTo('recent') },
    { id: 'menu', ico: '☰', label: 'Menu', action: () => { if (typeof openBurger === 'function') openBurger(); } }
  ];
  items.forEach(it => {
    const btn = document.createElement('button');
    btn.className = 'v56-bottom-nav-btn';
    btn.dataset.navId = it.id;
    btn.innerHTML = `<span class="v56-nav-ico">${it.ico}</span><span class="v56-nav-label">${it.label}</span><span class="v56-dot"></span>`;
    btn.onclick = it.action;
    nav.appendChild(btn);
  });
  document.body.appendChild(nav);
  v56_updateActiveNav();
}

function v56_updateActiveNav() {
  if (!document.body.classList.contains('v56-active')) return;
  const activePage = document.querySelector('.page.active');
  const pid = activePage ? activePage.id.replace('page-', '') : 'home';
  document.querySelectorAll('.v56-bottom-nav-btn').forEach(btn => {
    const id = btn.dataset.navId;
    btn.classList.toggle('active', id === pid || (id === 'home' && pid === 'home'));
  });
}

function v56_navTo(page) {
  if (typeof goTo === 'function') goTo(page);
  setTimeout(v56_updateActiveNav, 50);
}

