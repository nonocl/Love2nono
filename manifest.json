    } else {
      html += `<div style="background:var(--surfaceAlt); padding:10px 12px; border-radius:10px; margin-bottom:6px; display:flex; gap:10px; align-items:center; opacity:0.6;">
        <div style="font-size:12px; flex:1;">
          <div style="font-weight:700;">??? ???</div>
