let _psplFile = null;
function psplLoad(input) {
  _psplFile = (input.files || [])[0];
  document.getElementById('pspl-btn').disabled = !_psplFile;
  if (_psplFile) setStatus('pspl-status', `📄 ${_psplFile.name}`, 'info');
}
function parsePageRange(s, max) {
  const result = new Set();
  for (const part of s.split(',')) {
    const p = part.trim();
    if (!p) continue;
    if (p.includes('-')) {
      const [a, b] = p.split('-').map(x => parseInt(x.trim()));
      for (let i=a; i<=b; i++) if (i >= 1 && i <= max) result.add(i-1);
    } else {
      const n = parseInt(p);
      if (n >= 1 && n <= max) result.add(n-1);
    }
  }
  return Array.from(result).sort((a,b) => a-b);
}
async function psplRun() {
  if (!_psplFile) return;
  const range = document.getElementById('pspl-range').value.trim();
  if (!range) return setStatus('pspl-status', 'Indique les pages à extraire', 'error');
  setStatus('pspl-status', 'Chargement...', 'loading');
  try {
    const PDFLib = await ensurePdfLib();
    const buf = await _psplFile.arrayBuffer();
    const src = await PDFLib.PDFDocument.load(buf);
    const total = src.getPageCount();
    const pages = parsePageRange(range, total);
    if (!pages.length) return setStatus('pspl-status', `❌ Pages invalides (le PDF a ${total} pages)`, 'error');
    const out = await PDFLib.PDFDocument.create();
    const copied = await out.copyPages(src, pages);
    copied.forEach(p => out.addPage(p));
    const bytes = await out.save();
    dlBlob(new Blob([bytes], { type:'application/pdf' }), `extrait-${Date.now()}.pdf`);
    setStatus('pspl-status', `✅ ${pages.length} page${pages.length>1?'s':''} extraite${pages.length>1?'s':''}`, 'success');
  } catch (e) {
    console.error(e); setStatus('pspl-status', '❌ ' + e.message, 'error');
  }
}

