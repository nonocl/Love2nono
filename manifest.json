  const area = document.getElementById('aim-area');
  area.innerHTML = '';
  aimSpawn();
  // Update timer
  if (_aim.timer) clearInterval(_aim.timer);
  _aim.timer = setInterval(() => {
    if (!_aim || !_aim.running) return;
    const t = (Date.now() - _aim.start) / 1000;
    document.getElementById('aim-time').textContent = t.toFixed(1) + 's';
  }, 50);
}
function aimSpawn() {
  if (!_aim || !_aim.running) return;
  const area = document.getElementById('aim-area');
  area.innerHTML = '';
  const size = 50;
  const rect = area.getBoundingClientRect();
  const x = Math.random() * (rect.width - size);
  const y = Math.random() * (rect.height - size);
  const dot = document.createElement('div');
  dot.style.cssText = `position:absolute; left:${x}px; top:${y}px; width:${size}px; height:${size}px; border-radius:50%; background:radial-gradient(circle, #FF4757 30%, #8B0000 70%); cursor:pointer; box-shadow:0 0 12px rgba(255,71,87,0.6);`;
  dot.onclick = aimHit;
  area.appendChild(dot);
}
function aimHit(e) {
  e.stopPropagation();
  if (!_aim) return;
  _aim.count++;
  document.getElementById('aim-targets').textContent = `${_aim.count}/${_aim.target}`;
  if (_aim.count >= _aim.target) {
    _aim.running = false;
    clearInterval(_aim.timer);
    const total = (Date.now() - _aim.start) / 1000;
    document.getElementById('aim-area').innerHTML = `<div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center; background:rgba(0,0,0,0.6); color:white; flex-direction:column;">
      <div style="font-size:32px; font-weight:900;">🎯 ${total.toFixed(2)}s</div>
      <div style="font-size:13px; opacity:0.8; margin-top:6px;">${(total * 1000 / _aim.target).toFixed(0)} ms / cible</div>
    </div>`;
    const best = parseFloat(localStorage.getItem('nw_aim_best') || '999');
    if (total < best) localStorage.setItem('nw_aim_best', total);
  } else {
    aimSpawn();
  }
}

