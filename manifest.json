// IMAGE → PDF
// ============================================================
let _i2pFiles = [];
function i2pLoad(input) {
  _i2pFiles = Array.from(input.files || []);
  if (!_i2pFiles.length) { document.getElementById('i2p-btn').disabled = true; return; }
  document.getElementById('i2p-btn').disabled = false;
  const prev = document.getElementById('i2p-preview');
  prev.innerHTML = `<div style="font-size:12px; color:var(--textSec); margin-bottom:6px;">${_i2pFiles.length} image${_i2pFiles.length>1?'s':''} sélectionnée${_i2pFiles.length>1?'s':''}</div><div style="display:grid; grid-template-columns:repeat(4,1fr); gap:4px;">`;
  _i2pFiles.forEach((f, i) => {
    const url = URL.createObjectURL(f);
    prev.innerHTML += `<div style="position:relative; aspect-ratio:1; background:var(--surfaceAlt); border-radius:6px; overflow:hidden;"><img src="${url}" style="width:100%; height:100%; object-fit:cover;"><span style="position:absolute; top:2px; left:2px; background:rgba(0,0,0,0.6); color:white; padding:1px 5px; border-radius:4px; font-size:10px;">${i+1}</span></div>`;
  });
  prev.innerHTML += '</div>';
}
async function i2pCreate() {
  if (!_i2pFiles.length) return;
  setStatus('i2p-status', 'Chargement de la lib PDF...', 'loading');
  try {
    const PDFLib = await ensurePdfLib();
    setStatus('i2p-status', 'Création du PDF...', 'loading');
    const pdfDoc = await PDFLib.PDFDocument.create();
    const format = document.getElementById('i2p-format').value;
    const orientation = document.getElementById('i2p-orientation').value;
    const PAGES = { A4:[595,842], Letter:[612,792] };
    for (let i=0; i<_i2pFiles.length; i++) {
      setStatus('i2p-status', `Page ${i+1}/${_i2pFiles.length}...`, 'loading');
      const f = _i2pFiles[i];
      const buf = await f.arrayBuffer();
      let img;
      if (f.type === 'image/png') img = await pdfDoc.embedPng(buf);
      else if (f.type === 'image/jpeg' || f.type === 'image/jpg') img = await pdfDoc.embedJpg(buf);
      else {
        // Convertir en JPG via canvas
        const blob = await imgToJpgBlob(f);
        const buf2 = await blob.arrayBuffer();
        img = await pdfDoc.embedJpg(buf2);
      }
      let pw, ph;
      if (format === 'auto') { pw = img.width; ph = img.height; }
      else { [pw, ph] = PAGES[format] || PAGES.A4; }
      const isLand = orientation === 'landscape' || (orientation === 'auto' && img.width > img.height);
      if (isLand && format !== 'auto') { [pw, ph] = [ph, pw]; }
      const page = pdfDoc.addPage([pw, ph]);
      // Fit image in page with margin
      const margin = format === 'auto' ? 0 : 20;
      const aw = pw - 2*margin, ah = ph - 2*margin;
      const ratio = Math.min(aw/img.width, ah/img.height);
      const w = img.width * ratio, h = img.height * ratio;
      page.drawImage(img, { x:(pw-w)/2, y:(ph-h)/2, width:w, height:h });
    }
    const bytes = await pdfDoc.save();
    dlBlob(new Blob([bytes], { type:'application/pdf' }), `images-${Date.now()}.pdf`);
    setStatus('i2p-status', '✅ PDF créé !', 'success');
  } catch (e) {
    console.error(e); setStatus('i2p-status', '❌ ' + e.message, 'error');
  }
}
function imgToJpgBlob(file) {
  return new Promise((resolve, reject) => {
    const img = new Image();
    img.onload = () => {
      const c = document.createElement('canvas');
      c.width = img.width; c.height = img.height;
      const ctx = c.getContext('2d');
      ctx.fillStyle = '#fff'; ctx.fillRect(0,0,c.width,c.height);
      ctx.drawImage(img, 0, 0);
      c.toBlob(b => b ? resolve(b) : reject(new Error('Conv failed')), 'image/jpeg', 0.92);
    };
    img.onerror = reject;
    img.src = URL.createObjectURL(file);
  });
}

