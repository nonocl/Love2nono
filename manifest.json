let _guess = null;
async function initGuess() {
  const best = await getScore('guess');
  _guess = { num: Math.floor(Math.random()*100)+1, tries:0, max:10, history:[], best:best?best.value:null, over:false };
  document.getElementById('guess-best').textContent = _guess.best || '—';
  document.getElementById('guess-tries').textContent = '0/10';
  document.getElementById('guess-history').innerHTML = '';
  document.getElementById('guess-input').value = '';
}

function doGuess() {
  if (_guess.over) return;
  const v = parseInt(document.getElementById('guess-input').value);
  if (isNaN(v) || v < 1 || v > 100) { alert('Entre 1 et 100 STP'); return; }
  _guess.tries++;
  let hint;
  if (v === _guess.num) {
    hint = `🎉 ${v} ! Trouvé en ${_guess.tries} essais !`;
    _guess.over = true;
    setScore('guess', _guess.tries).then(isBest => {
      if (isBest) setTimeout(() => alert('🏆 Nouveau record !'), 300);
    });
  } else if (v < _guess.num) hint = `${v} → trop petit ⬆`;
  else hint = `${v} → trop grand ⬇`;
  _guess.history.unshift(hint);
  document.getElementById('guess-tries').textContent = `${_guess.tries}/10`;
  document.getElementById('guess-history').innerHTML = _guess.history.map(h => `<div style="padding:4px 0; font-size:13px;">${h}</div>`).join('');
  document.getElementById('guess-input').value = '';
  if (!_guess.over && _guess.tries >= _guess.max) {
    _guess.over = true;
    setTimeout(() => alert(`Perdu ! C'était ${_guess.num}`), 200);
  }
}

