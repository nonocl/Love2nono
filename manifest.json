const FIGURES = [
  { name:'Métaphore', def:'Comparaison sans outil de comparaison.', ex:'« Cette femme est une fleur » (au lieu de « comme une fleur »)' },
  { name:'Comparaison', def:'Rapprochement explicite entre deux éléments avec un outil de comparaison.', ex:'« Il est rusé comme un renard »' },
  { name:'Personnification', def:'Attribuer des caractéristiques humaines à un objet, animal ou idée.', ex:'« Le vent murmurait dans les arbres »' },
  { name:'Allégorie', def:'Représentation concrète d\'une idée abstraite.', ex:'« La justice » représentée par une femme aux yeux bandés' },
  { name:'Hyperbole', def:'Exagération volontaire pour produire un effet.', ex:'« Je meurs de faim »' },
  { name:'Litote', def:'Atténuer son propos pour mieux faire entendre l\'inverse.', ex:'« Va, je ne te hais point » (= je t\'aime) - Corneille' },
  { name:'Euphémisme', def:'Atténuer une réalité dure ou désagréable.', ex:'« Il nous a quittés » (= il est mort)' },
  { name:'Oxymore', def:'Réunir deux mots aux sens opposés.', ex:'« Cette obscure clarté » - Corneille' },
  { name:'Antithèse', def:'Opposer deux termes ou idées dans une même phrase.', ex:'« Je vis, je meurs » - Louise Labé' },
  { name:'Anaphore', def:'Répétition d\'un mot/groupe en début de phrases.', ex:'« Marcher, marcher, marcher »' },
  { name:'Énumération', def:'Liste de termes de même nature.', ex:'« Adieu veaux, vaches, cochons, couvées » - La Fontaine' },
  { name:'Gradation', def:'Énumération avec progression croissante ou décroissante.', ex:'« Va, cours, vole, et nous venge » - Corneille' },
  { name:'Allitération', def:'Répétition de consonnes.', ex:'« Pour qui sont ces serpents qui sifflent sur vos têtes » - Racine' },
  { name:'Assonance', def:'Répétition de voyelles.', ex:'« Tout m\'afflige et me nuit, et conspire à me nuire » - Racine' },
  { name:'Métonymie', def:'Désigner une chose par une autre qui lui est liée.', ex:'« Boire un verre » (= boire le contenu)' },
  { name:'Synecdoque', def:'Type de métonymie : la partie pour le tout.', ex:'« Une voile à l\'horizon » (= un bateau)' },
  { name:'Antiphrase', def:'Dire le contraire de ce qu\'on pense, ironie.', ex:'« Quel beau temps ! » (sous la pluie)' },
  { name:'Périphrase', def:'Remplacer un mot par une expression plus longue.', ex:'« La ville lumière » (= Paris)' },
  { name:'Chiasme', def:'Croisement de termes dans une phrase (AB-BA).', ex:'« Il faut manger pour vivre et non vivre pour manger »' },
  { name:'Parallélisme', def:'Construction symétrique de phrases.', ex:'« Tu travailles, tu réussis »' },
  { name:'Hypallage', def:'Attribut donné à un mot qu\'il ne devrait pas qualifier.', ex:'« Ce marchand accoudé sur son comptoir avide »' },
  { name:'Zeugma', def:'Lier deux termes hétérogènes avec un même verbe.', ex:'« Vêtu de probité candide et de lin blanc » - Hugo' },
  { name:'Apostrophe', def:'Interpeller directement quelqu\'un ou quelque chose.', ex:'« Ô temps, suspends ton vol ! » - Lamartine' },
  { name:'Question rhétorique', def:'Question dont la réponse est évidente, n\'attendant pas de réponse.', ex:'« Qui ne voit pas que c\'est faux ? »' },
];
function renderFigures() {
  const search = document.getElementById('fig-search').value.toLowerCase();
  const list = FIGURES.filter(f => !search || f.name.toLowerCase().includes(search) || f.def.toLowerCase().includes(search));
  const el = document.getElementById('fig-list');
  el.innerHTML = '';
  list.forEach(f => {
    const card = document.createElement('div');
    card.style.cssText = 'background:var(--surface); padding:14px; border-radius:12px; margin-bottom:8px;';
    card.innerHTML = `
      <h3 style="font-size:15px; font-weight:700; color:var(--primary); margin-bottom:6px;">${escapeHtml(f.name)}</h3>
      <p style="font-size:13px; color:var(--text); line-height:1.4;">${escapeHtml(f.def)}</p>
      <p style="font-size:12px; color:var(--textSec); font-style:italic; margin-top:6px;">📝 ${escapeHtml(f.ex)}</p>
    `;
    el.appendChild(card);
  });
}


