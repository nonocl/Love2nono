  { cat:'👕 Vêtements', items:['Sous-vêtements (×7)', 'Chaussettes (×7)', 'T-shirts', 'Pantalons / shorts', 'Pull / veste', 'Pyjama', 'Maillot de bain', 'Chaussures confort'] },
  { cat:'🧴 Hygiène', items:['Brosse à dents', 'Dentifrice', 'Shampooing', 'Gel douche', 'Déodorant', 'Crème solaire', 'Trousse à pharmacie'] },
  { cat:'📱 Tech', items:['Téléphone', 'Chargeur tel', 'Écouteurs', 'Adaptateur prise', 'Power bank', 'Appareil photo'] },
  { cat:'💼 Divers', items:['Lunettes de soleil', 'Carnet + stylo', 'Livre / liseuse', 'Sac à dos jour', 'Sachets plastique'] }
];
function getTravel() {
  let t;
  try { t = JSON.parse(localStorage.getItem('nw_travel') || 'null'); } catch { t = null; }
  if (!t) {
    t = TRAVEL_DEFAULT.map(c => ({ cat: c.cat, items: c.items.map(i => ({ text: i, done: false })) }));
    localStorage.setItem('nw_travel', JSON.stringify(t));
  }
  return t;
}
function saveTravel(d) { localStorage.setItem('nw_travel', JSON.stringify(d)); }
function renderTravel() {
  const t = getTravel();
  const total = t.reduce((s, c) => s + c.items.length, 0);
  const done = t.reduce((s, c) => s + c.items.filter(i => i.done).length, 0);
  const pct = total ? Math.round((done / total) * 100) : 0;
  let html = `<div style="background:linear-gradient(135deg,#5DADE2,#3498DB); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🧳</div>
    <div style="font-size:20px; font-weight:900;">${done}/${total}</div>
    <div style="background:rgba(255,255,255,0.3); height:6px; border-radius:3px; margin-top:8px; overflow:hidden;">
      <div style="background:white; height:100%; width:${pct}%;"></div>
    </div>
  </div>`;
  t.forEach((c, ci) => {
    const cd = c.items.filter(i => i.done).length;
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">${escapeHtml(c.cat)} <span style="font-size:11px; color:var(--textSec); font-weight:400;">${cd}/${c.items.length}</span></h3>`;
    c.items.forEach((it, ii) => {
      html += `<div onclick="travelCheck(${ci},${ii})" style="background:var(--surface); padding:10px 14px; border-radius:10px; margin-top:4px; display:flex; gap:10px; align-items:center; cursor:pointer; ${it.done?'opacity:0.6;':''}">
        <span style="width:20px; height:20px; border-radius:5px; border:2px solid var(--primary); background:${it.done?'var(--primary)':'transparent'}; color:white; display:inline-flex; align-items:center; justify-content:center; font-size:12px;">${it.done?'✓':''}</span>
        <span style="flex:1; ${it.done?'text-decoration:line-through;':''}">${escapeHtml(it.text)}</span>
        <button onclick="event.stopPropagation(); travelDelItem(${ci},${ii})" style="background:none; border:none; color:var(--danger); font-size:14px;">✗</button>
      </div>`;
    });
    html += `<button class="btn alt full" onclick="travelAddItem(${ci})" style="margin-top:6px; font-size:11px;">+ Ajouter</button>`;
  });
  document.getElementById('travel-content').innerHTML = html;
}
function travelCheck(ci, ii) { const t=getTravel(); t[ci].items[ii].done=!t[ci].items[ii].done; saveTravel(t); renderTravel(); }
function travelAddItem(ci) { const x=prompt('Item :'); if(!x)return; const t=getTravel(); t[ci].items.push({text:x,done:false}); saveTravel(t); renderTravel(); }
function travelDelItem(ci, ii) { const t=getTravel(); t[ci].items.splice(ii,1); saveTravel(t); renderTravel(); }
function travelReset() { if(!confirm('Décocher tout ?'))return; const t=getTravel(); t.forEach(c=>c.items.forEach(i=>i.done=false)); saveTravel(t); renderTravel(); }

