function getJgenHistory() {
  try { return JSON.parse(localStorage.getItem('nw_jgen_history') || '[]'); } catch { return []; }
}
function saveJgenHistory(h) { localStorage.setItem('nw_jgen_history', JSON.stringify(h.slice(0, 30))); }

let _jgenLastResult = null;

function renderJournalGen() {
  const today = new Date().toISOString().slice(0, 10);
  let html = `<div style="background:linear-gradient(135deg,#FF6FA3,#9B59B6,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">📝</div>
    <div style="font-size:16px; font-weight:800;">Générateur de journal</div>
    <div style="font-size:11px; opacity:0.9;">Date + mots-clés → mini texte naturel en 4 langues</div>
  </div>
  
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:16px;">📅 Date</h3>
  <input type="date" id="jgen-date" class="input" value="${today}" style="margin-top:6px;">
  
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">✏️ Mots-clés / activités</h3>
  <p style="font-size:10px; color:var(--textSec); margin-top:2px;">Une activité par ligne. Ex: "fait du sport", "vu un ami", "regardé un film"...</p>
  <textarea id="jgen-keywords" class="input" rows="6" placeholder="petit-déjeuner avec maman&#10;cours d'italien&#10;sport au parc&#10;film le soir avec papa" style="margin-top:6px; resize:vertical; font-family:inherit; line-height:1.5;"></textarea>
  
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">🌐 Langue de génération</h3>
  <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:6px; margin-top:6px;">
    <button class="btn alt jgen-lang-btn" data-lang="fr" onclick="jgenSetLang('fr')" style="padding:10px 4px;">🇫🇷 FR</button>
    <button class="btn alt jgen-lang-btn" data-lang="it" onclick="jgenSetLang('it')" style="padding:10px 4px;">🇮🇹 IT</button>
    <button class="btn alt jgen-lang-btn" data-lang="en" onclick="jgenSetLang('en')" style="padding:10px 4px;">🇬🇧 EN</button>
    <button class="btn alt jgen-lang-btn" data-lang="es" onclick="jgenSetLang('es')" style="padding:10px 4px;">🇪🇸 ES</button>
  </div>
  <input type="hidden" id="jgen-lang" value="fr">
  
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">🎨 Ton</h3>
  <select id="jgen-tone" class="input" style="margin-top:6px;">
    <option value="natural">Naturel et chaleureux</option>
    <option value="casual">Décontracté / casual</option>
    <option value="poetic">Poétique et littéraire</option>
    <option value="formal">Formel et soutenu</option>
    <option value="brief">Bref et factuel</option>
  </select>
  
  <button class="btn primary full" onclick="jgenGenerate()" style="margin-top:18px; padding:18px; font-size:15px;">✨ Générer mon journal</button>
  
  <div id="jgen-output" style="margin-top:14px;"></div>`;
  
  document.getElementById('journalgen-content').innerHTML = html;
  
  // Mark FR active
  jgenSetLang('fr');
}

function jgenSetLang(lang) {
  document.getElementById('jgen-lang').value = lang;
  document.querySelectorAll('.jgen-lang-btn').forEach(b => {
    if (b.dataset.lang === lang) {
      b.classList.remove('alt');
      b.classList.add('primary');
    } else {
      b.classList.remove('primary');
      b.classList.add('alt');
    }
  });
}

function jgenFormatDate(dateStr, lang) {
  const t = JGEN_TEMPLATES[lang];
  const d = new Date(dateStr + 'T12:00:00');
  const day = d.getDate();
  const month = t.months[d.getMonth()];
  const year = d.getFullYear();
  const weekday = t.weekdays[d.getDay()];
  
  let formatted;
  if (lang === 'en') {
    const ord = day + (day === 1 || day === 21 || day === 31 ? 'st' : day === 2 || day === 22 ? 'nd' : day === 3 || day === 23 ? 'rd' : 'th');
    formatted = `${month} ${ord}, ${year}`;
  } else if (lang === 'fr') {
    formatted = `${day === 1 ? '1er' : day} ${month} ${year}`;
  } else {
    formatted = `${day} ${month} ${year}`;
  }
  return { date: formatted, weekday };
}

function jgenPick(arr) {
  return arr[Math.floor(Math.random() * arr.length)];
}

function jgenCapitalize(s) {
  if (!s) return s;
  return s.charAt(0).toUpperCase() + s.slice(1);
}

function jgenGenerate() {
  const dateStr = document.getElementById('jgen-date').value;
  const kw = document.getElementById('jgen-keywords').value.trim();
  const lang = document.getElementById('jgen-lang').value;
  const tone = document.getElementById('jgen-tone').value;
  
  if (!dateStr) { toast('Choisis une date'); return; }
  if (!kw) { toast('Ajoute au moins un mot-clé'); return; }
  
  // Parse keywords - one per line, or comma-separated
  let activities = kw.split('\n').map(s => s.trim()).filter(Boolean);
  if (activities.length === 1 && activities[0].includes(',')) {
    activities = activities[0].split(',').map(s => s.trim()).filter(Boolean);
  }
  
  if (activities.length === 0) { toast('Ajoute au moins une activité'); return; }
  
  const t = JGEN_TEMPLATES[lang];
  const { date, weekday } = jgenFormatDate(dateStr, lang);
  
  // Pick intro based on count
  const useShortIntro = activities.length <= 2 && tone === 'brief';
  const intros = useShortIntro ? t.intros_short : t.intros;
  let intro = jgenPick(intros).replace(/{date}/g, date).replace(/{weekday}/g, weekday);
  
  // Build body
  let body = '';
  if (tone === 'brief') {
    // Just a list
    body = activities.map(a => `• ${jgenCapitalize(a)}.`).join('\n');
  } else {
    // Connect with smart connectors
    const sentences = [];
    for (let i = 0; i < activities.length; i++) {
      let conn;
      if (activities.length === 1) {
        conn = jgenPick(t.connectors_only);
      } else if (i === 0) {
        conn = jgenPick(t.connectors_first);
      } else if (i === activities.length - 1) {
        conn = jgenPick(t.connectors_last);
      } else {
        conn = jgenPick(t.connectors_middle);
      }
      
      // Check if activity already starts with a verb (j'ai, ho, I, etc)
      const lower = activities[i].toLowerCase();
      const startsWithVerb = /^(j'ai |je |i |yo |io |ho |sono |hice |fui |went |did |had |fait |vu |allé|been )/.test(lower);
      
      let sentence;
      if (startsWithVerb) {
        sentence = conn ? `${conn} ${activities[i]}` : jgenCapitalize(activities[i]);
      } else {
        // Prepend a verb based on language
        const verbPrefix = {
          fr: ['j\'ai fait ', 'j\'ai eu ', 'il y a eu ', 'j\'ai vécu '],
          it: ['ho fatto ', 'ho avuto ', 'c\'è stato ', 'ho vissuto '],
          en: ['I had ', 'I did ', 'there was ', 'I went for '],
          es: ['hice ', 'tuve ', 'hubo ', 'viví ']
        };
        const verb = jgenPick(verbPrefix[lang]);
        sentence = conn ? `${conn} ${verb}${activities[i]}` : `${jgenCapitalize(verb.trim())} ${activities[i]}`;
      }
      
      // Add sentence-ending punctuation
      if (!/[.!?]$/.test(sentence)) sentence += '.';
      sentences.push(sentence);
    }
    
    // Apply tone modifiers
    if (tone === 'poetic') {
      const poeticBits = {
        fr: [' avec délice', ' tout en douceur', ' avec un soupçon de magie', ', un vrai moment suspendu'],
        it: [' con piacere', ' con dolcezza', ' con un tocco di magia', ', un vero momento sospeso'],
        en: [' with delight', ' so gently', ' with a touch of magic', ', a moment suspended in time'],
        es: [' con deleite', ' con dulzura', ' con un toque mágico', ', un momento suspendido']
      };
      const bit = jgenPick(poeticBits[lang]);
      const idx = Math.floor(Math.random() * sentences.length);
      sentences[idx] = sentences[idx].replace(/\.$/, bit + '.');
    } else if (tone === 'casual') {
      const casualBits = {
        fr: [' (trop bien)', ' c\'était cool', ' énorme', ' grave bien', ' rip', ' j\'avoue'],
        it: [' (troppo figo)', ' è stato fico', ' bestiale', ' grande', ' top'],
        en: [' (so good)', ' it was lit', ' epic', ' fr fr', ' no cap', ' tbh'],
        es: [' (re bueno)', ' fue brutal', ' épico', ' la verdad']
      };
      // Add casual flair to ~30% of sentences
      sentences.forEach((s, i) => {
        if (Math.random() < 0.3) {
          const bit = jgenPick(casualBits[lang]);
          sentences[i] = s.replace(/\.$/, bit + '.');
        }
      });
    }
    
    body = sentences.join(' ');
  }
  
  // Closing
  let closing = '';
  if (tone !== 'brief' && activities.length >= 2) {
    closing = ' ' + jgenPick(t.closings).replace(/{date}/g, date);
  }
  
  const fullText = tone === 'brief' 
    ? `${intro}\n\n${body}` 
    : `${intro} ${body}${closing}`;
  
  // Render output
  const out = document.getElementById('jgen-output');
  out.innerHTML = `<div style="background:var(--surface); padding:18px; border-radius:14px; border-left:4px solid var(--primary);">
    <div style="font-size:11px; color:var(--textSec); margin-bottom:8px; letter-spacing:1px; text-transform:uppercase;">📖 ${LANG_FLAGS[lang]} Ton journal</div>
    <div id="jgen-text" style="font-size:14px; line-height:1.7; white-space:pre-wrap;">${escapeHtml(fullText)}</div>
    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:6px; margin-top:14px;">
      <button class="btn alt" onclick="jgenCopy()" style="font-size:12px; padding:8px 4px;">📋 Copier</button>
      <button class="btn alt" onclick="jgenGenerate()" style="font-size:12px; padding:8px 4px;">🔄 Refaire</button>
      <button class="btn primary" onclick="jgenSave()" style="font-size:12px; padding:8px 4px;">💾 Sauver</button>
    </div>
  </div>`;
  
  _jgenLastResult = { date: dateStr, lang, tone, activities, text: fullText, generated: Date.now() };
  
  if (navigator.vibrate) navigator.vibrate(15);
}

function jgenCopy() {
  if (!_jgenLastResult) return;
  navigator.clipboard.writeText(_jgenLastResult.text).then(() => {
    toast('📋 Copié !');
  }).catch(() => toast('Erreur copie'));
}

function jgenSave() {
  if (!_jgenLastResult) return;
  const h = getJgenHistory();
  h.unshift(_jgenLastResult);
  saveJgenHistory(h);
  toast('💾 Sauvé dans l\'historique');
}

function jgenHistory() {
  const h = getJgenHistory();
  if (!h.length) { toast('Aucun journal sauvé'); return; }
  let html = `<div style="background:linear-gradient(135deg,#9B59B6,#FF6FA3); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">📚</div>
    <div style="font-size:16px; font-weight:800;">Historique des journaux</div>
    <div style="font-size:11px; opacity:0.9;">${h.length} entrée${h.length > 1 ? 's' : ''}</div>
  </div>
  <button class="btn alt full" onclick="renderJournalGen()" style="margin-top:14px;">← Retour au générateur</button>`;
  
  h.forEach((entry, i) => {
    const d = new Date(entry.generated).toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' });
    html += `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:10px; border-left:3px solid var(--primary);">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
        <div style="font-size:11px; color:var(--textSec);">${LANG_FLAGS[entry.lang]} · ${entry.date} · sauvé le ${d}</div>
        <button onclick="jgenDelete(${i})" style="background:none; border:none; color:var(--danger); font-size:14px; cursor:pointer;">✗</button>
      </div>
      <div style="font-size:13px; line-height:1.6; white-space:pre-wrap;">${escapeHtml(entry.text)}</div>
      <button class="btn alt" onclick="navigator.clipboard.writeText(${JSON.stringify(entry.text).replace(/'/g,'&#39;')}); toast('📋 Copié');" style="font-size:11px; padding:6px 10px; margin-top:8px;">📋 Copier</button>
    </div>`;
  });
  document.getElementById('journalgen-content').innerHTML = html;
}

function jgenDelete(i) {
  if (!confirm('Supprimer cette entrée ?')) return;
  const h = getJgenHistory();
  h.splice(i, 1);
  saveJgenHistory(h);
  jgenHistory();
}

