// === 20. SPLITWISE MINI ===
function getSplit() { try { return JSON.parse(localStorage.getItem('nw_split') || '{"people":[],"expenses":[]}'); } catch { return {people:[],expenses:[]}; } }
function saveSplit(s) { localStorage.setItem('nw_split', JSON.stringify(s)); }
function renderSplit() {
  const data = getSplit();
  // Calcul soldes
  const balances = {};
  data.people.forEach(p => balances[p] = 0);
  data.expenses.forEach(e => {
    const share = e.amount / e.shared.length;
    balances[e.payer] = (balances[e.payer] || 0) + e.amount;
    e.shared.forEach(s => balances[s] = (balances[s] || 0) - share);
  });
  let html = `<div style="background:linear-gradient(135deg,#5DD68F,#FFD166); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🤝</div><div style="font-size:16px; font-weight:800;">Splitwise mini</div>
    <div style="font-size:11px; opacity:0.9;">${data.people.length} personnes · ${data.expenses.length} dépenses</div>
  </div>
  <div style="background:var(--surface); padding:12px; border-radius:12px; margin-top:14px;">
    <h3 style="font-size:13px; font-weight:700; color:var(--primary);">👥 Personnes</h3>
    <div style="display:grid; grid-template-columns:3fr 1fr; gap:6px; margin-top:6px;">
      <input type="text" id="sp-person" class="input" placeholder="Prénom" autocomplete="off">
      <button class="btn primary" onclick="spAddPerson()">➕</button>
    </div>
    ${data.people.length > 0 ? `<div style="margin-top:8px; display:flex; flex-wrap:wrap; gap:4px;">${data.people.map((p,i) => `<span style="background:var(--bg); padding:6px 10px; border-radius:8px; font-size:12px;">${escapeHtml(p)} <button onclick="spDelPerson(${i})" style="background:none; border:none; color:var(--danger); margin-left:4px;">✗</button></span>`).join('')}</div>` : ''}
  </div>`;
  if (data.people.length >= 2) {
    html += `<div style="background:var(--surface); padding:12px; border-radius:12px; margin-top:8px;">
      <h3 style="font-size:13px; font-weight:700; color:var(--primary);">💰 Nouvelle dépense</h3>
      <input type="text" id="sp-desc" class="input" placeholder="Description" style="margin-top:6px;">
      <input type="number" id="sp-amount" class="input" placeholder="Montant €" inputmode="decimal" step="0.01" style="margin-top:6px;">
      <select id="sp-payer" class="input" style="margin-top:6px;">
        <option value="">Payeur</option>
        ${data.people.map(p => `<option>${escapeHtml(p)}</option>`).join('')}
      </select>
      <div style="font-size:11px; color:var(--textSec); margin-top:6px;">Partagé entre :</div>
      <div style="display:flex; flex-wrap:wrap; gap:4px; margin-top:4px;">
        ${data.people.map(p => `<label style="background:var(--bg); padding:6px 10px; border-radius:8px; font-size:12px; cursor:pointer;"><input type="checkbox" class="sp-share" value="${escapeHtml(p)}" checked> ${escapeHtml(p)}</label>`).join('')}
      </div>
      <button class="btn primary full" onclick="spAddExpense()" style="margin-top:6px;">➕ Ajouter</button>
    </div>`;
  }
  if (Object.keys(balances).length > 0) {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📊 Soldes</h3>`;
    Object.entries(balances).forEach(([p, v]) => {
      const color = v > 0.01 ? '#5DD68F' : v < -0.01 ? '#E14D6B' : 'var(--textSec)';
      const sign = v > 0 ? '+' : '';
      html += `<div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-top:5px; display:flex; justify-content:space-between;">
        <div style="font-size:13px; font-weight:700;">${escapeHtml(p)}</div>
        <div style="font-weight:900; color:${color};">${sign}${v.toFixed(2)}€</div>
      </div>`;
    });
  }
  if (data.expenses.length > 0) {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📜 Historique</h3>`;
    data.expenses.slice().reverse().forEach((e, idx) => {
      const realIdx = data.expenses.length - 1 - idx;
      html += `<div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-top:5px;">
        <div style="display:flex; justify-content:space-between;">
          <div>
            <div style="font-size:12px; font-weight:700;">${escapeHtml(e.desc)}</div>
            <div style="font-size:10px; color:var(--textSec);">${escapeHtml(e.payer)} a payé · partagé ${e.shared.length}</div>
          </div>
          <div style="display:flex; align-items:center; gap:8px;">
            <strong style="color:var(--primary);">${e.amount.toFixed(2)}€</strong>
            <button onclick="spDelExpense(${realIdx})" style="background:none; border:none; color:var(--danger);">✗</button>
          </div>
        </div>
      </div>`;
    });
  }
  document.getElementById('split-content').innerHTML = html;
}
function spAddPerson() {
  const p = document.getElementById('sp-person').value.trim();
  if (!p) return;
  const data = getSplit();
  if (!data.people.includes(p)) { data.people.push(p.slice(0, 30)); saveSplit(data); }
  document.getElementById('sp-person').value = '';
  renderSplit();
}
function spDelPerson(i) {
  const data = getSplit();
  const removed = data.people.splice(i, 1)[0];
  data.expenses = data.expenses.filter(e => e.payer !== removed);
  data.expenses.forEach(e => { e.shared = e.shared.filter(s => s !== removed); });
  saveSplit(data); renderSplit();
}
function spAddExpense() {
  const desc = document.getElementById('sp-desc').value.trim();
  const amount = parseFloat(document.getElementById('sp-amount').value);
  const payer = document.getElementById('sp-payer').value;
  const shared = Array.from(document.querySelectorAll('.sp-share:checked')).map(c => c.value);
  if (!desc || isNaN(amount) || !payer || shared.length === 0) { toast('Tous les champs requis'); return; }
  const data = getSplit();
  data.expenses.push({ desc: desc.slice(0, 50), amount, payer, shared });
  saveSplit(data);
  document.getElementById('sp-desc').value = ''; document.getElementById('sp-amount').value = '';
  renderSplit();
}
function spDelExpense(i) { const d = getSplit(); d.expenses.splice(i,1); saveSplit(d); renderSplit(); }

// === 21. CALCULATEUR PRÊT/INTÉRÊTS ===
function renderLoanCalc() {
  let html = `<div style="background:linear-gradient(135deg,#5DADE2,#FFD166); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">💰</div><div style="font-size:16px; font-weight:800;">Calc prêt / intérêts</div>
  </div>
  <div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:14px;">
    <label style="font-size:11px; color:var(--textSec);">Montant emprunté (€)</label>
    <input type="number" id="lc-cap" class="input" value="10000" oninput="lcCalc()" style="margin-top:4px;">
    <label style="font-size:11px; color:var(--textSec); margin-top:8px; display:block;">Taux annuel (%)</label>
    <input type="number" id="lc-rate" class="input" value="3.5" step="0.1" oninput="lcCalc()" style="margin-top:4px;">
    <label style="font-size:11px; color:var(--textSec); margin-top:8px; display:block;">Durée (mois)</label>
    <input type="number" id="lc-months" class="input" value="60" oninput="lcCalc()" style="margin-top:4px;">
  </div>
  <div id="lc-result" style="margin-top:14px;"></div>`;
  document.getElementById('loancalc-content').innerHTML = html;
  setTimeout(lcCalc, 100);
}
function lcCalc() {
  const cap = parseFloat(document.getElementById('lc-cap').value);
  const rate = parseFloat(document.getElementById('lc-rate').value);
  const months = parseInt(document.getElementById('lc-months').value);
  if (isNaN(cap) || isNaN(rate) || isNaN(months) || cap <= 0 || months <= 0) return;
  const monthlyRate = rate / 100 / 12;
  const monthly = monthlyRate === 0 ? cap / months : cap * (monthlyRate * Math.pow(1 + monthlyRate, months)) / (Math.pow(1 + monthlyRate, months) - 1);
  const total = monthly * months;
  const interest = total - cap;
  document.getElementById('lc-result').innerHTML = `<div style="background:linear-gradient(135deg,#5DADE2,#FFD166); color:white; padding:18px; border-radius:14px;">
    <div style="font-size:11px; opacity:0.9;">Mensualité</div>
    <div style="font-size:28px; font-weight:900;">${monthly.toFixed(2)}€</div>
  </div>
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:8px;">
    <div style="background:var(--surface); padding:14px; border-radius:12px;">
      <div style="font-size:11px; color:var(--textSec);">Coût total</div>
      <div style="font-size:18px; font-weight:900; color:var(--primary);">${total.toFixed(2)}€</div>
    </div>
    <div style="background:var(--surface); padding:14px; border-radius:12px;">
      <div style="font-size:11px; color:var(--textSec);">Intérêts</div>
      <div style="font-size:18px; font-weight:900; color:#E14D6B;">${interest.toFixed(2)}€</div>
    </div>
  </div>`;
}

// === 22. CALCULATEUR ÉCONOMIES ===
function renderSavings() {
  let html = `<div style="background:linear-gradient(135deg,#5DD68F,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🐷</div><div style="font-size:16px; font-weight:800;">Calculateur épargne</div>
  </div>
  <div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:14px;">
    <label style="font-size:11px; color:var(--textSec);">Capital initial (€)</label>
    <input type="number" id="sv-initial" class="input" value="1000" oninput="svCalc()" style="margin-top:4px;">
    <label style="font-size:11px; color:var(--textSec); margin-top:8px; display:block;">Versement mensuel (€)</label>
    <input type="number" id="sv-monthly" class="input" value="100" oninput="svCalc()" style="margin-top:4px;">
    <label style="font-size:11px; color:var(--textSec); margin-top:8px; display:block;">Taux annuel (%)</label>
    <input type="number" id="sv-rate" class="input" value="3" step="0.1" oninput="svCalc()" style="margin-top:4px;">
    <label style="font-size:11px; color:var(--textSec); margin-top:8px; display:block;">Durée (années)</label>
    <input type="number" id="sv-years" class="input" value="10" oninput="svCalc()" style="margin-top:4px;">
  </div>
  <div id="sv-result" style="margin-top:14px;"></div>`;
  document.getElementById('savings-content').innerHTML = html;
  setTimeout(svCalc, 100);
}
function svCalc() {
  const init = parseFloat(document.getElementById('sv-initial').value) || 0;
  const monthly = parseFloat(document.getElementById('sv-monthly').value) || 0;
  const rate = parseFloat(document.getElementById('sv-rate').value) || 0;
  const years = parseFloat(document.getElementById('sv-years').value) || 0;
  if (years <= 0) return;
  const r = rate / 100 / 12;
  const months = years * 12;
  const final = init * Math.pow(1 + r, months) + monthly * (r === 0 ? months : (Math.pow(1 + r, months) - 1) / r);
  const totalDeposited = init + monthly * months;
  const gain = final - totalDeposited;
  document.getElementById('sv-result').innerHTML = `<div style="background:linear-gradient(135deg,#5DD68F,#5DADE2); color:white; padding:18px; border-radius:14px;">
    <div style="font-size:11px; opacity:0.9;">Total après ${years} ans</div>
    <div style="font-size:28px; font-weight:900;">${final.toFixed(2)}€</div>
  </div>
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:8px;">
    <div style="background:var(--surface); padding:14px; border-radius:12px;">
      <div style="font-size:11px; color:var(--textSec);">Versé</div>
      <div style="font-size:16px; font-weight:900;">${totalDeposited.toFixed(2)}€</div>
    </div>
    <div style="background:var(--surface); padding:14px; border-radius:12px;">
      <div style="font-size:11px; color:var(--textSec);">Gagné en intérêts</div>
      <div style="font-size:16px; font-weight:900; color:#5DD68F;">${gain.toFixed(2)}€</div>
    </div>
  </div>`;
}

// === 23. SPLITTER ADDITION ===
function renderBillSplit() {
  let html = `<div style="background:linear-gradient(135deg,#FFD166,#5DD68F); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🍽</div><div style="font-size:16px; font-weight:800;">Splitter addition</div>
    <div style="font-size:11px; opacity:0.9;">Split l'addition entre amis</div>
  </div>
  <div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:14px;">
    <label style="font-size:11px; color:var(--textSec);">Total addition (€)</label>
    <input type="number" id="bs-total" class="input" placeholder="Ex: 87.50" inputmode="decimal" step="0.01" oninput="bsCalc()" style="margin-top:4px;">
    <label style="font-size:11px; color:var(--textSec); margin-top:8px; display:block;">Pourboire (%)</label>
    <input type="number" id="bs-tip" class="input" value="0" oninput="bsCalc()" style="margin-top:4px;">
    <label style="font-size:11px; color:var(--textSec); margin-top:8px; display:block;">Nombre de personnes</label>
    <input type="number" id="bs-people" class="input" value="2" min="1" oninput="bsCalc()" style="margin-top:4px;">
  </div>
  <div id="bs-result" style="margin-top:14px;"></div>`;
  document.getElementById('billsplit-content').innerHTML = html;
}
function bsCalc() {
  const total = parseFloat(document.getElementById('bs-total').value);
  const tip = parseFloat(document.getElementById('bs-tip').value) || 0;
  const ppl = parseInt(document.getElementById('bs-people').value) || 1;
  if (isNaN(total) || total <= 0) { document.getElementById('bs-result').innerHTML = ''; return; }
  const tipAmount = total * tip / 100;
  const grandTotal = total + tipAmount;
  const perPerson = grandTotal / ppl;
  document.getElementById('bs-result').innerHTML = `<div style="background:linear-gradient(135deg,#FFD166,#5DD68F); color:white; padding:24px; border-radius:18px; text-align:center;">
    <div style="font-size:11px; opacity:0.9;">Par personne</div>
    <div style="font-size:42px; font-weight:900;">${perPerson.toFixed(2)}€</div>
  </div>
  <div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:8px;">
    <div style="display:flex; justify-content:space-between; margin-top:4px;"><span>Sous-total</span><strong>${total.toFixed(2)}€</strong></div>
