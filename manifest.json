function openPlaylistModal(playlist) {
  player.editingPlaylist = playlist;
  document.getElementById('playlist-modal-title').textContent = playlist ? 'Modifier' : 'Nouvelle playlist';
  document.getElementById('playlist-name-input').value = playlist ? playlist.name : '';
  document.getElementById('playlist-desc-input').value = playlist ? (playlist.description||'') : '';
  document.getElementById('playlist-del-btn').style.display = playlist ? 'inline-flex' : 'none';
  openModal('modal-playlist');
}

async function savePlaylist() {
  const name = document.getElementById('playlist-name-input').value.trim();
  const desc = document.getElementById('playlist-desc-input').value.trim();
  if (!name) { alert('Donne un nom.'); return; }
  if (player.editingPlaylist) {
    await dbPut('playlists', { ...player.editingPlaylist, name, description: desc });
  } else {
    await dbAdd('playlists', { name, description: desc, created_at: new Date().toISOString() });
  }
  closeModal('modal-playlist');
  renderPlaylists();
}

async function deletePlaylistNow() {
  if (!confirm(`Supprimer "${player.editingPlaylist.name}" ?`)) return;
  const links = await dbAll('playlist_tracks');
  for (const l of links.filter(x => x.playlist_id === player.editingPlaylist.id)) await dbDel('playlist_tracks', l.key);
  await dbDel('playlists', player.editingPlaylist.id);
  closeModal('modal-playlist');
  renderPlaylists();
}

async function openPlaylistDetail(playlist) {
  player.currentPlaylist = playlist;
  document.getElementById('playlist-detail-title').textContent = playlist.name;
  const links = await dbAll('playlist_tracks');
  const tracks = await dbAll('tracks');
  const myLinks = links.filter(l => l.playlist_id === playlist.id).sort((a,b)=>(a.added_at||'').localeCompare(b.added_at||''));
  const myTracks = myLinks.map(l => tracks.find(t => t.id === l.track_id)).filter(Boolean);
  const el = document.getElementById('playlist-tracks');
  el.innerHTML = '';
  if (myTracks.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">🎵</div><h3>Playlist vide</h3><p>Ajoute des pistes depuis le menu (⋯) d'une piste.</p></div>`;
  }
  for (const t of myTracks) {
    const row = document.createElement('button');
    row.className = 'track-row';
    row.innerHTML = `
      <div class="track-cover" style="background-image:url('${t.cover || (typeof v60_generateCoverFallback==='function' ? v60_generateCoverFallback(t.title, t.artist) : '')}')">${t.cover ? '' : ''}</div>
      <div class="track-info">
        <div class="track-title">${escapeHtml(t.title)}</div>
        <div class="track-meta">${escapeHtml(t.artist || 'Artiste inconnu')}</div>
      </div>
      <button class="track-btn" data-act="remove">×</button>
    `;
    row.onclick = async (ev) => {
      if (ev.target.dataset.act === 'remove') {
        const k = `${playlist.id}_${t.id}`;
        await dbDel('playlist_tracks', k);
        openPlaylistDetail(playlist);
        return;
      }
      playFromLibrary(t.id, myTracks.map(x => x.id));
    };
    el.appendChild(row);
  }
  goTo('playlist-detail');
}

function playPlaylistFromStart() {
  if (!player.currentPlaylist) return;
  dbAll('playlist_tracks').then(async (links) => {
    const ids = links.filter(l => l.playlist_id === player.currentPlaylist.id).sort((a,b)=>(a.added_at||'').localeCompare(b.added_at||'')).map(l => l.track_id);
    if (ids.length === 0) { toast('Playlist vide'); return; }
    await playFromQueue(ids, 0);
  });
}

function editCurrentPlaylist() {
  if (player.currentPlaylist) openPlaylistModal(player.currentPlaylist);
}

async function openPlaylistAdd() {
  const tid = player.trackMenuId || (player.currentTrack && player.currentTrack.id);
  if (!tid) return;
  closeModal('modal-track-menu');
  const playlists = await dbAll('playlists');
  const links = await dbAll('playlist_tracks');
  const list = document.getElementById('playlist-add-list');
  list.innerHTML = '';
  if (playlists.length === 0) {
    list.innerHTML = `<p style="color:var(--textSec); padding:16px; text-align:center;">Aucune playlist. Crée-en une depuis "Playlists".</p>`;
  }
  for (const p of playlists) {
    const inPlaylist = links.some(l => l.playlist_id === p.id && l.track_id === tid);
    const r = document.createElement('button');
    r.className = 'list-row';
    r.innerHTML = `
      <div style="width:36px; height:36px; border-radius:10px; background:linear-gradient(135deg, var(--primary), var(--accent)); display:flex; align-items:center; justify-content:center; font-size:18px; color:white;">📃</div>
      <div class="info"><div class="name">${escapeHtml(p.name)}</div></div>
      <div style="width:24px; height:24px; border-radius:6px; border:2px solid var(--border); display:flex; align-items:center; justify-content:center; ${inPlaylist?'background:var(--primary); border-color:var(--primary); color:white;':''}">${inPlaylist?'✓':''}</div>
    `;
    r.onclick = async () => {
      const k = `${p.id}_${tid}`;
      if (inPlaylist) {
        await dbDel('playlist_tracks', k);
      } else {
        await dbAdd('playlist_tracks', { key: k, playlist_id: p.id, track_id: tid, added_at: new Date().toISOString() });
      }
      openPlaylistAdd();
    };
    list.appendChild(r);
  }
  openModal('modal-playlist-add');
}

// ----- iOS background hack: keep audio context active -----
// On iOS, audio in PWAs gets suspended. There's no perfect fix, but
// using audio element directly (not WebAudio) gives the best chance.
// We also try to keep the page from being throttled.
let wakeLock = null;
async function tryWakeLock() {
  try {
    if ('wakeLock' in navigator) {
      wakeLock = await navigator.wakeLock.request('screen');
    }
  } catch (e) {}
}
audioEl.addEventListener('play', () => tryWakeLock());
audioEl.addEventListener('pause', () => { if (wakeLock) { wakeLock.release().catch(()=>{}); wakeLock = null; } });
document.addEventListener('visibilitychange', () => {
  if (document.visibilityState === 'visible' && audioEl.paused === false) tryWakeLock();
});


