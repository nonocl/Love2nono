function renderDice() {
  let html = `<div style="background:linear-gradient(135deg,#E14D6B,#FF6FA3); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🎲</div><div style="font-size:16px; font-weight:800;">Dé virtuel</div>
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">Type de dé</h3>
  <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:6px; margin-top:6px;">
    ${[4,6,8,10,12,20,100].map(n => `<button class="btn alt dice-btn" onclick="diceSet(${n})" data-n="${n}">D${n}</button>`).join('')}
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">Nombre de dés</h3>
  <input type="number" id="dice-n" class="input" value="1" min="1" max="20" inputmode="numeric">
  <input type="hidden" id="dice-faces" value="6">
  <button class="btn primary full" onclick="diceRoll()" style="margin-top:14px; padding:18px;">🎲 Lancer</button>
  <div id="dice-result" style="margin-top:14px;"></div>`;
  document.getElementById('dice-content').innerHTML = html;
  diceSet(6);
}
function diceSet(n) {
  document.getElementById('dice-faces').value = n;
  document.querySelectorAll('.dice-btn').forEach(b => {
    if (parseInt(b.dataset.n) === n) { b.classList.remove('alt'); b.classList.add('primary'); }
    else { b.classList.remove('primary'); b.classList.add('alt'); }
  });
}
function diceRoll() {
  const n = parseInt(document.getElementById('dice-n').value) || 1;
  const f = parseInt(document.getElementById('dice-faces').value);
  const rolls = [];
  for (let i = 0; i < Math.min(n, 20); i++) rolls.push(Math.floor(Math.random() * f) + 1);
  const total = rolls.reduce((s, r) => s + r, 0);
  document.getElementById('dice-result').innerHTML = `<div style="background:var(--surface); padding:18px; border-radius:14px; text-align:center;">
    <div style="font-size:11px; color:var(--textSec);">${n} × D${f}</div>
    <div style="display:flex; flex-wrap:wrap; gap:6px; justify-content:center; margin-top:10px;">
      ${rolls.map(r => `<div style="background:var(--bg); width:50px; height:50px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:20px; font-weight:900; color:var(--primary);">${r}</div>`).join('')}
    </div>
    ${n > 1 ? `<div style="margin-top:14px; font-size:32px; font-weight:900; color:var(--primary);">Total : ${total}</div>` : ''}
  </div>`;
  if (navigator.vibrate) navigator.vibrate(15);
}

