let _vocabCat = 'base';
function renderVocabChips() {
  const chips = document.getElementById('vocab-chips');
  chips.innerHTML = '';
  const labels = { base:'💬 Base', famille:'👨‍👩‍👧 Famille', scuola:'🏫 École', citta:'🏙️ Ville', passioni:'💖 Passions', cibo:'🍕 Nourriture', tempo:'📅 Temps' };
  for (const [k, lbl] of Object.entries(labels)) {
    chips.appendChild(createChip(lbl, null, null, _vocabCat===k, () => { _vocabCat=k; renderVocab(); renderVocabChips(); }));
  }
}
function renderVocab() {
  renderVocabChips();
  const search = document.getElementById('vocab-search').value.toLowerCase();
  const list = (VOCAB_IT[_vocabCat] || []).filter(w => !search || w.it.toLowerCase().includes(search) || w.fr.toLowerCase().includes(search));
  const el = document.getElementById('vocab-list');
  el.innerHTML = '';
  list.forEach(w => {
    const row = document.createElement('div');
    row.style.cssText = 'background:var(--surface); padding:12px; border-radius:10px; margin-bottom:6px; display:flex; align-items:center; gap:10px;';
    row.innerHTML = `
      <div style="flex:1; min-width:0;">
        <div style="font-weight:700; color:var(--primary); font-size:15px;">${escapeHtml(w.it)}</div>
        <div style="font-size:13px; color:var(--textSec); margin-top:2px;">${escapeHtml(w.fr)}</div>
      </div>
      <button class="btn alt" style="padding:6px 10px;" onclick="ttsItalian('${escapeHtml(w.it).replace(/'/g, "\\'")}')">🔊</button>
    `;
    el.appendChild(row);
  });
  if (list.length === 0) {
    el.innerHTML = `<p style="text-align:center; color:var(--textSec); padding:30px 0;">Aucun mot trouvé.</p>`;
  }
}
function ttsItalian(text) {
  if (!('speechSynthesis' in window)) { toast('TTS non supporté'); return; }
  const u = new SpeechSynthesisUtterance(text);
  u.lang = 'it-IT';
  u.rate = 0.9;
  speechSynthesis.cancel();
  speechSynthesis.speak(u);
}

// Quiz vocab
let _vquizDeck = []; let _vquizIdx = 0; let _vquizCorrect = 0;
function quizVocab() {
  // Build deck from current category
  _vquizDeck = (VOCAB_IT[_vocabCat] || []).slice().sort(() => Math.random()-0.5);
  _vquizIdx = 0; _vquizCorrect = 0;
  if (_vquizDeck.length === 0) { toast('Aucun mot dans cette catégorie'); return; }
  showVquizCard();
  openModal('modal-vocab-quiz');
}
function showVquizCard() {
  if (_vquizIdx >= _vquizDeck.length) {
    document.getElementById('vquiz-it').textContent = '🎉';
    document.getElementById('vquiz-fr').style.display = 'block';
    document.getElementById('vquiz-fr').textContent = `Quiz fini : ${_vquizCorrect}/${_vquizDeck.length}`;
    document.getElementById('vquiz-actions').style.display = 'none';
    document.getElementById('vquiz-reveal-btn').textContent = 'Recommencer';
    document.getElementById('vquiz-reveal-btn').onclick = () => quizVocab();
    return;
  }
  const w = _vquizDeck[_vquizIdx];
  document.getElementById('vquiz-it').textContent = w.it;
  document.getElementById('vquiz-fr').textContent = w.fr;
  document.getElementById('vquiz-fr').style.display = 'none';
  document.getElementById('vquiz-stats').textContent = `${_vquizIdx + 1}/${_vquizDeck.length} · ${_vquizCorrect} sus`;
  document.getElementById('vquiz-reveal-btn').style.display = 'inline-flex';
  document.getElementById('vquiz-reveal-btn').textContent = 'Révéler';
  document.getElementById('vquiz-reveal-btn').onclick = vquizReveal;
  document.getElementById('vquiz-actions').style.display = 'none';
}
function vquizReveal() {
  document.getElementById('vquiz-fr').style.display = 'block';
  document.getElementById('vquiz-reveal-btn').style.display = 'none';
  document.getElementById('vquiz-actions').style.display = 'flex';
}
function vquizNext(correct) {
  if (correct) _vquizCorrect++;
  _vquizIdx++;
  showVquizCard();
}

