let _editingMusicCat = null;
let _musicCatColor = '#FF6FA3';
let _musicCatIcon = '';

async function renderMusicCats() {
  const cats = await dbAll('music_cats');
  const links = await dbAll('track_cats');
  const el = document.getElementById('music-cats-list');
  el.innerHTML = '';
