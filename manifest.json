function dpHit(i) {
  DP_PADS[i].play();
  if (_dp.recording) _dp.events.push({ pad: i, t: Date.now() - _dp.recStart });
  // Visual feedback
  const btn = document.querySelectorAll('#dp-grid button')[i];
  btn.style.transform = 'scale(0.92)';
  setTimeout(() => btn.style.transform = '', 80);
}
function dpToggleRec() {
  if (_dp.recording) {
    _dp.recording = false;
    document.getElementById('dp-rec-btn').innerHTML = '⏺ Enregistrer';
    document.getElementById('dp-rec-info').textContent = `📼 ${_dp.events.length} hits enregistrés`;
  } else {
    _dp.recording = true;
    _dp.events = [];
    _dp.recStart = Date.now();
    document.getElementById('dp-rec-btn').innerHTML = '⏹ Stop';
    document.getElementById('dp-rec-info').textContent = '🔴 Enregistrement...';
  }
}
function dpPlayback() {
  if (!_dp.events.length) return toast('Rien à rejouer');
  for (const ev of _dp.events) setTimeout(() => DP_PADS[ev.pad].play(), ev.t);
  toast('▶ Lecture');
}
function dpClearRec() {
  _dp.events = [];
  document.getElementById('dp-rec-info').textContent = '';
  toast('🗑 Effacé');
}

