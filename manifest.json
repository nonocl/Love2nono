const v52_ASCII_FONTS = {
  block: { 'A':' ▄▄▄ \n█   █\n█▀▀▀█\n█   █', 'B':'█▀▀▄ \n█▄▄▀ \n█  █ \n█▄▄▀ ', 'C':' ▄▄▄ \n█    \n█    \n ▀▀▀ ', 'D':'█▀▀▄ \n█  █ \n█  █ \n█▄▄▀ ', 'E':'█▀▀▀\n█▀▀ \n█▀▀ \n█▄▄▄', 'F':'█▀▀▀\n█▀▀ \n█▀▀ \n█   ', 'G':' ▄▄▄ \n█    \n█  ▀█\n ▀▀▀▀', 'H':'█   █\n█▀▀▀█\n█   █\n█   █', 'I':'▐▌\n▐▌\n▐▌\n▐▌', 'O':' ▄▄▄ \n█   █\n█   █\n ▀▀▀ ', 'L':'█    \n█    \n█    \n█▄▄▄ ', 'N':'█▄  █\n█ █ █\n█  ██\n█   █', 'M':'█▄ ▄█\n█ █ █\n█   █\n█   █', 'R':'█▀▀▄ \n█▄▄▀ \n█  █ \n█  █ ', 'S':' ▄▄▄ \n█    \n ▀▀▄ \n▄▄▄▀ ', 'T':'▀▀█▀▀\n  █  \n  █  \n  █  ', 'U':'█   █\n█   █\n█   █\n ▀▀▀ ', 'V':'█   █\n█   █\n ▀▄▀ \n  ▀  ', 'W':'█   █\n█   █\n█ █ █\n ▀ ▀ ', 'X':'█   █\n ▀▄▀ \n ▄▀▄ \n█   █', 'Y':'█   █\n ▀▄▀ \n  █  \n  █  ', 'Z':'▀▀▀▀█\n   ▀ \n  ▀  \n█▀▀▀▀', '0':' ▄▄▄ \n█   █\n█   █\n ▀▀▀ ', '1':' ▄█  \n  █  \n  █  \n ▄█▄ ', '2':' ▄▄▄ \n   █ \n  ▀  \n▄▄▄▄ ', '3':' ▄▄▄ \n   █ \n  ▀▀ \n▄▄▄▀ ', ' ':'   \n   \n   \n   ', '!':' █ \n █ \n   \n █ ', '?':' ▄▄▄\n   █\n  ▀ \n  █ ' }
};
function renderAsciiArt() {
  let html = `<div style="background:linear-gradient(135deg,#787C7E,#9B59B6); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🅰️</div><div style="font-size:16px; font-weight:800;">ASCII art generator</div>
  </div>
  <input type="text" id="ascii-text" class="input" placeholder="HELLO" oninput="asciiGen()" style="margin-top:14px; text-transform:uppercase;" maxlength="20">
  <div id="ascii-output" style="margin-top:14px;"></div>`;
  document.getElementById('asciiart-content').innerHTML = html;
}
function asciiGen() {
  const t = document.getElementById('ascii-text').value.toUpperCase();
  if (!t) { document.getElementById('ascii-output').innerHTML = ''; return; }
  const font = v52_ASCII_FONTS.block;
  const lines = ['', '', '', ''];
  for (const ch of t) {
    const letter = font[ch] || font[' '];
    const parts = letter.split('\n');
    for (let i = 0; i < 4; i++) lines[i] += (parts[i] || '   ') + ' ';
  }
  const result = lines.join('\n');
  document.getElementById('ascii-output').innerHTML = `<pre style="background:var(--surface); padding:14px; border-radius:10px; font-family:monospace; font-size:14px; line-height:1.1; overflow-x:auto;">${escapeHtml(result)}</pre>
  <button class="btn alt full" onclick="navigator.clipboard.writeText(${JSON.stringify(result).replace(/'/g,'&#39;')}); toast('📋 Copié');" style="margin-top:8px;">📋 Copier</button>`;
}

