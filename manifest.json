// === REACTION TIME ===
let _reactionState = 'idle'; // idle, waiting, ready, done
let _reactionStart = 0;
let _reactionTimeout = null;
let _reactionScores = [];

function reactionClick() {
  const area = document.getElementById('reaction-area');
  const text = document.getElementById('reaction-text');
  
  if (_reactionState === 'idle') {
    _reactionState = 'waiting';
    area.style.background = '#FF4757';
    text.textContent = 'Attends...';
    const delay = 1000 + Math.random() * 3000;
    _reactionTimeout = setTimeout(() => {
      _reactionState = 'ready';
      area.style.background = '#5DD68F';
      text.textContent = 'TAP !';
      _reactionStart = Date.now();
    }, delay);
  } else if (_reactionState === 'waiting') {
    clearTimeout(_reactionTimeout);
    _reactionState = 'idle';
    area.style.background = '#FFD166';
    text.textContent = 'Trop tôt ! Tap pour réessayer';
  } else if (_reactionState === 'ready') {
    const time = Date.now() - _reactionStart;
    _reactionState = 'done';
    _reactionScores.push(time);
    if (_reactionScores.length > 10) _reactionScores.shift();
    area.style.background = '#5DADE2';
    text.innerHTML = `${time} ms<br><span style="font-size:13px; opacity:0.85;">Tap pour rejouer</span>`;
    renderReactionStats();
  } else if (_reactionState === 'done') {
    _reactionState = 'idle';
    area.style.background = '#FF4757';
    text.textContent = 'Tap pour démarrer';
  }
}

function renderReactionStats() {
  let best = parseInt(localStorage.getItem('nw_reaction_best') || '99999');
  if (_reactionScores.length) {
    const last = _reactionScores[_reactionScores.length - 1];
    if (last < best) {
      best = last;
      localStorage.setItem('nw_reaction_best', best);
    }
  }
  const avg = _reactionScores.length ? Math.round(_reactionScores.reduce((s,x)=>s+x,0) / _reactionScores.length) : 0;
  const html = `<div style="display:flex; justify-content:space-around; margin-top:10px;">
    <div><div style="font-size:10px; color:var(--textSec);">Dernière</div><div style="font-size:22px; font-weight:900;">${_reactionScores.length ? _reactionScores[_reactionScores.length-1] + ' ms' : '—'}</div></div>
    <div><div style="font-size:10px; color:var(--textSec);">Moyenne</div><div style="font-size:22px; font-weight:900;">${avg ? avg + ' ms' : '—'}</div></div>
    <div><div style="font-size:10px; color:var(--textSec);">Best</div><div style="font-size:22px; font-weight:900; color:var(--success);">${best < 99999 ? best + ' ms' : '—'}</div></div>
  </div>
  ${_reactionScores.length ? `<div style="font-size:11px; color:var(--textSec); margin-top:10px; text-align:center;">Note : moins de 200ms = pro · 200-300 = bon · 300-400 = moyen</div>` : ''}`;
  document.getElementById('reaction-stats').innerHTML = html;
}

function initReaction() {
  _reactionState = 'idle';
  _reactionScores = [];
  document.getElementById('reaction-area').style.background = '#FF4757';
  document.getElementById('reaction-text').textContent = 'Tap pour démarrer';
  renderReactionStats();
}

// === HIGHER OR LOWER ===
let _hiloCard = null;
let _hiloScore = 0;
function hiloDraw() {
  return Math.floor(Math.random() * 13) + 1; // 1-13
}
function hiloCardName(n) {
  if (n === 1) return 'A';
  if (n === 11) return 'J';
  if (n === 12) return 'Q';
  if (n === 13) return 'K';
  return n;
}
function hiloRender() {
  const suits = ['♠','♥','♦','♣'];
  const suit = suits[Math.floor(Math.random() * 4)];
  const isRed = suit === '♥' || suit === '♦';
  document.getElementById('hilo-card').innerHTML = `<div style="font-size:54px; font-weight:900; color:${isRed ? '#E74C3C' : '#1A1A1A'};">${hiloCardName(_hiloCard)}</div><div style="font-size:36px; color:${isRed ? '#E74C3C' : '#1A1A1A'};">${suit}</div>`;
  document.getElementById('hilo-score').textContent = _hiloScore;
  document.getElementById('hilo-best').textContent = localStorage.getItem('nw_hilo_best') || 0;
}
function hiloNew() {
  _hiloScore = 0;
  _hiloCard = hiloDraw();
  document.getElementById('hilo-result').textContent = '';
  hiloRender();
}
function hiloGuess(direction) {
  const next = hiloDraw();
  let win = false;
  if (next === _hiloCard) win = true; // égalité = gagne
  else if (direction === 'higher' && next > _hiloCard) win = true;
  else if (direction === 'lower' && next < _hiloCard) win = true;
  
  const oldCard = _hiloCard;
  _hiloCard = next;
  hiloRender();
  
  if (win) {
    _hiloScore++;
    document.getElementById('hilo-score').textContent = _hiloScore;
    document.getElementById('hilo-result').innerHTML = `<span style="color:var(--success);">✓ ${hiloCardName(oldCard)} → ${hiloCardName(next)}</span>`;
    const best = parseInt(localStorage.getItem('nw_hilo_best') || '0');
    if (_hiloScore > best) localStorage.setItem('nw_hilo_best', _hiloScore);
  } else {
    document.getElementById('hilo-result').innerHTML = `<span style="color:var(--danger);">✗ ${hiloCardName(oldCard)} → ${hiloCardName(next)} - Game over !</span>`;
    setTimeout(() => hiloNew(), 1500);
  }
}

// === BREAKOUT ===
let _bo = null;
function breakoutInit() {
  const c = document.getElementById('breakout-canvas');
  const ctx = c.getContext('2d');
  _bo = {
    ctx, c,
    paddle: { x: 130, y: 380, w: 60, h: 8 },
    ball: { x: 150, y: 200, dx: 2, dy: -2, r: 6 },
    bricks: [],
    score: 0,
    lives: 3,
    running: true,
    rafId: null
  };
  // Build bricks 6x4
  for (let r = 0; r < 4; r++) {
    for (let cc = 0; cc < 6; cc++) {
      _bo.bricks.push({
        x: 10 + cc * 47, y: 30 + r * 22, w: 42, h: 18,
        color: ['#FF4757','#FF8C42','#FFD166','#5DD68F'][r], hit: false
      });
    }
  }
  document.getElementById('bo-score').textContent = '0';
  document.getElementById('bo-lives').textContent = '3';
  
  // Touch handler
  if (!c._touchInit) {
    c.addEventListener('touchmove', e => {
      e.preventDefault();
      const rect = c.getBoundingClientRect();
      const x = e.touches[0].clientX - rect.left;
      const ratio = c.width / rect.width;
      _bo.paddle.x = Math.max(0, Math.min(c.width - _bo.paddle.w, x * ratio - _bo.paddle.w / 2));
    });
    c.addEventListener('mousemove', e => {
      const rect = c.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const ratio = c.width / rect.width;
      _bo.paddle.x = Math.max(0, Math.min(c.width - _bo.paddle.w, x * ratio - _bo.paddle.w / 2));
    });
    c._touchInit = true;
  }
  
  if (_bo.rafId) cancelAnimationFrame(_bo.rafId);
  breakoutLoop();
}
function breakoutLoop() {
  if (!_bo) return;
  const { ctx, c, paddle, ball, bricks } = _bo;
  ctx.clearRect(0, 0, c.width, c.height);
  
  // Ball
  ball.x += ball.dx; ball.y += ball.dy;
  if (ball.x - ball.r < 0 || ball.x + ball.r > c.width) ball.dx = -ball.dx;
  if (ball.y - ball.r < 0) ball.dy = -ball.dy;
  if (ball.y + ball.r > c.height) {
    _bo.lives--;
    document.getElementById('bo-lives').textContent = _bo.lives;
    if (_bo.lives <= 0) {
      _bo.running = false;
      ctx.fillStyle = 'rgba(0,0,0,0.7)';
      ctx.fillRect(0, 0, c.width, c.height);
      ctx.fillStyle = '#FF4757'; ctx.font = '24px sans-serif'; ctx.textAlign = 'center';
      ctx.fillText('Game Over', c.width / 2, c.height / 2);
      ctx.fillStyle = '#fff'; ctx.font = '14px sans-serif';
      ctx.fillText('Score: ' + _bo.score, c.width / 2, c.height / 2 + 30);
      const best = parseInt(localStorage.getItem('nw_breakout_best') || '0');
      if (_bo.score > best) localStorage.setItem('nw_breakout_best', _bo.score);
      return;
    }
    ball.x = c.width / 2; ball.y = c.height / 2;
    ball.dx = 2; ball.dy = -2;
  }
  
  // Paddle collision
  if (ball.y + ball.r > paddle.y && ball.x > paddle.x && ball.x < paddle.x + paddle.w) {
    ball.dy = -Math.abs(ball.dy);
    // Petit angle selon position
    const offset = (ball.x - (paddle.x + paddle.w / 2)) / (paddle.w / 2);
    ball.dx = offset * 3;
  }
  
  // Bricks collision
  for (const b of bricks) {
    if (b.hit) continue;
    if (ball.x > b.x && ball.x < b.x + b.w && ball.y > b.y && ball.y < b.y + b.h) {
      b.hit = true;
      ball.dy = -ball.dy;
      _bo.score += 10;
      document.getElementById('bo-score').textContent = _bo.score;
    }
  }
  
  // Win check
  if (bricks.every(b => b.hit)) {
    _bo.running = false;
    ctx.fillStyle = '#5DD68F'; ctx.font = '24px sans-serif'; ctx.textAlign = 'center';
    ctx.fillText('🎉 Win !', c.width / 2, c.height / 2);
    return;
  }
  
  // Draw bricks
  for (const b of bricks) {
    if (b.hit) continue;
    ctx.fillStyle = b.color;
    ctx.fillRect(b.x, b.y, b.w, b.h);
  }
  
  // Draw paddle
  ctx.fillStyle = '#FF6FA3';
  ctx.fillRect(paddle.x, paddle.y, paddle.w, paddle.h);
  
  // Draw ball
  ctx.fillStyle = '#FFD166';
  ctx.beginPath(); ctx.arc(ball.x, ball.y, ball.r, 0, Math.PI*2); ctx.fill();
  
  if (_bo.running) _bo.rafId = requestAnimationFrame(breakoutLoop);
}

// === COLOR MATCH (Stroop test) ===
const CM_COLORS = [
  {name:'rouge', hex:'#E74C3C'},
  {name:'bleu', hex:'#3498DB'},
  {name:'vert', hex:'#2ECC71'},
  {name:'jaune', hex:'#F1C40F'},
  {name:'violet', hex:'#9B59B6'},
  {name:'orange', hex:'#E67E22'}
];
let _cm = null;
function colorMatchInit() {
  _cm = { score: 0, time: 30, currentMatch: false, timer: null };
  document.getElementById('cm-score').textContent = '0';
  document.getElementById('cm-time').textContent = '30';
  document.getElementById('cm-best').textContent = localStorage.getItem('nw_colormatch_best') || '0';
  cmNext();
  if (_cm.timer) clearInterval(_cm.timer);
  _cm.timer = setInterval(() => {
    if (!_cm) return;
    _cm.time--;
    document.getElementById('cm-time').textContent = _cm.time;
    if (_cm.time <= 0) {
      clearInterval(_cm.timer);
      const best = parseInt(localStorage.getItem('nw_colormatch_best') || '0');
      if (_cm.score > best) localStorage.setItem('nw_colormatch_best', _cm.score);
      document.getElementById('cm-word').innerHTML = `<div style="font-size:24px;">Game Over</div><div style="font-size:16px; margin-top:8px;">Score : ${_cm.score}</div>`;
      _cm = null;
    }
  }, 1000);
}
function cmNext() {
  if (!_cm) return;
  const word = CM_COLORS[Math.floor(Math.random() * CM_COLORS.length)];
  const colorObj = CM_COLORS[Math.floor(Math.random() * CM_COLORS.length)];
  _cm.currentMatch = (word.name === colorObj.name);
  document.getElementById('cm-word').innerHTML = `<span style="color:${colorObj.hex};">${word.name}</span>`;
}
function cmAnswer(answer) {
  if (!_cm) return;
  if (answer === _cm.currentMatch) {
    _cm.score++;
    document.getElementById('cm-score').textContent = _cm.score;
  } else {
    _cm.score = Math.max(0, _cm.score - 1);
    document.getElementById('cm-score').textContent = _cm.score;
  }
  cmNext();
}

