function renderTipCalc() {
  let html = `<div style="background:linear-gradient(135deg,#5DD68F,#06FFA5); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">💵</div><div style="font-size:16px; font-weight:800;">Pourboire & split</div>
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">💰 Montant total</h3>
  <input type="number" id="tip-bill" class="input" placeholder="89.50" oninput="tipCalc()" inputmode="decimal">
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">% pourboire</h3>
  <div style="display:grid; grid-template-columns:repeat(5,1fr); gap:6px; margin-top:6px;">
    ${[0,5,10,15,20].map(p => `<button class="btn alt tip-btn" onclick="tipSet(${p})" data-p="${p}">${p}%</button>`).join('')}
  </div>
  <input type="number" id="tip-pct" class="input" value="15" oninput="tipCalc()" style="margin-top:6px;" inputmode="decimal">
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">👥 Nombre de personnes</h3>
