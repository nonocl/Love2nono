async function deletePfpAct() {
  if (!confirm('Supprimer cette PFP ?')) return;
  const links = await dbAll('pfp_cats');
  for (const l of links.filter(x => x.pfp_id === state.detailPfpId)) await dbDel('pfp_cats', l.key);
  const aLinks = await dbAll('pfp_albums');
  for (const l of aLinks.filter(x => x.pfp_id === state.detailPfpId)) await dbDel('pfp_albums', l.key);
  await dbDel('pfps', state.detailPfpId);
  goTo('gallery');
  toast('PFP supprimée');
}

function dataUrlToBlob(dataUrl) {
  const arr = dataUrl.split(',');
  const mime = arr[0].match(/:(.*?);/)[1];
  const bstr = atob(arr[1]);
  let n = bstr.length;
  const u8 = new Uint8Array(n);
  while (n--) u8[n] = bstr.charCodeAt(n);
  return new Blob([u8], { type: mime });
}

async function sharePfp() {
  const pfp = await dbGet('pfps', state.detailPfpId);
  const blob = dataUrlToBlob(pfp.uri);
  const file = new File([blob], 'pfp.jpg', { type: blob.type });
  if (navigator.canShare?.({ files: [file] })) {
    try { await navigator.share({ files: [file] }); } catch (e) {}
  } else {
    const url = URL.createObjectURL(blob);
    window.open(url, '_blank');
  }
}

async function savePfpToGallery() {
  const pfp = await dbGet('pfps', state.detailPfpId);
  const blob = dataUrlToBlob(pfp.uri);
  const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent);
  const url = URL.createObjectURL(blob);
  if (isIOS) {
    window.open(url, '_blank');
    toast('Maintiens et tape "Ajouter aux Photos"', 4000);
  } else {
    const a = document.createElement('a');
    a.href = url; a.download = `pfp_${Date.now()}.jpg`;
    document.body.appendChild(a); a.click(); a.remove();
    toast('Téléchargé ✨');
  }
}

