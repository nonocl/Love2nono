const MOOD_EMOJIS = ['😄','😊','😐','😔','😢','😡','🥰','😴','🤩','🥺'];
async function renderMood() {
  // Selector
  const ee = document.getElementById('mood-emojis');
  ee.innerHTML = '';
  for (const e of MOOD_EMOJIS) {
    const b = document.createElement('button');
    b.className = 'mood-emoji' + (e === state.selectedMood ? ' selected' : '');
    b.textContent = e;
    b.onclick = () => { state.selectedMood = e; renderMood(); };
    ee.appendChild(b);
  }
  // Grid this month
  const moods = await dbAll('moods');
  const now = new Date();
  const month = now.getMonth(), year = now.getFullYear();
  const daysInMonth = new Date(year, month+1, 0).getDate();
  document.getElementById('mood-month-title').textContent = now.toLocaleDateString('fr-FR', { month:'long', year:'numeric' });
  const grid = document.getElementById('mood-grid');
  grid.innerHTML = '';
  for (let d=1; d<=daysInMonth; d++) {
    const dateStr = `${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const mood = moods.find(m => m.date === dateStr);
    const cell = document.createElement('div');
    cell.className = 'mood-day';
    cell.innerHTML = `<span class="day-num">${d}</span>${mood ? mood.emoji : ''}`;
    if (mood?.note) cell.title = mood.note;
    grid.appendChild(cell);
  }
  // Today's mood
  const today = new Date().toISOString().split('T')[0];
  const todayMood = moods.find(m => m.date === today);
  if (todayMood && !state.selectedMood) {
    state.selectedMood = todayMood.emoji;
    document.getElementById('mood-note').value = todayMood.note || '';
    renderMood();
  }
}
async function saveMood() {
  if (!state.selectedMood) { alert('Choisis une humeur.'); return; }
  const today = new Date().toISOString().split('T')[0];
  const note = document.getElementById('mood-note').value.trim();
  const moods = await dbAll('moods');
  const existing = moods.find(m => m.date === today);
  if (existing) await dbPut('moods', { ...existing, emoji: state.selectedMood, note });
  else await dbAdd('moods', { date: today, emoji: state.selectedMood, note });
  toast('Humeur enregistrée ✨');
  renderMood();
}

