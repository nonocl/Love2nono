// === 21. HABIT TRACKER ===
function getHabits() { try { return JSON.parse(localStorage.getItem('nw_habits') || '[]'); } catch { return []; } }
function saveHabits(h) { localStorage.setItem('nw_habits', JSON.stringify(h)); }
function renderHabits() {
  const habits = getHabits();
  const today = new Date().toISOString().slice(0, 10);
  let html = `<div style="background:linear-gradient(135deg,#06FFA5,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">✅</div><div style="font-size:16px; font-weight:800;">Habit tracker</div>
    <div style="font-size:11px; opacity:0.9;">${habits.length} habitudes</div>
  </div>
  <button class="btn primary full" onclick="habitAdd()" style="margin-top:14px;">➕ Nouvelle habitude</button>`;
  habits.forEach((h, i) => {
    const todayDone = h.dates && h.dates.includes(today);
    const last30 = [];
    for (let d = 29; d >= 0; d--) {
      const dt = new Date(); dt.setDate(dt.getDate() - d);
      const ds = dt.toISOString().slice(0, 10);
      last30.push({ ds, done: h.dates && h.dates.includes(ds) });
    }
    const streak = computeStreak(h.dates || []);
    const total = (h.dates || []).length;
    html += `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:8px;">
      <div style="display:flex; justify-content:space-between; align-items:center;">
        <div style="flex:1;">
          <div style="font-size:14px; font-weight:700;">${escapeHtml(h.icon || '⭐')} ${escapeHtml(h.name)}</div>
          <div style="font-size:10px; color:var(--textSec); margin-top:2px;">🔥 ${streak} série · ${total} fois total</div>
        </div>
        <div style="display:flex; gap:6px;">
          <button onclick="habitToggle(${i})" style="background:${todayDone?'#5DD68F':'var(--bg)'}; color:${todayDone?'white':'var(--text)'}; border:1.5px solid var(--border); padding:8px 12px; border-radius:8px; font-weight:700;">${todayDone ? '✓ Fait' : 'Marquer'}</button>
          <button onclick="habitDel(${i})" style="background:none; border:none; color:var(--danger);">✗</button>
        </div>
      </div>
      <div style="display:flex; gap:2px; margin-top:10px; flex-wrap:wrap;">${last30.map(d => `<div style="width:14px; height:14px; background:${d.done ? '#5DD68F' : 'var(--bg)'}; border:1px solid var(--border); border-radius:3px;" title="${d.ds}"></div>`).join('')}</div>
    </div>`;
  });
  document.getElementById('habits-content').innerHTML = html;
}
function habitAdd() {
  const name = prompt('Nom de l\'habitude :');
  if (!name) return;
  const icon = prompt('Emoji (1 caractère) :') || '⭐';
  const habits = getHabits();
  habits.push({ name: name.slice(0, 40), icon, dates: [] });
  saveHabits(habits);
  renderHabits();
}
function habitToggle(i) {
  const habits = getHabits();
  if (!habits[i].dates) habits[i].dates = [];
  const today = new Date().toISOString().slice(0, 10);
  const idx = habits[i].dates.indexOf(today);
  if (idx >= 0) habits[i].dates.splice(idx, 1);
  else habits[i].dates.push(today);
  saveHabits(habits);
  if (navigator.vibrate) navigator.vibrate(10);
  renderHabits();
}
function habitDel(i) {
  if (!confirm('Supprimer cette habitude ?')) return;
  const habits = getHabits();
  habits.splice(i, 1);
  saveHabits(habits);
  renderHabits();
}
function computeStreak(dates) {
  if (!dates.length) return 0;
  const sorted = [...dates].sort();
  let streak = 0;
  let cur = new Date();
  cur.setHours(0, 0, 0, 0);
  while (true) {
    const ds = cur.toISOString().slice(0, 10);
    if (sorted.includes(ds)) { streak++; cur.setDate(cur.getDate() - 1); }
    else if (streak === 0 && cur.toDateString() === new Date().toDateString()) cur.setDate(cur.getDate() - 1);
    else break;
  }
  return streak;
}

// === 22. METRONOME ===
let _metroBpm = 100, _metroInterval = null, _metroBeat = 0, _metroSig = 4;
function renderMetronome() {
  let html = `<div style="background:linear-gradient(135deg,#000,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🎵</div><div style="font-size:16px; font-weight:800;">Métronome</div>
  </div>
  <div style="text-align:center; margin-top:24px;">
    <div id="metro-beat-display" style="display:flex; gap:10px; justify-content:center; margin-bottom:18px;">
      ${Array(_metroSig).fill(0).map((_, i) => `<div id="mb-${i}" style="width:24px; height:24px; border-radius:50%; background:var(--surface); border:2px solid var(--border);"></div>`).join('')}
    </div>
    <div style="font-size:64px; font-weight:900; color:var(--primary);" id="metro-bpm">${_metroBpm}</div>
    <div style="font-size:13px; color:var(--textSec);">BPM</div>
  </div>
  <input type="range" id="metro-slider" min="40" max="240" value="${_metroBpm}" oninput="metroSetBpm(this.value)" style="width:100%; margin-top:14px;">
  <div style="display:grid; grid-template-columns:repeat(5,1fr); gap:6px; margin-top:8px;">
    ${[60,80,100,120,140].map(b => `<button class="btn alt" onclick="metroSetBpm(${b})" style="font-size:11px;">${b}</button>`).join('')}
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">Signature</h3>
  <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:6px; margin-top:6px;">
    ${[2,3,4,6].map(s => `<button class="btn ${s===_metroSig?'primary':'alt'}" onclick="metroSetSig(${s})" style="font-size:13px;">${s}/4</button>`).join('')}
  </div>
  <button class="btn primary full" onclick="metroToggle()" style="margin-top:14px; padding:18px; font-size:16px;">${_metroInterval?'⏸ Stop':'▶️ Start'}</button>`;
  document.getElementById('metronome-content').innerHTML = html;
}
function metroSetBpm(b) {
  _metroBpm = parseInt(b);
  document.getElementById('metro-bpm').textContent = _metroBpm;
  const sl = document.getElementById('metro-slider');
  if (sl && sl.value != _metroBpm) sl.value = _metroBpm;
  if (_metroInterval) { metroToggle(); metroToggle(); }
}
function metroSetSig(s) { _metroSig = s; if (_metroInterval) { metroToggle(); metroToggle(); } else renderMetronome(); }
function metroToggle() {
  if (_metroInterval) {
    clearInterval(_metroInterval); _metroInterval = null; _metroBeat = 0;
    document.querySelectorAll('[id^="mb-"]').forEach(d => d.style.background = 'var(--surface)');
    renderMetronome();
  } else {
    const ms = 60000 / _metroBpm;
    _metroBeat = 0;
    metroTick();
    _metroInterval = setInterval(metroTick, ms);
    renderMetronome();
  }
}
function metroTick() {
  document.querySelectorAll('[id^="mb-"]').forEach(d => d.style.background = 'var(--surface)');
  const dot = document.getElementById('mb-' + _metroBeat);
  if (dot) {
    dot.style.background = _metroBeat === 0 ? '#FF6FA3' : 'var(--primary)';
    setTimeout(() => { if (dot) dot.style.background = 'var(--surface)'; }, 100);
  }
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    const osc = ctx.createOscillator(), gain = ctx.createGain();
    osc.frequency.value = _metroBeat === 0 ? 880 : 440;
    osc.connect(gain); gain.connect(ctx.destination);
    gain.gain.setValueAtTime(0.3, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.05);
    osc.start(); osc.stop(ctx.currentTime + 0.05);
  } catch {}
  _metroBeat = (_metroBeat + 1) % _metroSig;
}

// === 23. PIANO VIRTUEL ===
function v52_renderPiano() {
  const notes = [
    { n: 'Do', f: 261.63, k: 'C' },{ n: 'Do#', f: 277.18, k: 'C#' },
    { n: 'Ré', f: 293.66, k: 'D' },{ n: 'Ré#', f: 311.13, k: 'D#' },
    { n: 'Mi', f: 329.63, k: 'E' },
    { n: 'Fa', f: 349.23, k: 'F' },{ n: 'Fa#', f: 369.99, k: 'F#' },
    { n: 'Sol', f: 392.00, k: 'G' },{ n: 'Sol#', f: 415.30, k: 'G#' },
    { n: 'La', f: 440.00, k: 'A' },{ n: 'La#', f: 466.16, k: 'A#' },
    { n: 'Si', f: 493.88, k: 'B' },
    { n: 'Do', f: 523.25, k: 'C2' }
  ];
  let html = `<div style="background:linear-gradient(135deg,#000,#9B59B6); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🎹</div><div style="font-size:16px; font-weight:800;">Piano virtuel</div>
    <div style="font-size:11px; opacity:0.9;">1 octave + une note</div>
  </div>
  <div style="position:relative; margin-top:24px; padding:14px; background:var(--surface); border-radius:12px;">
    <div style="display:flex; gap:2px; height:140px;">`;
  // White keys only
  notes.filter(n => !n.n.includes('#')).forEach(n => {
    html += `<button onclick="v52_pianoPlay(${n.f})" ontouchstart="v52_pianoPlay(${n.f})" style="flex:1; background:white; border:1px solid #ddd; border-radius:0 0 6px 6px; cursor:pointer; display:flex; align-items:flex-end; justify-content:center; padding-bottom:6px; color:black; font-size:11px; font-weight:700;">${n.n}</button>`;
  });
  html += `</div>
    <div style="position:absolute; top:14px; left:14px; right:14px; height:80px; pointer-events:none;">
      <div style="display:flex; gap:2px; height:100%; pointer-events:none;">`;
  // Black keys overlay
  let pos = 0;
  notes.filter(n => !n.n.includes('#')).forEach((n, i) => {
    const next = notes.filter(x => !x.n.includes('#'))[i + 1];
    if (!next) return;
    // Find black key between n and next
    const idxN = notes.indexOf(n);
    if (idxN + 1 < notes.length && notes[idxN + 1].n.includes('#')) {
      const black = notes[idxN + 1];
      pos++;
      html += `<button onclick="v52_pianoPlay(${black.f})" ontouchstart="v52_pianoPlay(${black.f})" style="position:absolute; left:calc(${(i+1)*100/7}% - 14px); top:0; width:28px; height:80px; background:#222; border:none; border-radius:0 0 4px 4px; cursor:pointer; color:white; font-size:9px; pointer-events:auto;">${black.n}</button>`;
    } else {
      html += '<div style="flex:1;"></div>';
    }
  });
  html += `</div></div></div>`;
  document.getElementById('piano-content').innerHTML = html;
}
function v52_pianoPlay(freq) {
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    const osc = ctx.createOscillator(), gain = ctx.createGain();
    osc.frequency.value = freq;
    osc.type = 'triangle';
    osc.connect(gain); gain.connect(ctx.destination);
    gain.gain.setValueAtTime(0.3, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.6);
    osc.start();
    osc.stop(ctx.currentTime + 0.6);
  } catch {}
  if (navigator.vibrate) navigator.vibrate(5);
}

// === 24. CHRONOMÈTRE CUISINE MULTI ===
let _kitchenTimers = [];
function renderKitchenTimer() {
  let html = `<div style="background:linear-gradient(135deg,#FF8C42,#FFD166); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🍳</div><div style="font-size:16px; font-weight:800;">Timers cuisine multi</div>
    <div style="font-size:11px; opacity:0.9;">Lance plusieurs timers en parallèle</div>
  </div>
  <div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:14px;">
    <input type="text" id="kt-name" class="input" placeholder="Nom (ex: pâtes)" autocomplete="off">
    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:6px; margin-top:6px;">
      <input type="number" id="kt-min" class="input" placeholder="Min" value="5" min="0" inputmode="numeric">
      <input type="number" id="kt-sec" class="input" placeholder="Sec" value="0" min="0" max="59" inputmode="numeric">
      <button class="btn primary" onclick="ktAdd()">▶️ Lancer</button>
    </div>
  </div>
  <div id="kt-list" style="margin-top:14px;"></div>`;
  document.getElementById('kitchentimer-content').innerHTML = html;
  ktUpdate();
}
function ktAdd() {
  const name = document.getElementById('kt-name').value.trim() || 'Timer';
  const min = parseInt(document.getElementById('kt-min').value) || 0;
  const sec = parseInt(document.getElementById('kt-sec').value) || 0;
  const total = min * 60 + sec;
  if (total <= 0) { toast('Durée > 0'); return; }
  _kitchenTimers.push({ name: name.slice(0, 20), endTime: Date.now() + total * 1000, fired: false });
  document.getElementById('kt-name').value = '';
  ktUpdate();
}
function ktUpdate() {
  const list = document.getElementById('kt-list');
  if (!list) return;
  let html = '';
  _kitchenTimers.forEach((t, i) => {
    const remaining = Math.max(0, Math.floor((t.endTime - Date.now()) / 1000));
    const min = Math.floor(remaining / 60), sec = remaining % 60;
    if (remaining === 0 && !t.fired) {
      t.fired = true;
      try {
        const ctx = new (window.AudioContext || window.webkitAudioContext)();
        for (let j = 0; j < 3; j++) {
          const osc = ctx.createOscillator(), gain = ctx.createGain();
          osc.frequency.value = 880; osc.connect(gain); gain.connect(ctx.destination);
          gain.gain.setValueAtTime(0.3, ctx.currentTime + j * 0.4);
          osc.start(ctx.currentTime + j * 0.4); osc.stop(ctx.currentTime + j * 0.4 + 0.3);
        }
      } catch {}
      if (navigator.vibrate) navigator.vibrate([200,100,200]);
      toast('⏰ ' + t.name + ' !');
    }
    const pct = remaining > 0 ? 100 : 0;
    html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px; ${remaining===0?'opacity:0.6;':''}">
      <div style="display:flex; justify-content:space-between; align-items:center;">
        <div style="font-size:13px; font-weight:700;">${escapeHtml(t.name)}</div>
        <div style="display:flex; gap:6px; align-items:center;">
          <div style="font-family:monospace; font-size:18px; font-weight:900; color:${remaining===0?'#5DD68F':'var(--primary)'};">${remaining===0?'🔔 FINI':String(min).padStart(2,'0')+':'+String(sec).padStart(2,'0')}</div>
          <button onclick="ktDel(${i})" style="background:none; border:none; color:var(--danger); font-size:14px;">✗</button>
        </div>
      </div>
    </div>`;
  });
  list.innerHTML = html;
  if (_kitchenTimers.length > 0) setTimeout(ktUpdate, 1000);
}
function ktDel(i) { _kitchenTimers.splice(i, 1); ktUpdate(); }

// === 25. JOURNAL D'INTIMITÉ (chiffré simple par mot de passe) ===
function getDiaryPwd() { return localStorage.getItem('nw_diary_pwd_hash') || ''; }
function setDiaryPwd(p) { return crypto.subtle.digest('SHA-256', new TextEncoder().encode(p)).then(b => { localStorage.setItem('nw_diary_pwd_hash', Array.from(new Uint8Array(b)).map(x => x.toString(16).padStart(2,'0')).join('')); }); }
async function checkDiaryPwd(p) {
  const stored = localStorage.getItem('nw_diary_pwd_hash');
  if (!stored) return false;
  const b = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(p));
  const h = Array.from(new Uint8Array(b)).map(x => x.toString(16).padStart(2,'0')).join('');
  return h === stored;
}
let _diaryUnlocked = false;
function renderDiary() {
  const pwSet = !!localStorage.getItem('nw_diary_pwd_hash');
  let html = `<div style="background:linear-gradient(135deg,#9B59B6,#000); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🔒</div><div style="font-size:16px; font-weight:800;">Journal intime</div>
    <div style="font-size:11px; opacity:0.9;">${pwSet ? 'Protégé par mot de passe' : 'Définis un mot de passe'}</div>
  </div>`;
  if (!pwSet) {
    html += `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:14px;">
      <p style="font-size:11px; color:var(--textSec); line-height:1.5;">⚠️ Le journal est stocké localement chiffré. Si tu oublies le mot de passe, c'est définitivement perdu. Note-le quelque part.</p>
      <input type="password" id="diary-newpwd" class="input" placeholder="Nouveau mot de passe (min 4 car)" style="margin-top:10px;">
      <button class="btn primary full" onclick="diarySetup()" style="margin-top:6px;">🔐 Configurer</button>
    </div>`;
  } else if (!_diaryUnlocked) {
    html += `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:14px;">
      <input type="password" id="diary-pwd" class="input" placeholder="Mot de passe..." onkeydown="if(event.key==='Enter') diaryUnlock()">
      <button class="btn primary full" onclick="diaryUnlock()" style="margin-top:6px;">🔓 Déverrouiller</button>
      <button class="btn alt full" onclick="diaryReset()" style="margin-top:6px; opacity:0.6; font-size:11px;">⚠️ Reset (perd tout)</button>
    </div>`;
  } else {
    const today = new Date().toISOString().slice(0, 10);
    let entries; try { entries = JSON.parse(localStorage.getItem('nw_diary_entries') || '[]'); } catch { entries = []; }
    const todayEntry = entries.find(e => e.date === today);
    html += `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:14px;">
      <div style="font-size:11px; color:var(--textSec);">${new Date().toLocaleDateString('fr-FR', {weekday:'long',day:'numeric',month:'long'})}</div>
      <textarea id="diary-text" class="input" rows="8" placeholder="Mes pensées du jour..." style="margin-top:8px; font-family:inherit;">${todayEntry ? escapeHtml(todayEntry.text) : ''}</textarea>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:6px;">
        <button class="btn primary" onclick="diarySave()">💾 Sauver</button>
        <button class="btn alt" onclick="_diaryUnlocked=false; renderDiary();">🔒 Verrouiller</button>
      </div>
    </div>`;
    if (entries.length > 0) {
      html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📚 Historique (${entries.length})</h3>`;
      entries.slice().reverse().slice(0, 30).forEach(e => {
        const d = new Date(e.date).toLocaleDateString('fr-FR', { weekday:'long', day:'numeric', month:'long' });
        html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px;">
          <div style="font-size:10px; color:var(--textSec); margin-bottom:4px;">${d}</div>
          <div style="font-size:13px; line-height:1.5; white-space:pre-wrap;">${escapeHtml(e.text)}</div>
        </div>`;
      });
    }
  }
  document.getElementById('diary-content').innerHTML = html;
}
async function diarySetup() {
  const p = document.getElementById('diary-newpwd').value;
  if (p.length < 4) { toast('Min 4 car'); return; }
  await setDiaryPwd(p);
  _diaryUnlocked = true;
  toast('🔐 Configuré');
  renderDiary();
}
async function diaryUnlock() {
  const p = document.getElementById('diary-pwd').value;
  const ok = await checkDiaryPwd(p);
  if (!ok) { toast('❌ Mot de passe incorrect'); return; }
  _diaryUnlocked = true;
  if (navigator.vibrate) navigator.vibrate(10);
  renderDiary();
}
function diaryReset() {
  if (!confirm('⚠️ Cela supprimera TOUS tes entrées. Confirmer ?')) return;
  localStorage.removeItem('nw_diary_pwd_hash');
  localStorage.removeItem('nw_diary_entries');
  _diaryUnlocked = false;
  renderDiary();
}
function diarySave() {
  const txt = document.getElementById('diary-text').value;
  let entries; try { entries = JSON.parse(localStorage.getItem('nw_diary_entries') || '[]'); } catch { entries = []; }
  const today = new Date().toISOString().slice(0, 10);
  entries = entries.filter(e => e.date !== today);
  if (txt.trim()) entries.push({ date: today, text: txt });
  localStorage.setItem('nw_diary_entries', JSON.stringify(entries));
  toast('💾 Sauvé');
  renderDiary();
}



