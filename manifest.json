};
function applyFancy(text, style) {
  const s = FANCY_STYLES[style];
  if (!s) return text;
  const lower = 'abcdefghijklmnopqrstuvwxyz';
  const upper = 'abcdefghijklmnopqrstuvwxyz'.toUpperCase();
  // Map by code-point (some maps use surrogate pairs)
  const lArr = Array.from(s.mapL);
  const uArr = Array.from(s.mapU);
  let out = '';
  for (const c of text) {
    const li = lower.indexOf(c);
    const ui = upper.indexOf(c);
    if (li >= 0) out += lArr[li] || c;
    else if (ui >= 0) out += uArr[ui] || c;
    else out += c;
  }
  if (s.reverse) out = Array.from(out).reverse().join('');
  return out;
}
function renderFancyText() {
  let html = `<div style="background:linear-gradient(135deg,#9B59B6,#FF1493); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">𝓕</div>
    <div style="font-size:16px; font-weight:800;">Police fancy Unicode</div>
    <div style="font-size:11px; opacity:0.9;">16 styles · marche partout (bio, DM, posts)</div>
  </div>
  <textarea class="input" id="fancy-input" rows="2" placeholder="Tape ton texte ici..." oninput="renderFancyResults()" style="margin-top:14px; font-size:15px;">Hello Nono</textarea>
  <div id="fancy-results" style="margin-top:14px;"></div>`;
  document.getElementById('fancytext-content').innerHTML = html;
  renderFancyResults();
}
function renderFancyResults() {
  const txt = document.getElementById('fancy-input').value || 'Hello Nono';
  let html = '';
  Object.keys(FANCY_STYLES).forEach(style => {
    const result = applyFancy(txt, style);
    html += `<div style="background:var(--surface); padding:12px; border-radius:12px; margin-top:6px; cursor:pointer;" onclick="copyText('${result.replace(/'/g, "\\'")}', '📋 ' + '${style}' + ' copié !')">
      <div style="font-size:10px; color:var(--textSec); font-weight:700; margin-bottom:4px;">${style}</div>
      <div style="font-size:16px; word-break:break-word;">${result}</div>
    </div>`;
  });
  document.getElementById('fancy-results').innerHTML = html;
}

// === 2. ZALGO ===
function zalgoText(text, level) {
  const above = ['̍','̎','̄','̅','̿','̑','̆','̐','͒','͗','͑','̇','̈','̊','͂','̓','̈','͊','͋','͌','̃','̂','̌','͐','̀','́','̋','̏','̒','̓','̔','̽','̉','ͣ','ͤ','ͥ','ͦ','ͧ','ͨ','ͩ','ͪ','ͫ','ͬ','ͭ','ͮ','ͯ','̾','͛','͆','̚'];
  const below = ['̖','̗','̘','̙','̜','̝','̞','̟','̠','̤','̥','̦','̩','̪','̫','̬','̭','̮','̯','̰','̱','̲','̳','̹','̺','̻','̼','ͅ','͇','͈','͉','͍','͎','͓','͔','͕','͖','͙','͚','̣'];
  const middle = ['̕','̛','̀','́','͘','̡','̢','̧','̨','̴','̵','̶','͜','͝','͞','͟','͠','͢','̸','̷','͡'];
  const intensity = { low: 2, medium: 5, high: 10, extreme: 20 }[level] || 5;
  return Array.from(text).map(c => {
    if (c === ' ' || c === '\n') return c;
    let result = c;
    for (let i = 0; i < intensity; i++) {
      result += above[Math.floor(Math.random() * above.length)];
    }
    for (let i = 0; i < intensity; i++) {
      result += below[Math.floor(Math.random() * below.length)];
    }
    for (let i = 0; i < Math.floor(intensity/2); i++) {
      result += middle[Math.floor(Math.random() * middle.length)];
    }
    return result;
  }).join('');
}
function renderZalgo() {
  let html = `<div style="background:linear-gradient(135deg,#1A1A1A,#5D2E8C); color:#FF4757; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">Z̸a̷l̴g̸o̵</div>
    <div style="font-size:11px; opacity:0.9;">Texte glitch / corrompu</div>
  </div>
  <textarea class="input" id="zalgo-input" rows="2" placeholder="Texte normal..." oninput="zalgoUpdate()" style="margin-top:14px;">Hello</textarea>
  <span class="label">Intensité</span>
  <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:4px;">
    <button class="btn alt" onclick="zalgoSetLevel('low')" id="zlvl-low">Léger</button>
    <button class="btn primary" onclick="zalgoSetLevel('medium')" id="zlvl-medium">Moyen</button>
    <button class="btn alt" onclick="zalgoSetLevel('high')" id="zlvl-high">Fort</button>
    <button class="btn alt" onclick="zalgoSetLevel('extreme')" id="zlvl-extreme">Extrême</button>
  </div>
  <div id="zalgo-output" style="background:var(--surface); padding:18px; border-radius:14px; margin-top:14px; min-height:60px; word-break:break-word; line-height:2; font-size:18px;"></div>
  <button class="btn primary full" onclick="zalgoCopy()" style="margin-top:8px;">📋 Copier</button>`;
  document.getElementById('zalgo-content').innerHTML = html;
  zalgoUpdate();
}
let _zalgoLevel = 'medium';
function zalgoSetLevel(l) { _zalgoLevel = l; renderZalgo(); }
