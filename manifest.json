// ============================================================
function hydData() { try { return JSON.parse(localStorage.getItem('nw_hydra') || '{}'); } catch { return {}; } }
function hydSave(d) { localStorage.setItem('nw_hydra', JSON.stringify(d)); }
function hydToday() { const d = hydData(); return d[todayKey()] || 0; }
function hydAdd(ml) { const d = hydData(); d[todayKey()] = (d[todayKey()]||0) + ml; hydSave(d); renderHydra(); toast(`+${ml}ml`); }
function hydAddCustom() { const v = parseInt(document.getElementById('hyd-custom').value); if (!v) return; hydAdd(v); document.getElementById('hyd-custom').value = ''; }
function hydReset() { if (!confirm('Reset aujourd\'hui ?')) return; const d = hydData(); delete d[todayKey()]; hydSave(d); renderHydra(); }
function hydSetGoal(v) { localStorage.setItem('nw_hydra_goal', parseInt(v) || 2000); renderHydra(); }
function hydGoal() { return parseInt(localStorage.getItem('nw_hydra_goal') || 2000); }
function renderHydra() {
  const today = hydToday();
  const goal = hydGoal();
  document.getElementById('hyd-amount').textContent = today;
  document.getElementById('hyd-goal-display').textContent = goal;
  document.getElementById('hyd-progress').style.width = Math.min(100, today/goal*100) + '%';
  document.getElementById('hyd-goal').value = goal;
  // Week chart
  const data = hydData();
  const days = ['Dim','Lun','Mar','Mer','Jeu','Ven','Sam'];
  let html = '<div style="display:flex; gap:4px; align-items:flex-end; height:80px;">';
  const today_d = new Date();
  for (let i=6; i>=0; i--) {
    const d = new Date(today_d); d.setDate(d.getDate() - i);
    const k = d.toISOString().slice(0,10);
    const v = data[k] || 0;
    const pct = Math.min(100, v/goal*100);
    const isToday = i === 0;
    html += `<div style="flex:1; display:flex; flex-direction:column; align-items:center; gap:2px;">
      <div style="font-size:10px; color:var(--textSec);">${v > 999 ? (v/1000).toFixed(1)+'L' : v}</div>
      <div style="width:100%; background:var(--surfaceAlt); border-radius:4px; height:40px; display:flex; align-items:flex-end;">
        <div style="width:100%; background:${isToday ? 'linear-gradient(180deg, #5DADE2, #06FFA5)' : '#5DADE2'}; height:${pct}%; border-radius:4px;"></div>
      </div>
      <div style="font-size:10px; ${isToday ? 'color:#5DADE2; font-weight:700' : 'color:var(--textSec)'};">${days[d.getDay()]}</div>
    </div>`;
  }
  html += '</div>';
  document.getElementById('hyd-week').innerHTML = html;
}

