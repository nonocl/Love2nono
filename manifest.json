// === 3. VAPORWAVE ===
function vaporwaveText(text) {
  return Array.from(text).map(c => {
    const code = c.charCodeAt(0);
    if (code === 0x20) return '　'; // ideographic space
    if (code >= 0x21 && code <= 0x7E) return String.fromCharCode(code + 0xFEE0);
    return c;
  }).join('');
}
