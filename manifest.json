function privFolderDel(id) {
  if (!confirm('Supprimer ce dossier et toutes ses notes ?')) return;
  savePrivFolders(getPrivFolders().filter(f => f.id !== id));
  renderPrivFolder();
}
function privFolderAddNote(id) {
  const inp = document.getElementById('pf-input-'+id);
  const txt = inp.value.trim();
  if (!txt) return;
  const folders = getPrivFolders();
  const f = folders.find(x => x.id === id);
  if (!f) return;
  f.notes = f.notes || [];
  f.notes.push({ text: txt, created: Date.now() });
  savePrivFolders(folders);
  inp.value = '';
  renderPrivFolder();
}
function privFolderDelNote(id, i) {
  const folders = getPrivFolders();
  const f = folders.find(x => x.id === id);
  if (!f) return;
  f.notes.splice(i, 1);
  savePrivFolders(folders);
  renderPrivFolder();
}

