    <div style="font-size:11px; opacity:0.9;">Cycle ${_pomoCycle} · ${s.sessions} sessions totales</div>
  </div>
  <div id="pomo-display" style="font-size:80px; font-weight:900; text-align:center; margin-top:30px; color:${colors[_pomoMode]}; font-family:monospace;">${pomoFormat(_pomoRemaining)}</div>
  <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:6px; margin-top:18px;">
    <button class="btn alt" onclick="pomoReset()">🔄 Reset</button>
    <button id="pomo-toggle" class="btn primary" onclick="pomoToggle()">${_pomoRunning?'⏸ Pause':'▶️ Start'}</button>
    <button class="btn alt" onclick="pomoSkip()">⏭ Skip</button>
  </div>
  <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:6px; margin-top:8px;">
    <button class="btn alt" onclick="pomoSet('work')" style="font-size:11px;">🍅 25 min</button>
    <button class="btn alt" onclick="pomoSet('short')" style="font-size:11px;">☕ 5 min</button>
    <button class="btn alt" onclick="pomoSet('long')" style="font-size:11px;">🌴 15 min</button>
  </div>
  <div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:14px; text-align:center;">
    <div style="font-size:11px; color:var(--textSec);">📊 Stats</div>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:6px;">
      <div><div style="font-size:18px; font-weight:900;">${s.sessions}</div><div style="font-size:10px; color:var(--textSec);">sessions</div></div>
      <div><div style="font-size:18px; font-weight:900;">${Math.floor(s.totalMin/60)}h${String(s.totalMin%60).padStart(2,'0')}</div><div style="font-size:10px; color:var(--textSec);">temps total</div></div>
    </div>
  </div>`;
  document.getElementById('pomodoro-content').innerHTML = html;
}
function pomoToggle() {
  if (_pomoRunning) {
    clearInterval(_pomoTimer); _pomoRunning = false;
  } else {
    _pomoTimer = setInterval(pomoTick, 1000); _pomoRunning = true;
  }
  v51_renderPomodoro();
}
function pomoTick() {
  _pomoRemaining--;
  const el = document.getElementById('pomo-display');
  if (el) el.textContent = pomoFormat(_pomoRemaining);
  if (_pomoRemaining <= 0) {
    clearInterval(_pomoTimer); _pomoRunning = false;
    if (_pomoMode === 'work') {
      const s = getPomoStats();
      s.sessions++;
      s.totalMin += 25;
      savePomoStats(s);
    }
    try {
      const ctx = new (window.AudioContext || window.webkitAudioContext)();
      for (let i = 0; i < 3; i++) {
        const osc = ctx.createOscillator(), gain = ctx.createGain();
        osc.frequency.value = 660 + i * 110; osc.connect(gain); gain.connect(ctx.destination);
        gain.gain.setValueAtTime(0.2, ctx.currentTime + i * 0.4);
        osc.start(ctx.currentTime + i * 0.4); osc.stop(ctx.currentTime + i * 0.4 + 0.3);
      }
    } catch {}
    if (navigator.vibrate) navigator.vibrate([200, 100, 200, 100, 200]);
    toast('🍅 Session terminée !');
    pomoSkip();
  }
}
function pomoFormat(s) {
  const m = Math.floor(s / 60), sec = s % 60;
  return `${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
}
function pomoSet(mode) {
  clearInterval(_pomoTimer); _pomoRunning = false;
  _pomoMode = mode;
  _pomoRemaining = mode === 'work' ? 25*60 : mode === 'short' ? 5*60 : 15*60;
  v51_renderPomodoro();
}
function pomoReset() { pomoSet(_pomoMode); }
function pomoSkip() {
  if (_pomoMode === 'work') {
    if (_pomoCycle % 4 === 0) pomoSet('long');
    else pomoSet('short');
    _pomoCycle++;
  } else {
    pomoSet('work');
  }
}

