    3: { t: 'Le Créatif', d: 'Expressif, artistique, joyeux. Tu inspires par ta créativité.', emoji: '🎨' },
    4: { t: 'Le Constructeur', d: 'Travailleur, pragmatique, fiable. Tu bâtis des fondations solides.', emoji: '🏗️' },
    5: { t: "L'Aventurier", d: 'Libre, curieux, changeant. Tu vis pour l\'expérience.', emoji: '🌍' },
    6: { t: 'Le Protecteur', d: 'Aimant, responsable, dévoué. Tu prends soin de ton entourage.', emoji: '💗' },
    7: { t: 'Le Penseur', d: 'Spirituel, analytique, sage. Tu cherches la vérité profonde.', emoji: '🔮' },
    8: { t: 'Le Bâtisseur d\'empire', d: 'Ambitieux, organisateur, puissant. Tu réussis matériellement.', emoji: '💼' },
    9: { t: "L'Humaniste", d: 'Compassionnel, idéaliste, universel. Tu sers une cause plus grande.', emoji: '🌟' },
    11: { t: 'Le Visionnaire (maître)', d: 'Hyper-intuitif, inspirant, mystique. Tu vois l\'invisible.', emoji: '✨' },
    22: { t: 'Le Maître bâtisseur', d: 'Tu réalises des projets immenses qui marquent l\'humanité.', emoji: '🏛️' },
    33: { t: 'Le Maître enseignant', d: 'Amour inconditionnel, guérisseur, exemple pour les autres.', emoji: '💫' }
  };
  const m = meanings[sum];
  document.getElementById('num-result').innerHTML = `<div style="background:linear-gradient(135deg,#FFD166,#9B59B6); color:white; padding:24px; border-radius:18px; text-align:center;">
