// IMC
// ============================================================
function calcBmi() {
  const h = parseFloat(document.getElementById('bmi-h').value);
  const w = parseFloat(document.getElementById('bmi-w').value);
  if (!h || !w) { document.getElementById('bmi-value').textContent = '—'; document.getElementById('bmi-label').textContent = 'Renseigne taille + poids'; return; }
  const bmi = w / Math.pow(h/100, 2);
  document.getElementById('bmi-value').textContent = bmi.toFixed(1);
  let label, color;
  if (bmi < 18.5) { label = '🟦 Insuffisance pondérale'; color = '#5B8DEF'; }
  else if (bmi < 25) { label = '🟢 Corpulence normale'; color = '#5DD68F'; }
  else if (bmi < 30) { label = '🟡 Surpoids'; color = '#FFD166'; }
  else if (bmi < 35) { label = '🟠 Obésité modérée'; color = '#FF8C42'; }
  else { label = '🔴 Obésité sévère'; color = '#FF6B7A'; }
  document.getElementById('bmi-label').textContent = label;
  document.getElementById('bmi-result').style.borderLeft = `4px solid ${color}`;
}

// ============================================================
// AGE PRECIS
// ============================================================
let _ageInterval = null;
function calcAge() {
  if (_ageInterval) clearInterval(_ageInterval);
  const v = document.getElementById('age-input').value;
  if (!v) { document.getElementById('age-result').innerHTML = ''; return; }
  const update = () => {
    const birth = new Date(v).getTime();
    const now = Date.now();
    if (birth > now) { document.getElementById('age-result').innerHTML = '<p>Date dans le futur</p>'; return; }
    const ms = now - birth;
    const totalSec = Math.floor(ms / 1000);
    const totalMin = Math.floor(totalSec / 60);
    const totalH = Math.floor(totalMin / 60);
    const totalDays = Math.floor(totalH / 24);
    const totalWeeks = Math.floor(totalDays / 7);
    const totalMonths = Math.floor(totalDays / 30.4375);
    const years = Math.floor(totalDays / 365.25);
    const remDays = totalDays - Math.floor(years * 365.25);
    document.getElementById('age-result').innerHTML = `
      <div style="background:var(--surfaceAlt); padding:18px; border-radius:14px; text-align:center; margin-bottom:8px;">
        <div style="font-size:13px; color:var(--textSec);">Tu as</div>
        <div style="font-size:36px; font-weight:900; color:var(--primary);">${years} ans</div>
        <div style="font-size:14px; color:var(--textSec);">et environ ${remDays} jours</div>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; font-size:12px;">
        <div style="background:var(--surfaceAlt); padding:8px 10px; border-radius:8px;"><div style="color:var(--textSec);">Mois</div><strong>${totalMonths.toLocaleString('fr')}</strong></div>
        <div style="background:var(--surfaceAlt); padding:8px 10px; border-radius:8px;"><div style="color:var(--textSec);">Semaines</div><strong>${totalWeeks.toLocaleString('fr')}</strong></div>
        <div style="background:var(--surfaceAlt); padding:8px 10px; border-radius:8px;"><div style="color:var(--textSec);">Jours</div><strong>${totalDays.toLocaleString('fr')}</strong></div>
        <div style="background:var(--surfaceAlt); padding:8px 10px; border-radius:8px;"><div style="color:var(--textSec);">Heures</div><strong>${totalH.toLocaleString('fr')}</strong></div>
        <div style="background:var(--surfaceAlt); padding:8px 10px; border-radius:8px;"><div style="color:var(--textSec);">Minutes</div><strong>${totalMin.toLocaleString('fr')}</strong></div>
        <div style="background:var(--surfaceAlt); padding:8px 10px; border-radius:8px;"><div style="color:var(--textSec);">Secondes</div><strong>${totalSec.toLocaleString('fr')}</strong></div>
      </div>
    `;
  };
  update();
  _ageInterval = setInterval(update, 1000);
}

// ============================================================
// STOPWATCH
// ============================================================
let _sw = { start:0, elapsed:0, running:false, interval:null, laps:[] };
function swStart() {
  if (_sw.running) {
    _sw.running = false;
    _sw.elapsed += Date.now() - _sw.start;
    clearInterval(_sw.interval);
    document.getElementById('sw-start').textContent = '▶ Reprendre';
  } else {
    _sw.start = Date.now();
    _sw.running = true;
    _sw.interval = setInterval(swUpdate, 31);
    document.getElementById('sw-start').textContent = '⏸ Pause';
  }
}
function swUpdate() {
  const ms = (_sw.running ? Date.now() - _sw.start : 0) + _sw.elapsed;
  const m = Math.floor(ms/60000), s = Math.floor((ms%60000)/1000), cs = Math.floor((ms%1000)/10);
  document.getElementById('sw-display').textContent = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}.${String(cs).padStart(2,'0')}`;
}
function swReset() {
  if (_sw.interval) clearInterval(_sw.interval);
  _sw = { start:0, elapsed:0, running:false, interval:null, laps:[] };
  document.getElementById('sw-display').textContent = '00:00.00';
  document.getElementById('sw-start').textContent = '▶ Démarrer';
  document.getElementById('sw-laps').innerHTML = '';
}
function swLap() {
  if (!_sw.running && _sw.elapsed === 0) return;
  const ms = (_sw.running ? Date.now() - _sw.start : 0) + _sw.elapsed;
  _sw.laps.push(ms);
  const m = Math.floor(ms/60000), s = Math.floor((ms%60000)/1000), cs = Math.floor((ms%1000)/10);
  const time = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}.${String(cs).padStart(2,'0')}`;
  const lapsEl = document.getElementById('sw-laps');
  const div = document.createElement('div');
  div.style.cssText = 'display:flex; justify-content:space-between; padding:8px 12px; background:var(--surfaceAlt); border-radius:8px; margin-bottom:4px; font-family:monospace;';
  div.innerHTML = `<span>Tour ${_sw.laps.length}</span><span>${time}</span>`;
  lapsEl.insertBefore(div, lapsEl.firstChild);
}

// ============================================================
// MULTI-TIMERS
// ============================================================
let _timers = [];
let _timerNextId = 1;
function addTimer() {
  const m = prompt('Durée en minutes ?', '5');
  if (!m) return;
  const min = parseFloat(m);
  if (isNaN(min) || min <= 0) return;
  const name = prompt('Nom (optionnel)', '') || `Timer ${_timerNextId}`;
  const t = { id: _timerNextId++, name, totalSec: Math.floor(min*60), remaining: Math.floor(min*60), running:false, interval:null, ts:0 };
  _timers.push(t);
  renderTimers();
}
function renderTimers() {
  const el = document.getElementById('timers-list');
  el.innerHTML = '';
  if (_timers.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">⏰</div><h3>Aucun minuteur</h3><p>Tap sur + pour ajouter un minuteur. Tu peux en lancer plusieurs en parallèle.</p></div>`;
    return;
  }
  for (const t of _timers) {
    const m = Math.floor(t.remaining/60), s = t.remaining%60;
    const card = document.createElement('div');
    card.style.cssText = 'background:var(--surface); border-radius:14px; padding:14px; margin-bottom:8px;';
    card.innerHTML = `
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
        <div style="font-weight:600;">${escapeHtml(t.name)}</div>
        <button class="btn ghost" style="color:var(--danger); padding:4px 8px; font-size:14px;" onclick="rmTimer(${t.id})">✕</button>
      </div>
      <div style="font-size:36px; font-weight:900; color:${t.remaining<=10 && t.remaining>0?'var(--danger)':'var(--primary)'}; text-align:center; font-variant-numeric:tabular-nums;">
        ${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}
      </div>
      <div style="display:flex; gap:6px; margin-top:8px;">
        <button class="btn primary" onclick="toggleTimer(${t.id})" style="flex:1;">${t.running?'⏸':'▶'}</button>
        <button class="btn alt" onclick="resetTimer(${t.id})" style="flex:1;">↻</button>
      </div>
    `;
    el.appendChild(card);
  }
}
function getTimer(id) { return _timers.find(t => t.id === id); }
function toggleTimer(id) {
  const t = getTimer(id); if (!t) return;
  if (t.running) { clearInterval(t.interval); t.running = false; }
  else {
    t.running = true;
    t.interval = setInterval(() => {
      t.remaining--;
      if (t.remaining <= 0) {
        clearInterval(t.interval); t.running = false; t.remaining = 0;
        if ('vibrate' in navigator) navigator.vibrate([200,100,200,100,200]);
        toast(`⏰ ${t.name} terminé !`, 4000);
      }
      renderTimers();
    }, 1000);
  }
  renderTimers();
}
function resetTimer(id) {
  const t = getTimer(id); if (!t) return;
  if (t.interval) clearInterval(t.interval);
  t.running = false; t.remaining = t.totalSec;
  renderTimers();
}
function rmTimer(id) {
  const t = getTimer(id);
  if (t && t.interval) clearInterval(t.interval);
  _timers = _timers.filter(x => x.id !== id);
  renderTimers();
}

