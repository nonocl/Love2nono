// ============================================================
// CALC GRAPHIQUE
// ============================================================
function safeEval(expr, x) {
  try {
    expr = expr.replace(/\^/g, '**');
    const fn = new Function('x', `with (Math) { return ${expr}; }`);
    return fn(x);
  } catch { return NaN; }
}
function plotGraph() {
  const fnStr = document.getElementById('graph-fn').value;
  const xMin = parseFloat(document.getElementById('graph-xmin').value);
  const xMax = parseFloat(document.getElementById('graph-xmax').value);
  const c = document.getElementById('graph-canvas');
  const ctx = c.getContext('2d');
  const W = c.width, H = c.height;
  ctx.fillStyle = getComputedStyle(c).backgroundColor || '#fff';
  ctx.fillRect(0, 0, W, H);
  // Compute y range
  let yMin = Infinity, yMax = -Infinity;
  const points = [];
  for (let px = 0; px < W; px++) {
    const x = xMin + (xMax - xMin) * px / W;
    const y = safeEval(fnStr, x);
    if (isFinite(y)) {
      points.push([px, y]);
      if (y < yMin) yMin = y;
      if (y > yMax) yMax = y;
    } else points.push([px, null]);
  }
  if (yMin === Infinity) { ctx.fillStyle = '#888'; ctx.font = '14px sans-serif'; ctx.fillText('Erreur dans la fonction', 10, 30); return; }
  const yRange = yMax - yMin || 1;
  const yPad = yRange * 0.1;
  yMin -= yPad; yMax += yPad;
  // Axes
  ctx.strokeStyle = '#888'; ctx.lineWidth = 1;
  // X axis (y=0)
  if (yMin <= 0 && yMax >= 0) {
    const py = H - (0 - yMin) / (yMax - yMin) * H;
    ctx.beginPath(); ctx.moveTo(0, py); ctx.lineTo(W, py); ctx.stroke();
  }
  if (xMin <= 0 && xMax >= 0) {
    const px = (0 - xMin) / (xMax - xMin) * W;
    ctx.beginPath(); ctx.moveTo(px, 0); ctx.lineTo(px, H); ctx.stroke();
  }
  // Plot
  ctx.strokeStyle = getComputedStyle(document.documentElement).getPropertyValue('--primary') || '#FF6FA3';
  ctx.lineWidth = 2;
  ctx.beginPath();
  let started = false;
  for (const [px, y] of points) {
    if (y === null) { started = false; continue; }
    const py = H - (y - yMin) / (yMax - yMin) * H;
    if (!started) { ctx.moveTo(px, py); started = true; }
    else ctx.lineTo(px, py);
  }
  ctx.stroke();
  // Labels
  ctx.fillStyle = '#888'; ctx.font = '10px sans-serif';
  ctx.fillText(xMin.toFixed(1), 4, H-4);
  ctx.fillText(xMax.toFixed(1), W-30, H-4);
  ctx.fillText(yMin.toFixed(1), 4, H-14);
  ctx.fillText(yMax.toFixed(1), 4, 12);
}

