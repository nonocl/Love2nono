let _metroTimer = null;
function renderMetronomeV54() {
  let html = `<div style="background:linear-gradient(135deg,#9B59B6,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🎵</div><div style="font-size:16px; font-weight:800;">Métronome</div>
  </div>
  <div style="background:var(--surface); padding:18px; border-radius:14px; margin-top:14px; text-align:center;">
    <div id="metro54-bpm" style="font-size:48px; font-weight:900; color:var(--primary);">100</div>
    <div style="font-size:11px; color:var(--textSec); margin-top:-6px;">BPM</div>
    <input type="range" id="metro54-slider" min="40" max="220" value="100" oninput="metro54Update()" style="width:100%; margin-top:14px;">
    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:6px; margin-top:14px;">
      <button class="btn alt" onclick="metro54Step(-5)">-5</button>
      <button class="btn alt" onclick="metro54Step(-1)">-1</button>
      <button class="btn alt" onclick="metro54Step(1)">+1</button>
    </div>
    <button class="btn primary full" id="metro54-btn" onclick="metro54Toggle()" style="margin-top:14px; padding:18px;">▶️ Démarrer</button>
  </div>
  <div id="metro54-pulse" style="margin:24px auto 0; width:80px; height:80px; border-radius:50%; background:var(--surface); border:3px solid var(--primary); transition:all 0.1s;"></div>`;
  document.getElementById('metronome54-content').innerHTML = html;
}
function metro54Update() {
  const v = document.getElementById('metro54-slider').value;
  document.getElementById('metro54-bpm').textContent = v;
  if (_metroTimer) { metro54Toggle(); metro54Toggle(); }
}
function metro54Step(d) {
  const slider = document.getElementById('metro54-slider');
  slider.value = Math.max(40, Math.min(220, parseInt(slider.value) + d));
  metro54Update();
}
function metro54Toggle() {
  const btn = document.getElementById('metro54-btn');
  if (_metroTimer) {
    clearInterval(_metroTimer); _metroTimer = null; btn.textContent = '▶️ Démarrer';
  } else {
    const bpm = parseInt(document.getElementById('metro54-slider').value);
    const interval = 60000 / bpm;
    _metroTimer = setInterval(() => {
      const pulse = document.getElementById('metro54-pulse');
      if (pulse) {
        pulse.style.background = 'var(--primary)';
        pulse.style.transform = 'scale(1.2)';
        setTimeout(() => { if (pulse) { pulse.style.background = 'var(--surface)'; pulse.style.transform = 'scale(1)'; } }, 100);
      }
      try {
        const ctx = new (window.AudioContext || window.webkitAudioContext)();
        const osc = ctx.createOscillator(); const gain = ctx.createGain();
        osc.frequency.value = 1000; osc.type = 'square';
        gain.gain.setValueAtTime(0.3, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.05);
        osc.connect(gain); gain.connect(ctx.destination);
        osc.start(); osc.stop(ctx.currentTime + 0.05);
      } catch {}
    }, interval);
    btn.textContent = '⏸ Stop';
  }
}

