function peAddSticker(emoji) {
  peSnapshot();
  const sticker = { type:'sticker', emoji, x: _pe.W/2, y: _pe.H/2, size: 80 };
  _pe.overlays.push(sticker);
  _pe.selectedOverlay = sticker;
  peRedraw();
  peRenderStickers();
}
function peAddCustomSticker() {
  const v = document.getElementById('pe-st-custom').value.trim();
  if (!v) return;
