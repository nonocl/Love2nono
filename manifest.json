function renderDateDiff() {
  let html = `<div style="background:linear-gradient(135deg,#06FFA5,#FFD166); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">📅</div><div style="font-size:16px; font-weight:800;">Diff entre 2 dates</div>
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">Date 1</h3>
  <input type="date" id="dd-1" class="input" oninput="ddCalc()" style="margin-top:6px;">
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">Date 2</h3>
  <input type="date" id="dd-2" class="input" oninput="ddCalc()" style="margin-top:6px;">
  <div id="dd-result" style="margin-top:14px;"></div>`;
  document.getElementById('datediff-content').innerHTML = html;
}
function ddCalc() {
  const d1 = document.getElementById('dd-1').value;
  const d2 = document.getElementById('dd-2').value;
  if (!d1 || !d2) return;
  const da = new Date(d1), db = new Date(d2);
  const ms = Math.abs(db - da);
  const days = Math.floor(ms / 86400000);
  const weeks = Math.floor(days / 7);
  const months = Math.floor(days / 30.44);
  const years = (days / 365.25).toFixed(2);
  document.getElementById('dd-result').innerHTML = `<div style="background:var(--surface); padding:18px; border-radius:14px; text-align:center;">
    <div style="font-size:48px; font-weight:900; color:var(--primary);">${days.toLocaleString('fr-FR')}</div>
    <div style="font-size:13px; color:var(--textSec);">jours d'écart</div>
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:6px; margin-top:14px;">
      <div><div style="font-size:18px; font-weight:900;">${weeks}</div><div style="font-size:10px; color:var(--textSec);">semaines</div></div>
      <div><div style="font-size:18px; font-weight:900;">${months}</div><div style="font-size:10px; color:var(--textSec);">mois</div></div>
      <div><div style="font-size:18px; font-weight:900;">${years}</div><div style="font-size:10px; color:var(--textSec);">années</div></div>
    </div>
  </div>`;
}

// === 15. CHRONOMÈTRE ===
let _stopwatchStart = 0, _stopwatchInterval = null, _stopwatchLaps = [], _stopwatchPaused = 0, _stopwatchRunning = false;
function renderStopwatch() {
  let html = `<div style="background:linear-gradient(135deg,#5DADE2,#06FFA5); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">⏱</div><div style="font-size:16px; font-weight:800;">Chronomètre</div>
  </div>
  <div id="sw-display" style="font-size:56px; font-weight:900; text-align:center; margin-top:24px; color:var(--primary); font-family:monospace;">00:00.00</div>
  <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:6px; margin-top:14px;">
    <button class="btn alt" onclick="v51_swReset()">🔄 Reset</button>
    <button id="sw-toggle" class="btn primary" onclick="swToggle()">▶️ Start</button>
    <button class="btn alt" onclick="v51_swLap()">🏁 Tour</button>
  </div>
  <div id="sw-laps" style="margin-top:14px;"></div>`;
  document.getElementById('stopwatch-content').innerHTML = html;
  v51_swUpdate();
}
function swToggle() {
  if (_stopwatchRunning) {
    _stopwatchPaused = Date.now() - _stopwatchStart;
    clearInterval(_stopwatchInterval);
    _stopwatchRunning = false;
    document.getElementById('sw-toggle').textContent = '▶️ Resume';
  } else {
    _stopwatchStart = Date.now() - _stopwatchPaused;
    _stopwatchInterval = setInterval(v51_swUpdate, 50);
    _stopwatchRunning = true;
    document.getElementById('sw-toggle').textContent = '⏸ Pause';
  }
}
function v51_swReset() {
  clearInterval(_stopwatchInterval);
  _stopwatchStart = 0; _stopwatchPaused = 0; _stopwatchLaps = []; _stopwatchRunning = false;
  document.getElementById('sw-toggle').textContent = '▶️ Start';
  v51_swUpdate();
  document.getElementById('sw-laps').innerHTML = '';
}
function v51_swLap() {
  if (!_stopwatchRunning) return;
  const t = Date.now() - _stopwatchStart;
  _stopwatchLaps.unshift(t);
  let html = '<h3 style="font-size:13px; font-weight:700; color:var(--primary);">🏁 Tours</h3>';
  _stopwatchLaps.forEach((l, i) => {
    html += `<div style="background:var(--surface); padding:8px 12px; border-radius:8px; margin-top:4px; display:flex; justify-content:space-between; font-size:13px;">
      <span>Tour ${_stopwatchLaps.length - i}</span><span style="font-family:monospace; font-weight:700;">${swFormat(l)}</span>
    </div>`;
  });
  document.getElementById('sw-laps').innerHTML = html;
}
function v51_swUpdate() {
  const t = _stopwatchRunning ? Date.now() - _stopwatchStart : _stopwatchPaused;
  const el = document.getElementById('sw-display');
  if (el) el.textContent = swFormat(t);
}
function swFormat(t) {
  const min = Math.floor(t / 60000);
  const sec = Math.floor((t % 60000) / 1000);
  const ms = Math.floor((t % 1000) / 10);
  return `${String(min).padStart(2,'0')}:${String(sec).padStart(2,'0')}.${String(ms).padStart(2,'0')}`;
}

