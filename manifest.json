    sum = String(sum).split('').reduce((s, d) => s + parseInt(d), 0);
  }
  const meanings = {
    1: { t: 'Le Leader', d: 'Tu es indépendant·e, ambitieux·se, pionnier·ère. Tu prends les devants.', emoji: '👑' },
