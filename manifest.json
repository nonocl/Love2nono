const NOTE_COLORS = [
  { id:'default', bg:'var(--surface)', label:'Défaut' },
  { id:'pink', bg:'#FFD6E8', label:'Rose' },
  { id:'red', bg:'#FFB3B3', label:'Rouge' },
  { id:'orange', bg:'#FFD9B3', label:'Orange' },
  { id:'yellow', bg:'#FFF3B3', label:'Jaune' },
  { id:'green', bg:'#C6F0C6', label:'Vert' },
  { id:'mint', bg:'#B3F0E8', label:'Menthe' },
  { id:'blue', bg:'#B3D9FF', label:'Bleu' },
  { id:'purple', bg:'#D9B3FF', label:'Violet' },
  { id:'lavender', bg:'#E0CCFF', label:'Lavande' },
  { id:'gray', bg:'#D0D0D0', label:'Gris' },
];
function noteColorBg(colorId) {
  const c = NOTE_COLORS.find(x => x.id === colorId) || NOTE_COLORS[0];
  return c.bg;
}

// Auto-classement par mots-clés
