// ============================================================
// PLANNER RÉVISIONS AUTO
// ============================================================
function rpGenerate() {
  const date = document.getElementById('rp-date').value;
  const hours = parseFloat(document.getElementById('rp-hours').value) || 2;
  const matText = document.getElementById('rp-matieres').value.trim();
  if (!date) return toast('Choisis une date');
  if (!matText) return toast('Ajoute des matières');
  const target = new Date(date);
  const today = new Date(); today.setHours(0,0,0,0);
  const days = Math.floor((target - today) / (1000*60*60*24));
  if (days <= 0) return toast('La date doit être dans le futur');
  const mats = matText.split('\n').map(l => {
    const [name, prio] = l.split(':').map(s => s?.trim());
    return { name: name || 'Matière', prio: parseInt(prio) || 3 };
  }).filter(m => m.name);
  if (!mats.length) return toast('Pas de matières valides');
  const totalMin = hours * 60;
  let html = `<div style="background:linear-gradient(135deg, var(--primary), var(--accent)); color:white; padding:14px; border-radius:14px; margin-bottom:14px;">
    <div style="font-size:12px; opacity:0.85;">📚 Planning généré</div>
    <div style="font-size:20px; font-weight:800; margin-top:4px;">${days} jour${days>1?'s':''} jusqu'au contrôle</div>
    <div style="font-size:12px; margin-top:4px;">${(hours*days).toFixed(1)}h de révision au total</div>
  </div>`;
  for (let d = 0; d < days; d++) {
    const dDate = new Date(today);
    dDate.setDate(dDate.getDate() + d);
    const isLastDay = d === days - 1;
    html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-bottom:6px; ${isLastDay ? 'border:2px solid var(--primary);' : ''}">
      <div style="font-weight:700; font-size:13px; ${isLastDay ? 'color:var(--primary);' : ''}">
        ${dDate.toLocaleDateString('fr-FR', { weekday:'long', day:'numeric', month:'short' })}
        ${isLastDay ? ' · 🎯 Veille' : ''}
      </div>`;
    let dayMats = mats.slice();
    if (isLastDay) dayMats = mats.filter(m => m.prio >= 4);
    if (!dayMats.length) dayMats = mats;
    const dayTotalPrio = dayMats.reduce((a,m) => a + m.prio, 0);
    for (const m of dayMats) {
      const min = Math.round(totalMin * m.prio / dayTotalPrio);
      const stars = '⭐'.repeat(m.prio);
      html += `<div style="display:flex; justify-content:space-between; padding:6px 0; font-size:13px; border-top:1px solid var(--border);">
        <span>${escapeHtml(m.name)} ${stars}</span>
        <span style="color:var(--primary); font-weight:600;">${min} min</span>
      </div>`;
    }
    html += `</div>`;
  }
  html += `<button class="btn alt full" onclick="rpSaveToNotes()" style="margin-top:14px;">💾 Sauvegarder en note</button>`;
  document.getElementById('rp-result').innerHTML = html;
  state._rpPlan = html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
}
async function rpSaveToNotes() {
  if (!state._rpPlan) return;
  const date = document.getElementById('rp-date').value;
  await dbAdd('notes', { 
    title: '📅 Planning révisions ' + date,
    content: state._rpPlan,
    color: 'blue', cat: 'École',
    created_at: new Date().toISOString(), updated_at: new Date().toISOString()
  });
  toast('💾 Sauvegardé dans tes notes');
}

