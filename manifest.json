// === STACK TOWER ===
let _stack = null;
function stackInit() {
  const c = document.getElementById('stack-canvas');
  const ctx = c.getContext('2d');
  _stack = {
    ctx, c,
    blocks: [{ x: 100, y: 360, w: 100, color: '#FF6FA3' }],
    moving: { x: 0, y: 320, w: 100, dir: 2, color: '#A78BFA' },
    cameraY: 0,
    running: true,
    rafId: null
  };
  document.getElementById('stack-h').textContent = '0';
  document.getElementById('stack-best').textContent = localStorage.getItem('nw_stack_best') || '0';
  if (_stack.rafId) cancelAnimationFrame(_stack.rafId);
  stackLoop();
}
function stackLoop() {
  if (!_stack || !_stack.running) return;
  const { ctx, c, blocks, moving } = _stack;
  ctx.fillStyle = '#0a0a14';
  ctx.fillRect(0, 0, c.width, c.height);
  
  // Move bloc
  moving.x += moving.dir;
  if (moving.x <= 0 || moving.x + moving.w >= c.width) moving.dir = -moving.dir;
  
  // Draw blocks
  ctx.save();
  ctx.translate(0, _stack.cameraY);
  for (const b of blocks) {
    ctx.fillStyle = b.color;
    ctx.fillRect(b.x, b.y, b.w, 30);
  }
  ctx.fillStyle = moving.color;
  ctx.fillRect(moving.x, moving.y, moving.w, 30);
  ctx.restore();
  
  _stack.rafId = requestAnimationFrame(stackLoop);
}
function stackTap() {
  if (!_stack || !_stack.running) return;
  const { blocks, moving } = _stack;
  const last = blocks[blocks.length - 1];
  const overlapL = Math.max(last.x, moving.x);
  const overlapR = Math.min(last.x + last.w, moving.x + moving.w);
  const overlapW = overlapR - overlapL;
  if (overlapW <= 0) {
    // Game over
    _stack.running = false;
    const ctx = _stack.ctx;
    ctx.fillStyle = 'rgba(0,0,0,0.7)';
    ctx.fillRect(0, 0, _stack.c.width, _stack.c.height);
    ctx.fillStyle = '#FF4757'; ctx.font = '24px sans-serif'; ctx.textAlign = 'center';
    ctx.fillText('Game Over', _stack.c.width / 2, _stack.c.height / 2);
    ctx.fillStyle = '#fff'; ctx.font = '14px sans-serif';
    ctx.fillText('Hauteur: ' + (blocks.length - 1), _stack.c.width / 2, _stack.c.height / 2 + 30);
    const best = parseInt(localStorage.getItem('nw_stack_best') || '0');
    if (blocks.length - 1 > best) localStorage.setItem('nw_stack_best', blocks.length - 1);
    return;
  }
  // Place block
  blocks.push({ x: overlapL, y: moving.y, w: overlapW, color: moving.color });
  document.getElementById('stack-h').textContent = blocks.length - 1;
  // New moving block
  const colors = ['#FF6FA3','#A78BFA','#5DADE2','#5DD68F','#FFD166','#FF8C42'];
  moving.color = colors[blocks.length % colors.length];
  moving.w = overlapW;
  moving.x = (Math.random() < 0.5) ? 0 : _stack.c.width - moving.w;
  moving.y -= 30;
  // Camera scroll up
  if (moving.y < 100) {
    _stack.cameraY += 30;
    moving.y += 30;
    blocks.forEach(b => b.y += 30);
  }
  moving.dir = 2 + Math.min(blocks.length * 0.1, 4);
}




