function renderConjen() {
  const v = document.getElementById('conjen-input').value.trim().toLowerCase();
  const out = document.getElementById('conjen-output');
  if (!v) {
    const list = Object.entries(EN_VERBS).map(([k,vd]) => `<button class="btn alt full" style="margin-top:6px; text-align:left;" onclick="document.getElementById('conjen-input').value='${k}'; renderConjen();"><strong>${k}</strong> <span style="color:var(--textSec); font-size:12px;">— ${vd.fr}</span></button>`).join('');
    out.innerHTML = `<p style="color:var(--textSec); font-size:13px; margin:10px 0;">Verbes irréguliers :</p>${list}`;
    return;
  }
  const verb = EN_VERBS[v];
  if (!verb) { out.innerHTML = `<p style="color:var(--danger); padding:14px;">Verbe non trouvé.</p>`; return; }
  let html = `<div style="background:var(--surfaceAlt); padding:14px; border-radius:14px; margin-top:10px; text-align:center;"><div style="font-size:24px; font-weight:900; color:var(--primary);">${v}</div><div style="font-size:14px; color:var(--textSec);">— ${verb.fr}</div></div>`;
  for (const [tk, tname] of EN_TENSES) {
    if (!verb[tk]) continue;
    html += `<div style="background:var(--surface); padding:12px; border-radius:12px; margin-top:8px;"><h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-bottom:6px;">${tname}</h3>`;
    for (let i=0; i<6; i++) {
      html += `<div style="display:flex; padding:4px 0; font-size:13px;"><strong>${verb[tk][i]}</strong></div>`;
    }
    html += '</div>';
  }
  out.innerHTML = html;
}

