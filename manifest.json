  </div>
  <p style="font-size:11px; color:var(--textSec); margin-top:10px;">💡 Décris ta vie idéale dans 5-10 ans. Sois précis·e, sois ambitieux·se. Relis souvent.</p>`;
  pillars.forEach(p => {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">${p.emoji} ${p.name}</h3>
      <textarea class="input" id="dl-${p.key}" rows="3" placeholder="${escapeHtml(p.placeholder)}" oninput="dlSave()">${escapeHtml(d[p.key]||'')}</textarea>`;
  });
  html += `<p style="font-size:11px; color:var(--textSec); text-align:center; margin-top:14px;">✨ Sauvegarde automatique</p>`;
  document.getElementById('dreamlife-content').innerHTML = html;
