async function startReview() {
  const cards = (await dbAll('cards')).filter(c => c.deck_id === _currentDeck.id);
  const today = new Date().toISOString().split('T')[0];
  // Cards due today (or never reviewed)
  const due = cards.filter(c => !c.next_due || c.next_due <= today);
  if (due.length === 0) { toast('Aucune carte à réviser pour le moment ✨'); return; }
  // Shuffle
  for (let i=due.length-1; i>0; i--) {
    const j = Math.floor(Math.random()*(i+1));
    [due[i], due[j]] = [due[j], due[i]];
  }
  _reviewCards = due;
  _reviewIndex = 0;
  _reviewFlipped = false;
  showReviewCard();
  goTo('deck-review');
}

function showReviewCard() {
  const c = _reviewCards[_reviewIndex];
  document.getElementById('review-progress').textContent = `${_reviewIndex+1} / ${_reviewCards.length}`;
  document.getElementById('review-side').textContent = 'Question';
  document.getElementById('review-text').textContent = c.front;
  document.getElementById('review-controls').style.display = 'none';
  _reviewFlipped = false;
}

function flipCard() {
  if (_reviewFlipped) return;
  const c = _reviewCards[_reviewIndex];
  document.getElementById('review-side').textContent = 'Réponse';
  document.getElementById('review-text').textContent = c.back;
  document.getElementById('review-controls').style.display = 'block';
  _reviewFlipped = true;
}

async function rateCard(quality) {
  // Spaced repetition: simple SM-style
  // 0=non (reset to 0), 1=bof (level stays or +1), 2=oui (level +1, longer interval)
  const c = _reviewCards[_reviewIndex];
  let level = c.level || 0;
  if (quality === 0) level = 0;
  else if (quality === 1) level = Math.max(level, 1);
  else level = level + 1;
  // Intervals (days): 0=tomorrow, 1=2j, 2=4j, 3=7j, 4=14j, 5=30j, 6=60j
  const intervals = [1, 2, 4, 7, 14, 30, 60, 120];
  const days = intervals[Math.min(level, intervals.length-1)];
  const next = new Date();
  next.setDate(next.getDate() + days);
  c.level = level;
  c.next_due = next.toISOString().split('T')[0];
  await dbPut('cards', c);
  _reviewIndex++;
  if (_reviewIndex >= _reviewCards.length) {
    toast('Session terminée ✨');
    endReview();
  } else {
    showReviewCard();
  }
}

function endReview() {
  goTo('deck-detail');
}

// ============================================================
// POMODORO
// ============================================================
const pomo = {
  mode: 'work',  // 'work' | 'short' | 'long'
  remaining: 25 * 60,
  running: false,
  interval: null,
  session: 0,
  settings: {
    work: parseInt(localStorage.getItem('nw_pomo_work') || '25'),
    short: parseInt(localStorage.getItem('nw_pomo_short') || '5'),
    long: parseInt(localStorage.getItem('nw_pomo_long') || '15'),
    cycle: parseInt(localStorage.getItem('nw_pomo_cycle') || '4'),
  },
};

function renderPomodoro() {
  const min = Math.floor(pomo.remaining / 60);
  const sec = pomo.remaining % 60;
  document.getElementById('pomodoro-time').textContent = `${String(min).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
  const modeLabel = pomo.mode === 'work' ? 'Travail' : (pomo.mode === 'short' ? 'Pause courte' : 'Pause longue');
  document.getElementById('pomodoro-mode').textContent = modeLabel;
  document.getElementById('pomodoro-sessions').textContent = `Session ${pomo.session % pomo.settings.cycle} / ${pomo.settings.cycle}`;
  document.getElementById('pomo-start-btn').textContent = pomo.running ? '⏸ Pause' : '▶ Démarrer';
  // Today total
  const today = new Date().toISOString().split('T')[0];
  const todayMins = parseInt(localStorage.getItem('nw_pomo_today_' + today) || '0');
  document.getElementById('pomo-today').textContent = `${todayMins} min`;
}

function togglePomodoro() {
  if (pomo.running) {
    pomo.running = false;
    if (pomo.interval) clearInterval(pomo.interval);
  } else {
    pomo.running = true;
    pomo.interval = setInterval(() => {
      pomo.remaining--;
      if (pomo.remaining <= 0) {
        pomoFinish();
      }
      v51_renderPomodoro();
    }, 1000);
  }
  v51_renderPomodoro();
}

function pomoFinish() {
  clearInterval(pomo.interval);
  pomo.running = false;
  // Track work time
  if (pomo.mode === 'work') {
    const today = new Date().toISOString().split('T')[0];
    const cur = parseInt(localStorage.getItem('nw_pomo_today_' + today) || '0');
    localStorage.setItem('nw_pomo_today_' + today, cur + pomo.settings.work);
    pomo.session++;
  }
  // Switch mode
  if (pomo.mode === 'work') {
    if (pomo.session % pomo.settings.cycle === 0) {
      pomo.mode = 'long';
      pomo.remaining = pomo.settings.long * 60;
      toast('🎉 Pause longue !', 3000);
    } else {
      pomo.mode = 'short';
      pomo.remaining = pomo.settings.short * 60;
      toast('☕ Pause courte', 3000);
    }
  } else {
    pomo.mode = 'work';
    pomo.remaining = pomo.settings.work * 60;
    toast('💪 Au boulot !', 3000);
  }
  // Vibration
  if ('vibrate' in navigator) navigator.vibrate([200, 100, 200, 100, 200]);
  v51_renderPomodoro();
}

function resetPomodoro() {
  if (pomo.interval) clearInterval(pomo.interval);
  pomo.running = false;
  pomo.mode = 'work';
  pomo.session = 0;
  pomo.remaining = pomo.settings.work * 60;
  v51_renderPomodoro();
}

function skipPomodoro() {
  pomo.remaining = 0;
  pomoFinish();
}

function openPomodoroSettings() {
  document.getElementById('pomo-work-input').value = pomo.settings.work;
  document.getElementById('pomo-short-input').value = pomo.settings.short;
  document.getElementById('pomo-long-input').value = pomo.settings.long;
  document.getElementById('pomo-cycle-input').value = pomo.settings.cycle;
  openModal('modal-pomo-settings');
}

function savePomodoroSettings() {
  pomo.settings.work = parseInt(document.getElementById('pomo-work-input').value) || 25;
  pomo.settings.short = parseInt(document.getElementById('pomo-short-input').value) || 5;
  pomo.settings.long = parseInt(document.getElementById('pomo-long-input').value) || 15;
  pomo.settings.cycle = parseInt(document.getElementById('pomo-cycle-input').value) || 4;
  localStorage.setItem('nw_pomo_work', pomo.settings.work);
  localStorage.setItem('nw_pomo_short', pomo.settings.short);
  localStorage.setItem('nw_pomo_long', pomo.settings.long);
  localStorage.setItem('nw_pomo_cycle', pomo.settings.cycle);
  if (!pomo.running) resetPomodoro();
  closeModal('modal-pomo-settings');
}

