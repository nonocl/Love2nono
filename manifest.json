function v57_isTheme(name) {
  // Check via state.themeName ou via localStorage
  try {
    const t = localStorage.getItem('nw_theme');
    return t === name;
  } catch { return false; }
}

function v57_getActiveCombo() {
  for (const egg of V57_EASTER_EGGS) {
    try {
      if (egg.detect()) return egg;
    } catch {}
  }
  return null;
}

// Met le thème en attribut data pour les sélecteurs CSS
function v57_syncThemeAttr() {
  try {
    const t = localStorage.getItem('nw_theme');
    if (t) document.body.setAttribute('data-theme', t);
  } catch {}
}

// Hook setTheme si dispo
(function v57_hookSetTheme() {
  if (typeof window.setTheme === 'function') {
    const orig = window.setTheme;
    window.setTheme = function() {
      const r = orig.apply(this, arguments);
      setTimeout(() => {
        v57_syncThemeAttr();
        v57_checkAndAnnounceCombo();
        v57_renderComboIndicator();
      }, 50);
      return r;
    };
  }
})();

// Hook applyVibe pour relancer la détection
(function v57_hookVibe() {
  if (typeof window.v56_applyVibe === 'function') {
    const orig = window.v56_applyVibe;
    window.v56_applyVibe = function() {
      const r = orig.apply(this, arguments);
      setTimeout(() => {
        v57_checkAndAnnounceCombo();
        v57_renderComboIndicator();
      }, 50);
      return r;
    };
  }
})();

// Annonce une combo nouvelle
function v57_checkAndAnnounceCombo() {
  const combo = v57_getActiveCombo();
  if (!combo) return;
  const seen = JSON.parse(localStorage.getItem('nw_v57_combos_seen') || '[]');
  if (!seen.includes(combo.id)) {
    seen.push(combo.id);
    localStorage.setItem('nw_v57_combos_seen', JSON.stringify(seen));
    if (typeof toast === 'function') {
      toast(`✨ Combo débloquée : ${combo.name} — ${combo.desc} !`);
    }
    if (navigator.vibrate) navigator.vibrate([20, 50, 20, 50, 20]);
  }
}

// Render l'indicateur de combo dans les settings
function v57_renderComboIndicator() {
  const block = document.getElementById('v56-vibe-picker-block');
  if (!block) return;
  let indic = document.getElementById('v57-combo-indicator');
  const combo = v57_getActiveCombo();
  const seen = JSON.parse(localStorage.getItem('nw_v57_combos_seen') || '[]');
  if (!indic) {
    indic = document.createElement('div');
    indic.id = 'v57-combo-indicator';
    indic.className = 'v57-combo-indicator';
    block.appendChild(indic);
  }
  let html;
  if (combo) {
    html = `<div style="font-size:11px; color:var(--textSec); font-weight:700;">✨ COMBO ACTIVE</div>
      <div class="v57-combo-active">${combo.name}</div>
