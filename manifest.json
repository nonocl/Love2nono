// ============================================================
const BAC_GENERAL_COEFFS = [
  { name: 'Français écrit (1ère)', coef: 5 },
  { name: 'Français oral (1ère)', coef: 5 },
  { name: 'Philosophie', coef: 8 },
  { name: 'Grand oral', coef: 10 },
  { name: 'Spécialité 1', coef: 16 },
  { name: 'Spécialité 2', coef: 16 },
  { name: 'Contrôle continu', coef: 40 },
];
function renderBacSim() {
  const saved = JSON.parse(localStorage.getItem('nw_bacsim') || '{}');
  let html = '';
  for (const m of BAC_GENERAL_COEFFS) {
    const v = saved[m.name] || '';
    const safeName = m.name.replace(/'/g, "\\'");
    html += `<div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-bottom:6px; display:flex; gap:10px; align-items:center;">
      <div style="flex:1; min-width:0;">
        <div style="font-weight:600; font-size:13px;">${escapeHtml(m.name)}</div>
        <div style="font-size:11px; color:var(--textSec);">Coeff ${m.coef}</div>
      </div>
      <input type="number" class="input" value="${v}" step="0.5" min="0" max="20" placeholder="/20" style="width:70px; padding:6px;" oninput="bsUpdate('${safeName}', this.value)">
    </div>`;
  }
  document.getElementById('bs-list').innerHTML = html;
  bsCalc();
}
function bsUpdate(name, val) {
  const s = JSON.parse(localStorage.getItem('nw_bacsim') || '{}');
  if (val === '') delete s[name]; else s[name] = parseFloat(val);
  localStorage.setItem('nw_bacsim', JSON.stringify(s));
  bsCalc();
}
function bsCalc() {
  const s = JSON.parse(localStorage.getItem('nw_bacsim') || '{}');
  let total = 0, totalCoef = 0;
  for (const m of BAC_GENERAL_COEFFS) {
    if (s[m.name] !== undefined && s[m.name] !== '') {
      total += s[m.name] * m.coef;
      totalCoef += m.coef;
    }
  }
  if (!totalCoef) {
    document.getElementById('bs-result').innerHTML = '<p style="text-align:center; color:var(--textSec); font-size:12px;">Tape tes notes ↑</p>';
    return;
  }
  const moy = total / totalCoef;
  let mention = '';
  if (moy >= 18) mention = '🥇 TB Félicitations';
  else if (moy >= 16) mention = '🥈 Très Bien';
  else if (moy >= 14) mention = '🥉 Bien';
  else if (moy >= 12) mention = '✅ Assez Bien';
  else if (moy >= 10) mention = '✓ Admis';
  else if (moy >= 8) mention = '⚠️ Rattrapage';
  else mention = '❌ Refusé';
  document.getElementById('bs-result').innerHTML = `<div style="background:linear-gradient(135deg, var(--primary), var(--accent)); color:white; padding:20px; border-radius:14px; text-align:center;">
    <div style="font-size:11px; opacity:0.85;">Moyenne au bac</div>
    <div style="font-size:48px; font-weight:900;">${moy.toFixed(2)}<span style="font-size:20px; opacity:0.7;">/20</span></div>
    <div style="font-size:14px; margin-top:6px;">${mention}</div>
    <div style="font-size:11px; opacity:0.7; margin-top:6px;">Coeff renseignés : ${totalCoef}/100</div>
  </div>`;
}

// ============================================================
// CALC MOYENNE COEFF
// ============================================================
let _mcRows = [];
function mcInit() {
  if (!_mcRows.length) _mcRows = [{note:'', coef:1}];
  mcRender();
}
function mcAdd() { _mcRows.push({note:'', coef:1}); mcRender(); }
function mcDel(i) { _mcRows.splice(i, 1); mcRender(); }
function mcRender() {
  const el = document.getElementById('mc-rows');
  el.innerHTML = _mcRows.map((r, i) => `
    <div style="display:flex; gap:6px; margin-bottom:6px;">
      <input type="number" class="input" placeholder="Note /20" value="${r.note}" step="0.5" oninput="_mcRows[${i}].note=this.value; mcCalc();" style="flex:2; padding:8px;">
      <input type="number" class="input" placeholder="Coeff" value="${r.coef}" step="0.5" oninput="_mcRows[${i}].coef=this.value; mcCalc();" style="flex:1; padding:8px;">
      <button class="btn alt" onclick="mcDel(${i})" style="padding:6px 10px;">×</button>
    </div>
  `).join('');
  mcCalc();
}
function mcCalc() {
  let total = 0, totalCoef = 0;
  for (const r of _mcRows) {
    const n = parseFloat(r.note), c = parseFloat(r.coef);
    if (!isNaN(n) && !isNaN(c) && c > 0) { total += n * c; totalCoef += c; }
  }
  if (!totalCoef) { document.getElementById('mc-result').innerHTML = ''; return; }
  const m = total / totalCoef;
  document.getElementById('mc-result').innerHTML = `<div style="background:var(--surface); padding:14px; border-radius:10px; text-align:center;">
    <div style="font-size:11px; color:var(--textSec);">Moyenne actuelle</div>
    <div style="font-size:36px; font-weight:900; color:var(--primary);">${m.toFixed(2)}<span style="font-size:18px; opacity:0.6;">/20</span></div>
  </div>`;
}
function mcCalcGoal() {
  const goal = parseFloat(document.getElementById('mc-goal').value);
  const nextCoef = parseFloat(document.getElementById('mc-next-coef').value);
  if (isNaN(goal) || isNaN(nextCoef)) return toast('Remplis les champs');
  let total = 0, totalCoef = 0;
  for (const r of _mcRows) {
    const n = parseFloat(r.note), c = parseFloat(r.coef);
    if (!isNaN(n) && !isNaN(c) && c > 0) { total += n * c; totalCoef += c; }
  }
  const needed = (goal * (totalCoef + nextCoef) - total) / nextCoef;
  let msg, col;
  if (needed > 20) { msg = `❌ Impossible d'atteindre ${goal}/20 avec une seule note (faudrait ${needed.toFixed(2)})`; col = 'var(--danger)'; }
  else if (needed < 0) { msg = `🎉 T'as déjà la moyenne ${goal}/20 garantie ! Tu peux te chiller.`; col = 'var(--success)'; }
  else { msg = `📊 Il te faut <strong>${needed.toFixed(2)}/20</strong> à la prochaine note pour atteindre ${goal}/20.`; col = 'var(--primary)'; }
  document.getElementById('mc-goal-result').innerHTML = `<div style="background:var(--surface); padding:14px; border-radius:10px; border-left:4px solid ${col};">${msg}</div>`;
}

