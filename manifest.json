// ============================================================
// MODE PANIQUE DEVOIR
// ============================================================
function paGenerate() {
  const type = document.getElementById('pa-type').value;
  const dl = document.getElementById('pa-deadline').value;
  const diff = parseInt(document.getElementById('pa-diff').value);
  if (!dl) return toast('Choisis une deadline');
  const target = new Date(dl);
  const now = new Date();
  const diffMs = target - now;
  if (diffMs <= 0) return toast('La deadline est déjà passée');
  const hours = Math.floor(diffMs / (1000*60*60));
  const mins = Math.floor((diffMs % (1000*60*60)) / 60000);
  const days = Math.floor(hours / 24);
  // Plans selon type
  const PLANS = {
    dm: { 
      easy: ['Lis tous les exos rapidement (5 min)', 'Fais ceux que tu sais direct', 'Cherche les autres en regardant ton cours', 'Vérifie tes calculs', 'Recopie au propre'],
      mid: ['Identifie les exos par difficulté (5 min)', 'Commence par les plus faciles pour gagner des points sûrs', 'Cherche le cours pour les durs (max 10 min/exo)', 'Si bloqué, demande à un pote ou ChatGPT', 'Recopie au propre proprement'],
      hard: ['Concentre-toi sur les exos qui rapportent le plus', 'Lâche ceux où t\'es à 0, fais semblant', 'Recopie depuis ton cours quand c\'est applicable', 'Si vraiment perdu, écris au moins quelque chose'],
      very: ['DEMANDE de l\'aide MAINTENANT (pote, parent, internet)', 'Ne reste pas seul devant ta feuille', 'Choisis 2-3 exos clés et fais ceux-là à fond', 'Mieux vaut 30% qu\'une feuille vide']
    },
    dissertation: {
      easy: ['Lis bien le sujet (5 min)', 'Fais un plan en 3 parties (10 min)', 'Trouve 2-3 exemples par partie', 'Rédige sans te relire', 'Relis et corrige'],
      mid: ['Décortique le sujet : mots-clés, problématique', 'Brainstorm 10 min sans censure', 'Plan détaillé : 3 parties × 2 sous-parties', 'Rédaction : 1h pour intro+I, 1h pour II+III, 30 min conclusion', 'Relecture finale orthographe'],
      hard: ['Cherche un plan-type existant pour ce sujet (Google)', 'Utilise des citations et exemples génériques', 'Construis un plan dialectique thèse/antithèse/synthèse', 'Rédige même si t\'es pas sûr', 'Évite les phrases trop longues qui partent en couilles'],
      very: ['Utilise un plan ultra basique : oui/non/dépend', 'Recycle des idées vues en cours', 'Au pire, fais juste intro + 2 parties + conclusion courte', 'Mieux vaut une dissert moyenne qu\'aucune']
    },
    expose: {
      easy: ['Cherche les infos clés (15 min)', 'Note 5-7 idées principales', 'Crée tes slides simples', 'Répète 2 fois à voix haute', 'Prévois 30sec d\'intro et de conclu'],
      mid: ['Trouve 3-4 sources fiables (20 min)', 'Plan : intro / 3 parties / conclu', 'Crée tes slides avec peu de texte (mots-clés + images)', 'Écris ton script mot-à-mot puis essaie sans', 'Répète 3 fois en chronométrant'],
      hard: ['Va à l\'essentiel : 5 idées MAX', 'Slides minimalistes avec gros texte', 'Mets-toi des notes sur ton tel/papier', 'Répète au moins 1 fois en entier', 'Si on te pose une question dont tu sais pas, dis "bonne question, je vais creuser"'],
      very: ['Demande à ton binôme de prendre la majorité', 'Apprends 3 idées par cœur que tu peux dire', 'Mets tout en slides très visuelles, lis-les', 'Reste calme et parle lentement']
    },
    ds: {
      easy: ['Survole tes fiches (10 min)', 'Note 5 trucs à revoir', 'Fais 2-3 exos types', 'Vérifie les formules clés', 'Va dormir tôt'],
      mid: ['Liste les chapitres concernés', 'Pomodoro 25 min sur chaque chapitre', 'Refais les exos types du cours', 'Prépare une fiche mémo formules/dates clés', 'Sommeil > révisions à 1h du mat'],
      hard: ['Concentre-toi sur les bases : si tu sais 50% de l\'essentiel, tu sauves la note', 'Refais UN exo type par chapitre, c\'est mieux que 10 mal faits', 'Apprends par cœur les formules / définitions', 'Repère ce qui tombe le plus souvent'],
      very: ['Liste 5 trucs vraiment essentiels et apprends ceux-là à fond', 'Au pire tu sauves la moyenne sur ces 5 questions', 'Sommeil > révisions paniquées', 'Le matin du DS : relecture rapide, pas plus']
    },
    oral: {
      easy: ['Structure ton discours en 3 points', 'Apprends ton intro et ta conclu par cœur', 'Répète 2× à voix haute', 'Prévois 1 anecdote / exemple', 'Souris au début'],
      mid: ['Plan clair : accroche / 3 idées / ouverture', 'Note les transitions entre parties', 'Apprends mot-à-mot l\'intro et la conclu', 'Répète face à un miroir 3×', 'Prépare 3-5 questions probables et tes réponses'],
      hard: ['Apprends l\'intro et la conclu par cœur, le reste tu improvises', 'Identifie 5 mots-clés à dire absolument', 'Si tu bloques, dis "alors..." en gagnant du temps', 'Répète au moins 2× même si c\'est tard'],
      very: ['Note tes idées sur petits papiers que tu peux regarder discrètement', 'Apprends 3 phrases impactantes que tu peux placer', 'Parle lentement, ça impressionne', 'Si tu blanc total : "je préfère reformuler"']
    },
    fiche: {
      easy: ['Relis le cours rapidement (15 min)', 'Note les titres de chaque partie', 'Sous chaque titre : 3-5 points clés', 'Ajoute formules/dates/définitions encadrées', 'Surligne en couleurs'],
      mid: ['Découpe le cours en grandes parties', 'Pour chaque : titre + 5 points + 1 exemple', 'Met les formules/dates en gras/encadré', 'Code couleur : vert=définition, jaune=formule, rouge=exception', 'Schéma ou mind-map en marge'],
      hard: ['Va à l\'essentiel : 1 page par chapitre max', 'Définitions + formules + 1 exemple par concept', 'Évite les phrases longues, fais des bullets', 'Apprends pendant que tu fais la fiche'],
      very: ['Recopie juste les titres et formules', 'Au pire, photo de la page la plus dense', 'Apprends en faisant la fiche, c\'est le but']
    }
  };
  let level = 'mid';
  if (diff === 1) level = 'easy';
  else if (diff === 3) level = 'hard';
  else if (diff === 4) level = 'very';
  const steps = PLANS[type][level];
  // Calc temps par étape
  const totalMin = hours*60 + mins;
  const minPerStep = Math.floor(totalMin / steps.length);
  const urg = totalMin < 60 ? 'EXTRÊME' : totalMin < 180 ? 'HAUTE' : totalMin < 720 ? 'MOYENNE' : 'GÉRABLE';
  const urgCol = totalMin < 60 ? '#FF4757' : totalMin < 180 ? '#FF8C42' : totalMin < 720 ? '#FFD166' : '#5DD68F';
  let html = `<div style="background:${urgCol}; color:white; padding:14px; border-radius:14px; margin-bottom:14px;">
    <div style="font-size:11px; opacity:0.85;">⏰ Temps restant</div>
    <div style="font-size:24px; font-weight:900;">${days > 0 ? days+'j ' : ''}${hours%24}h ${mins}min</div>
    <div style="font-size:11px; margin-top:4px;">Urgence : ${urg}</div>
  </div>`;
  steps.forEach((s, i) => {
    html += `<div style="background:var(--surface); padding:12px 14px; border-radius:10px; margin-bottom:6px; display:flex; gap:10px; align-items:flex-start;">
      <div style="background:var(--primary); color:white; width:28px; height:28px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; flex-shrink:0;">${i+1}</div>
      <div style="flex:1;">
        <div style="font-size:13px; line-height:1.4;">${escapeHtml(s)}</div>
        <div style="font-size:11px; color:var(--primary); margin-top:4px;">≈ ${minPerStep} min</div>
      </div>
    </div>`;
  });
  html += `<div style="background:var(--surface); padding:14px; border-radius:10px; margin-top:14px; border-left:4px solid var(--primary);">
    <div style="font-size:13px; font-weight:700;">💡 Mindset</div>
    <p style="font-size:12px; color:var(--textSec); margin-top:6px; line-height:1.5;">Respire. Tu vas y arriver. Mieux vaut un truc bof rendu que rien rendu. Coupe les notifs, mets de la musique sans paroles, et lance-toi.</p>
  </div>`;
  document.getElementById('pa-result').innerHTML = html;
  if (typeof badgeUnlock === 'function') badgeUnlock('panic_user');
}

