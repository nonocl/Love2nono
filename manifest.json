function g2048Start() {
  V54__g2048 = { grid: Array(4).fill(0).map(() => Array(4).fill(0)), score: 0 };
  g2048Add(); g2048Add(); g2048Render();
}
function g2048Add() {
  const empties = [];
  for (let r = 0; r < 4; r++) for (let c = 0; c < 4; c++) if (V54__g2048.grid[r][c] === 0) empties.push([r,c]);
  if (empties.length === 0) return;
  const [r,c] = empties[Math.floor(Math.random()*empties.length)];
  V54__g2048.grid[r][c] = Math.random() < 0.9 ? 2 : 4;
}
function g2048Render() {
  const colors = {0:'#444',2:'#eee4da',4:'#ede0c8',8:'#f2b179',16:'#f59563',32:'#f67c5f',64:'#f65e3b',128:'#edcf72',256:'#edcc61',512:'#edc850',1024:'#edc53f',2048:'#edc22e'};
  let html = `<div style="display:grid; grid-template-columns:repeat(4,1fr); gap:6px; background:#bbada0; padding:6px; border-radius:8px;">`;
  for (let r = 0; r < 4; r++) for (let c = 0; c < 4; c++) {
    const v = V54__g2048.grid[r][c];
    const color = v >= 8 ? '#fff' : '#776e65';
    html += `<div style="aspect-ratio:1; background:${colors[v]||'#3c3a32'}; border-radius:4px; display:flex; align-items:center; justify-content:center; font-size:${v>1000?18:24}px; font-weight:900; color:${color};">${v||''}</div>`;
