// ============================================================
// WHEEL
// ============================================================
function drawLuckWheel() {
  const txt = document.getElementById('luckwheel-options').value || 'Pizza\nSushi\nBurger\nSalade';
  const opts = txt.split('\n').filter(x => x.trim()).map(x => x.trim());
  if (opts.length < 2) return;
  const c = document.getElementById('luckwheel-canvas');
  const ctx = c.getContext('2d');
  const W = c.width, H = c.height;
  const cx = W/2, cy = H/2, r = Math.min(W,H)/2 - 8;
  ctx.clearRect(0,0,W,H);
  ctx.save();
  ctx.translate(cx, cy);
  ctx.rotate(state.wheelRotation);
  const colors = ['#FF6FA3','#FFB6D9','#C77DFF','#9D4EDD','#7B61FF','#5DD6E5','#5DD68F','#FFD166','#FF8C42','#FF6B7A','#A78BFA','#06FFA5'];
  const seg = 2*Math.PI / opts.length;
  for (let i=0; i<opts.length; i++) {
    ctx.beginPath();
    ctx.moveTo(0,0);
    ctx.arc(0,0,r,i*seg,(i+1)*seg);
    ctx.closePath();
    ctx.fillStyle = colors[i % colors.length];
    ctx.fill();
    // Text
    ctx.save();
    ctx.rotate(i*seg + seg/2);
    ctx.fillStyle = 'white';
    ctx.font = 'bold 14px system-ui';
    ctx.textAlign = 'right';
    ctx.fillText(opts[i].length > 14 ? opts[i].slice(0,13)+'…' : opts[i], r-12, 5);
    ctx.restore();
  }
  ctx.restore();
}

function spinLuckWheel() {
  const txt = document.getElementById('luckwheel-options').value || 'Pizza\nSushi\nBurger\nSalade';
  const opts = txt.split('\n').filter(x => x.trim());
  if (opts.length < 2) { toast('Il faut au moins 2 options'); return; }
  const winner = Math.floor(Math.random() * opts.length);
  const seg = 2*Math.PI / opts.length;
  const target = -(winner * seg + seg/2) + Math.PI*1.5; // pointe en haut
  const totalRotations = 5 + Math.random() * 3;
  const finalRot = totalRotations * 2*Math.PI + target;
  const start = state.wheelRotation;
  const startTime = performance.now();
  const duration = 4000;
  function animate(t) {
    const elapsed = t - startTime;
    const progress = Math.min(elapsed/duration, 1);
    const eased = 1 - Math.pow(1-progress, 3);
    state.wheelRotation = start + (finalRot - start) * eased;
    drawLuckWheel();
    if (progress < 1) requestAnimationFrame(animate);
    else {
      state.wheelRotation = state.wheelRotation % (2*Math.PI);
      setTimeout(() => alert('🎯 ' + opts[winner]), 300);
    }
  }
  requestAnimationFrame(animate);
}

