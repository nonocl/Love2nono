const MOODS = [
  { e: '😄', l: 'Heureux', v: 5 },
  { e: '😊', l: 'Bien', v: 4 },
  { e: '😐', l: 'Neutre', v: 3 },
  { e: '😔', l: 'Triste', v: 2 },
