  'decir': { presente:['digo','dices','dice','decimos','decís','dicen'], imperfecto:['decía','decías','decía','decíamos','decíais','decían'], indefinido:['dije','dijiste','dijo','dijimos','dijisteis','dijeron'], futuro:['diré','dirás','dirá','diremos','diréis','dirán'], condicional:['diría','dirías','diría','diríamos','diríais','dirían'] },
