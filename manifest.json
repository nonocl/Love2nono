  _editTrackCats = new Set(links.filter(l => l.track_id === tid).map(l => l.cat_id));
  document.getElementById('track-edit-title').textContent = 'Modifier la piste';
  document.getElementById('track-edit-title-input').value = t.title;
  document.getElementById('track-edit-artist-input').value = t.artist || '';
  document.getElementById('track-edit-album-input').value = t.album || '';
  document.getElementById('track-edit-batch-info').textContent = '';
  document.getElementById('track-edit-skip').style.display = 'none';
  updateTrackEditCover();
  await renderTrackEditCats();
  openModal('modal-track-edit');
}

// ----- Track categories picker (depuis menu piste) -----
async function openTrackCatsPicker() {
  closeModal('modal-track-menu');
  const tid = player.trackMenuId;
  const cats = await dbAll('music_cats');
  const links = await dbAll('track_cats');
