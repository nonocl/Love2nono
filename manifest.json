function phishExample() {
  const ex = `URGENT - Votre colis est bloqué à la douane. Régularisez dans les 24h pour éviter le retour à l'expéditeur.
  
Frais de douane : 1.99€
Suivi : laposte-colis-bloque-2024.tk/regulariser?id=FR8472

Service Client La Poste`;
  document.getElementById('phi-input').value = ex;
}
function phishCheck() {
  const text = document.getElementById('phi-input').value.trim();
  if (!text) { toast('Colle un message'); return; }
  
  const flags = [];
  const lower = text.toLowerCase();
  
  // Patterns français de scams connus
  const scamPatterns = [
    { p: /colis (?:bloqué|en attente|expir)/i, msg: '🚨 Pattern "colis bloqué"', det: 'Scam ultra classique imitant La Poste/Chronopost/UPS' },
    { p: /ameli|carte vitale|cpam/i, msg: '🚨 Mention Ameli/Carte Vitale', det: 'Ameli ne demande JAMAIS d\'infos par SMS/email avec lien' },
    { p: /(?:impôts|impots|trésor public|dgfip).*rembours/i, msg: '🚨 "Impôts remboursement"', det: 'Scam classique. Le fisc ne fait jamais ça par SMS' },
    { p: /caf|allocations? familiales/i, msg: '⚠️ Mention CAF', det: 'La CAF ne demande pas d\'infos personnelles par lien externe' },
    { p: /compte (?:bloqué|suspendu|piraté|désactivé)/i, msg: '🚨 "Compte bloqué/suspendu"', det: 'Création d\'urgence pour te faire cliquer sans réfléchir' },
    { p: /vous avez gagné|tirage au sort|gagnant|prize|lottery/i, msg: '🚨 "Vous avez gagné"', det: 'Tu n\'as pas joué = tu n\'as pas gagné. C\'est un scam.' },
    { p: /microsoft.*support|support technique/i, msg: '🚨 "Support technique Microsoft"', det: 'Microsoft ne contacte JAMAIS par téléphone/email d\'eux-mêmes' },
    { p: /héritage|millionnaire|prince nigérian/i, msg: '🚨 Pattern "héritage/prince"', det: 'Scam classique 419 nigérian' },
    { p: /verrouill[éeè]|verifier (?:votre |vos )/i, msg: '⚠️ "Vérifier votre compte"', det: 'Sentiment d\'urgence forcé' },
    { p: /netflix.*paiement|netflix.*suspend/i, msg: '🚨 "Netflix paiement échoué"', det: 'Top 5 des scams 2024' },
    { p: /amazon.*commande|amazon.*remboursement/i, msg: '🚨 "Amazon commande"', det: 'Connecte-toi directement sur amazon.fr, jamais via le lien' },
    { p: /paypal.*verif|paypal.*confirm/i, msg: '🚨 "PayPal vérification"', det: 'PayPal ne demande pas via email avec lien externe' },
    { p: /bit\.ly|tinyurl|short\.link|t\.co|goo\.gl/i, msg: '⚠️ Lien raccourci', det: 'Cache la vraie destination — toujours suspect dans un email pro' },
  ];
  
  for (const sp of scamPatterns) {
    if (sp.p.test(text)) flags.push({ sev: 'high', msg: sp.msg, detail: sp.det });
  }
  
  // Urgence artificielle
  const urgencyWords = ['urgent','immédiat','24h','48h','dernier délai','aujourd\'hui','maintenant','tout de suite','sans délai','expire','expirera','expire bientôt'];
  const urgencyCount = urgencyWords.filter(w => lower.includes(w)).length;
  if (urgencyCount >= 2) flags.push({ sev: 'high', msg: '⏰ Urgence artificielle', detail: `${urgencyCount} mots créant une pression temporelle (urgent, 24h, immédiat...)` });
  else if (urgencyCount === 1) flags.push({ sev: 'med', msg: '⏰ Mot d\'urgence', detail: 'Pression temporelle suspecte' });
  
  // Demande d'infos sensibles
  const sensitive = ['mot de passe','code carte','carte bancaire','iban','rib','numéro de sécurité','code confidentiel','identifiants','login','password','cvv'];
  const sFound = sensitive.filter(w => lower.includes(w));
  if (sFound.length > 0) flags.push({ sev: 'high', msg: '💳 Demande d\'infos sensibles', detail: `Trouvés : ${sFound.join(', ')}` });
  
  // Liens dans le texte
  const urls = text.match(/https?:\/\/[^\s]+/gi) || [];
  if (urls.length > 0) {
    let suspiciousUrls = 0;
    for (const u of urls) {
      if (/\.(tk|ml|ga|cf|gq|xyz|click|top|icu)/.test(u)) suspiciousUrls++;
      if (/[а-яА-Я]/.test(u)) suspiciousUrls++;
      if (u.includes('@')) suspiciousUrls++;
    }
    if (suspiciousUrls > 0) flags.push({ sev: 'high', msg: `🔗 ${suspiciousUrls} URL suspecte${suspiciousUrls > 1 ? 's' : ''}`, detail: 'Tap "Scanner URL" pour analyse détaillée' });
  }
  
  // Fautes d'orthographe (heuristique simple)
  const fautes = ['bloque','livre','recu','regularise','telecharge','votre compte est','paiement echou','commande enregitr'];
  const fCount = fautes.filter(w => lower.includes(w)).length;
  if (fCount >= 2) flags.push({ sev: 'med', msg: '✏️ Possibles fautes d\'orthographe', detail: 'Les vrais services en France utilisent un français correct' });
  
  // Salutations génériques
  if (/(cher client|bonjour cher|cher utilisateur|hello dear|hello user)/i.test(text)) flags.push({ sev: 'med', msg: '👤 Salutation générique', detail: 'Les vraies entreprises utilisent ton nom (qu\'elles ont déjà)' });
  
  // Score
  const highCount = flags.filter(f => f.sev === 'high').length;
  const medCount = flags.filter(f => f.sev === 'med').length;
  let score = 100 - (highCount * 25 + medCount * 12);
  if (score < 0) score = 0;
  
  let verdict, color, icon;
  if (highCount >= 2 || score < 30) { verdict = 'PHISHING TRÈS PROBABLE'; color = '#E14D6B'; icon = '🚨'; }
  else if (highCount >= 1 || score < 60) { verdict = 'TRÈS SUSPECT'; color = '#FF8C42'; icon = '⚠️'; }
  else if (medCount >= 2) { verdict = 'À VÉRIFIER'; color = '#FFC542'; icon = '🤔'; }
  else { verdict = 'PROBABLEMENT LÉGITIME'; color = '#5DD68F'; icon = '✅'; }
  
  let html = `<div style="background:${color}; color:white; padding:18px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">${icon}</div>
    <div style="font-size:16px; font-weight:900; margin-top:4px;">${verdict}</div>
    <div style="font-size:12px; opacity:0.9; margin-top:4px;">${flags.length} drapeau${flags.length !== 1 ? 'x' : ''} · Score : ${score}/100</div>
  </div>`;
  
  if (flags.length > 0) {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">🚩 Signaux détectés</h3>`;
    flags.forEach(f => {
      const c = f.sev === 'high' ? '#E14D6B' : f.sev === 'med' ? '#FFC542' : '#5DADE2';
      html += `<div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-top:6px; border-left:4px solid ${c};">
        <div style="font-size:12px; font-weight:700;">${escapeHtml(f.msg)}</div>
        <div style="font-size:10px; color:var(--textSec); margin-top:3px; line-height:1.4;">${escapeHtml(f.detail)}</div>
      </div>`;
    });
  }
  
  if (highCount >= 1) {
    html += `<div style="background:#E14D6B; color:white; padding:14px; border-radius:12px; margin-top:14px;">
      <div style="font-size:13px; font-weight:900;">🛡️ Que faire ?</div>
      <ul style="font-size:11px; margin-top:6px; padding-left:18px; line-height:1.6;">
        <li>Ne clique sur aucun lien</li>
        <li>Ne donne aucune info personnelle</li>
        <li>Signale sur signal-spam.fr (email) ou 33700 (SMS)</li>
        <li>Connecte-toi directement au site officiel pour vérifier</li>
        <li>Supprime le message</li>
      </ul>
    </div>`;
  }
  
  document.getElementById('phi-result').innerHTML = html;
}

