<!-- DISCORD EDITOR -->
<div class="page" id="page-sim-discord">
  <div class="page-header">
    <button class="back-btn" onclick="goBack()">‹</button>
    <div class="page-title">💜 Discord</div>
    <button class="icon-btn" onclick="saveSocialSim('discord')" title="Enregistrer">💾</button>
  </div>
  <div class="section">
    <div style="display:flex; gap:6px; margin-bottom:14px;">
      <button class="btn alt" id="disc-mode-norm" onclick="setDiscNitro(false)" style="flex:1;">Standard</button>
      <button class="btn primary" id="disc-mode-nitro" onclick="setDiscNitro(true)" style="flex:1;">✨ Nitro</button>
    </div>
    <span class="label">Pseudo affiché</span>
    <input type="text" class="input" id="disc-name" oninput="renderDiscord()" placeholder="Nono ✨" maxlength="32">
    <span class="label">Identifiant (handle, sans @)</span>
    <input type="text" class="input" id="disc-handle" oninput="renderDiscord()" placeholder="nono.disc94" maxlength="32">
    <span class="label">Avatar (image)</span>
    <input type="file" accept="image/*" class="input" id="disc-avatar-file" onchange="setSimAvatar('discord', this)">
    <button class="btn ghost" onclick="window.simData.discord.avatar=null; window.simData.discord.autoColor=null; document.getElementById('disc-avatar-file').value=''; renderDiscord();" style="font-size:11px; color:var(--danger);">Retirer avatar</button>
    <p id="disc-standard-info" style="font-size:11px; color:var(--textSec); padding:8px; background:var(--surfaceAlt); border-radius:8px; margin-top:8px;">📌 <strong>Mode Standard :</strong> la bannière s'adapte automatiquement à la couleur de ton avatar (comme la vraie Discord). Pas de personnalisation possible — c'est le but de Nitro.</p>

    <div id="disc-nitro-only" style="margin-top:14px; padding:14px; border:1px solid var(--primary); border-radius:12px; background:linear-gradient(135deg, var(--primary)10, transparent);">
      <div style="font-size:11px; font-weight:700; color:var(--primary); text-transform:uppercase; letter-spacing:0.4px; margin-bottom:10px;">✨ Personnalisation Nitro</div>

      <span class="label">Type de bannière</span>
      <div style="display:flex; gap:6px; flex-wrap:wrap; margin-bottom:8px;">
        <button class="btn alt" data-disc-banner-type="solid" onclick="setDiscBannerType('solid')" style="flex:1;">Couleur unie</button>
        <button class="btn alt" data-disc-banner-type="gradient" onclick="setDiscBannerType('gradient')" style="flex:1;">Dégradé</button>
        <button class="btn alt" data-disc-banner-type="image" onclick="setDiscBannerType('image')" style="flex:1;">Image</button>
      </div>

      <div id="disc-banner-solid-fields">
        <span class="label">Couleur de la bannière</span>
        <div id="disc-color-presets" style="display:flex; flex-wrap:wrap; gap:5px; margin-bottom:6px;"></div>
        <input type="color" class="input" id="disc-color1" oninput="renderDiscord()" value="#5865f2" style="height:42px; width:100%;">
      </div>

      <div id="disc-banner-gradient-fields" style="display:none;">
        <span class="label">Couleur 1</span>
        <input type="color" class="input" id="disc-color1-grad" oninput="syncGradColors()" value="#5865f2" style="height:42px; width:100%;">
        <span class="label">Couleur 2</span>
        <input type="color" class="input" id="disc-color2" oninput="renderDiscord()" value="#eb459e" style="height:42px; width:100%;">
        <span class="label">Angle du dégradé</span>
        <input type="range" id="disc-grad-angle" min="0" max="360" value="135" oninput="renderDiscord()" style="width:100%;">
      </div>

      <div id="disc-banner-image-fields" style="display:none;">
        <span class="label">Image de bannière</span>
        <input type="file" accept="image/*" class="input" id="disc-banner-file" onchange="setSimBanner('discord', this)">
        <button class="btn ghost" onclick="window.simData.discord.banner=null; document.getElementById('disc-banner-file').value=''; renderDiscord();" style="font-size:11px; color:var(--danger);">Retirer image</button>
      </div>

      <span class="label">Effet de profil (animé)</span>
      <select class="input" id="disc-effect" onchange="renderDiscord()">
        <option value="">Aucun</option>
        <option value="confetti">🎉 Confettis</option>
        <option value="hearts">💕 Cœurs flottants</option>
        <option value="sparkles">✨ Étincelles</option>
        <option value="bubbles">🫧 Bulles</option>
        <option value="snow">❄️ Neige</option>
        <option value="fireworks">🎆 Feux d'artifice</option>
        <option value="leaves">🍃 Feuilles</option>
        <option value="petals">🌸 Pétales</option>
      </select>

      <span class="label">Décoration d'avatar (cadre)</span>
      <select class="input" id="disc-deco" onchange="renderDiscord()">
        <option value="">Aucune</option>
        <option value="dragon">🐲 Dragon</option>
        <option value="cat">🐱 Chat</option>
        <option value="fire">🔥 Flammes</option>
        <option value="crown">👑 Couronne</option>
        <option value="halo">😇 Auréole</option>
        <option value="butterfly">🦋 Papillons</option>
        <option value="flowers">🌹 Roses</option>
        <option value="stars">⭐ Étoiles</option>
        <option value="ghost">👻 Fantôme</option>
        <option value="bow">🎀 Nœud rose</option>
      </select>

      <span class="label">Plaque (Clan tag)</span>
      <input type="text" class="input" id="disc-plate" oninput="renderDiscord()" placeholder="NONO" maxlength="4">
      <p style="font-size:10px; color:var(--textSec); margin-top:2px;">4 caractères max - s'affiche en petite plaque colorée à côté du nom.</p>

      <span class="label">Couleur de la plaque</span>
      <input type="color" class="input" id="disc-plate-color" oninput="renderDiscord()" value="#eb459e" style="height:42px; width:100%;">

      <span class="label">Pronoms</span>
      <input type="text" class="input" id="disc-pronouns" oninput="renderDiscord()" placeholder="il/lui">
    </div>

    <span class="label">Statut en ligne</span>
    <div style="display:flex; gap:6px; flex-wrap:wrap;">
      <button class="btn alt" data-disc-status="online" onclick="setDiscStatus('online')" style="flex:1;">🟢 En ligne</button>
      <button class="btn alt" data-disc-status="idle" onclick="setDiscStatus('idle')" style="flex:1;">🌙 Inactif</button>
      <button class="btn alt" data-disc-status="dnd" onclick="setDiscStatus('dnd')" style="flex:1;">⛔ Ne pas déranger</button>
      <button class="btn alt" data-disc-status="offline" onclick="setDiscStatus('offline')" style="flex:1;">⚫ Hors ligne</button>
    </div>
    <span class="label">Message de statut custom (court)</span>
    <input type="text" class="input" id="disc-customstatus" oninput="renderDiscord()" placeholder="✨ vibing" maxlength="50">
    <span class="label">À propos de moi (bio)</span>
    <textarea class="input" id="disc-bio" oninput="renderDiscord()" rows="3" placeholder="Italien Seconde 🇮🇹 · Pokémon Z-A · Corto Maltese"></textarea>
    <span class="label">Badges</span>
    <div id="disc-badge-picker" style="display:flex; gap:4px; flex-wrap:wrap; padding:6px 0;"></div>
    <span class="label">Membre depuis</span>
    <input type="text" class="input" id="disc-since" oninput="renderDiscord()" placeholder="15 mars 2022">
    <span class="label">Activité (jeu / Spotify)</span>
    <select class="input" id="disc-activity-type" onchange="renderDiscord()">
      <option value="">Aucune</option>
      <option value="playing">🎮 Joue à</option>
      <option value="spotify">🎵 Écoute sur Spotify</option>
      <option value="streaming">🟣 Stream</option>
      <option value="watching">📺 Regarde</option>
      <option value="custom">💬 Activité custom</option>
    </select>
    <input type="text" class="input" id="disc-activity" oninput="renderDiscord()" placeholder="Pokémon Z-A">
  </div>
  <div class="section" style="background:var(--surfaceAlt); border-radius:14px; margin:0 16px 16px; padding:18px;">
    <h3 style="font-size:13px; font-weight:700; text-align:center; margin-bottom:14px;">APERÇU</h3>
    <div id="disc-preview"></div>
  </div>
  <div style="padding:0 16px 80px;">
    <button class="btn primary full" onclick="exportSocialSim('discord')">📸 Exporter en image</button>
  </div>
</div>

