// === Helpers crypto SHA-256 (Web Crypto) ===
async function sha256(text) {
  const buffer = new TextEncoder().encode(text);
  const hashBuf = await crypto.subtle.digest('SHA-256', buffer);
  return Array.from(new Uint8Array(hashBuf)).map(b => b.toString(16).padStart(2, '0')).join('');
}

// === 1. PIN LOCK ===
async function renderPinLock() {
  const hasPin = !!localStorage.getItem('nw_pin_hash');
  const isLocked = localStorage.getItem('nw_pin_locked') === '1';
  
  let html = `<div style="background:linear-gradient(135deg, #6B6B6B, #2A2A2A); color:white; padding:18px; border-radius:18px; text-align:center;">
    <div style="font-size:48px;">🔒</div>
    <div style="font-size:18px; font-weight:800; margin-top:6px;">Verrouillage PIN</div>
    <div style="font-size:11px; opacity:0.9; margin-top:4px;">État : ${hasPin ? (isLocked ? '🔴 Actif' : '🟡 Configuré (inactif)') : '⚪ Pas configuré'}</div>
  </div>`;
  
  html += `<div style="background:#FF8C42; color:white; padding:12px; border-radius:12px; margin-top:14px; font-size:11px; line-height:1.5;">
    ⚠️ <strong>Important</strong> : ce verrouillage est local à l'app. Ce n'est pas un chiffrement militaire — un développeur déterminé pourrait contourner. Ne mets pas tes vrais secrets de banque ici.
  </div>`;
  
  if (!hasPin) {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:18px;">⚙️ Configurer un PIN</h3>
      <div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:8px;">
        <span class="label">Nouveau PIN (4-8 chiffres)</span>
        <input type="password" inputmode="numeric" pattern="[0-9]*" class="input" id="pin-new" placeholder="••••" maxlength="8">
        <span class="label" style="margin-top:8px;">Confirmer</span>
        <input type="password" inputmode="numeric" pattern="[0-9]*" class="input" id="pin-confirm" placeholder="••••" maxlength="8">
        <button class="btn primary full" onclick="pinSet()" style="margin-top:10px;">🔐 Définir</button>
      </div>`;
  } else {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:18px;">🎛️ Actions</h3>
      <button class="btn primary full" onclick="pinToggle()" style="margin-top:8px;">${isLocked ? '🔓 Désactiver' : '🔒 Activer'}</button>
      <button class="btn alt full" onclick="pinChange()" style="margin-top:6px;">✎ Changer le PIN</button>
      <button class="btn alt full" onclick="pinRemove()" style="margin-top:6px; color:var(--danger);">🗑 Supprimer le PIN</button>
      <p style="font-size:11px; color:var(--textSec); margin-top:14px; text-align:center;">${isLocked ? 'PIN demandé à chaque ouverture de l\'app' : 'PIN configuré mais pas demandé à l\'ouverture'}</p>`;
  }
  
  document.getElementById('pinlock-content').innerHTML = html;
}
async function pinSet() {
  const a = document.getElementById('pin-new').value;
  const b = document.getElementById('pin-confirm').value;
  if (!/^\d{4,8}$/.test(a)) { toast('PIN doit être 4-8 chiffres'); return; }
  if (a !== b) { toast('Les deux PINs ne correspondent pas'); return; }
  const h = await sha256(a + '_nw_salt_v1');
  localStorage.setItem('nw_pin_hash', h);
  localStorage.setItem('nw_pin_locked', '1');
  toast('🔐 PIN configuré et activé');
  renderPinLock();
}
async function pinChange() {
  const old = prompt('PIN actuel :');
  if (!old) return;
  const oldH = await sha256(old + '_nw_salt_v1');
  if (oldH !== localStorage.getItem('nw_pin_hash')) { toast('❌ PIN incorrect'); return; }
  const a = prompt('Nouveau PIN (4-8 chiffres) :');
  if (!/^\d{4,8}$/.test(a || '')) { toast('PIN invalide'); return; }
  const newH = await sha256(a + '_nw_salt_v1');
  localStorage.setItem('nw_pin_hash', newH);
  toast('✅ PIN changé');
  renderPinLock();
}
async function pinRemove() {
  const old = prompt('PIN actuel pour confirmer :');
  if (!old) return;
  const oldH = await sha256(old + '_nw_salt_v1');
  if (oldH !== localStorage.getItem('nw_pin_hash')) { toast('❌ PIN incorrect'); return; }
  if (!confirm('Supprimer le PIN définitivement ?')) return;
  localStorage.removeItem('nw_pin_hash');
  localStorage.removeItem('nw_pin_locked');
  toast('🗑 PIN supprimé');
  renderPinLock();
}
function pinToggle() {
  const cur = localStorage.getItem('nw_pin_locked') === '1';
  localStorage.setItem('nw_pin_locked', cur ? '0' : '1');
  toast(cur ? '🔓 Verrouillage désactivé' : '🔒 Verrouillage activé');
  renderPinLock();
}

