}

// === 29. QUIZ DRAPEAUX ===
function renderFlagQuiz() {
  const c = RANDOM_COUNTRIES[Math.floor(Math.random() * RANDOM_COUNTRIES.length)];
  // 3 wrong + 1 correct
  const wrong = RANDOM_COUNTRIES.filter(x => x.n !== c.n).sort(() => Math.random() - 0.5).slice(0, 3);
  const opts = [...wrong, c].sort(() => Math.random() - 0.5);
  let stats; try { stats = JSON.parse(localStorage.getItem('nw_flagquiz') || '{"ok":0,"ko":0}'); } catch { stats = {ok:0,ko:0}; }
  let html = `<div style="background:linear-gradient(135deg,#5DADE2,#FFD166); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🚩</div><div style="font-size:16px; font-weight:800;">Quiz drapeaux</div>
    <div style="font-size:11px; opacity:0.9;">Score : ${stats.ok} / ${stats.ok + stats.ko}</div>
  </div>
  <div style="background:var(--surface); padding:24px; border-radius:18px; text-align:center; margin-top:14px;">
    <div style="font-size:120px;">${c.c}</div>
    <div style="font-size:13px; color:var(--textSec); margin-top:4px;">Quel pays ?</div>
  </div>
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:14px;">`;
  opts.forEach(o => {
    html += `<button onclick="fqAnswer('${escapeJs(o.n)}','${escapeJs(c.n)}')" class="btn alt" style="padding:14px 4px;">${escapeHtml(o.n)}</button>`;
  });
  html += `</div>`;
  document.getElementById('flagquiz-content').innerHTML = html;
}
function fqAnswer(picked, correct) {
  let stats; try { stats = JSON.parse(localStorage.getItem('nw_flagquiz') || '{"ok":0,"ko":0}'); } catch { stats = {ok:0,ko:0}; }
  if (picked === correct) {
    stats.ok++;
    toast('✓ Bravo !');
    if (navigator.vibrate) navigator.vibrate(15);
  } else {
    stats.ko++;
    toast('✗ Faux ! C\'était : ' + correct);
    if (navigator.vibrate) navigator.vibrate([20, 50, 20]);
  }
  localStorage.setItem('nw_flagquiz', JSON.stringify(stats));
  setTimeout(renderFlagQuiz, 1000);
}

// === 30. LOREM IPSUM GENERATOR ===
const v51_LOREM_WORDS = 'lorem ipsum dolor sit amet consectetur adipiscing elit sed do eiusmod tempor incididunt ut labore et dolore magna aliqua enim ad minim veniam quis nostrud exercitation ullamco laboris nisi aliquip ex ea commodo consequat duis aute irure in reprehenderit voluptate velit esse cillum eu fugiat nulla pariatur excepteur sint occaecat cupidatat non proident sunt culpa qui officia deserunt mollit anim id est laborum'.split(' ');
function v51_renderLorem() {
  let html = `<div style="background:linear-gradient(135deg,#787C7E,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">📝</div><div style="font-size:16px; font-weight:800;">Lorem Ipsum</div>
    <div style="font-size:11px; opacity:0.9;">Texte placeholder pour design/dev</div>
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">Type</h3>
  <select id="lorem-type" class="input" style="margin-top:6px;">
    <option value="words">Mots</option>
    <option value="sentences">Phrases</option>
    <option value="paragraphs">Paragraphes</option>
  </select>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">Quantité</h3>
  <input type="number" id="lorem-n" class="input" value="3" min="1" max="50" inputmode="numeric">
  <button class="btn primary full" onclick="loremGen()" style="margin-top:14px;">📝 Générer</button>
  <div id="lorem-result" style="margin-top:14px;"></div>`;
  document.getElementById('lorem-content').innerHTML = html;
}
function loremGen() {
  const type = document.getElementById('lorem-type').value;
  const n = parseInt(document.getElementById('lorem-n').value) || 3;
  let text = '';
  const word = () => v51_LOREM_WORDS[Math.floor(Math.random() * v51_LOREM_WORDS.length)];
  const sentence = () => {
    const len = 8 + Math.floor(Math.random() * 10);
    const words = [];
    for (let i = 0; i < len; i++) words.push(word());
    let s = words.join(' ');
    s = s[0].toUpperCase() + s.slice(1);
    return s + '.';
  };
  const para = () => {
    const len = 4 + Math.floor(Math.random() * 4);
    const sents = [];
    for (let i = 0; i < len; i++) sents.push(sentence());
    return sents.join(' ');
  };
  if (type === 'words') {
    const arr = [];
    for (let i = 0; i < n; i++) arr.push(word());
    text = arr.join(' ');
    text = text[0].toUpperCase() + text.slice(1);
  } else if (type === 'sentences') {
    const arr = [];
    for (let i = 0; i < n; i++) arr.push(sentence());
    text = arr.join(' ');
  } else {
    const arr = [];
    for (let i = 0; i < n; i++) arr.push(para());
    text = arr.join('\n\n');
  }
  document.getElementById('lorem-result').innerHTML = `<div style="background:var(--surface); padding:14px; border-radius:12px;">
    <div style="font-size:13px; line-height:1.7; white-space:pre-wrap;">${escapeHtml(text)}</div>
    <button class="btn primary full" onclick="navigator.clipboard.writeText(${JSON.stringify(text).replace(/'/g,'&#39;')}); toast('📋 Copié');" style="margin-top:10px;">📋 Copier</button>
  </div>`;
}


