      { code:'\\\\1', desc:'Référence au 1er groupe' },
    ]},
    { cat:'Exemples utiles', items:[
      { code:'^[\\\\w._-]+@[\\\\w.-]+\\\\.[a-z]{2,}$', desc:'Email basique' },
      { code:'^https?://[\\\\w.-]+', desc:'URL http(s)' },
      { code:'\\\\d{2}/\\\\d{2}/\\\\d{4}', desc:'Date jj/mm/aaaa' },
      { code:'[\\\\d]{10}', desc:'Numéro 10 chiffres' },
    ]}
  ]
};
function renderCheatSheet() {
  const lang = document.getElementById('cs-lang').value;
  const search = (document.getElementById('cs-search').value || '').toLowerCase();
  const data = CHEATS[lang] || [];
  let html = '';
  for (const cat of data) {
    let items = cat.items;
    if (search) items = items.filter(it => 
      it.code.toLowerCase().includes(search) || 
      (it.desc||'').toLowerCase().includes(search)
    );
    if (!items.length) continue;
    html += `<h3 style="font-size:14px; font-weight:700; color:var(--primary); margin:14px 0 8px;">${escapeHtml(cat.cat)}</h3>`;
    for (const it of items) {
      const safeCode = it.code.replace(/'/g, "\\'");
      html += `<div onclick="navigator.clipboard?.writeText(\`${it.code.replace(/`/g, '\\`')}\`); toast('📋 Copié');" style="background:var(--surface); padding:10px 12px; border-radius:8px; margin-bottom:4px; cursor:pointer;">
        <div style="font-family:monospace; font-size:12px; color:var(--primary); word-break:break-all; white-space:pre-wrap;">${escapeHtml(it.code)}</div>
        <div style="font-size:11px; color:var(--textSec); margin-top:4px;">${escapeHtml(it.desc)}</div>
      </div>`;
    }
  }
  if (!html) html = '<p style="text-align:center; color:var(--textSec); padding:30px;">Rien trouvé</p>';
  document.getElementById('cs-content').innerHTML = html;
}


// ============================================================
// SOKOBAN
// W=mur, .=sol, $=caisse, *=caisse sur cible, @=joueur, +=joueur sur cible, -=cible vide
// ============================================================
const SOK_LEVELS = [
  ['#####','#@$.#','#####'],
  ['#######','#.@$..#','#..#..#','#..$..#','#..#..#','#.....#','#######'].map(s => s.replace(/\./g, ' ').replace(/^/, '').replace(/^/, '')),
  // Format simplifié : utilisons un autre format
];
// Refais avec format propre
const SOK_LEVELS_RAW = [
  // 0: tutoriel ultra simple
  [
    "#####",
    "#@$-#",
    "#####"
  ],
  // 1: facile
  [
    "  ###  ",
    "###-###",
    "#-$@$-#",
    "#######"
  ],
  // 2: moyen
  [
    "########",
    "#-  @  #",
    "#- $ $ #",
    "#-     #",
    "########"
  ],
  // 3: 4 caisses
  [
    "########",
    "#  -   #",
    "# $ $- #",
    "#@$ $- #",
    "#- - - #",
    "########"
  ],
  // 4: classique
  [
    "  #####  ",
    "###   ###",
    "#  -$-  #",
    "# $@$ $ #",
    "#  -$-  #",
    "###   ###",
    "  #####  "
  ]
];
let _sok = null;
let _sokLevel = 0;
let _sokHistory = [];
function sokInit(lvl) {
  _sokLevel = lvl;
  const raw = SOK_LEVELS_RAW[lvl];
  if (!raw) return;
  _sok = {
    grid: raw.map(row => row.split('')),
    moves: 0,
    targets: []
  };
  // Indexe les cibles
  for (let y = 0; y < _sok.grid.length; y++) {
    for (let x = 0; x < _sok.grid[y].length; x++) {
      if (_sok.grid[y][x] === '-') _sok.targets.push([x,y]);
    }
  }
  _sokHistory = [];
  // Render levels list
  document.getElementById('sok-levels').innerHTML = SOK_LEVELS_RAW.map((_, i) =>
    `<button class="btn ${i === _sokLevel ? 'primary' : 'alt'}" onclick="sokInit(${i})" style="font-size:12px; padding:6px 12px;">${i+1}</button>`
  ).join('');
  sokRender();
}
function sokFindPlayer() {
  for (let y = 0; y < _sok.grid.length; y++) {
    for (let x = 0; x < _sok.grid[y].length; x++) {
      const c = _sok.grid[y][x];
      if (c === '@' || c === '+') return [x, y];
    }
  }
  return null;
}
function sokIsTarget(x, y) {
  return _sok.targets.some(([tx,ty]) => tx === x && ty === y);
}
function sokMove(dx, dy) {
  if (!_sok) return;
  const [px, py] = sokFindPlayer();
  const nx = px + dx, ny = py + dy;
  if (ny < 0 || ny >= _sok.grid.length || nx < 0 || nx >= _sok.grid[ny].length) return;
  const next = _sok.grid[ny][nx];
  if (next === '#') return; // mur
  // Save state for undo
  _sokHistory.push(_sok.grid.map(r => r.slice()));
  if (next === '$' || next === '*') {
    // Pousser caisse
    const bx = nx + dx, by = ny + dy;
    if (by < 0 || by >= _sok.grid.length || bx < 0 || bx >= _sok.grid[by].length) { _sokHistory.pop(); return; }
    const after = _sok.grid[by][bx];
    if (after === '#' || after === '$' || after === '*') { _sokHistory.pop(); return; }
    _sok.grid[by][bx] = sokIsTarget(bx, by) ? '*' : '$';
    _sok.grid[ny][nx] = sokIsTarget(nx, ny) ? '+' : '@';
  } else {
    _sok.grid[ny][nx] = sokIsTarget(nx, ny) ? '+' : '@';
  }
  _sok.grid[py][px] = sokIsTarget(px, py) ? '-' : ' ';
  _sok.moves++;
  sokRender();
  // Win check
  if (sokCheckWin()) {
    setTimeout(() => {
      toast(`🎉 Niveau ${_sokLevel+1} fini en ${_sok.moves} coups !`);
      if (typeof badgeUnlock === 'function') badgeUnlock('sokoban_master');
      if (typeof badgeIncrement === 'function') badgeIncrement('games_played', 5, 'gamer');
    }, 100);
  }
}
function sokUndo() {
  if (!_sokHistory.length) return;
  _sok.grid = _sokHistory.pop();
  _sok.moves--;
  sokRender();
}
function sokCheckWin() {
  for (let y = 0; y < _sok.grid.length; y++) {
    for (let x = 0; x < _sok.grid[y].length; x++) {
      if (_sok.grid[y][x] === '$') return false;
    }
  }
  return true;
}
function sokRender() {
  if (!_sok) return;
  const c = document.getElementById('sok-canvas');
  const w = Math.max(...(_sok.grid.map(r => r.length)));
  const h = _sok.grid.length;
  const size = Math.min(40, Math.floor(Math.min(window.innerWidth - 40, 360) / w));
  c.width = w * size; c.height = h * size;
  const ctx = c.getContext('2d');
  // Fond
  const bg = getComputedStyle(document.body).getPropertyValue('--surfaceAlt').trim() || '#f0f0f0';
  ctx.fillStyle = bg; ctx.fillRect(0, 0, c.width, c.height);
  for (let y = 0; y < h; y++) {
    for (let x = 0; x < _sok.grid[y].length; x++) {
      const cell = _sok.grid[y][x];
      const px = x * size, py = y * size;
      if (cell === '#') {
        ctx.fillStyle = '#555';
        ctx.fillRect(px, py, size, size);
      } else if (cell === '-' || cell === '+') {
        ctx.fillStyle = '#FFD166';
        ctx.beginPath(); ctx.arc(px+size/2, py+size/2, size*0.3, 0, Math.PI*2); ctx.fill();
      }
      if (cell === '$') {
        ctx.fillStyle = '#FF8C42';
        ctx.fillRect(px+4, py+4, size-8, size-8);
      } else if (cell === '*') {
        ctx.fillStyle = '#5DD68F';
        ctx.fillRect(px+4, py+4, size-8, size-8);
      } else if (cell === '@' || cell === '+') {
        ctx.fillStyle = '#FF4757';
        ctx.beginPath(); ctx.arc(px+size/2, py+size/2, size*0.4, 0, Math.PI*2); ctx.fill();
      }
    }
  }
  document.getElementById('sok-info').textContent = `Niveau ${_sokLevel+1} · Coups : ${_sok.moves}`;
}

