  { e: '😡', l: 'Énervé', v: 1 },
  { e: '😴', l: 'Fatigué', v: 2 },
  { e: '🤩', l: 'Excité', v: 5 },
  { e: '😰', l: 'Anxieux', v: 2 },
  { e: '😍', l: 'Amoureux', v: 5 }
];
function v51_getMoods() { try { return JSON.parse(localStorage.getItem('nw_moods') || '[]'); } catch { return []; } }
function v51_saveMoods(m) { localStorage.setItem('nw_moods', JSON.stringify(m)); }
function renderMoodTracker() {
  const m = v51_getMoods();
  const today = new Date().toISOString().slice(0, 10);
  const todayMood = m.find(x => x.date === today);
  let html = `<div style="background:linear-gradient(135deg,#FF6FA3,#FFD166); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">💭</div><div style="font-size:16px; font-weight:800;">Tracker d'humeur</div>
    <div style="font-size:11px; opacity:0.9;">${m.length} jours suivis</div>
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">Comment tu te sens aujourd'hui ?</h3>
  <div style="display:grid; grid-template-columns:repeat(5,1fr); gap:8px; margin-top:8px;">`;
  MOODS.forEach((mo, i) => {
    const sel = todayMood && todayMood.idx === i ? 'border:3px solid var(--primary); background:var(--surfaceAlt);' : '';
    html += `<button onclick="moodPick(${i})" style="background:var(--surface); ${sel} padding:14px 4px; border-radius:14px; border:2px solid var(--border); cursor:pointer;">
      <div style="font-size:32px;">${mo.e}</div>
      <div style="font-size:9px; color:var(--textSec); margin-top:2px;">${mo.l}</div>
    </button>`;
  });
  html += `</div>
  <textarea id="mood-note" class="input" placeholder="Note du jour (optionnel)..." rows="2" style="margin-top:10px;">${todayMood && todayMood.note ? escapeHtml(todayMood.note) : ''}</textarea>`;
  if (m.length > 0) {
    // Mini calendar last 30 days
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:18px;">📅 30 derniers jours</h3>
    <div style="display:flex; flex-wrap:wrap; gap:3px; margin-top:6px;">`;
    for (let i = 29; i >= 0; i--) {
      const d = new Date();
      d.setDate(d.getDate() - i);
      const ds = d.toISOString().slice(0, 10);
      const me = m.find(x => x.date === ds);
      const c = me ? MOODS[me.idx].e : '·';
      html += `<div style="width:30px; height:30px; background:var(--surface); border-radius:6px; display:flex; align-items:center; justify-content:center; font-size:18px;" title="${d.toLocaleDateString('fr-FR')}">${c}</div>`;
    }
    html += `</div>`;
    
    // Stats
    const valid = m.filter(x => MOODS[x.idx]);
    if (valid.length) {
      const avg = valid.reduce((s, x) => s + MOODS[x.idx].v, 0) / valid.length;
      html += `<div style="background:var(--surface); padding:10px; border-radius:10px; margin-top:10px; text-align:center;">
        <div style="font-size:11px; color:var(--textSec);">Humeur moyenne</div>
        <div style="font-size:18px; font-weight:900; color:var(--primary);">${avg.toFixed(1)}/5</div>
      </div>`;
    }
  }
  document.getElementById('moodtracker-content').innerHTML = html;
}
function moodPick(idx) {
  const today = new Date().toISOString().slice(0, 10);
  let m = v51_getMoods();
  m = m.filter(x => x.date !== today);
  const note = document.getElementById('mood-note').value.trim();
  m.push({ date: today, idx, note });
  v51_saveMoods(m);
  if (navigator.vibrate) navigator.vibrate(15);
  renderMoodTracker();
}

