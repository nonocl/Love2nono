function updateGradient() {
  const c1 = document.getElementById('grad-c1').value;
  const c2 = document.getElementById('grad-c2').value;
  const type = document.getElementById('grad-type').value;
  const angle = document.getElementById('grad-angle').value;
  const css = type === 'linear' ? `linear-gradient(${angle}deg, ${c1}, ${c2})` : `radial-gradient(circle, ${c1}, ${c2})`;
  document.getElementById('grad-preview').style.background = css;
  document.getElementById('grad-css').value = `background: ${css};`;
}
function copyGradCss() {
  navigator.clipboard.writeText(document.getElementById('grad-css').value).then(() => toast('📋 Copié !'));
}
function exportGradient() {
  const c = document.createElement('canvas');
  c.width = 1080; c.height = 1080;
  const ctx = c.getContext('2d');
  const c1 = document.getElementById('grad-c1').value;
  const c2 = document.getElementById('grad-c2').value;
  const type = document.getElementById('grad-type').value;
  const angle = parseFloat(document.getElementById('grad-angle').value) * Math.PI / 180;
  let g;
  if (type === 'linear') {
    const dx = Math.cos(angle), dy = Math.sin(angle);
    g = ctx.createLinearGradient(540 - 540*dx, 540 - 540*dy, 540 + 540*dx, 540 + 540*dy);
  } else g = ctx.createRadialGradient(540,540,0,540,540,540);
  g.addColorStop(0, c1); g.addColorStop(1, c2);
  ctx.fillStyle = g; ctx.fillRect(0,0,1080,1080);
  c.toBlob(b => { const a=document.createElement('a'); a.href=URL.createObjectURL(b); a.download='gradient.png'; a.click(); });
}

// ============================================================
// EXTRACTION COULEURS
// ============================================================
function extractColors(input) {
  const f = input.files && input.files[0]; if (!f) return;
  const r = new FileReader();
  r.onload = e => {
    const img = new Image();
    img.onload = () => {
      document.getElementById('ce-preview').src = e.target.result;
      document.getElementById('ce-preview').style.display = 'block';
      const c = document.getElementById('ce-canvas');
      c.width = 100; c.height = 100;
      const ctx = c.getContext('2d');
      ctx.drawImage(img, 0, 0, 100, 100);
      const data = ctx.getImageData(0,0,100,100).data;
      // Quantize to color buckets
      const buckets = {};
      for (let i=0; i<data.length; i+=4) {
        const a = data[i+3]; if (a < 128) continue;
        const r = Math.round(data[i]/40)*40, g = Math.round(data[i+1]/40)*40, b = Math.round(data[i+2]/40)*40;
        const k = `${r},${g},${b}`;
        buckets[k] = (buckets[k] || 0) + 1;
      }
      const top = Object.entries(buckets).sort((a,b)=>b[1]-a[1]).slice(0,8);
      const out = document.getElementById('ce-palette');
      out.innerHTML = '<h3 style="font-size:14px; font-weight:700; color:var(--primary);">Palette dominante</h3>';
      for (const [k] of top) {
        const [r,g,b] = k.split(',').map(Number);
        const hex = '#' + [r,g,b].map(v => v.toString(16).padStart(2,'0')).join('');
        const item = document.createElement('div');
        item.style.cssText = `display:flex; align-items:center; gap:10px; padding:8px 12px; background:var(--surface); border-radius:8px; margin-top:4px; cursor:pointer;`;
        item.innerHTML = `<div style="width:30px; height:30px; border-radius:6px; background:${hex};"></div><strong style="font-family:monospace;">${hex}</strong>`;
        item.onclick = () => { navigator.clipboard.writeText(hex); toast('Copié : '+hex); };
        out.appendChild(item);
      }
    };
    img.src = e.target.result;
  };
  r.readAsDataURL(f);
}

// ============================================================
// CONTRASTE WCAG
// ============================================================
function luminance(hex) {
  const rgb = [hex.slice(1,3), hex.slice(3,5), hex.slice(5,7)].map(c => parseInt(c,16)/255);
  const [r,g,b] = rgb.map(v => v <= 0.03928 ? v/12.92 : Math.pow((v+0.055)/1.055, 2.4));
  return 0.2126*r + 0.7152*g + 0.0722*b;
}
function updateContrast() {
  const fg = document.getElementById('contr-fg').value;
  const bg = document.getElementById('contr-bg').value;
  const l1 = luminance(fg), l2 = luminance(bg);
  const ratio = (Math.max(l1,l2) + 0.05) / (Math.min(l1,l2) + 0.05);
  let level = 'Échec', color = 'var(--danger)';
  if (ratio >= 7) { level = 'AAA ✨ (excellent)'; color = 'var(--success)'; }
  else if (ratio >= 4.5) { level = 'AA ✅ (bon)'; color = '#5DD68F'; }
  else if (ratio >= 3) { level = 'AA grand texte uniquement'; color = '#FFD166'; }
  document.getElementById('contr-output').innerHTML = `
    <div style="background:${bg}; color:${fg}; padding:30px 18px; border-radius:14px; text-align:center; border:1px solid var(--border);">
      <div style="font-size:18px; font-weight:700;">Le quick brown fox</div>
      <div style="font-size:13px; margin-top:6px;">Petit texte d'exemple pour vérifier le contraste.</div>
    </div>
    <div style="text-align:center; margin-top:14px;">
      <div style="font-size:48px; font-weight:900; color:${color};">${ratio.toFixed(2)}:1</div>
      <div style="font-size:14px; font-weight:700; color:${color};">${level}</div>
    </div>
    <p style="font-size:11px; color:var(--textSec); margin-top:8px; text-align:center;">WCAG AA : 4.5:1 normal, 3:1 grand. AAA : 7:1 normal, 4.5:1 grand.</p>
  `;
}

