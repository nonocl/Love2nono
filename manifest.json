function renderSymbols() {
  const search = (document.getElementById('sym-search').value || '').toLowerCase();
  const out = document.getElementById('sym-list');
  out.innerHTML = '';
  for (const [groupName, symbols] of Object.entries(SYMBOL_GROUPS)) {
    if (search && !groupName.toLowerCase().includes(search) && !symbols.some(s => s.toLowerCase().includes(search))) continue;
    const group = document.createElement('div');
    group.style.cssText = 'background:var(--surface); padding:14px; border-radius:14px; margin-bottom:8px;';
    group.innerHTML = `<h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-bottom:10px;">${escapeHtml(groupName)}</h3>`;
    const grid = document.createElement('div');
    grid.style.cssText = 'display:flex; flex-wrap:wrap; gap:6px;';
    for (const sym of symbols) {
      const btn = document.createElement('button');
      btn.style.cssText = 'background:var(--surfaceAlt); border:none; padding:8px 10px; border-radius:8px; font-size:18px; cursor:pointer; min-width:38px; min-height:38px; color:var(--text);';
      btn.textContent = sym;
      btn.title = sym;
      btn.onclick = () => { navigator.clipboard?.writeText(sym); toast('Copié : ' + sym); };
      grid.appendChild(btn);
    }
    group.appendChild(grid);
    out.appendChild(group);
  }
  if (!out.children.length) {
    out.innerHTML = '<p style="text-align:center; color:var(--textSec); padding:30px;">Aucun symbole trouvé.</p>';
  }
}



// ============================================================
// GESTIONNAIRE DE FICHIERS
// ============================================================
let _curFolder = null; // null = root
const COMPRESSION_THRESHOLD = 500 * 1024; // 500 KB

function getFileTypeInfo(name, mime) {
  const ext = name.split('.').pop().toLowerCase();
  if (mime?.startsWith('image/')) return { ico:'🖼️', cat:'image' };
  if (mime?.startsWith('video/')) return { ico:'🎬', cat:'video' };
  if (mime?.startsWith('audio/')) return { ico:'🎵', cat:'audio' };
  if (mime === 'application/pdf' || ext === 'pdf') return { ico:'📄', cat:'pdf' };
  if (['doc','docx','odt','rtf'].includes(ext)) return { ico:'📝', cat:'doc' };
  if (['xls','xlsx','csv'].includes(ext)) return { ico:'📊', cat:'sheet' };
  if (['ppt','pptx'].includes(ext)) return { ico:'📺', cat:'slide' };
  if (['zip','rar','7z','tar','gz'].includes(ext)) return { ico:'🗜️', cat:'archive' };
  if (['txt','md','json','xml','log'].includes(ext)) return { ico:'📃', cat:'text' };
  if (['html','css','js','ts','py','java','cpp','c','rs','go'].includes(ext)) return { ico:'💻', cat:'code' };
  return { ico:'📎', cat:'other' };
}

async function compressIfNeeded(file) {
  // Si image > seuil, compresse
  if (file.type?.startsWith('image/') && file.size > COMPRESSION_THRESHOLD) {
    return await compressImage(file);
  }
  // Sinon retourne tel quel
  return new Promise(res => {
    const r = new FileReader();
    r.onload = () => res({ data: r.result, compressed: false, size: file.size });
    r.readAsDataURL(file);
  });
}
function compressImage(file) {
  return new Promise((res, rej) => {
    const img = new Image();
    img.onload = () => {
      const maxDim = 1920;
      let w = img.width, h = img.height;
      if (w > maxDim || h > maxDim) {
        const r = Math.min(maxDim/w, maxDim/h);
        w = w * r; h = h * r;
      }
      const c = document.createElement('canvas');
      c.width = w; c.height = h;
      const ctx = c.getContext('2d');
      ctx.fillStyle = '#fff'; ctx.fillRect(0,0,w,h);
      ctx.drawImage(img, 0, 0, w, h);
      const dataUrl = c.toDataURL('image/jpeg', 0.85);
      // Approx size (base64 ~33% larger than binary)
      const approxSize = Math.round(dataUrl.length * 0.75);
      res({ data: dataUrl, compressed: true, size: approxSize, originalSize: file.size });
    };
    img.onerror = rej;
    img.src = URL.createObjectURL(file);
  });
}

async function filesAdd(input) {
  const files = Array.from(input.files || []);
  if (!files.length) return;
  toast(`📤 Import de ${files.length} fichier${files.length>1?'s':''}...`);
  for (const f of files) {
    try {
      const result = await compressIfNeeded(f);
      const tx = db.transaction('files', 'readwrite');
      tx.objectStore('files').add({
        name: f.name,
        mime: f.type || 'application/octet-stream',
        size: result.size,
        originalSize: result.originalSize || f.size,
        compressed: result.compressed,
        data: result.data,
        folder: _curFolder,
        added: Date.now(),
      });
    } catch (e) {
      console.error('File err:', e);
      toast('❌ Erreur sur ' + f.name);
    }
  }
  input.value = '';
  toast('✅ Importé !');
  renderFiles();
}

async function filesNewFolder() {
  const name = prompt('Nom du dossier ?');
  if (!name?.trim()) return;
  const tx = db.transaction('file_folders', 'readwrite');
  tx.objectStore('file_folders').add({ name: name.trim(), added: Date.now() });
  setTimeout(renderFiles, 100);
}

async function filesDelFolder(id) {
  if (!confirm('Supprimer ce dossier ? Les fichiers dedans seront remis à la racine.')) return;
  // Move files to root
  const tx1 = db.transaction('files', 'readwrite');
  const store = tx1.objectStore('files');
  const all = await new Promise(r => { const req = store.getAll(); req.onsuccess = () => r(req.result); });
  for (const f of all.filter(x => x.folder === id)) { f.folder = null; store.put(f); }
  // Delete folder
  await new Promise(r => { const req = db.transaction('file_folders','readwrite').objectStore('file_folders').delete(id); req.onsuccess = r; });
  if (_curFolder === id) _curFolder = null;
  renderFiles();
}

async function renderFiles() {
  if (!db) return;
  const search = (document.getElementById('files-search')?.value || '').toLowerCase();
  // Folders
  const folders = await new Promise(r => { const req = db.transaction('file_folders','readonly').objectStore('file_folders').getAll(); req.onsuccess = () => r(req.result); });
  const foldersEl = document.getElementById('files-folders');
  let foldersHtml = `<button class="btn ${_curFolder === null ? 'primary' : 'alt'}" style="padding:6px 12px; font-size:12px;" onclick="filesGoFolder(null)">📁 Racine</button>`;
  for (const f of folders) {
    foldersHtml += `<button class="btn ${_curFolder === f.id ? 'primary' : 'alt'}" style="padding:6px 12px; font-size:12px;" onclick="filesGoFolder(${f.id})" oncontextmenu="event.preventDefault(); filesDelFolder(${f.id})">📁 ${escapeHtml(f.name)}</button>`;
  }
  foldersEl.innerHTML = foldersHtml;
  // Files
  const files = await new Promise(r => { const req = db.transaction('files','readonly').objectStore('files').getAll(); req.onsuccess = () => r(req.result); });
  let visible = files.filter(f => f.folder === _curFolder);
  if (search) visible = visible.filter(f => f.name.toLowerCase().includes(search));
  visible.sort((a,b) => b.added - a.added);
  const list = document.getElementById('files-list');
  if (!visible.length) {
    list.innerHTML = `<div style="text-align:center; padding:40px 20px; color:var(--textSec);"><div style="font-size:48px;">📭</div><p style="margin-top:10px;">Aucun fichier ${_curFolder ? 'dans ce dossier' : 'pour le moment'}.</p><p style="font-size:12px;">Tap + pour importer !</p></div>`;
    return;
  }
  list.innerHTML = visible.map(f => {
    const t = getFileTypeInfo(f.name, f.mime);
    const sizeMB = (f.size / (1024*1024)).toFixed(2);
    const sizeKB = (f.size / 1024).toFixed(0);
    const sizeStr = f.size > 1024*1024 ? `${sizeMB} Mo` : `${sizeKB} Ko`;
    const date = new Date(f.added).toLocaleDateString('fr-FR');
    let preview = `<div style="font-size:32px;">${t.ico}</div>`;
    if (t.cat === 'image' && f.data) {
      preview = `<img src="${f.data}" style="width:48px; height:48px; object-fit:cover; border-radius:6px;">`;
    }
    return `<div style="display:flex; gap:12px; align-items:center; padding:10px 12px; background:var(--surface); border-radius:10px; margin-bottom:6px; cursor:pointer;" onclick="fdOpen(${f.id})">
      ${preview}
      <div style="flex:1; min-width:0;">
        <div style="font-weight:600; font-size:14px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${escapeHtml(f.name)}</div>
        <div style="font-size:11px; color:var(--textSec);">${sizeStr} · ${date}${f.compressed ? ' · 🗜️ compressé' : ''}</div>
      </div>
    </div>`;
  }).join('');
}

function filesGoFolder(id) {
  _curFolder = id;
  renderFiles();
}

let _fdCur = null;
async function fdOpen(id) {
  const f = await new Promise(r => { const req = db.transaction('files','readonly').objectStore('files').get(id); req.onsuccess = () => r(req.result); });
  if (!f) return;
  _fdCur = f;
  document.getElementById('fd-title').textContent = f.name;
  const t = getFileTypeInfo(f.name, f.mime);
  let preview = `<div style="text-align:center; padding:40px; background:var(--surface); border-radius:14px;"><div style="font-size:80px;">${t.ico}</div></div>`;
  if (t.cat === 'image' && f.data) {
    preview = `<img src="${f.data}" style="width:100%; border-radius:14px; max-height:400px; object-fit:contain;">`;
  } else if (t.cat === 'audio' && f.data) {
    preview = `<audio controls style="width:100%;" src="${f.data}"></audio>`;
  } else if (t.cat === 'video' && f.data) {
    preview = `<video controls style="width:100%; border-radius:14px; max-height:400px;" src="${f.data}"></video>`;
  } else if (t.cat === 'pdf' && f.data) {
    preview = `<iframe src="${f.data}" style="width:100%; height:60vh; border:none; border-radius:14px;"></iframe>`;
  } else if (t.cat === 'text' && f.data) {
    try {
      const txt = atob(f.data.split(',')[1]);
      preview = `<pre style="background:var(--surface); padding:14px; border-radius:10px; max-height:400px; overflow:auto; font-size:12px; white-space:pre-wrap;">${escapeHtml(txt.slice(0,5000))}</pre>`;
    } catch {}
  }
  document.getElementById('fd-preview').innerHTML = preview;
  const sizeStr = f.size > 1024*1024 ? `${(f.size/(1024*1024)).toFixed(2)} Mo` : `${(f.size/1024).toFixed(0)} Ko`;
  document.getElementById('fd-info').innerHTML = `
    <div style="background:var(--surface); padding:14px; border-radius:10px;">
      <div style="font-size:13px; line-height:1.7;">
        <div><strong>Type :</strong> ${escapeHtml(f.mime || 'inconnu')}</div>
        <div><strong>Taille :</strong> ${sizeStr}</div>
        ${f.compressed ? `<div><strong>Original :</strong> ${(f.originalSize/1024).toFixed(0)} Ko (auto-compressé)</div>` : ''}
        <div><strong>Importé :</strong> ${new Date(f.added).toLocaleString('fr-FR')}</div>
      </div>
    </div>
  `;
  goTo('file-detail');
}

function fdDownload() {
  if (!_fdCur) return;
  const a = document.createElement('a');
  a.href = _fdCur.data;
  a.download = _fdCur.name;
  a.click();
}
async function fdShare() {
  if (!_fdCur) return;
  if (navigator.share) {
    try {
      const blob = await (await fetch(_fdCur.data)).blob();
      const file = new File([blob], _fdCur.name, { type: _fdCur.mime });
      await navigator.share({ files:[file], title:_fdCur.name });
    } catch (e) { fdDownload(); }
  } else fdDownload();
}
async function fdDelete() {
  if (!_fdCur) return;
  if (!confirm('Supprimer définitivement ce fichier ?')) return;
  await new Promise(r => { const req = db.transaction('files','readwrite').objectStore('files').delete(_fdCur.id); req.onsuccess = r; });
  toast('🗑 Supprimé');
  goTo('files');
}
async function fdMenu() {
  if (!_fdCur) return;
  // Show folder picker
  const folders = await new Promise(r => { const req = db.transaction('file_folders','readonly').objectStore('file_folders').getAll(); req.onsuccess = () => r(req.result); });
  const opts = [{ id: null, name: 'Racine' }, ...folders];
  const choice = prompt(`Déplacer vers le dossier ?\n${opts.map((o,i) => `${i}: ${o.name}`).join('\n')}\n\nTape le numéro :`);
  const idx = parseInt(choice);
  if (isNaN(idx) || idx < 0 || idx >= opts.length) return;
  _fdCur.folder = opts[idx].id;
  await new Promise(r => { const req = db.transaction('files','readwrite').objectStore('files').put(_fdCur); req.onsuccess = r; });
  toast(`📁 Déplacé vers ${opts[idx].name}`);
  goTo('files');
}



// ============================================================
// APP DESSIN PRO (calques, formes, undo/redo, export)
// ============================================================
const D_QUICK_COLORS = ['#000000','#FFFFFF','#FF6FA3','#FF4757','#FFA502','#FFD166','#5DD68F','#06FFA5','#5DD6E5','#5DADE2','#A78BFA','#C77DFF','#FF8C42','#8B4513','#888888','#E5E5E5'];

let _draw = {
  layers: [],         // {canvas, ctx, name, visible, opacity}
  curLayer: 0,
  tool: 'pen',
  color: '#000000',
  size: 4,
  opacity: 1,
  undoStack: [],
  redoStack: [],
  drawing: false,
  lastX: 0, lastY: 0,
  startX: 0, startY: 0,
  W: 600, H: 600,
  bgImg: null,
  shapeStartSnap: null,
};

function drawInit() {
  if (_draw.layers.length > 0) return;
  const wrap = document.getElementById('d-canvas-wrap');
  const rect = wrap.getBoundingClientRect();
  _draw.W = Math.round(rect.width * 2);
  _draw.H = Math.round(rect.height * 2);
  // Crée un calque initial
  drawAddLayer(true);
  // Setup event handlers
  setupDrawEvents();
  drawRenderLayers();
  drawRenderPalette();
  drawTool('pen');
}

function drawAddLayer(isFirst) {
  const c = document.createElement('canvas');
  c.width = _draw.W; c.height = _draw.H;
  const ctx = c.getContext('2d');
  if (isFirst) {
    ctx.fillStyle = 'white';
    ctx.fillRect(0, 0, _draw.W, _draw.H);
  }
  _draw.layers.push({ canvas: c, ctx, name: `Calque ${_draw.layers.length+1}`, visible: true, opacity: 1 });
  _draw.curLayer = _draw.layers.length - 1;
  if (!isFirst) {
    drawRenderLayers();
    drawComposite();
  }
}

function drawSelectLayer(i) {
  _draw.curLayer = i;
  drawRenderLayers();
}

function drawDelLayer(i) {
  if (_draw.layers.length <= 1) return toast('Il faut au moins 1 calque');
  if (!confirm(`Supprimer ${_draw.layers[i].name} ?`)) return;
  _draw.layers.splice(i, 1);
  if (_draw.curLayer >= _draw.layers.length) _draw.curLayer = _draw.layers.length - 1;
  drawRenderLayers();
  drawComposite();
}

function drawToggleLayer(i) {
  _draw.layers[i].visible = !_draw.layers[i].visible;
  drawRenderLayers();
  drawComposite();
}

function drawRenderLayers() {
  const el = document.getElementById('d-layers');
  el.innerHTML = '';
  _draw.layers.forEach((l, i) => {
    const btn = document.createElement('div');
    btn.style.cssText = `display:flex; align-items:center; gap:4px; padding:4px 8px; border-radius:6px; background:${i === _draw.curLayer ? 'var(--primary)' : 'var(--surface)'}; color:${i === _draw.curLayer ? 'white' : 'var(--text)'}; font-size:11px; cursor:pointer; white-space:nowrap;`;
    btn.innerHTML = `<span onclick="drawToggleLayer(${i})" style="cursor:pointer;">${l.visible ? '👁' : '🚫'}</span><span onclick="drawSelectLayer(${i})">${l.name}</span><span onclick="drawDelLayer(${i})" style="cursor:pointer; opacity:0.7;">×</span>`;
    el.appendChild(btn);
  });
}

function drawRenderPalette() {
  const el = document.getElementById('d-palette');
  el.innerHTML = '';
  D_QUICK_COLORS.forEach(c => {
    const sw = document.createElement('button');
    sw.style.cssText = `width:24px; height:24px; border-radius:50%; background:${c}; border:2px solid ${c === _draw.color ? '#fff' : 'transparent'}; box-shadow:0 0 0 1px var(--border); cursor:pointer;`;
    sw.onclick = () => { _draw.color = c; document.getElementById('d-color').value = c; drawRenderPalette(); };
    el.appendChild(sw);
  });
}

function drawTool(t) {
  _draw.tool = t;
  ['pen','marker','spray','eraser','line','rect','circle','fill','text','eyedropper'].forEach(name => {
    const btn = document.getElementById('dt-' + name);
    if (btn) btn.className = 'btn ' + (name === t ? 'primary' : 'alt');
  });
}

function drawUpdSize() {
  _draw.size = parseInt(document.getElementById('d-size').value);
  document.getElementById('d-size-lbl').textContent = _draw.size;
}
function drawUpdOpa() {
  const v = parseInt(document.getElementById('d-opacity').value);
  _draw.opacity = v / 100;
  document.getElementById('d-opacity-lbl').textContent = v + '%';
}

function drawSnapshot() {
  // Push to undo stack
  if (_draw.undoStack.length >= 30) _draw.undoStack.shift();
  const snap = _draw.layers.map(l => l.canvas.toDataURL());
  _draw.undoStack.push({ data:snap, layer:_draw.curLayer });
  _draw.redoStack = [];
}

function drawUndo() {
  if (!_draw.undoStack.length) return toast('Rien à annuler');
  const cur = _draw.layers.map(l => l.canvas.toDataURL());
  _draw.redoStack.push({ data:cur, layer:_draw.curLayer });
  const snap = _draw.undoStack.pop();
  drawRestoreSnap(snap.data);
}
function drawRedo() {
  if (!_draw.redoStack.length) return toast('Rien à refaire');
  const cur = _draw.layers.map(l => l.canvas.toDataURL());
  _draw.undoStack.push({ data:cur, layer:_draw.curLayer });
  const snap = _draw.redoStack.pop();
  drawRestoreSnap(snap.data);
}
function drawRestoreSnap(snapData) {
  // S'assurer qu'on a le même nombre de calques
  while (_draw.layers.length < snapData.length) drawAddLayer(false);
  while (_draw.layers.length > snapData.length) _draw.layers.pop();
  let loaded = 0;
  snapData.forEach((d, i) => {
    const img = new Image();
    img.onload = () => {
      _draw.layers[i].ctx.clearRect(0, 0, _draw.W, _draw.H);
      _draw.layers[i].ctx.drawImage(img, 0, 0);
      loaded++;
      if (loaded === snapData.length) drawComposite();
    };
    img.src = d;
  });
}

function drawClear() {
  if (!confirm('Effacer le calque actuel ?')) return;
  drawSnapshot();
  const ctx = _draw.layers[_draw.curLayer].ctx;
  ctx.clearRect(0, 0, _draw.W, _draw.H);
  if (_draw.curLayer === 0) {
    ctx.fillStyle = 'white';
    ctx.fillRect(0, 0, _draw.W, _draw.H);
  }
  drawComposite();
}

function drawComposite() {
  const c = document.getElementById('d-canvas');
  c.width = _draw.W; c.height = _draw.H;
  const ctx = c.getContext('2d');
  ctx.clearRect(0, 0, _draw.W, _draw.H);
  for (const l of _draw.layers) {
    if (!l.visible) continue;
    ctx.globalAlpha = l.opacity;
    ctx.drawImage(l.canvas, 0, 0);
  }
  ctx.globalAlpha = 1;
}

function drawLoadBg(input) {
  const f = (input.files || [])[0];
  if (!f) return;
  const img = new Image();
  img.onload = () => {
    drawSnapshot();
    const ctx = _draw.layers[0].ctx;
    ctx.fillStyle = 'white';
    ctx.fillRect(0, 0, _draw.W, _draw.H);
    // Fit
    const r = Math.min(_draw.W / img.width, _draw.H / img.height);
    const w = img.width * r, h = img.height * r;
    ctx.drawImage(img, (_draw.W - w)/2, (_draw.H - h)/2, w, h);
    drawComposite();
    toast('🖼 Fond importé');
  };
  img.src = URL.createObjectURL(f);
}

function getDrawXY(e) {
  const c = document.getElementById('d-canvas');
  const rect = c.getBoundingClientRect();
  const t = e.touches ? e.touches[0] : e;
  return {
    x: (t.clientX - rect.left) * _draw.W / rect.width,
    y: (t.clientY - rect.top) * _draw.H / rect.height,
  };
}

function setupDrawEvents() {
  const c = document.getElementById('d-canvas');
  const start = (e) => {
    e.preventDefault();
    _draw.color = document.getElementById('d-color').value;
    const { x, y } = getDrawXY(e);
    _draw.drawing = true;
    _draw.startX = x; _draw.startY = y;
    _draw.lastX = x; _draw.lastY = y;
    drawSnapshot();
    if (_draw.tool === 'fill') {
      drawFill(x, y);
      _draw.drawing = false;
    } else if (_draw.tool === 'eyedropper') {
      const ctx = _draw.layers[_draw.curLayer].ctx;
      const px = ctx.getImageData(x, y, 1, 1).data;
      const col = '#' + [px[0], px[1], px[2]].map(v => v.toString(16).padStart(2,'0')).join('');
      _draw.color = col;
      document.getElementById('d-color').value = col;
      _draw.drawing = false;
      toast('💧 Couleur : ' + col);
    } else if (_draw.tool === 'text') {
      const text = prompt('Texte ?');
      if (text) {
        const ctx = _draw.layers[_draw.curLayer].ctx;
        ctx.globalAlpha = _draw.opacity;
        ctx.fillStyle = _draw.color;
        ctx.font = `${_draw.size * 4}px sans-serif`;
        ctx.fillText(text, x, y);
        ctx.globalAlpha = 1;
        drawComposite();
      }
      _draw.drawing = false;
    } else if (['line','rect','circle'].includes(_draw.tool)) {
      // Snapshot before shape
      _draw.shapeStartSnap = _draw.layers[_draw.curLayer].canvas.toDataURL();
    } else {
      drawDot(x, y);
    }
  };
  const move = (e) => {
    if (!_draw.drawing) return;
    e.preventDefault();
    const { x, y } = getDrawXY(e);
    if (_draw.tool === 'pen' || _draw.tool === 'marker' || _draw.tool === 'eraser') {
      drawSegment(_draw.lastX, _draw.lastY, x, y);
    } else if (_draw.tool === 'spray') {
      drawSpray(x, y);
    } else if (['line','rect','circle'].includes(_draw.tool)) {
      // Restore snap then redraw shape
      const img = new Image();
      img.onload = () => {
        const ctx = _draw.layers[_draw.curLayer].ctx;
        ctx.clearRect(0, 0, _draw.W, _draw.H);
        ctx.drawImage(img, 0, 0);
        drawShape(x, y);
        drawComposite();
      };
      img.src = _draw.shapeStartSnap;
      _draw.lastX = x; _draw.lastY = y;
      return;
    }
    _draw.lastX = x; _draw.lastY = y;
  };
  const end = () => { _draw.drawing = false; };
  c.addEventListener('mousedown', start);
  c.addEventListener('mousemove', move);
  c.addEventListener('mouseup', end);
  c.addEventListener('mouseleave', end);
  c.addEventListener('touchstart', start, { passive:false });
  c.addEventListener('touchmove', move, { passive:false });
  c.addEventListener('touchend', end);
  c.addEventListener('touchcancel', end);
}

function drawDot(x, y) {
  const ctx = _draw.layers[_draw.curLayer].ctx;
  ctx.globalAlpha = _draw.opacity;
  if (_draw.tool === 'eraser') {
    ctx.globalCompositeOperation = 'destination-out';
    ctx.fillStyle = 'rgba(0,0,0,1)';
  } else {
    ctx.globalCompositeOperation = 'source-over';
    ctx.fillStyle = _draw.color;
  }
  ctx.beginPath();
  ctx.arc(x, y, _draw.size, 0, Math.PI*2);
  ctx.fill();
  ctx.globalCompositeOperation = 'source-over';
  ctx.globalAlpha = 1;
  drawComposite();
}

function drawSegment(x1, y1, x2, y2) {
  const ctx = _draw.layers[_draw.curLayer].ctx;
  ctx.globalAlpha = _draw.tool === 'marker' ? _draw.opacity * 0.6 : _draw.opacity;
  if (_draw.tool === 'eraser') {
    ctx.globalCompositeOperation = 'destination-out';
    ctx.strokeStyle = 'rgba(0,0,0,1)';
  } else {
    ctx.globalCompositeOperation = _draw.tool === 'marker' ? 'multiply' : 'source-over';
    ctx.strokeStyle = _draw.color;
  }
  ctx.lineWidth = _draw.size * 2;
  ctx.lineCap = 'round';
  ctx.lineJoin = 'round';
  ctx.beginPath();
  ctx.moveTo(x1, y1);
  ctx.lineTo(x2, y2);
  ctx.stroke();
  ctx.globalCompositeOperation = 'source-over';
  ctx.globalAlpha = 1;
  drawComposite();
}

function drawSpray(x, y) {
  const ctx = _draw.layers[_draw.curLayer].ctx;
  ctx.globalAlpha = _draw.opacity * 0.5;
  ctx.fillStyle = _draw.color;
  for (let i=0; i<20; i++) {
    const angle = Math.random() * Math.PI * 2;
    const r = Math.random() * _draw.size * 2;
    const px = x + Math.cos(angle) * r;
    const py = y + Math.sin(angle) * r;
    ctx.fillRect(px, py, 2, 2);
  }
  ctx.globalAlpha = 1;
  drawComposite();
}

function drawShape(x, y) {
  const ctx = _draw.layers[_draw.curLayer].ctx;
  ctx.globalAlpha = _draw.opacity;
  ctx.strokeStyle = _draw.color;
  ctx.lineWidth = _draw.size * 2;
  ctx.lineCap = 'round';
  ctx.beginPath();
  if (_draw.tool === 'line') {
    ctx.moveTo(_draw.startX, _draw.startY);
    ctx.lineTo(x, y);
  } else if (_draw.tool === 'rect') {
    ctx.rect(_draw.startX, _draw.startY, x - _draw.startX, y - _draw.startY);
  } else if (_draw.tool === 'circle') {
    const cx = (_draw.startX + x) / 2, cy = (_draw.startY + y) / 2;
    const rx = Math.abs(x - _draw.startX) / 2, ry = Math.abs(y - _draw.startY) / 2;
    ctx.ellipse(cx, cy, rx, ry, 0, 0, Math.PI*2);
  }
  ctx.stroke();
  ctx.globalAlpha = 1;
}

function drawFill(x, y) {
  // Bucket fill simple (flood fill)
  const ctx = _draw.layers[_draw.curLayer].ctx;
  const img = ctx.getImageData(0, 0, _draw.W, _draw.H);
  const data = img.data;
  const idx = (Math.round(y) * _draw.W + Math.round(x)) * 4;
  const targetR = data[idx], targetG = data[idx+1], targetB = data[idx+2], targetA = data[idx+3];
  const fc = hexToRgb(_draw.color);
  if (!fc) return;
  if (targetR === fc.r && targetG === fc.g && targetB === fc.b && targetA === 255) return;
  const stack = [[Math.round(x), Math.round(y)]];
  while (stack.length) {
    const [cx, cy] = stack.pop();
    if (cx < 0 || cx >= _draw.W || cy < 0 || cy >= _draw.H) continue;
    const i = (cy * _draw.W + cx) * 4;
    if (data[i] !== targetR || data[i+1] !== targetG || data[i+2] !== targetB || data[i+3] !== targetA) continue;
    data[i] = fc.r; data[i+1] = fc.g; data[i+2] = fc.b; data[i+3] = 255;
    stack.push([cx+1, cy], [cx-1, cy], [cx, cy+1], [cx, cy-1]);
  }
  ctx.putImageData(img, 0, 0);
  drawComposite();
}
function hexToRgb(h) {
  const m = h.match(/^#?([\da-f]{2})([\da-f]{2})([\da-f]{2})$/i);
  return m ? { r:parseInt(m[1],16), g:parseInt(m[2],16), b:parseInt(m[3],16) } : null;
}

function drawComposeFinal() {
  // Compose all layers into one canvas and return
  const c = document.createElement('canvas');
  c.width = _draw.W; c.height = _draw.H;
  const ctx = c.getContext('2d');
  for (const l of _draw.layers) {
    if (!l.visible) continue;
    ctx.globalAlpha = l.opacity;
    ctx.drawImage(l.canvas, 0, 0);
  }
  return c;
}

function drawExportPng() {
  const c = drawComposeFinal();
  c.toBlob(b => {
    const a = document.createElement('a');
    a.href = URL.createObjectURL(b);
    a.download = `dessin-${Date.now()}.png`;
    a.click();
    toast('📥 Exporté !');
  }, 'image/png');
}

async function drawSave() {
  const name = prompt('Nom du dessin ?', 'Dessin ' + new Date().toLocaleDateString('fr-FR'));
  if (!name) return;
  const c = drawComposeFinal();
  const dataUrl = c.toDataURL('image/png');
  // Sauve dans 'drawings' store
  const tx = db.transaction('drawings', 'readwrite');
  tx.objectStore('drawings').add({ name, data: dataUrl, w: _draw.W, h: _draw.H, added: Date.now() });
  toast('💾 Dessin sauvé !');
}

async function drawSaveToFiles() {
  const name = prompt('Nom du fichier ?', 'dessin-' + Date.now() + '.png');
  if (!name) return;
  const c = drawComposeFinal();
  const dataUrl = c.toDataURL('image/png');
  const tx = db.transaction('files', 'readwrite');
  tx.objectStore('files').add({
    name, mime: 'image/png', size: dataUrl.length * 0.75, originalSize: dataUrl.length * 0.75,
    compressed: false, data: dataUrl, folder: null, added: Date.now()
  });
  toast('📁 Sauvé dans Mes fichiers !');
}

async function renderDrawings() {
  if (!db) return;
  const list = await new Promise(r => { const req = db.transaction('drawings','readonly').objectStore('drawings').getAll(); req.onsuccess = () => r(req.result); });
  const grid = document.getElementById('drawings-grid');
  if (!list.length) {
    grid.innerHTML = '<div style="grid-column:1/-1; text-align:center; padding:40px; color:var(--textSec);"><div style="font-size:48px;">🎨</div><p style="margin-top:10px;">Aucun dessin pour le moment.</p><button class="btn primary" onclick="goTo(\'draw\')" style="margin-top:14px;">+ Nouveau dessin</button></div>';
    return;
  }
  list.sort((a,b) => b.added - a.added);
  grid.innerHTML = list.map(d => `
    <div style="background:var(--surface); border-radius:10px; overflow:hidden;" onclick="drawingDel(${d.id}, '${escapeHtml(d.name).replace(/'/g, "\\'")}')">
      <img src="${d.data}" style="width:100%; aspect-ratio:1; object-fit:cover; cursor:pointer;">
      <div style="padding:8px;">
        <div style="font-size:13px; font-weight:600; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${escapeHtml(d.name)}</div>
        <div style="font-size:11px; color:var(--textSec);">${new Date(d.added).toLocaleDateString('fr-FR')}</div>
      </div>
    </div>
  `).join('');
}
async function drawingDel(id, name) {
  if (!confirm(`"${name}"\n\nQue faire ?\nOK = Télécharger\nAnnuler = Supprimer`)) {
    if (!confirm('Vraiment supprimer ?')) return;
    await new Promise(r => { const req = db.transaction('drawings','readwrite').objectStore('drawings').delete(id); req.onsuccess = r; });
    renderDrawings();
    toast('🗑 Supprimé');
    return;
  }
  // Download
  const d = await new Promise(r => { const req = db.transaction('drawings','readonly').objectStore('drawings').get(id); req.onsuccess = () => r(req.result); });
  const a = document.createElement('a');
  a.href = d.data; a.download = name + '.png'; a.click();
}



// ============================================================
// ÉDITEUR PHOTO COMPLET
// ============================================================
let _pe = {
  origImg: null,
  baseCanvas: null,    // Image de départ
  workCanvas: null,    // Canvas de travail (avec filtres CSS appliqués)
  overlayCanvas: null, // Canvas overlay (texte, stickers, dessin)
  W: 0, H: 0,
  tool: null,
  // Filter state
  filter: { brightness:100, contrast:100, saturate:100, blur:0, hue:0, sepia:0, grayscale:0 },
  cssFilter: '',
  // Drawing/blur state
  drawing: false, lastX: 0, lastY: 0,
  // Stickers/text overlays
  overlays: [], // {type:'text'|'sticker', x, y, text/emoji, color, size, font}
  selectedOverlay: null,
  // History
  undoStack: [], redoStack: [],
};

const PE_FILTERS = [
  { id:'none', name:'Aucun', css:'' },
  { id:'bw', name:'N&B', css:'grayscale(1)' },
  { id:'sepia', name:'Sépia', css:'sepia(1)' },
  { id:'vintage', name:'Vintage', css:'sepia(0.5) contrast(0.85) brightness(0.95) saturate(0.8)' },
  { id:'vibrant', name:'Vibrant', css:'saturate(1.8) contrast(1.1)' },
  { id:'dark', name:'Dark', css:'brightness(0.7) contrast(1.2)' },
  { id:'cool', name:'Cool', css:'hue-rotate(180deg) saturate(0.8)' },
  { id:'warm', name:'Chaud', css:'sepia(0.2) saturate(1.5) hue-rotate(-15deg)' },
  { id:'faded', name:'Fané', css:'contrast(0.85) saturate(0.7) brightness(1.05)' },
  { id:'lomo', name:'Lomo', css:'saturate(1.5) contrast(1.4) brightness(0.9)' },
  { id:'noir', name:'Noir', css:'grayscale(1) contrast(1.5) brightness(0.85)' },
  { id:'pastel', name:'Pastel', css:'saturate(0.7) brightness(1.1) contrast(0.9)' },
  { id:'cinema', name:'Cinéma', css:'contrast(1.2) saturate(1.1) brightness(0.95) hue-rotate(-5deg)' },
  { id:'cyan', name:'Cyan', css:'hue-rotate(150deg) saturate(1.3)' },
];

function peLoadImg(input) {
  const f = (input.files || [])[0]; if (!f) return;
  const r = new FileReader();
  r.onload = e => {
    const img = new Image();
    img.onload = () => {
      _pe.origImg = img;
      // Resize si trop grand
      const maxDim = 1600;
      let w = img.width, h = img.height;
      if (w > maxDim || h > maxDim) {
        const r = Math.min(maxDim/w, maxDim/h);
        w = Math.round(w*r); h = Math.round(h*r);
      }
      _pe.W = w; _pe.H = h;
      // Init canvases
      const c = document.getElementById('pe-canvas');
      c.width = w; c.height = h;
      _pe.workCanvas = c;
      const ovl = document.getElementById('pe-overlay');
      ovl.width = w; ovl.height = h;
      _pe.overlayCanvas = ovl;
      // Base canvas hidden for redraw
      const base = document.createElement('canvas');
      base.width = w; base.height = h;
      base.getContext('2d').drawImage(img, 0, 0, w, h);
      _pe.baseCanvas = base;
      _pe.overlays = [];
      _pe.undoStack = []; _pe.redoStack = [];
      _pe.filter = { brightness:100, contrast:100, saturate:100, blur:0, hue:0, sepia:0, grayscale:0 };
      _pe.cssFilter = '';
      peRedraw();
      // Show UI
      document.getElementById('pe-canvas-wrap').style.display = 'block';
      document.getElementById('pe-tools').style.display = 'flex';
      document.getElementById('pe-undo-bar').style.display = 'flex';
      peTool('filter');
    };
    img.src = e.target.result;
  };
  r.readAsDataURL(f);
}

function peRedraw() {
  if (!_pe.baseCanvas) return;
  const ctx = _pe.workCanvas.getContext('2d');
  ctx.filter = _pe.cssFilter || 'none';
  ctx.drawImage(_pe.baseCanvas, 0, 0);
  ctx.filter = 'none';
  // Render overlays
  peRedrawOverlays();
}

function peRedrawOverlays() {
  const ctx = _pe.overlayCanvas.getContext('2d');
  ctx.clearRect(0, 0, _pe.W, _pe.H);
  for (const o of _pe.overlays) {
    if (o.type === 'text') {
      ctx.font = `${o.bold ? 'bold ' : ''}${o.italic ? 'italic ' : ''}${o.size}px ${o.font}`;
      // Stroke (outline)
      if (o.outline) {
        ctx.strokeStyle = o.outline;
        ctx.lineWidth = Math.max(2, o.size / 16);
        ctx.strokeText(o.text, o.x, o.y);
      }
      ctx.fillStyle = o.color;
      ctx.fillText(o.text, o.x, o.y);
    } else if (o.type === 'sticker') {
      ctx.font = `${o.size}px sans-serif`;
      ctx.textBaseline = 'middle';
      ctx.textAlign = 'center';
      ctx.fillText(o.emoji, o.x, o.y);
      ctx.textBaseline = 'alphabetic';
      ctx.textAlign = 'start';
    }
  }
  // Draw selection box
  if (_pe.selectedOverlay) {
    const o = _pe.selectedOverlay;
    ctx.strokeStyle = '#FF6FA3';
    ctx.lineWidth = 2;
    ctx.setLineDash([6, 4]);
    if (o.type === 'text') {
      ctx.font = `${o.bold ? 'bold ' : ''}${o.italic ? 'italic ' : ''}${o.size}px ${o.font}`;
      const m = ctx.measureText(o.text);
      ctx.strokeRect(o.x - 4, o.y - o.size, m.width + 8, o.size + 8);
    } else {
      ctx.strokeRect(o.x - o.size/2 - 4, o.y - o.size/2 - 4, o.size + 8, o.size + 8);
    }
    ctx.setLineDash([]);
  }
}

function peSnapshot() {
  if (_pe.undoStack.length >= 20) _pe.undoStack.shift();
  _pe.undoStack.push({
    base: _pe.baseCanvas.toDataURL(),
    overlays: JSON.parse(JSON.stringify(_pe.overlays)),
    filter: { ..._pe.filter },
    cssFilter: _pe.cssFilter,
  });
  _pe.redoStack = [];
}

function peUndo() {
  if (!_pe.undoStack.length) return toast('Rien à annuler');
  // Save current to redo
  _pe.redoStack.push({
    base: _pe.baseCanvas.toDataURL(),
    overlays: JSON.parse(JSON.stringify(_pe.overlays)),
    filter: { ..._pe.filter },
    cssFilter: _pe.cssFilter,
  });
  const snap = _pe.undoStack.pop();
  peRestoreSnap(snap);
}
function peRedo() {
  if (!_pe.redoStack.length) return toast('Rien à refaire');
  _pe.undoStack.push({
    base: _pe.baseCanvas.toDataURL(),
    overlays: JSON.parse(JSON.stringify(_pe.overlays)),
    filter: { ..._pe.filter },
    cssFilter: _pe.cssFilter,
  });
  const snap = _pe.redoStack.pop();
  peRestoreSnap(snap);
}
function peRestoreSnap(snap) {
  const img = new Image();
  img.onload = () => {
    _pe.baseCanvas.getContext('2d').clearRect(0, 0, _pe.W, _pe.H);
    _pe.baseCanvas.getContext('2d').drawImage(img, 0, 0);
    _pe.overlays = snap.overlays;
    _pe.filter = snap.filter;
    _pe.cssFilter = snap.cssFilter;
    peRedraw();
  };
  img.src = snap.base;
}
function peReset() {
  if (!confirm('Réinitialiser toutes les modifs ?')) return;
  if (!_pe.origImg) return;
  _pe.baseCanvas.getContext('2d').clearRect(0, 0, _pe.W, _pe.H);
  _pe.baseCanvas.getContext('2d').drawImage(_pe.origImg, 0, 0, _pe.W, _pe.H);
  _pe.overlays = [];
  _pe.filter = { brightness:100, contrast:100, saturate:100, blur:0, hue:0, sepia:0, grayscale:0 };
  _pe.cssFilter = '';
  _pe.selectedOverlay = null;
  _pe.undoStack = []; _pe.redoStack = [];
  peRedraw();
  toast('↺ Réinitialisé');
}

// === Switch tools + render panneau ===
function peTool(t) {
  _pe.tool = t;
  ['filter','adjust','blur','text','sticker','anno','crop'].forEach(name => {
    const btn = document.getElementById('pet-' + name);
    if (btn) btn.className = 'btn ' + (name === t ? 'primary' : 'alt');
  });
  const panel = document.getElementById('pe-panel');
  panel.style.display = 'block';
  // Selected overlay reset
  _pe.selectedOverlay = null;
  // Pointer events
  const ovl = _pe.overlayCanvas;
  ovl.style.pointerEvents = (t === 'blur' || t === 'anno' || t === 'text' || t === 'sticker' || t === 'crop') ? 'auto' : 'none';
  // Render appropriate panel
  if (t === 'filter') peRenderFilters();
  else if (t === 'adjust') peRenderAdjust();
  else if (t === 'blur') peRenderBlur();
  else if (t === 'text') peRenderText();
  else if (t === 'sticker') peRenderStickers();
  else if (t === 'anno') peRenderAnno();
  else if (t === 'crop') peRenderCrop();
  peRedraw();
}

function peRenderFilters() {
  const panel = document.getElementById('pe-panel');
  panel.innerHTML = `
    <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-bottom:8px;">Filtres prédéfinis</h3>
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:6px;">
      ${PE_FILTERS.map(f => `<button class="btn ${_pe.cssFilter === f.css ? 'primary' : 'alt'}" onclick="peApplyFilter('${f.css}')" style="padding:8px 4px; font-size:11px;">${f.name}</button>`).join('')}
    </div>
  `;
}
function peApplyFilter(css) {
  peSnapshot();
  _pe.cssFilter = css;
  peRedraw();
  peRenderFilters();
}

function peRenderAdjust() {
  const panel = document.getElementById('pe-panel');
  panel.innerHTML = `
    <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-bottom:8px;">Réglages manuels</h3>
    <div style="font-size:11px; color:var(--textSec); margin-bottom:6px;">Luminosité <span id="adj-bri-v">${_pe.filter.brightness}</span>%</div>
    <input type="range" min="0" max="200" value="${_pe.filter.brightness}" oninput="peAdjust('brightness', this.value)" style="width:100%;">
    <div style="font-size:11px; color:var(--textSec); margin-top:8px;">Contraste <span id="adj-con-v">${_pe.filter.contrast}</span>%</div>
    <input type="range" min="0" max="200" value="${_pe.filter.contrast}" oninput="peAdjust('contrast', this.value)" style="width:100%;">
    <div style="font-size:11px; color:var(--textSec); margin-top:8px;">Saturation <span id="adj-sat-v">${_pe.filter.saturate}</span>%</div>
    <input type="range" min="0" max="200" value="${_pe.filter.saturate}" oninput="peAdjust('saturate', this.value)" style="width:100%;">
    <div style="font-size:11px; color:var(--textSec); margin-top:8px;">Teinte <span id="adj-hue-v">${_pe.filter.hue}</span>°</div>
    <input type="range" min="0" max="360" value="${_pe.filter.hue}" oninput="peAdjust('hue', this.value)" style="width:100%;">
    <div style="font-size:11px; color:var(--textSec); margin-top:8px;">Flou global <span id="adj-blur-v">${_pe.filter.blur}</span>px</div>
    <input type="range" min="0" max="20" value="${_pe.filter.blur}" oninput="peAdjust('blur', this.value)" style="width:100%;">
    <button class="btn alt full" onclick="peResetAdjust()" style="margin-top:10px;">↺ Reset réglages</button>
  `;
}
function peAdjust(key, val) {
  _pe.filter[key] = parseInt(val);
  document.getElementById('adj-bri-v') && (document.getElementById('adj-bri-v').textContent = _pe.filter.brightness);
  document.getElementById('adj-con-v') && (document.getElementById('adj-con-v').textContent = _pe.filter.contrast);
  document.getElementById('adj-sat-v') && (document.getElementById('adj-sat-v').textContent = _pe.filter.saturate);
  document.getElementById('adj-hue-v') && (document.getElementById('adj-hue-v').textContent = _pe.filter.hue);
  document.getElementById('adj-blur-v') && (document.getElementById('adj-blur-v').textContent = _pe.filter.blur);
  _pe.cssFilter = `brightness(${_pe.filter.brightness}%) contrast(${_pe.filter.contrast}%) saturate(${_pe.filter.saturate}%) hue-rotate(${_pe.filter.hue}deg) blur(${_pe.filter.blur}px)`;
  peRedraw();
}
function peResetAdjust() {
  peSnapshot();
  _pe.filter = { brightness:100, contrast:100, saturate:100, blur:0, hue:0, sepia:0, grayscale:0 };
  _pe.cssFilter = '';
  peRedraw();
  peRenderAdjust();
}

// === BLUR (peindre la zone à flouter) ===
function peRenderBlur() {
  const panel = document.getElementById('pe-panel');
  panel.innerHTML = `
    <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-bottom:8px;">Flouter une zone</h3>
    <p style="font-size:11px; color:var(--textSec); margin-bottom:6px;">Peins par-dessus la zone à flouter (visages, infos perso, etc).</p>
    <div style="font-size:11px; color:var(--textSec);">Taille pinceau <span id="blur-size-v">40</span>px</div>
    <input type="range" id="blur-size" min="10" max="100" value="40" oninput="document.getElementById('blur-size-v').textContent=this.value;" style="width:100%;">
    <div style="font-size:11px; color:var(--textSec);">Intensité flou <span id="blur-intensity-v">10</span>px</div>
    <input type="range" id="blur-intensity" min="3" max="30" value="10" oninput="document.getElementById('blur-intensity-v').textContent=this.value;" style="width:100%;">
    <button class="btn alt full" onclick="peApplyMosaic()" style="margin-top:10px; font-size:12px;">🟦 Pixéliser à la place</button>
  `;
  peSetupBlurDraw();
}

function peSetupBlurDraw() {
  const ovl = _pe.overlayCanvas;
  const start = (e) => {
    if (_pe.tool !== 'blur') return;
    e.preventDefault();
    peSnapshot();
    _pe.drawing = true;
    const { x, y } = peXY(e);
    _pe.lastX = x; _pe.lastY = y;
    peApplyBlurAt(x, y);
  };
  const move = (e) => {
    if (!_pe.drawing || _pe.tool !== 'blur') return;
    e.preventDefault();
    const { x, y } = peXY(e);
    // Interpole entre last et current
    const dx = x - _pe.lastX, dy = y - _pe.lastY;
    const dist = Math.sqrt(dx*dx + dy*dy);
    const steps = Math.max(1, Math.floor(dist / 5));
    for (let i=1; i<=steps; i++) {
      peApplyBlurAt(_pe.lastX + dx * i/steps, _pe.lastY + dy * i/steps);
    }
    _pe.lastX = x; _pe.lastY = y;
  };
  const end = () => { _pe.drawing = false; };
  ovl._blurStart = start; ovl._blurMove = move; ovl._blurEnd = end;
  ovl.addEventListener('mousedown', start);
  ovl.addEventListener('mousemove', move);
  ovl.addEventListener('mouseup', end);
  ovl.addEventListener('mouseleave', end);
  ovl.addEventListener('touchstart', start, { passive:false });
  ovl.addEventListener('touchmove', move, { passive:false });
  ovl.addEventListener('touchend', end);
}

function peApplyBlurAt(x, y) {
  const size = parseInt(document.getElementById('blur-size')?.value || 40);
  const intensity = parseInt(document.getElementById('blur-intensity')?.value || 10);
  // Crop zone, blur, paste back
  const ctx = _pe.baseCanvas.getContext('2d');
  const tmp = document.createElement('canvas');
  tmp.width = size * 2; tmp.height = size * 2;
  const tctx = tmp.getContext('2d');
  tctx.filter = `blur(${intensity}px)`;
  tctx.drawImage(_pe.baseCanvas, x - size, y - size, size*2, size*2, 0, 0, size*2, size*2);
  // Apply circular mask
  const finalCtx = ctx;
  finalCtx.save();
  finalCtx.beginPath();
  finalCtx.arc(x, y, size, 0, Math.PI*2);
  finalCtx.clip();
  finalCtx.drawImage(tmp, x - size, y - size);
  finalCtx.restore();
  peRedraw();
}

function peApplyMosaic() {
  if (!confirm('Pixéliser toute l\'image ?')) return;
  peSnapshot();
  const blockSize = 12;
  const ctx = _pe.baseCanvas.getContext('2d');
  const w = _pe.W, h = _pe.H;
  const data = ctx.getImageData(0, 0, w, h);
  const px = data.data;
  for (let y=0; y<h; y+=blockSize) {
    for (let x=0; x<w; x+=blockSize) {
      // Average color in block
      let r=0,g=0,b=0,n=0;
      for (let by=0; by<blockSize && y+by<h; by++) {
        for (let bx=0; bx<blockSize && x+bx<w; bx++) {
          const i = ((y+by)*w + (x+bx)) * 4;
          r += px[i]; g += px[i+1]; b += px[i+2]; n++;
        }
      }
      r=r/n|0; g=g/n|0; b=b/n|0;
      // Fill block
      for (let by=0; by<blockSize && y+by<h; by++) {
        for (let bx=0; bx<blockSize && x+bx<w; bx++) {
          const i = ((y+by)*w + (x+bx)) * 4;
          px[i]=r; px[i+1]=g; px[i+2]=b;
        }
      }
    }
  }
  ctx.putImageData(data, 0, 0);
  peRedraw();
}

// === TEXTE ===
function peRenderText() {
  const panel = document.getElementById('pe-panel');
  const sel = _pe.selectedOverlay && _pe.selectedOverlay.type === 'text' ? _pe.selectedOverlay : null;
  panel.innerHTML = `
    <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-bottom:8px;">${sel ? 'Modifier texte' : 'Ajouter du texte'}</h3>
    <input type="text" class="input" id="pe-txt" placeholder="Ton texte..." value="${sel ? escapeHtml(sel.text) : ''}" style="margin-bottom:6px;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px;">
      <div>
        <span style="font-size:11px; color:var(--textSec);">Couleur</span>
        <input type="color" id="pe-txt-color" value="${sel?.color || '#ffffff'}" style="width:100%; height:36px; border:none; border-radius:8px;">
      </div>
      <div>
        <span style="font-size:11px; color:var(--textSec);">Contour</span>
        <input type="color" id="pe-txt-outline" value="${sel?.outline || '#000000'}" style="width:100%; height:36px; border:none; border-radius:8px;">
      </div>
    </div>
    <div style="font-size:11px; color:var(--textSec); margin-top:6px;">Taille <span id="pe-txt-size-v">${sel?.size || 48}</span>px</div>
    <input type="range" id="pe-txt-size" min="14" max="200" value="${sel?.size || 48}" oninput="document.getElementById('pe-txt-size-v').textContent=this.value;" style="width:100%;">
    <span style="font-size:11px; color:var(--textSec);">Police</span>
    <select class="input" id="pe-txt-font">
      ${['sans-serif','serif','monospace','cursive','Georgia','Impact','Comic Sans MS','Arial Black','Courier New','Times New Roman'].map(f => `<option value="${f}" ${sel?.font === f ? 'selected' : ''}>${f}</option>`).join('')}
    </select>
    <div style="display:flex; gap:6px; margin-top:6px;">
      <label style="font-size:12px; flex:1;"><input type="checkbox" id="pe-txt-bold" ${sel?.bold ? 'checked' : ''}> Gras</label>
      <label style="font-size:12px; flex:1;"><input type="checkbox" id="pe-txt-italic" ${sel?.italic ? 'checked' : ''}> Italique</label>
      <label style="font-size:12px; flex:1;"><input type="checkbox" id="pe-txt-stroke" ${sel?.outline ? 'checked' : ''}> Contour</label>
    </div>
    <button class="btn primary full" onclick="peTextApply()" style="margin-top:10px;">${sel ? '✓ Modifier' : '+ Ajouter au centre'}</button>
    ${sel ? `<button class="btn alt full" onclick="peDelOverlay()" style="margin-top:6px; color:var(--danger);">🗑 Supprimer</button>` : ''}
    <p style="font-size:11px; color:var(--textSec); margin-top:8px;">💡 Tap sur un texte pour le sélectionner, glisse-le pour le déplacer.</p>
  `;
  peSetupOverlayInteract();
}

function peTextApply() {
  const text = document.getElementById('pe-txt').value;
  if (!text.trim()) return toast('Tape un texte');
  peSnapshot();
  const useStroke = document.getElementById('pe-txt-stroke').checked;
  const data = {
    type: 'text',
    text,
    color: document.getElementById('pe-txt-color').value,
    outline: useStroke ? document.getElementById('pe-txt-outline').value : null,
    size: parseInt(document.getElementById('pe-txt-size').value),
    font: document.getElementById('pe-txt-font').value,
    bold: document.getElementById('pe-txt-bold').checked,
    italic: document.getElementById('pe-txt-italic').checked,
  };
  if (_pe.selectedOverlay && _pe.selectedOverlay.type === 'text') {
    Object.assign(_pe.selectedOverlay, data);
  } else {
    data.x = _pe.W / 2 - 100;
    data.y = _pe.H / 2;
    _pe.overlays.push(data);
    _pe.selectedOverlay = data;
  }
  peRedraw();
  peRenderText();
}

