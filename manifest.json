  { id:'flashcard_grinder', emoji:'🃏', name:'Flashcard Grinder', desc:'Créé 50 flashcards', xp:30 },
  { id:'hydrator', emoji:'💧', name:'Hydraté', desc:'Atteint l\'objectif d\'hydratation 1 fois', xp:5 },
  { id:'hydrator_week', emoji:'🌊', name:'Vague hydratée', desc:'Atteint l\'objectif 7 jours total', xp:25 },
  { id:'theme_explorer', emoji:'🎨', name:'Explorateur de thèmes', desc:'Testé 5 thèmes différents', xp:10 },
  { id:'photographer', emoji:'📸', name:'Photographe', desc:'Importé 50 PFP', xp:20 },
  { id:'collector', emoji:'📦', name:'Collectionneur', desc:'10 objets dans l\'inventaire', xp:15 },
  { id:'cleaner', emoji:'🔒', name:'Privacy Pro', desc:'Nettoyé une photo des EXIF', xp:10 },
