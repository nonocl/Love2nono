async function docCoffreUnlock() {
  const pin = prompt('PIN :');
  if (!pin) return;
  const h = await sha256(pin + '_nw_salt_v1');
  if (h !== localStorage.getItem('nw_pin_hash')) { toast('❌ PIN incorrect'); return; }
  _docCoffreUnlocked = true;
  renderDocCoffre();
}
function docCoffreAdd() {
  if (!_docCoffreUnlocked) { toast('Déverrouille d\'abord'); return; }
  const inp = document.createElement('input');
  inp.type = 'file'; inp.accept = 'image/*,application/pdf';
  inp.onchange = async (e) => {
    const file = e.target.files[0];
    if (!file) return;
    if (file.size > 5*1024*1024) { toast('Max 5Mo'); return; }
    const reader = new FileReader();
    reader.onload = () => {
      const name = prompt('Nom du document :', file.name) || file.name;
      const type = prompt('Type (CIN, Passeport, Garantie...) :') || 'Document';
      const notes = prompt('Notes (optionnel) :') || '';
      const docs = getDocCoffre();
      docs.unshift({
        id: 'dc_'+Date.now(), name, type, notes,
        thumb: file.type.startsWith('image/') ? reader.result : null,
        added: Date.now()
      });
      saveDocCoffre(docs);
      renderDocCoffre();
      toast('✅ Ajouté');
    };
    reader.readAsDataURL(file);
  };
  inp.click();
}
function docCoffreView(id) {
  const d = getDocCoffre().find(x => x.id === id);
  if (!d || !d.thumb) return;
  const overlay = document.createElement('div');
  overlay.style.cssText = 'position:fixed; inset:0; background:rgba(0,0,0,0.95); z-index:9999; display:flex; align-items:center; justify-content:center; cursor:pointer;';
  overlay.innerHTML = `<img src="${d.thumb}" style="max-width:95%; max-height:95%; object-fit:contain;">`;
  overlay.onclick = () => overlay.remove();
  document.body.appendChild(overlay);
}
function docCoffreDel(id) {
  if (!confirm('Supprimer ce document ?')) return;
  saveDocCoffre(getDocCoffre().filter(d => d.id !== id));
  renderDocCoffre();
}



