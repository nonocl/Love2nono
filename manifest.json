const FONT_MAPS = {
  'Bold Sans': { a:0x1D5D4, A:0x1D5D4-32 },
  'Italic': { a:0x1D44E-26, A:0x1D434 },
  'Bold Italic': { a:0x1D482-26, A:0x1D468 },
  'Cursive': { a:0x1D4B6-26, A:0x1D49C },
  'Bold Cursive': { a:0x1D4EA-26, A:0x1D4D0 },
  'Fraktur': { a:0x1D51E-26, A:0x1D504 },
  'Double-struck': { a:0x1D552-26, A:0x1D538 },
  'Monospace': { a:0x1D68A-26, A:0x1D670 },
};
function transformChar(c, code) {
  if (c >= 'a' && c <= 'z') return String.fromCodePoint(c.charCodeAt(0) - 'a'.charCodeAt(0) + code.a + 26);
  if (c >= 'A' && c <= 'Z') return String.fromCodePoint(c.charCodeAt(0) - 'A'.charCodeAt(0) + code.A);
  return c;
}
function transform(text, code) {
  return [...text].map(c => transformChar(c, code)).join('');
}
function smallCaps(text) {
  const map = {a:'ᴀ',b:'ʙ',c:'ᴄ',d:'ᴅ',e:'ᴇ',f:'ꜰ',g:'ɢ',h:'ʜ',i:'ɪ',j:'ᴊ',k:'ᴋ',l:'ʟ',m:'ᴍ',n:'ɴ',o:'ᴏ',p:'ᴘ',q:'ǫ',r:'ʀ',s:'s',t:'ᴛ',u:'ᴜ',v:'ᴠ',w:'ᴡ',x:'x',y:'ʏ',z:'ᴢ'};
  return text.toLowerCase().split('').map(c => map[c] || c).join('');
}
function bubble(text) {
  const map = 'ⓐⓑⓒⓓⓔⓕⓖⓗⓘⓙⓚⓛⓜⓝⓞⓟⓠⓡⓢⓣⓤⓥⓦⓧⓨⓩ';
  return text.toLowerCase().split('').map(c => c >= 'a' && c <= 'z' ? map[c.charCodeAt(0)-97] : c).join('');
}
function reversed(text) { return text.split('').reverse().join(''); }
function spaced(text) { return text.split('').join(' '); }
function squiggle(text) { return text.split('').map(c => c + (Math.random()<0.5?'̃':'̈')).join(''); }

