// WIDGET BANDEAU ACCUEIL
// ============================================================
function getWidgetEnabled() { return localStorage.getItem('nw_widget_on') !== '0'; }
function setWidgetEnabled(on) {
  localStorage.setItem('nw_widget_on', on ? '1' : '0');
  renderHomeWidget();
}
async function renderHomeWidget() {
  const el = document.getElementById('home-widget');
  if (!el) return;
  if (!getWidgetEnabled()) { el.style.display = 'none'; return; }
  el.style.display = '';
  const today = new Date().toISOString().slice(0, 10);
  let cards = [];
  // 1) Devoirs aujourd'hui ou en retard
  try {
    const hw = await dbAll('homework');
    const hot = hw.filter(h => !h.done && h.due && h.due <= today);
    if (hot.length) cards.push({
      ico: '📝',
      label: hot.length === 1 ? '1 devoir urgent' : `${hot.length} devoirs urgents`,
      val: hot[0].title.slice(0, 24),
      color: '#FF4757',
      route: 'homework'
    });
  } catch {}
  // 2) Hydratation
  try {
    const hyd = JSON.parse(localStorage.getItem('nw_hydra') || '{}')[today] || 0;
    const goal = parseInt(localStorage.getItem('nw_hydra_goal') || 2000);
    cards.push({
      ico: '💧',
      label: 'Hydra',
      val: `${hyd}/${goal}ml`,
      color: hyd >= goal ? '#5DD68F' : '#5DADE2',
      route: 'hydra'
    });
  } catch {}
  // 3) Bac countdown
  try {
    const bd = localStorage.getItem('nw_bac_date');
    if (bd) {
      const t = new Date(bd); t.setHours(0,0,0,0);
      const n = new Date(); n.setHours(0,0,0,0);
      const days = Math.floor((t-n)/86400000);
      if (days > 0) cards.push({ ico:'🎓', label:'Bac', val:`J-${days}`, color:'#A78BFA', route:'home' });
    }
  } catch {}
  // 4) Anniversaire aujourd'hui
  try {
    const bd = await dbAll('bdays');
    const md = (new Date().getMonth()+1).toString().padStart(2,'0') + '-' + new Date().getDate().toString().padStart(2,'0');
    const t = bd.filter(b => b.date && b.date.slice(5) === md);
    if (t.length) cards.push({ ico:'🎂', label:'Anniv', val:t[0].name.slice(0,18), color:'#FF6FA3', route:'bdays' });
  } catch {}
  // 5) Habits du jour
  try {
    const habits = await dbAll('habits');
    if (habits.length) {
      const logs = await dbAll('habit_logs');
      const todayLogs = logs.filter(l => l.date === today).map(l => l.habit_id);
      const done = habits.filter(h => todayLogs.includes(h.id)).length;
      cards.push({ ico:'🎯', label:'Habits', val:`${done}/${habits.length}`, color: done === habits.length ? '#5DD68F' : '#FFD166', route:'habits' });
    }
  } catch {}

  if (!cards.length) {
    el.innerHTML = `<div onclick="goTo('today')" style="background:linear-gradient(135deg, var(--primary), var(--accent)); color:white; padding:10px 14px; border-radius:14px; cursor:pointer; display:flex; align-items:center; gap:8px;">
      <div style="font-size:22px;">☀️</div>
      <div style="flex:1;">
        <div style="font-weight:700; font-size:13px;">Bonjour !</div>
        <div style="font-size:11px; opacity:0.9;">Tap pour voir ton dashboard</div>
      </div>
      <div style="font-size:18px;">→</div>
    </div>`;
    return;
  }
  // Display 4 max
  cards = cards.slice(0, 4);
  el.innerHTML = `<div style="display:flex; gap:6px; overflow-x:auto; padding-bottom:4px;">${cards.map(c =>
    `<div onclick="goTo('${c.route}')" style="flex-shrink:0; min-width:115px; background:${c.color}; color:white; padding:8px 10px; border-radius:12px; cursor:pointer;">
      <div style="display:flex; align-items:center; gap:6px;">
        <div style="font-size:18px;">${c.ico}</div>
        <div style="font-size:10px; opacity:0.9; font-weight:600;">${escapeHtml(c.label)}</div>
      </div>
      <div style="font-size:13px; font-weight:800; margin-top:2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${escapeHtml(c.val)}</div>
    </div>`
  ).join('')}</div>`;
}



