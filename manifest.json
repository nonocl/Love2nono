let _aim = null;
function aimInit() {
  _aim = { count: 0, target: 30, start: Date.now(), running: true };
  document.getElementById('aim-targets').textContent = '0/30';
  document.getElementById('aim-time').textContent = '0.0s';
  const best = localStorage.getItem('nw_aim_best');
