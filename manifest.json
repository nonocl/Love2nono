  color: #FF1B1C !important;
  text-shadow: 2px 2px 0 #FFCC02;
}

/* === EASTER EGG #13 : MIDNIGHT NEUO ===
   theme moonlight + vibe-neuo = lune zen */
body[data-theme="moonlight"].vibe-neuo {
  background: #0A0F1F !important;
  background-image: radial-gradient(circle at 80% 20%, rgba(200, 184, 229, 0.15) 0%, transparent 40%) !important;
}
body[data-theme="moonlight"].vibe-neuo .v56-greeting,
body[data-theme="moonlight"].vibe-neuo .v56-card {
  background: #141A2E !important;
  box-shadow: 8px 8px 20px rgba(0,0,0,0.6), -6px -6px 16px rgba(122, 168, 255, 0.08) !important;
  border: none !important;
  border-radius: 24px !important;
}

/* === EASTER EGG #14 : MANGA BRUTAL ===
   design-manga + vibe-brut = comic book aesthetic */
body.design-manga.vibe-brut .v56-greeting,
body.design-manga.vibe-brut .v56-card,
body.design-manga.vibe-brut .home-tile {
  background: #FFFFFF !important;
