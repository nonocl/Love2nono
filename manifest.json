// JSON FORMATTER
// ============================================================
function fmtJson(spaces) {
  const inp = document.getElementById('json-in').value;
  const out = document.getElementById('json-out');
  const status = document.getElementById('json-status');
  if (!inp.trim()) { out.value = ''; status.innerHTML = ''; return; }
  try {
    const obj = JSON.parse(inp);
    out.value = JSON.stringify(obj, null, spaces === undefined ? 2 : spaces);
    status.innerHTML = `<span style="color:var(--success);">✅ JSON valide</span>`;
  } catch (e) {
    out.value = '';
    status.innerHTML = `<span style="color:var(--danger);">❌ ${e.message}</span>`;
  }
}

// ============================================================
// MARKDOWN PREVIEW
// ============================================================
function renderMd() {
  const t = document.getElementById('md-in').value;
  let html = escapeHtml(t);
  html = html.replace(/^### (.+)$/gm, '<h3>$1</h3>');
  html = html.replace(/^## (.+)$/gm, '<h2>$1</h2>');
  html = html.replace(/^# (.+)$/gm, '<h1>$1</h1>');
  html = html.replace(/^&gt; (.+)$/gm, '<blockquote style="border-left:3px solid var(--primary); padding-left:10px; color:var(--textSec); margin:6px 0;">$1</blockquote>');
  html = html.replace(/^- (.+)$/gm, '<li>$1</li>');
  html = html.replace(/(<li>.+<\/li>\n?)+/g, m => '<ul>'+m+'</ul>');
  html = html.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
  html = html.replace(/\*([^*]+)\*/g, '<em>$1</em>');
  html = html.replace(/`([^`]+)`/g, '<code style="background:var(--surfaceAlt); padding:1px 4px; border-radius:3px; font-family:monospace;">$1</code>');
  html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" style="color:var(--primary);">$1</a>');
  html = html.replace(/\n\n/g, '</p><p>');
  html = '<p>' + html + '</p>';
  document.getElementById('md-out').innerHTML = html;
}

// ============================================================
// REGEX TESTER
// ============================================================
function testRegex() {
  const pat = document.getElementById('re-pat').value;
  const flags = document.getElementById('re-flags').value;
  const text = document.getElementById('re-text').value;
  const out = document.getElementById('re-output');
  if (!pat) { out.innerHTML = ''; return; }
  try {
    const re = new RegExp(pat, flags);
    const matches = [];
    if (flags.includes('g')) {
      let m;
      while ((m = re.exec(text)) !== null) {
        matches.push(m);
        if (m.index === re.lastIndex) re.lastIndex++;
      }
    } else {
      const m = re.exec(text);
      if (m) matches.push(m);
    }
    let html = `<div style="background:var(--surface); padding:14px; border-radius:10px;"><h3 style="font-size:14px; font-weight:700; color:var(--primary);">${matches.length} match${matches.length===1?'':'es'}</h3>`;
    matches.slice(0, 50).forEach((m, i) => {
      html += `<div style="padding:6px 0; font-family:monospace; font-size:12px; border-top:1px solid var(--border);"><strong>${i+1}.</strong> "${escapeHtml(m[0])}" <span style="color:var(--textSec);">@${m.index}</span></div>`;
    });
    // Highlight in text
    if (matches.length > 0) {
      let hlText = '';
      let last = 0;
      for (const m of matches) {
        hlText += escapeHtml(text.slice(last, m.index));
        hlText += `<mark style="background:var(--primary); color:white;">${escapeHtml(m[0])}</mark>`;
        last = m.index + m[0].length;
      }
      hlText += escapeHtml(text.slice(last));
      html += `<div style="margin-top:10px; padding:10px; background:var(--surfaceAlt); border-radius:8px; font-family:monospace; font-size:11px; white-space:pre-wrap; max-height:200px; overflow-y:auto;">${hlText}</div>`;
    }
    html += '</div>';
    out.innerHTML = html;
  } catch (e) {
    out.innerHTML = `<div style="background:var(--surface); padding:14px; border-radius:10px; color:var(--danger);">❌ ${e.message}</div>`;
  }
}

