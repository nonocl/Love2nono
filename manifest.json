const TG_DEFAULT = [
  { text: "Lever entre 6h et 7h30", done: false },
  { text: "Eau citron au réveil", done: false },
  { text: "Skincare AM complète", done: false },
  { text: "Petit-déj sain et coloré", done: false },
  { text: "Mouvement / sport 30 min", done: false },
  { text: "Journaling matin (3 pages)", done: false },
  { text: "Lire 10 pages d'un livre", done: false },
  { text: "Boire 2L d'eau", done: false },
  { text: "Tenue qui te fait sentir belle/beau", done: false },
  { text: "Manger un repas équilibré midi", done: false },
  { text: "Pause 15 min méditation/respiration", done: false },
  { text: "1 chose productive pour ton futur", done: false },
  { text: "Skincare PM", done: false },
  { text: "Pas d'écran 30 min avant dodo", done: false },
  { text: "Coucher avant 23h", done: false }
];
function getTG() {
  let d;
  try { d = JSON.parse(localStorage.getItem('nw_thatgirl') || 'null'); } catch { d = null; }
  if (!d) d = { items: TG_DEFAULT.slice(), lastReset: new Date().toISOString().slice(0,10), streak: 0 };
  // Reset daily
  const today = new Date().toISOString().slice(0,10);
  if (d.lastReset !== today) {
    const wasFull = d.items.every(i => i.done);
    if (wasFull) d.streak = (d.streak || 0) + 1;
    else d.streak = 0;
    d.items.forEach(i => i.done = false);
    d.lastReset = today;
    localStorage.setItem('nw_thatgirl', JSON.stringify(d));
  }
  return d;
}
function saveTG(d) { localStorage.setItem('nw_thatgirl', JSON.stringify(d)); }
function renderThatGirl() {
  const d = getTG();
  const done = d.items.filter(i => i.done).length;
  const pct = Math.round(done / d.items.length * 100);
  let html = `<div style="background:linear-gradient(135deg,#FFE0EC,#FFC8DD,#FFAFCC); color:#4A1A2C; padding:18px; border-radius:18px; text-align:center;">
    <div style="font-size:36px;">✨</div>
    <div style="font-size:18px; font-weight:900;">that girl mode</div>
    <div style="font-size:24px; font-weight:900; margin-top:10px;">${done}/${d.items.length}</div>
    <div style="background:rgba(255,255,255,0.5); height:8px; border-radius:4px; margin-top:8px; overflow:hidden;">
      <div style="background:#FF1493; height:100%; width:${pct}%; transition:width 0.3s;"></div>
    </div>
    <div style="font-size:12px; margin-top:10px;">🔥 Streak : ${d.streak||0} jour${(d.streak||0)>1?'s':''}</div>
  </div>`;
  d.items.forEach((it, i) => {
    html += `<div onclick="tgCheck(${i})" style="background:var(--surface); padding:12px 14px; border-radius:10px; margin-top:5px; display:flex; gap:10px; align-items:center; cursor:pointer; ${it.done?'opacity:0.6;':''}">
      <span style="width:22px; height:22px; border-radius:6px; border:2px solid #FF1493; background:${it.done?'#FF1493':'transparent'}; color:white; display:inline-flex; align-items:center; justify-content:center; font-size:14px; flex-shrink:0;">${it.done?'✓':''}</span>
      <span style="font-size:14px; ${it.done?'text-decoration:line-through;':''}">${escapeHtml(it.text)}</span>
    </div>`;
  });
  html += `<p style="font-size:11px; color:var(--textSec); text-align:center; margin-top:14px;">↻ Reset auto chaque jour. Tout cocher = +1 streak 🔥</p>`;
  document.getElementById('thatgirl-content').innerHTML = html;
}
function tgCheck(i) {
  const d = getTG();
  d.items[i].done = !d.items[i].done;
  saveTG(d); renderThatGirl();
}

// === 18. LETTRES AU FUTUR SOI ===
function getLetters() { try { return JSON.parse(localStorage.getItem('nw_futureletters') || '[]'); } catch { return []; } }
function saveLetters(d) { localStorage.setItem('nw_futureletters', JSON.stringify(d)); }
function renderFutureLetter() {
  const letters = getLetters();
  const now = Date.now();
  let html = `<div style="background:linear-gradient(135deg,#9B59B6,#FF6FA3); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">💌</div>
    <div style="font-size:16px; font-weight:800;">Lettres au futur soi</div>
    <div style="font-size:11px; opacity:0.9;">${letters.length} lettres · déverrouillage à la date prévue</div>
  </div>`;
  if (!letters.length) html += '<p style="text-align:center; color:var(--textSec); padding:20px;">Aucune lettre. Tap + pour en écrire une.</p>';
  letters.forEach(l => {
    const unlock = new Date(l.unlockAt).getTime();
    const isUnlocked = now >= unlock;
    const days = Math.ceil((unlock - now) / (24*60*60*1000));
    html += `<div style="background:${isUnlocked?'linear-gradient(135deg,#FFE0EC,#FFC8DD)':'var(--surface)'}; color:${isUnlocked?'#4A1A2C':'var(--text)'}; padding:14px; border-radius:12px; margin-top:8px; ${isUnlocked?'border:2px solid #FF1493;':''}">
      <div style="display:flex; justify-content:space-between; align-items:flex-start;">
        <div style="flex:1;">
          <div style="font-size:14px; font-weight:700;">${isUnlocked?'💗':'🔒'} ${escapeHtml(l.title || 'Lettre')}</div>
          <div style="font-size:10px; opacity:0.7; margin-top:2px;">📅 ${isUnlocked ? 'Déverrouillée le ' + new Date(l.unlockAt).toLocaleDateString('fr-FR') : 'Déverrouille dans '+days+' jour'+(days>1?'s':'')}</div>
          ${isUnlocked ? `<div style="font-size:13px; line-height:1.6; margin-top:10px; padding:10px; background:rgba(255,255,255,0.5); border-radius:8px; white-space:pre-wrap;">${escapeHtml(l.body)}</div>` : '<p style="font-size:11px; opacity:0.6; margin-top:6px; font-style:italic;">Reviens à la date pour la lire 💕</p>'}
        </div>
        <button onclick="flDel('${l.id}')" style="background:none; border:none; color:var(--danger); font-size:18px;">✗</button>
      </div>
    </div>`;
  });
  document.getElementById('futureletter-content').innerHTML = html;
}
function flAdd() {
  const title = prompt('Titre de la lettre :');
  if (!title) return;
  const body = prompt('Lettre à ton futur toi :');
  if (!body) return;
  const choice = prompt('Déverrouiller dans :\n1. 1 semaine\n2. 1 mois\n3. 6 mois\n4. 1 an\n5. 5 ans\n6. Date custom');
  let unlockAt;
  const now = new Date();
  if (choice === '1') unlockAt = new Date(now.getTime() + 7*24*60*60*1000);
  else if (choice === '2') { unlockAt = new Date(now); unlockAt.setMonth(unlockAt.getMonth()+1); }
  else if (choice === '3') { unlockAt = new Date(now); unlockAt.setMonth(unlockAt.getMonth()+6); }
  else if (choice === '4') { unlockAt = new Date(now); unlockAt.setFullYear(unlockAt.getFullYear()+1); }
  else if (choice === '5') { unlockAt = new Date(now); unlockAt.setFullYear(unlockAt.getFullYear()+5); }
  else if (choice === '6') {
    const d = prompt('Date (YYYY-MM-DD) :', '2025-12-31');
    if (!d) return;
    unlockAt = new Date(d);
  } else return;
  const letters = getLetters();
  letters.unshift({ id: 'fl_'+Date.now(), title, body, unlockAt: unlockAt.toISOString(), created: Date.now() });
  saveLetters(letters); renderFutureLetter();
  toast('💌 Lettre scellée !');
}
function flDel(id) {
  if (!confirm('Supprimer cette lettre ?')) return;
  saveLetters(getLetters().filter(l => l.id !== id));
  renderFutureLetter();
}

