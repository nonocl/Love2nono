    row.onclick = () => openCatModal(c);
    el.appendChild(row);
  }
}

function openCatModal(cat) {
  state.editingCat = cat;
  document.getElementById('cat-modal-title').textContent = cat ? 'Modifier' : 'Nouvelle catégorie';
  document.getElementById('cat-name-input').value = cat ? cat.name : '';
  state.catColor = cat ? cat.color : '#FF6FA3';
  state.catIcon = cat ? (cat.icon || '') : '';
  document.getElementById('cat-del-btn').style.display = cat ? 'inline-flex' : 'none';
  // Swatches
  const palette = ['#FF6FA3','#FFB6D9','#C77DFF','#9D4EDD','#7B61FF','#5DD6E5','#5DD68F','#FFD166','#FF8C42','#FF6B7A','#A78BFA','#06FFA5'];
  const sw = document.getElementById('cat-swatches');
  sw.innerHTML = '';
  for (const c of palette) {
    const b = document.createElement('button');
    b.className = 'swatch' + (c===state.catColor?' selected':'');
    b.style.background = c;
    b.textContent = c===state.catColor ? '✓' : '';
    b.onclick = () => { state.catColor = c; openCatModal(cat); };
    sw.appendChild(b);
  }
  // Icons
  const ic = document.getElementById('cat-icons');
  ic.innerHTML = '';
  const noneBtn = document.createElement('button');
  noneBtn.className = 'swatch' + (state.catIcon === '' ? ' selected' : '');
  noneBtn.style.background = 'var(--surface)'; noneBtn.style.color = 'var(--textSec)';
  noneBtn.textContent = '—';
  noneBtn.onclick = () => { state.catIcon = ''; openCatModal(cat); };
  ic.appendChild(noneBtn);
  for (const i of ICONS) {
    const b = document.createElement('button');
    b.className = 'swatch' + (i === state.catIcon ? ' selected' : '');
    b.style.background = 'var(--surface)';
    b.textContent = i;
    b.onclick = () => { state.catIcon = i; openCatModal(cat); };
    ic.appendChild(b);
  }
  openModal('modal-cat');
}

async function saveCat() {
  const name = document.getElementById('cat-name-input').value.trim();
  if (!name) { alert('Donne un nom.'); return; }
  if (state.editingCat) {
    await dbPut('categories', { ...state.editingCat, name, color: state.catColor, icon: state.catIcon || null });
  } else {
    await dbAdd('categories', { name, color: state.catColor, icon: state.catIcon || null, created_at: new Date().toISOString() });
  }
  closeModal('modal-cat');
  renderCategories();
}

