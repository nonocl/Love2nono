// === 2. RÉVEIL / ALARMES ===
function getAlarms() { try { return JSON.parse(localStorage.getItem('nw_alarms') || '[]'); } catch { return []; } }
function saveAlarms(a) { localStorage.setItem('nw_alarms', JSON.stringify(a)); }
let _alarmInterval = null;
function renderAlarms() {
  const alarms = getAlarms();
  const now = new Date();
  const nowStr = now.toLocaleTimeString('fr-FR');
  let html = `<div style="background:linear-gradient(135deg,#FF6FA3,#FF8C42); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">⏰</div><div style="font-size:16px; font-weight:800;">Réveil & Alarmes</div>
    <div style="font-size:11px; opacity:0.9;">Heure actuelle : ${nowStr}</div>
  </div>
  <p style="font-size:10px; color:var(--textSec); margin-top:8px; padding:8px; background:var(--surface); border-radius:8px;">⚠️ Garde l'app ouverte pour que l'alarme sonne. Pour vrais réveils, utilise l'app native.</p>
  <div style="display:grid; grid-template-columns:2fr 1fr; gap:6px; margin-top:10px;">
    <input type="time" id="alarm-time" class="input" value="${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}">
    <button class="btn primary" onclick="alarmAdd()">➕ Ajouter</button>
  </div>`;
  if (!alarms.length) html += `<p style="text-align:center; color:var(--textSec); font-size:11px; margin-top:14px;">Aucune alarme</p>`;
  alarms.forEach((a, i) => {
    html += `<div style="background:var(--surface); padding:12px; border-radius:12px; margin-top:6px; display:flex; justify-content:space-between; align-items:center;">
      <div>
        <div style="font-size:24px; font-weight:900;">${a.time}</div>
        <div style="font-size:10px; color:var(--textSec);">${a.active ? '✅ Active' : '⏸ Désactivée'}</div>
      </div>
      <div style="display:flex; gap:6px;">
        <button class="btn alt" onclick="alarmToggle(${i})" style="font-size:11px; padding:6px 10px;">${a.active ? '⏸' : '▶️'}</button>
        <button class="btn alt" onclick="alarmDel(${i})" style="font-size:11px; padding:6px 10px; color:var(--danger);">✗</button>
      </div>
    </div>`;
  });
  document.getElementById('alarms-content').innerHTML = html;
  if (!_alarmInterval) _alarmInterval = setInterval(alarmCheck, 30000);
}
function alarmAdd() {
  const time = document.getElementById('alarm-time').value;
  if (!time) return;
  const a = getAlarms();
  a.push({ time, active: true });
  saveAlarms(a);
  renderAlarms();
}
function alarmToggle(i) { const a = getAlarms(); a[i].active = !a[i].active; saveAlarms(a); renderAlarms(); }
function alarmDel(i) { const a = getAlarms(); a.splice(i, 1); saveAlarms(a); renderAlarms(); }
function alarmCheck() {
  const a = getAlarms();
  const now = new Date();
  const cur = String(now.getHours()).padStart(2, '0') + ':' + String(now.getMinutes()).padStart(2, '0');
  for (const al of a) {
    if (al.active && al.time === cur && al.lastFired !== now.toDateString()) {
      al.lastFired = now.toDateString();
      saveAlarms(a);
      try {
        const ctx = new (window.AudioContext || window.webkitAudioContext)();
        for (let i = 0; i < 5; i++) {
          const osc = ctx.createOscillator(), gain = ctx.createGain();
          osc.frequency.value = 880; osc.connect(gain); gain.connect(ctx.destination);
          gain.gain.setValueAtTime(0.3, ctx.currentTime + i * 0.5);
          osc.start(ctx.currentTime + i * 0.5);
          osc.stop(ctx.currentTime + i * 0.5 + 0.4);
        }
      } catch {}
      if (navigator.vibrate) navigator.vibrate([300, 100, 300, 100, 300]);
      toast('⏰ ALARME : ' + al.time);
    }
  }
}

// === 3. COMPTE À REBOURS ===
function getCountdowns() { try { return JSON.parse(localStorage.getItem('nw_countdowns') || '[]'); } catch { return []; } }
function saveCountdowns(c) { localStorage.setItem('nw_countdowns', JSON.stringify(c)); }
function renderCountdown() {
  const cds = getCountdowns();
  const today = new Date().toISOString().slice(0, 10);
  let html = `<div style="background:linear-gradient(135deg,#9B59B6,#FF6FA3); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">⏳</div><div style="font-size:16px; font-weight:800;">Compte à rebours</div>
    <div style="font-size:11px; opacity:0.9;">Combien de jours avant tes événements ?</div>
  </div>
  <div style="background:var(--surface); padding:10px; border-radius:10px; margin-top:14px;">
    <input type="text" id="cd-name" class="input" placeholder="Événement (ex: Vacances été)" maxlength="40">
    <input type="date" id="cd-date" class="input" value="${today}" style="margin-top:6px;">
    <button class="btn primary full" onclick="cdAdd()" style="margin-top:6px;">➕ Ajouter</button>
  </div>`;
  // Sort by closest
  cds.sort((a, b) => new Date(a.date) - new Date(b.date));
  cds.forEach((c, i) => {
    const target = new Date(c.date + 'T00:00:00');
    const days = Math.ceil((target - new Date()) / 86400000);
    let label, color;
    if (days < 0) { label = `Passé (J+${-days})`; color = '#787C7E'; }
    else if (days === 0) { label = "AUJOURD'HUI 🎉"; color = '#5DD68F'; }
    else if (days === 1) { label = 'DEMAIN'; color = '#FF6FA3'; }
    else if (days <= 7) { label = `J-${days}`; color = '#FF8C42'; }
    else { label = `J-${days}`; color = 'var(--primary)'; }
    html += `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:8px; border-left:4px solid ${color};">
      <div style="display:flex; justify-content:space-between; align-items:flex-start;">
        <div style="flex:1;">
          <div style="font-size:14px; font-weight:700;">${escapeHtml(c.name)}</div>
          <div style="font-size:10px; color:var(--textSec); margin-top:2px;">${target.toLocaleDateString('fr-FR', {weekday:'long', day:'numeric', month:'long', year:'numeric'})}</div>
        </div>
        <button onclick="cdDel(${i})" style="background:none; border:none; color:var(--danger); font-size:14px;">✗</button>
      </div>
      <div style="font-size:32px; font-weight:900; color:${color}; text-align:center; margin-top:8px;">${label}</div>
    </div>`;
  });
  document.getElementById('countdown-content').innerHTML = html;
}
function cdAdd() {
  const name = document.getElementById('cd-name').value.trim();
  const date = document.getElementById('cd-date').value;
  if (!name || !date) { toast('Nom + date requis'); return; }
  const cds = getCountdowns();
  cds.push({ name: name.slice(0, 40), date });
  saveCountdowns(cds);
  document.getElementById('cd-name').value = '';
  renderCountdown();
}
function cdDel(i) { const c = getCountdowns(); c.splice(i, 1); saveCountdowns(c); renderCountdown(); }

// === 4. CALCULATEUR D'ÂGE PRÉCIS ===
function renderAgeCalc() {
  let html = `<div style="background:linear-gradient(135deg,#06FFA5,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🎂</div><div style="font-size:16px; font-weight:800;">Calculateur d'âge</div>
    <div style="font-size:11px; opacity:0.9;">Précision à la seconde près</div>
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📅 Date de naissance</h3>
  <input type="datetime-local" id="age-birth" class="input" oninput="ageCalc()" style="margin-top:6px;">
  <div id="age-result" style="margin-top:14px;"></div>`;
  document.getElementById('agecalc-content').innerHTML = html;
}
function ageCalc() {
  const v = document.getElementById('age-birth').value;
  if (!v) return;
  const birth = new Date(v);
  const now = new Date();
  if (birth > now) { document.getElementById('age-result').innerHTML = '<div style="color:var(--textSec);">Date dans le futur</div>'; return; }
  const diff = now - birth;
  const years = Math.floor(diff / (365.25 * 86400000));
  const ms = diff - years * 365.25 * 86400000;
  const days = Math.floor(ms / 86400000);
  const months = Math.floor(days / 30.44);
  const totalDays = Math.floor(diff / 86400000);
  const totalHours = Math.floor(diff / 3600000);
  const totalMin = Math.floor(diff / 60000);
  const totalSec = Math.floor(diff / 1000);
  const html = `<div style="background:var(--surface); padding:18px; border-radius:14px; text-align:center;">
    <div style="font-size:48px; font-weight:900; color:var(--primary);">${years} ans</div>
    <div style="font-size:13px; color:var(--textSec); margin-top:4px;">${months} mois et ${days % 30} jours environ</div>
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📊 En détail</h3>
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:6px;">
    <div style="background:var(--surface); padding:10px; border-radius:10px; text-align:center;"><div style="font-size:9px; color:var(--textSec);">JOURS</div><div style="font-size:16px; font-weight:900;">${totalDays.toLocaleString('fr-FR')}</div></div>
    <div style="background:var(--surface); padding:10px; border-radius:10px; text-align:center;"><div style="font-size:9px; color:var(--textSec);">HEURES</div><div style="font-size:16px; font-weight:900;">${totalHours.toLocaleString('fr-FR')}</div></div>
    <div style="background:var(--surface); padding:10px; border-radius:10px; text-align:center;"><div style="font-size:9px; color:var(--textSec);">MINUTES</div><div style="font-size:16px; font-weight:900;">${totalMin.toLocaleString('fr-FR')}</div></div>
    <div style="background:var(--surface); padding:10px; border-radius:10px; text-align:center;"><div style="font-size:9px; color:var(--textSec);">SECONDES</div><div style="font-size:16px; font-weight:900;">${totalSec.toLocaleString('fr-FR')}</div></div>
  </div>`;
  document.getElementById('age-result').innerHTML = html;
}

