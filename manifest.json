let _editingSob = null;

async function renderSobriety() {
  const all = await dbAll('sobriety');
  const el = document.getElementById('sobriety-list');
  el.innerHTML = '';
  if (all.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">🌿</div><h3>Aucun compteur</h3><p>Ajoute ce que tu veux arrêter (clope, sucre, alcool, jeux vidéo, réseaux sociaux...) avec ta date d'arrêt.</p></div>`;
    return;
  }
  const now = Date.now();
  for (const s of all.sort((a,b)=>new Date(b.startDate)-new Date(a.startDate))) {
    const start = new Date(s.startDate).getTime();
    const elapsed = now - start;
    const days = Math.floor(elapsed / 86400000);
    const hours = Math.floor((elapsed % 86400000) / 3600000);
    const mins = Math.floor((elapsed % 3600000) / 60000);
    const months = Math.floor(days / 30);
    const years = Math.floor(days / 365);
    let mainLabel;
    if (years > 0) mainLabel = `${years} an${years>1?'s':''}`;
    else if (months > 0) mainLabel = `${months} mois`;
    else if (days > 0) mainLabel = `${days} jour${days>1?'s':''}`;
    else mainLabel = `${hours}h ${mins}min`;
    const subLabel = days > 0 ? `${days} jours · ${hours}h ${mins}min` : `${hours} heures, ${mins} minutes`;
    const saved = s.costPerDay ? (s.costPerDay * (elapsed/86400000)).toFixed(2) : null;
    const card = document.createElement('button');
    card.style.cssText = 'display:block; width:100%; text-align:left; background:var(--surface); border-radius:18px; padding:18px; margin-bottom:10px; border:none; cursor:pointer;';
    card.innerHTML = `
      <div style="display:flex; align-items:center; gap:12px; margin-bottom:10px;">
        <div style="font-size:36px;">${s.icon || '🌿'}</div>
        <div style="flex:1; min-width:0;">
          <div style="font-size:18px; font-weight:700;">${escapeHtml(s.name)}</div>
