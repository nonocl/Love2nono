  </div>
  <p style="font-size:12px; color:var(--textSec); margin-top:14px; line-height:1.5;">
    Active cette option, puis dans n'importe quelle page tu peux <strong>tap 3 fois rapidement sur l'écran</strong> pour faire apparaître un écran noir/calc qui masque tout.<br><br>
    Tap 3 fois à nouveau pour réafficher.
  </p>
  <button class="btn primary full" onclick="quickHideToggle()" style="margin-top:14px;">${active ? '🔓 Désactiver' : '👁️ Activer'}</button>
  ${active ? `<button class="btn alt full" onclick="quickHideTrigger()" style="margin-top:6px;">🧪 Tester maintenant</button>` : ''}`;
  document.getElementById('quickhide-content').innerHTML = html;
}
function quickHideToggle() {
  localStorage.setItem('nw_quickhide', isQuickHide() ? '0' : '1');
  toast(isQuickHide() ? '👁️ Activé' : '🔓 Désactivé');
  renderQuickHide();
  setupQuickHide();
}
let _quickHideTaps = [];
function setupQuickHide() {
  if (window._quickHideListener) document.removeEventListener('click', window._quickHideListener);
  if (!isQuickHide()) return;
  window._quickHideListener = (e) => {
    const now = Date.now();
    _quickHideTaps = _quickHideTaps.filter(t => now - t < 600);
    _quickHideTaps.push(now);
    if (_quickHideTaps.length >= 3) {
      _quickHideTaps = [];
      quickHideTrigger();
    }
  };
  document.addEventListener('click', window._quickHideListener);
}
function quickHideTrigger() {
  let overlay = document.getElementById('quickhide-overlay');
  if (overlay) {
    overlay.remove();
    return;
  }
  overlay = document.createElement('div');
  overlay.id = 'quickhide-overlay';
  overlay.style.cssText = 'position:fixed; inset:0; background:#000; color:#888; z-index:99999; display:flex; align-items:center; justify-content:center; flex-direction:column; font-family:monospace;';
  overlay.innerHTML = `<div style="font-size:80px;">🔋</div><div style="margin-top:20px; font-size:14px;">${new Date().toLocaleTimeString('fr-FR').slice(0,5)}</div><div style="margin-top:30px; font-size:11px; opacity:0.4;">tap 3x pour revenir</div>`;
  let taps = [];
  overlay.addEventListener('click', () => {
    const now = Date.now();
    taps = taps.filter(t => now - t < 600);
    taps.push(now);
    if (taps.length >= 3) overlay.remove();
  });
  document.body.appendChild(overlay);
}

