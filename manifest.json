function getNoteCats() {
  // Custom + auto fixed
  try {
    return new Promise(r => {
      const req = db.transaction('note_cats','readonly').objectStore('note_cats').getAll();
      req.onsuccess = () => r(req.result || []);
      req.onerror = () => r([]);
    });
  } catch { return Promise.resolve([]); }
}

async function notesAddCat() {
  const name = prompt('Nom de la catégorie ?');
  if (!name?.trim()) return;
  const tx = db.transaction('note_cats','readwrite');
  tx.objectStore('note_cats').add({ name: name.trim(), added: Date.now() });
  setTimeout(renderNotes, 150);
}

let _curNoteFilter = 'all';
async function renderNotes() {
  if (!db) return;
  const notes = await dbAll('notes');
  const customCats = await getNoteCats();
  // Compter notes par cat
  const counts = { all: notes.length };
  for (const c of Object.keys(NOTE_AUTO_KW)) counts[c] = 0;
  for (const c of customCats) counts[c.name] = 0;
  for (const n of notes) {
    if (n.cat && counts[n.cat] !== undefined) counts[n.cat]++;
  }
  // Render filter chips
  const chipsEl = document.getElementById('notes-cats');
  if (chipsEl) {
    let html = `<div class="home-tab ${_curNoteFilter === 'all' ? 'active' : ''}" onclick="filterNotes('all')">Tout (${counts.all})</div>`;
    const allCatNames = [...new Set([...Object.keys(NOTE_AUTO_KW), ...customCats.map(c => c.name)])];
    for (const c of allCatNames) {
      if (counts[c] > 0) {
        html += `<div class="home-tab ${_curNoteFilter === c ? 'active' : ''}" onclick="filterNotes('${escapeHtml(c).replace(/'/g, "\\'")}')">${escapeHtml(c)} (${counts[c]})</div>`;
      }
    }
    chipsEl.innerHTML = html;
  }
  // Filter & search
  const search = (document.getElementById('notes-search')?.value || '').toLowerCase();
  let visible = notes.slice();
  if (_curNoteFilter !== 'all') visible = visible.filter(n => n.cat === _curNoteFilter);
  if (search) visible = visible.filter(n => (n.title||'').toLowerCase().includes(search) || (n.content||'').toLowerCase().includes(search));
  visible.sort((a,b)=>(b.updated_at||'').localeCompare(a.updated_at||''));
  // Render grid (style Google Keep, 2 cols)
  const el = document.getElementById('notes-list');
  el.innerHTML = '';
  if (!visible.length) {
    el.innerHTML = `<div class="empty"><div class="icon">📌</div><h3>${notes.length === 0 ? 'Aucune note' : 'Rien dans cette catégorie'}</h3><p>${notes.length === 0 ? 'Tape sur + pour créer ta première note.' : ''}</p></div>`;
    return;
  }
  el.style.cssText = 'display:grid; grid-template-columns:1fr 1fr; gap:8px;';
  for (const n of visible) {
    const bg = noteColorBg(n.color || 'default');
    const card = document.createElement('div');
    card.style.cssText = `background:${bg}; padding:12px; border-radius:14px; cursor:pointer; min-height:100px; box-shadow:0 1px 3px var(--shadow); color:#1c1c1e;`;
    const previewLines = (n.content||'').split('\n').slice(0, 5).join('\n').slice(0, 150);
    card.innerHTML = `
      <div style="font-weight:700; font-size:14px; margin-bottom:6px;">${escapeHtml(n.title || '(sans titre)')}</div>
      <div style="font-size:12px; line-height:1.4; white-space:pre-wrap; opacity:0.8;">${escapeHtml(previewLines)}</div>
      ${n.cat ? `<div style="display:inline-block; margin-top:8px; font-size:10px; background:rgba(0,0,0,0.1); padding:2px 8px; border-radius:8px;">${escapeHtml(n.cat)}</div>` : ''}
      <div style="font-size:10px; opacity:0.5; margin-top:6px;">${new Date(n.updated_at||n.created_at).toLocaleDateString('fr-FR')}</div>
    `;
    card.onclick = () => openNote(n);
    el.appendChild(card);
  }
}

function filterNotes(c) { _curNoteFilter = c; renderNotes(); }

async function openNote(note) {
  state.editingNoteId = note ? note.id : null;
  document.getElementById('note-title').value = note ? (note.title||'') : '';
  document.getElementById('note-content').value = note ? (note.content||'') : '';
  // Couleurs
  const colorEl = document.getElementById('note-colors');
  if (colorEl) {
    const curColor = note?.color || 'default';
    colorEl.innerHTML = NOTE_COLORS.map(c => `<button onclick="setNoteColor('${c.id}')" style="width:28px; height:28px; border-radius:50%; border:2px solid ${curColor === c.id ? 'var(--text)' : 'transparent'}; background:${c.bg}; cursor:pointer; box-shadow:0 0 0 1px var(--border);" title="${c.label}"></button>`).join('');
    state._editColor = curColor;
  }
  // Cats
  const cats = await getNoteCats();
  const catEl = document.getElementById('note-cat');
  if (catEl) {
    let opts = '<option value="">Sans catégorie</option>';
    const allNames = [...new Set([...Object.keys(NOTE_AUTO_KW), ...cats.map(c => c.name)])];
    for (const n of allNames) opts += `<option value="${escapeHtml(n)}">${escapeHtml(n)}</option>`;
    catEl.innerHTML = opts;
    catEl.value = note?.cat || '';
  }
  // Apply BG
  applyNoteBgPreview();
  document.getElementById('note-suggest').innerHTML = '';
  goTo('note-editor');
}
function setNoteColor(id) {
  state._editColor = id;
  // Re-render swatches
  const colorEl = document.getElementById('note-colors');
  colorEl.innerHTML = NOTE_COLORS.map(c => `<button onclick="setNoteColor('${c.id}')" style="width:28px; height:28px; border-radius:50%; border:2px solid ${id === c.id ? 'var(--text)' : 'transparent'}; background:${c.bg}; cursor:pointer; box-shadow:0 0 0 1px var(--border);" title="${c.label}"></button>`).join('');
  applyNoteBgPreview();
}
function applyNoteBgPreview() {
  const sec = document.getElementById('note-editor-section');
  if (sec) sec.style.background = noteColorBg(state._editColor || 'default');
  // Adjust text color for light backgrounds
  const c = state._editColor;
  if (c && c !== 'default') {
    document.getElementById('note-title').style.color = '#1c1c1e';
    document.getElementById('note-content').style.color = '#1c1c1e';
  } else {
    document.getElementById('note-title').style.color = '';
    document.getElementById('note-content').style.color = '';
  }
}

// Auto-classement intelligent
function noteAutoClassify() {
  const title = document.getElementById('note-title').value.toLowerCase();
  const content = document.getElementById('note-content').value.toLowerCase();
  const text = title + ' ' + content;
  if (!text.trim()) return toast('Tape du contenu d\'abord');
  const scores = {};
  for (const [cat, kws] of Object.entries(NOTE_AUTO_KW)) {
    scores[cat] = 0;
    for (const kw of kws) {
      const re = new RegExp('\\b' + kw + '\\b', 'gi');
      const matches = text.match(re);
      if (matches) scores[cat] += matches.length;
    }
  }
  const best = Object.entries(scores).filter(([,s]) => s > 0).sort((a,b) => b[1] - a[1]);
  const sug = document.getElementById('note-suggest');
  if (!best.length) {
    sug.innerHTML = '<div style="background:var(--surfaceAlt); padding:10px; border-radius:8px; font-size:12px; color:var(--textSec);">🤔 Pas de catégorie évidente détectée. Tu peux en choisir une manuellement ci-dessus.</div>';
    return;
  }
  const top3 = best.slice(0, 3);
  sug.innerHTML = `<div style="background:var(--surfaceAlt); padding:10px; border-radius:8px; font-size:12px;">
    ✨ <strong>Suggestions :</strong>
    <div style="display:flex; gap:4px; flex-wrap:wrap; margin-top:6px;">
      ${top3.map(([cat, s]) => `<button class="btn primary" style="padding:6px 12px; font-size:11px;" onclick="applyNoteCat('${cat}')">${cat} <span style="opacity:0.7;">(${s})</span></button>`).join('')}
    </div>
  </div>`;
}
function applyNoteCat(cat) {
  document.getElementById('note-cat').value = cat;
  toast(`✅ Catégorie : ${cat}`);
  document.getElementById('note-suggest').innerHTML = '';
}

async function saveNoteAndBack() {
  const title = document.getElementById('note-title').value.trim();
  const content = document.getElementById('note-content').value;
  const color = state._editColor || 'default';
  const cat = document.getElementById('note-cat')?.value || null;
  if (!title && !content) { goTo('notes'); return; }
  if (state.editingNoteId) {
    const n = await dbGet('notes', state.editingNoteId);
    await dbPut('notes', { ...n, title, content, color, cat, updated_at: new Date().toISOString() });
  } else {
    await dbAdd('notes', { title, content, color, cat, created_at: new Date().toISOString(), updated_at: new Date().toISOString() });
  }
  goTo('notes');
}
async function deleteCurrentNote() {
  if (!state.editingNoteId) { goTo('notes'); return; }
  if (!confirm('Supprimer cette note ?')) return;
  await dbDel('notes', state.editingNoteId);
  goTo('notes');
}

