// Shortcuts par défaut
const DEFAULT_SHORTCUTS = ['notes','homework','flashcards','muscu','wardrobe','cycle','games','wallet2'];
function getDashShortcuts() {
  let arr; try { arr = JSON.parse(localStorage.getItem('nw_dash_shortcuts') || 'null'); } catch { arr = null; }
  return arr || DEFAULT_SHORTCUTS.slice();
}
function saveDashShortcuts(arr) { localStorage.setItem('nw_dash_shortcuts', JSON.stringify(arr)); }

let _dashEditMode = false;

function renderDash() {
  // Salutation
  const h = new Date().getHours();
  let greet = '';
  if (h < 6) greet = '🌙 Encore éveillé(e) ?';
  else if (h < 12) greet = '☀️ Bon matin';
  else if (h < 18) greet = '🌤 Bon après-midi';
  else if (h < 22) greet = '🌆 Bonne soirée';
  else greet = '🌙 Bonne nuit';
  
  const day = new Date().toLocaleDateString('fr-FR', { weekday:'long', day:'numeric', month:'long' });
  // Récupérer le prénom si disponible
  let userName = '';
  try { userName = localStorage.getItem('nw_user_name') || ''; } catch {}
  
  // Citation aléatoire d'inspiration courte
  const dailyVibes = [
    'today is yours ✨', 'glow up time 💫', 'soft & strong 🌸', 'main character era 🎬',
    'manifest mode 🌙', 'thrive babe 🦋', 'good vibes only 💞', "let's gooo 🔥",
    'be soft, be strong 🌷', 'choose joy ☀️', 'breathe & receive 🌿', 'iconic 💖'
  ];
  const vibe = dailyVibes[Math.floor(Math.random() * dailyVibes.length)];
  
  document.getElementById('dash-greeting').innerHTML = `
    <div style="font-size:11px; color:var(--textSec); font-weight:700; letter-spacing:1.5px; text-transform:uppercase; opacity:0.7;">${greet}${userName ? ', '+escapeHtml(userName) : ''}</div>
    <div class="dash-greeting-name" style="font-size:28px; font-weight:900; margin-top:4px; line-height:1.1; letter-spacing:-0.02em;">${escapeHtml(vibe)}</div>
    <div style="font-size:11px; color:var(--textSec); opacity:0.6; margin-top:6px; text-transform:capitalize; font-weight:600;">${day}</div>`;
  
  // Shortcuts
  renderDashShortcuts();
  
  // Widget bandeau (si activé)
  if (typeof renderHomeWidget === 'function') renderHomeWidget();
  
  // Quick stats
  renderDashQuick();
  
  // Inspiration
  renderDashInspire();
}

function renderDashShortcuts() {
  const shortcuts = getDashShortcuts();
  const wrap = document.getElementById('dash-shortcuts');
  if (!wrap) return;
  
  // Trouver les infos depuis PAGE_INDEX
  const pages = (typeof PAGE_INDEX !== 'undefined') ? PAGE_INDEX : [];
  
  let html = '';
  shortcuts.forEach(id => {
    const p = pages.find(x => x.page === id);
    if (!p) return;
    if (_dashEditMode) {
      html += `<button onclick="dashRemoveShortcut('${id}')" style="background:var(--surface); border:1px solid var(--danger); border-radius:14px; padding:12px 4px; cursor:pointer; display:flex; flex-direction:column; align-items:center; gap:4px; position:relative;">
        <div style="position:absolute; top:-6px; right:-6px; background:var(--danger); color:white; width:20px; height:20px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:700;">−</div>
        <div style="font-size:24px;">${p.ico || '·'}</div>
        <div style="font-size:10px; line-height:1.2; color:var(--text); font-weight:600; text-align:center;">${escapeHtml(p.name)}</div>
      </button>`;
    } else {
      html += `<button onclick="goTo('${id}')" style="background:var(--surface); border:none; border-radius:14px; padding:12px 4px; cursor:pointer; display:flex; flex-direction:column; align-items:center; gap:4px;">
        <div style="font-size:24px;">${p.ico || '·'}</div>
        <div style="font-size:10px; line-height:1.2; color:var(--text); font-weight:600; text-align:center; word-break:break-word;">${escapeHtml(p.name)}</div>
      </button>`;
    }
  });
  
  // Bouton "Ajouter" en mode édition
  if (_dashEditMode) {
    html += `<button onclick="dashAddShortcut()" style="background:transparent; border:2px dashed var(--primary); border-radius:14px; padding:12px 4px; cursor:pointer; display:flex; flex-direction:column; align-items:center; gap:4px; color:var(--primary);">
      <div style="font-size:24px;">+</div>
      <div style="font-size:10px; font-weight:700;">Ajouter</div>
    </button>`;
  }
  
  if (!html && !_dashEditMode) {
    html = `<div style="grid-column:1/-1; text-align:center; padding:14px; color:var(--textSec); font-size:12px;">
      Aucun raccourci. Tap "Modifier" pour en ajouter.
    </div>`;
  }
  
  wrap.innerHTML = html;
}

function dashEditMode() {
  _dashEditMode = !_dashEditMode;
  const btn = document.getElementById('dash-edit-btn');
  if (btn) btn.textContent = _dashEditMode ? '✓ Terminé' : '✎ Modifier';
  renderDashShortcuts();
}

function dashRemoveShortcut(id) {
  if (!confirm('Retirer ce raccourci ?')) return;
  const shortcuts = getDashShortcuts().filter(s => s !== id);
  saveDashShortcuts(shortcuts);
  renderDashShortcuts();
}

function dashAddShortcut() {
  const cur = getDashShortcuts();
  const pages = (typeof PAGE_INDEX !== 'undefined') ? PAGE_INDEX : [];
  const available = pages.filter(p => !cur.includes(p.page));
  
  // Afficher modal avec liste des pages disponibles
  const modalHtml = `<div id="dash-add-modal" style="position:fixed; inset:0; background:rgba(0,0,0,0.7); z-index:9999; display:flex; align-items:flex-end;" onclick="if(event.target===this)closeDashAdd()">
    <div style="background:var(--bg); width:100%; max-height:80vh; border-radius:20px 20px 0 0; padding:20px; overflow-y:auto;">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:14px;">
        <h3 style="font-size:16px; font-weight:700; margin:0;">+ Ajouter un raccourci</h3>
        <button onclick="closeDashAdd()" style="background:none; border:none; font-size:24px; cursor:pointer; color:var(--text);">✗</button>
      </div>
      <input type="text" class="input" id="dash-search" placeholder="🔍 Chercher..." oninput="dashFilterAdd(this.value)" style="margin-bottom:10px;">
      <div id="dash-add-list" style="max-height:60vh; overflow-y:auto;"></div>
    </div>
  </div>`;
  
  const div = document.createElement('div');
  div.innerHTML = modalHtml;
  document.body.appendChild(div.firstElementChild);
  
  dashFilterAdd('');
  setTimeout(() => document.getElementById('dash-search')?.focus(), 100);
}

function dashFilterAdd(q) {
  const cur = getDashShortcuts();
  const pages = (typeof PAGE_INDEX !== 'undefined') ? PAGE_INDEX : [];
  const ql = (q || '').toLowerCase();
  const list = pages.filter(p => 
    !cur.includes(p.page) && 
    (!ql || (p.name||'').toLowerCase().includes(ql) || (p.kw||'').toLowerCase().includes(ql) || (p.cat||'').toLowerCase().includes(ql))
  );
  
  // Grouper par catégorie
  const grouped = {};
  list.forEach(p => {
    const cat = p.cat || 'Autres';
    if (!grouped[cat]) grouped[cat] = [];
    grouped[cat].push(p);
  });
  
  let html = '';
  Object.entries(grouped).forEach(([cat, items]) => {
    html += `<div style="font-size:11px; color:var(--primary); font-weight:700; text-transform:uppercase; letter-spacing:1px; margin:10px 0 4px;">${escapeHtml(cat)}</div>`;
    items.forEach(p => {
      html += `<div onclick="dashConfirmAdd('${p.page}')" style="display:flex; gap:10px; align-items:center; padding:10px 12px; background:var(--surface); border-radius:8px; margin-bottom:4px; cursor:pointer;">
        <div style="font-size:20px;">${p.ico || '·'}</div>
        <div style="flex:1; font-size:13px; font-weight:600;">${escapeHtml(p.name)}</div>
        <div style="font-size:18px; color:var(--primary);">+</div>
      </div>`;
    });
  });
  
  if (!html) html = '<p style="text-align:center; color:var(--textSec); padding:30px;">Aucune fonctionnalité trouvée</p>';
  
  document.getElementById('dash-add-list').innerHTML = html;
}

function dashConfirmAdd(id) {
  const shortcuts = getDashShortcuts();
  if (shortcuts.length >= 12) {
    if (!confirm('T\'as déjà 12 raccourcis. Continuer ?')) return;
  }
  shortcuts.push(id);
  saveDashShortcuts(shortcuts);
  closeDashAdd();
  renderDashShortcuts();
  toast('✓ Raccourci ajouté');
}

function closeDashAdd() {
  const m = document.getElementById('dash-add-modal');
  if (m) m.remove();
}

async function renderDashQuick() {
  const wrap = document.getElementById('dash-quick');
  if (!wrap) return;
  let cards = [];
  const today = todayKey();
  
  // Devoirs urgents
  try {
    const hw = (await dbAll('homework')) || [];
    const urgent = hw.filter(h => !h.done && h.due && h.due <= today);
    if (urgent.length) cards.push({
      ico:'📝', label:`${urgent.length} devoir${urgent.length>1?'s':''} urgent${urgent.length>1?'s':''}`,
      val: urgent[0].title.slice(0, 22), color:'#FF4757', route:'homework'
    });
  } catch {}
  
  // Hydratation
  try {
    const hyd = JSON.parse(localStorage.getItem('nw_hydra') || '{}')[today] || 0;
    const goal = parseInt(localStorage.getItem('nw_hydra_goal') || 2000);
    const pct = Math.round((hyd/goal)*100);
    cards.push({
      ico:'💧', label:'Hydratation',
      val:`${pct}%`, color: pct >= 100 ? '#5DD68F' : '#5DADE2', route:'hydra'
    });
  } catch {}
  
  // Habitudes
  try {
    const habits = (await dbAll('habits')) || [];
    if (habits.length) {
      const logs = (await dbAll('habit_logs')) || [];
      const todayLogs = logs.filter(l => l.date === today).map(l => l.habit_id);
      const done = habits.filter(h => todayLogs.includes(h.id)).length;
      cards.push({
        ico:'🎯', label:'Habitudes',
        val:`${done}/${habits.length}`, color: done === habits.length ? '#5DD68F' : '#FFD166', route:'habits'
      });
    }
  } catch {}
  
  // Bac countdown
  try {
    const bd = localStorage.getItem('nw_bac_date');
    if (bd) {
      const t = new Date(bd); t.setHours(0,0,0,0);
      const n = new Date(); n.setHours(0,0,0,0);
      const days = Math.floor((t-n)/86400000);
      if (days > 0) cards.push({ ico:'🎓', label:'Bac dans', val:`${days}j`, color:'#A78BFA', route:'home' });
    }
  } catch {}
  
  // Limiter à 4 cartes
  cards = cards.slice(0, 4);
  
  if (!cards.length) {
    wrap.innerHTML = `<div style="grid-column:1/-1; background:var(--surface); padding:18px; border-radius:14px; text-align:center;">
      <div style="font-size:32px;">📊</div>
      <div style="font-size:12px; color:var(--textSec); margin-top:6px;">Aucune donnée à afficher</div>
      <div style="font-size:11px; color:var(--textSec); margin-top:2px;">Configure tes habitudes, devoirs, etc. pour voir tes stats ici</div>
    </div>`;
    return;
  }
  
  wrap.innerHTML = cards.map(c => `<div onclick="goTo('${c.route}')" style="background:var(--surface); border-left:4px solid ${c.color}; padding:12px; border-radius:10px; cursor:pointer;">
    <div style="display:flex; gap:6px; align-items:center;">
      <div style="font-size:22px;">${c.ico}</div>
      <div style="font-size:10px; color:var(--textSec); font-weight:600;">${escapeHtml(c.label)}</div>
    </div>
    <div style="font-size:18px; font-weight:800; color:${c.color}; margin-top:4px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${escapeHtml(c.val)}</div>
  </div>`).join('');
}

function renderDashInspire() {
  const wrap = document.getElementById('dash-inspire');
  if (!wrap) return;
  // Soit citation soit compliment soit mentor selon le jour
  const today = todayKey();
  const seed = parseInt(today.replace(/-/g,''));
  const choice = seed % 3;
  
  let html = '';
  if (choice === 0 && typeof CITATIONS !== 'undefined' && CITATIONS.length) {
    const c = CITATIONS[seed % CITATIONS.length];
    html = `<div onclick="goTo('quotes')" style="background:linear-gradient(135deg, var(--primary), var(--accent)); color:white; padding:16px; border-radius:14px; cursor:pointer;">
      <div style="font-size:11px; opacity:0.85; text-transform:uppercase; letter-spacing:1.5px;">💭 Citation du jour</div>
      <p style="font-style:italic; font-size:13px; line-height:1.5; margin-top:8px;">« ${escapeHtml(c.texte)} »</p>
      <div style="font-size:11px; text-align:right; opacity:0.85; margin-top:4px;">— ${escapeHtml(c.auteur)}</div>
    </div>`;
  } else if (choice === 1 && typeof COMPLIMENTS !== 'undefined') {
    const txt = COMPLIMENTS[seed % COMPLIMENTS.length];
    html = `<div onclick="goTo('compliment')" style="background:linear-gradient(135deg, #FFB6D9, #FF6FA3); color:white; padding:16px; border-radius:14px; cursor:pointer;">
      <div style="font-size:11px; opacity:0.85; text-transform:uppercase; letter-spacing:1.5px;">💕 Compliment</div>
      <p style="font-size:14px; line-height:1.5; margin-top:8px; font-style:italic; font-weight:600;">${escapeHtml(txt)}</p>
    </div>`;
  } else if (typeof MENTORS !== 'undefined') {
    const m = MENTORS[seed % MENTORS.length];
    html = `<div onclick="goTo('mentor')" style="background:linear-gradient(135deg, #FF4757, #1A1A1A); color:white; padding:16px; border-radius:14px; cursor:pointer;">
      <div style="font-size:11px; opacity:0.85; text-transform:uppercase; letter-spacing:1.5px;">🎯 Mentor du jour</div>
      <p style="font-size:13px; line-height:1.5; margin-top:8px; font-style:italic;">« ${escapeHtml(m.txt)} »</p>
      <div style="font-size:11px; text-align:right; color:#FFD700; font-weight:700; margin-top:4px;">— ${escapeHtml(m.auteur)}</div>
    </div>`;
  }
  wrap.innerHTML = html;
}



