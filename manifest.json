      <button class="btn alt" onclick="pedoQuickAdd(2000)" style="flex:1; padding:6px; font-size:11px;">+2000</button>
      <button class="btn alt" onclick="pedoQuickAdd(5000)" style="flex:1; padding:6px; font-size:11px;">+5000</button>
