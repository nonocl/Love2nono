const V53_ES_PRONOUNS = ['yo','tú','él/ella','nosotros','vosotros','ellos'];
function renderConjugEs() {
  let html = `<div style="background:linear-gradient(135deg,#FFD166,#E14D6B); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🇪🇸</div><div style="font-size:16px; font-weight:800;">Conjugador español</div>
  </div>
  <input type="text" id="ces-verb" class="input" placeholder="Verbo (hablar, comer, vivir, ser, ir...)" oninput="cesConj()" style="margin-top:14px;" autocomplete="off">
  <div id="ces-result" style="margin-top:14px;"></div>`;
  document.getElementById('conjuges-content').innerHTML = html;
}
function cesConj() {
  const v = document.getElementById('ces-verb').value.trim().toLowerCase();
  if (!v) { document.getElementById('ces-result').innerHTML = ''; return; }
  let conj;
  if (V53_ES_IRREG[v]) { conj = V53_ES_IRREG[v]; }
  else if (v.endsWith('ar') || v.endsWith('er') || v.endsWith('ir')) {
    const ending = v.slice(-2);
    const stem = v.slice(0, -2);
    const tmpl = V53_ES_VERBS[ending];
    conj = {};
    for (const t in tmpl) conj[t] = tmpl[t].map(s => stem + s);
  } else { document.getElementById('ces-result').innerHTML = '<div style="background:var(--surface); padding:14px; border-radius:12px; color:var(--textSec); font-size:12px;">Verbo no reconocido. Prueba -ar/-er/-ir o irregular.</div>'; return; }
  let html = '';
  const labels = { presente: 'Presente', imperfecto: 'Imperfecto', indefinido: 'Pretérito indefinido', futuro: 'Futuro', condicional: 'Condicional' };
  for (const t in labels) {
    if (!conj[t]) continue;
    html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px;"><div style="font-size:11px; font-weight:700; color:var(--primary); margin-bottom:4px;">${labels[t]}</div>`;
