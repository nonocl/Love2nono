// JEU: TETRIS
// ============================================================
const TETRIS_COLS = 10, TETRIS_ROWS = 20;
const TETRIS_PIECES = {
  I: { shape: [[1,1,1,1]], color: '#5DD6E5' },
  O: { shape: [[1,1],[1,1]], color: '#FFD166' },
  T: { shape: [[0,1,0],[1,1,1]], color: '#C77DFF' },
  S: { shape: [[0,1,1],[1,1,0]], color: '#5DD68F' },
  Z: { shape: [[1,1,0],[0,1,1]], color: '#FF6B7A' },
  L: { shape: [[1,0],[1,0],[1,1]], color: '#FF8C42' },
  J: { shape: [[0,1],[0,1],[1,1]], color: '#5B8DEF' },
};
let _tetris = null;
let _tetrisInterval = null;

async function initTetris() {
  if (_tetrisInterval) clearInterval(_tetrisInterval);
  const best = await getScore('tetris');
  _tetris = {
    board: Array.from({length:TETRIS_ROWS}, () => Array(TETRIS_COLS).fill(0)),
    piece: null, x:0, y:0, rotation:0,
    score:0, lines:0, best: best?best.value:0, running:false
  };
  document.getElementById('tetris-best').textContent = _tetris.best;
  document.getElementById('tetris-score').textContent = '0';
  document.getElementById('tetris-lines').textContent = '0';
  document.getElementById('tetris-play-btn').textContent = '▶ Démarrer';
  spawnTetrisPiece();
  drawTetris();
}

function tetrisStartPause() {
  if (!_tetris) initTetris();
  if (_tetris.running) {
    _tetris.running = false; clearInterval(_tetrisInterval); _tetrisInterval = null;
    document.getElementById('tetris-play-btn').textContent = '▶ Reprendre';
  } else {
    _tetris.running = true;
    document.getElementById('tetris-play-btn').textContent = '⏸ Pause';
    _tetrisInterval = setInterval(tetrisTick, 600);
  }
}

function spawnTetrisPiece() {
  const keys = Object.keys(TETRIS_PIECES);
  const k = keys[Math.floor(Math.random()*keys.length)];
  _tetris.piece = TETRIS_PIECES[k].shape.map(r=>r.slice());
  _tetris.color = TETRIS_PIECES[k].color;
  _tetris.x = Math.floor(TETRIS_COLS/2) - Math.floor(_tetris.piece[0].length/2);
  _tetris.y = 0;
  if (tetrisCollision(_tetris.piece, _tetris.x, _tetris.y)) {
    // Game over
    _tetris.running = false;
    clearInterval(_tetrisInterval); _tetrisInterval = null;
    document.getElementById('tetris-play-btn').textContent = '▶ Rejouer';
    if (_tetris.score > _tetris.best) { setScore('tetris', _tetris.score); _tetris.best = _tetris.score; document.getElementById('tetris-best').textContent = _tetris.best; }
    setTimeout(() => alert(`Game Over ! Score: ${_tetris.score}`), 200);
  }
}

function tetrisCollision(piece, x, y) {
  for (let r=0; r<piece.length; r++) for (let c=0; c<piece[r].length; c++) {
    if (!piece[r][c]) continue;
    const nr = y + r, nc = x + c;
    if (nr >= TETRIS_ROWS || nc < 0 || nc >= TETRIS_COLS) return true;
    if (nr >= 0 && _tetris.board[nr][nc]) return true;
  }
  return false;
}

function tetrisMove(dx) {
  if (!_tetris || !_tetris.piece) return;
  if (!tetrisCollision(_tetris.piece, _tetris.x + dx, _tetris.y)) {
    _tetris.x += dx; drawTetris();
  }
}

function tetrisRot() {
  if (!_tetris || !_tetris.piece) return;
  // Rotate clockwise
  const p = _tetris.piece;
  const rotated = Array.from({length: p[0].length}, (_,i) => p.map(row => row[i]).reverse());
  if (!tetrisCollision(rotated, _tetris.x, _tetris.y)) {
    _tetris.piece = rotated; drawTetris();
  }
}

function tetrisDrop() {
  if (!_tetris || !_tetris.piece) return;
  while (!tetrisCollision(_tetris.piece, _tetris.x, _tetris.y + 1)) {
    _tetris.y++;
  }
  tetrisLockPiece();
}

function tetrisTick() {
  if (!tetrisCollision(_tetris.piece, _tetris.x, _tetris.y + 1)) {
    _tetris.y++;
  } else {
    tetrisLockPiece();
  }
  drawTetris();
}

function tetrisLockPiece() {
  for (let r=0; r<_tetris.piece.length; r++) for (let c=0; c<_tetris.piece[r].length; c++) {
    if (_tetris.piece[r][c]) {
      const nr = _tetris.y + r, nc = _tetris.x + c;
      if (nr >= 0) _tetris.board[nr][nc] = _tetris.color;
    }
  }
  // Clear lines
  let cleared = 0;
  for (let r=TETRIS_ROWS-1; r>=0; r--) {
    if (_tetris.board[r].every(v => v !== 0)) {
      _tetris.board.splice(r, 1);
      _tetris.board.unshift(Array(TETRIS_COLS).fill(0));
      cleared++;
      r++;
    }
  }
  if (cleared > 0) {
    _tetris.lines += cleared;
    _tetris.score += [0, 100, 300, 500, 800][cleared] || 1000;
    document.getElementById('tetris-score').textContent = _tetris.score;
    document.getElementById('tetris-lines').textContent = _tetris.lines;
    if (_tetris.score > _tetris.best) { setScore('tetris', _tetris.score); _tetris.best = _tetris.score; document.getElementById('tetris-best').textContent = _tetris.best; }
  }
  spawnTetrisPiece();
}

function drawTetris() {
  const c = document.getElementById('tetris-canvas');
  if (!c || !_tetris) return;
  const ctx = c.getContext('2d');
  const cs = c.width / TETRIS_COLS;
  ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--surfaceAlt').trim();
  ctx.fillRect(0, 0, c.width, c.height);
  // Board
  for (let r=0; r<TETRIS_ROWS; r++) for (let col=0; col<TETRIS_COLS; col++) {
    if (_tetris.board[r][col]) {
      ctx.fillStyle = _tetris.board[r][col];
      ctx.fillRect(col*cs+1, r*cs+1, cs-2, cs-2);
    }
  }
  // Current piece
  if (_tetris.piece) {
    ctx.fillStyle = _tetris.color;
    for (let r=0; r<_tetris.piece.length; r++) for (let col=0; col<_tetris.piece[r].length; col++) {
      if (_tetris.piece[r][col]) {
        const nr = _tetris.y + r, nc = _tetris.x + col;
        if (nr >= 0) ctx.fillRect(nc*cs+1, nr*cs+1, cs-2, cs-2);
      }
    }
  }
}

