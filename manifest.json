  document.getElementById('ttt-content').innerHTML = html;
  tttStart();
}
function tttStart() { _tttState = { b: Array(9).fill(''), turn: 'X', over: false }; tttRender(); }
function tttRender() {
  let html = '<div style="display:grid; grid-template-columns:repeat(3,1fr); gap:4px; max-width:300px; margin:0 auto;">';
  _tttState.b.forEach((c, i) => {
    const color = c === 'X' ? '#5DADE2' : '#FF6FA3';
    html += `<button onclick="tttPlay(${i})" style="aspect-ratio:1; background:var(--surface); border:2px solid var(--border); border-radius:10px; font-size:48px; font-weight:900; color:${color};">${c}</button>`;
  });
  html += '</div>';
  document.getElementById('ttt-board').innerHTML = html;
}
function tttCheck(b) {
  const lines = [[0,1,2],[3,4,5],[6,7,8],[0,3,6],[1,4,7],[2,5,8],[0,4,8],[2,4,6]];
  for (const [a,c,d] of lines) if (b[a] && b[a] === b[c] && b[c] === b[d]) return b[a];
  if (b.every(x => x)) return 'tie';
  return null;
}
function tttPlay(i) {
  if (_tttState.over || _tttState.b[i] || _tttState.turn !== 'X') return;
  _tttState.b[i] = 'X'; _tttState.turn = 'O'; tttRender();
  const w = tttCheck(_tttState.b);
  if (w) { _tttState.over = true; document.getElementById('ttt-status').textContent = w === 'tie' ? '🤝 Égalité' : (w === 'X' ? '🏆 Tu gagnes !' : '💀 IA gagne'); return; }
  setTimeout(() => {
    // IA simple : essayer de gagner > bloquer > prendre centre > random
    function findWin(p) {
      for (let i = 0; i < 9; i++) if (!_tttState.b[i]) {
        const tmp = _tttState.b.slice(); tmp[i] = p;
        if (tttCheck(tmp) === p) return i;
      }
      return -1;
    }
    let move = findWin('O');
    if (move === -1) move = findWin('X'); // bloquer
    if (move === -1 && !_tttState.b[4]) move = 4;
    if (move === -1) {
      const empties = _tttState.b.map((c,i) => c?-1:i).filter(x => x !== -1);
      move = empties[Math.floor(Math.random()*empties.length)];
    }
    _tttState.b[move] = 'O'; _tttState.turn = 'X'; tttRender();
    const w2 = tttCheck(_tttState.b);
    if (w2) { _tttState.over = true; document.getElementById('ttt-status').textContent = w2 === 'tie' ? '🤝 Égalité' : (w2 === 'X' ? '🏆 Tu gagnes !' : '💀 IA gagne'); }
    else document.getElementById('ttt-status').textContent = 'À toi (X) ✊';
  }, 400);
}

