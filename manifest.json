// === COMMAND PALETTE OVERLAY ===
let _cmdSelectedIdx = 0;
let _cmdResults = [];

function openCmdPalette() {
  let pal = document.getElementById('cmd-palette');
  if (!pal) {
    pal = document.createElement('div');
    pal.id = 'cmd-palette';
    pal.className = 'cmd-palette';
    pal.innerHTML = `
      <div class="cmd-palette-box" onclick="event.stopPropagation()">
        <div class="cmd-palette-input-wrap">
          <span style="font-size:18px;">🔍</span>
          <input type="text" class="cmd-palette-input" id="cmd-input" placeholder="Tape pour chercher tout (max 285 features)..." autocomplete="off" autocorrect="off" spellcheck="false">
          <span class="cmd-palette-kbd">esc</span>
        </div>
        <div class="cmd-palette-results" id="cmd-results"></div>
        <div class="cmd-palette-footer">
          <span><kbd>↑↓</kbd> naviguer</span>
          <span><kbd>↵</kbd> ouvrir</span>
          <span><kbd>esc</kbd> fermer</span>
        </div>
      </div>
    `;
    pal.onclick = (e) => { if (e.target === pal) closeCmdPalette(); };
    document.body.appendChild(pal);
  }
  pal.classList.add('open');
  const inp = document.getElementById('cmd-input');
  inp.value = '';
  inp.focus();
  _cmdSelectedIdx = 0;
  cmdRender();
  
  // Attach keyboard handlers
  inp.onkeydown = (e) => {
    if (e.key === 'Escape') { e.preventDefault(); closeCmdPalette(); }
    else if (e.key === 'ArrowDown') {
      e.preventDefault();
      _cmdSelectedIdx = Math.min(_cmdResults.length - 1, _cmdSelectedIdx + 1);
      cmdRefreshSelected();
    }
    else if (e.key === 'ArrowUp') {
      e.preventDefault();
      _cmdSelectedIdx = Math.max(0, _cmdSelectedIdx - 1);
      cmdRefreshSelected();
    }
    else if (e.key === 'Enter') {
      e.preventDefault();
      if (_cmdResults[_cmdSelectedIdx]) {
        cmdGoTo(_cmdResults[_cmdSelectedIdx].page);
      }
    }
  };
  inp.oninput = () => { _cmdSelectedIdx = 0; cmdRender(); };
}

function closeCmdPalette() {
  const pal = document.getElementById('cmd-palette');
  if (pal) pal.classList.remove('open');
}

// Fuzzy search scoring
function fuzzyScore(item, query) {
  const q = query.toLowerCase().trim();
  if (!q) return 1;
  const name = (item.name || '').toLowerCase();
  const cat = (item.cat || '').toLowerCase();
  const kw = (item.kw || '').toLowerCase();
  const ico = item.ico || '';
  const haystack = `${name} ${cat} ${kw}`;
  
  // Exact match in name
  if (name === q) return 1000;
  // Starts with
  if (name.startsWith(q)) return 800;
  // Word boundary
  const words = name.split(/\s+/);
  if (words.some(w => w.startsWith(q))) return 600;
  // Includes anywhere in name
  if (name.includes(q)) return 500;
  // Match in cat
  if (cat.includes(q)) return 300;
  // Match in keywords
  if (kw.includes(q)) return 250;
  // Fuzzy: all chars present in order
  let i = 0;
  for (const c of haystack) {
    if (c === q[i]) i++;
    if (i === q.length) break;
  }
  if (i === q.length) return 100;
  return 0;
}

function highlightMatch(text, query) {
  if (!query) return escapeHtml(text);
  const q = query.toLowerCase().trim();
  const lower = text.toLowerCase();
  const idx = lower.indexOf(q);
  if (idx === -1) return escapeHtml(text);
  return escapeHtml(text.slice(0, idx)) + 
         '<mark class="fuzzy-match">' + escapeHtml(text.slice(idx, idx + q.length)) + '</mark>' + 
         escapeHtml(text.slice(idx + q.length));
}

function cmdRender() {
  const inp = document.getElementById('cmd-input');
  const q = inp ? inp.value : '';
  const pages = (typeof PAGE_INDEX !== 'undefined') ? PAGE_INDEX : [];
  
  // Score and sort
  const scored = pages.map(p => ({...p, _score: fuzzyScore(p, q)}))
                     .filter(p => p._score > 0)
                     .sort((a, b) => b._score - a._score);
  
  // Show recent first if no query
  if (!q.trim()) {
    let recent = [];
    try { recent = JSON.parse(localStorage.getItem('nw_recent') || '[]'); } catch {}
    const recentPages = recent.slice(0, 8).map(id => pages.find(p => p.page === id)).filter(Boolean);
    const others = pages.filter(p => !recent.includes(p.page));
    _cmdResults = [...recentPages, ...others].slice(0, 50);
  } else {
    _cmdResults = scored.slice(0, 30);
  }
  
  const out = document.getElementById('cmd-results');
  if (!out) return;
  
  if (!_cmdResults.length) {
    out.innerHTML = '<div class="cmd-result-empty">😶 Aucun résultat pour "' + escapeHtml(q) + '"</div>';
    return;
  }
  
  let recentSet = [];
  if (!q.trim()) {
    try { recentSet = JSON.parse(localStorage.getItem('nw_recent') || '[]').slice(0, 8); } catch {}
  }
  
  let html = '';
  if (!q.trim() && recentSet.length) {
    html += '<div style="font-size:10px; color:var(--textSec); padding:8px 12px 4px; text-transform:uppercase; letter-spacing:1.5px; font-weight:700;">Récents</div>';
  }
  
  _cmdResults.forEach((r, i) => {
    if (!q.trim() && i === recentSet.length && recentSet.length) {
      html += '<div style="font-size:10px; color:var(--textSec); padding:12px 12px 4px; text-transform:uppercase; letter-spacing:1.5px; font-weight:700;">Toutes les fonctionnalités</div>';
    }
    html += `<div class="cmd-result ${i === _cmdSelectedIdx ? 'selected' : ''}" data-idx="${i}" onclick="cmdGoTo('${r.page}')">
      <div class="cmd-result-ico">${r.ico}</div>
      <div class="cmd-result-text">
        <div class="cmd-result-name">${highlightMatch(r.name, q)}</div>
        <div class="cmd-result-cat">${escapeHtml(r.cat)}</div>
      </div>
      <span class="cmd-result-action">↵ ouvrir</span>
    </div>`;
  });
  out.innerHTML = html;
  
  // Scroll to selected
  setTimeout(() => {
    const sel = out.querySelector('.cmd-result.selected');
    if (sel) sel.scrollIntoView({ block: 'nearest' });
  }, 0);
}

function cmdRefreshSelected() {
  document.querySelectorAll('.cmd-result').forEach((el, i) => {
    el.classList.toggle('selected', i === _cmdSelectedIdx);
  });
  const sel = document.querySelector('.cmd-result.selected');
  if (sel) sel.scrollIntoView({ block: 'nearest' });
}

function cmdGoTo(page) {
  closeCmdPalette();
  goTo(page);
}

// Track recent pages
function trackRecent(page) {
  if (!page || page === 'home') return;
  let recent = [];
  try { recent = JSON.parse(localStorage.getItem('nw_recent') || '[]'); } catch {}
  recent = recent.filter(p => p !== page);
  recent.unshift(page);
  recent = recent.slice(0, 30);
  localStorage.setItem('nw_recent', JSON.stringify(recent));
}

// Hook into goTo
const _v42origGoTo = window.goTo;
if (_v42origGoTo && !window._goToHooked) {
  window._goToHooked = true;
  window.goTo = function(page) {
    try { if (typeof trackRecent === 'function') trackRecent(page); } catch(e) { console.warn('trackRecent err', e); }
    return _v42origGoTo.apply(this, arguments);
  };
}

// === KEYBOARD SHORTCUTS GLOBAL ===
document.addEventListener('keydown', (e) => {
  // Cmd/Ctrl + K -> command palette
  if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
    e.preventDefault();
    openCmdPalette();
  }
  // / -> command palette (no input focused)
  if (e.key === '/' && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
    e.preventDefault();
    openCmdPalette();
  }
});

// === SWIPE GESTURES (back navigation) ===
let _swipeStartX = null, _swipeStartY = null, _swipeStartT = null;
let _swipeIndicator = null;

document.addEventListener('touchstart', (e) => {
  if (e.touches.length !== 1) return;
  // Only edge swipe (left edge for back)
  if (e.touches[0].clientX > 30) return;
  _swipeStartX = e.touches[0].clientX;
  _swipeStartY = e.touches[0].clientY;
  _swipeStartT = Date.now();
}, { passive: true });

document.addEventListener('touchmove', (e) => {
  if (_swipeStartX === null) return;
  const x = e.touches[0].clientX;
  const y = e.touches[0].clientY;
  const dx = x - _swipeStartX;
  const dy = Math.abs(y - _swipeStartY);
  
  if (dx > 30 && dy < 50) {
    // Show indicator
    if (!_swipeIndicator) {
      _swipeIndicator = document.createElement('div');
      _swipeIndicator.className = 'swipe-back-indicator';
      _swipeIndicator.textContent = '‹';
      document.body.appendChild(_swipeIndicator);
    }
    const progress = Math.min(1, dx / 120);
    _swipeIndicator.style.transform = `translate(${(progress - 1) * 100}%, -50%)`;
    _swipeIndicator.style.opacity = progress;
  }
}, { passive: true });

document.addEventListener('touchend', (e) => {
  if (_swipeStartX === null) return;
  const x = e.changedTouches[0].clientX;
  const dx = x - _swipeStartX;
  const dt = Date.now() - _swipeStartT;
  
  if (_swipeIndicator) {
    _swipeIndicator.remove();
    _swipeIndicator = null;
  }
  
  // Trigger back if swipe right > 100px in <600ms (or any width if slow)
  if (dx > 100 && dt < 800) {
    if (typeof goBack === 'function' && state && state.page !== 'home') {
      if (navigator.vibrate) navigator.vibrate(15);
      goBack();
    }
  }
  
  _swipeStartX = null;
  _swipeStartY = null;
  _swipeStartT = null;
}, { passive: true });

// === QUICK SWITCHER (double-tap nav button to toggle 2 last pages) ===
let _lastTapTime = 0;
let _lastTapPage = null;

function quickToggle() {
  const last = window._navHistory && window._navHistory[window._navHistory.length - 1];
  if (last && last !== state.page) {
