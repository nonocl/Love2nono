// === 9. MOOD BOARD ===
function getMoodBoard() { try { return JSON.parse(localStorage.getItem('nw_moodboard') || '[]'); } catch { return []; } }
function saveMoodBoard(d) { localStorage.setItem('nw_moodboard', JSON.stringify(d)); }
function renderMoodBoard() {
  const items = getMoodBoard();
  let html = `<div style="background:linear-gradient(135deg,#FF6FA3,#FFD166,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🎨</div>
    <div style="font-size:16px; font-weight:800;">Mood board</div>
    <div style="font-size:11px; opacity:0.9;">${items.length}/30 items · images, couleurs, mots</div>
  </div>
  <p style="font-size:11px; color:var(--textSec); margin-top:10px;">💡 Tap + pour ajouter image, couleur ou mot. Crée ton mood visuel.</p>`;
  
  if (!items.length) html += '<p style="text-align:center; color:var(--textSec); padding:20px;">Board vide. Tap + pour créer.</p>';
  else {
    html += '<div style="display:grid; grid-template-columns:repeat(3,1fr); gap:6px; margin-top:14px;">';
    items.forEach(it => {
      let content;
      if (it.type === 'image') content = `<img src="${it.data}" style="width:100%; height:100%; object-fit:cover;">`;
      else if (it.type === 'color') content = `<div style="background:${it.data}; width:100%; height:100%;"></div>`;
      else content = `<div style="padding:8px; font-size:13px; font-weight:700; text-align:center; word-break:break-word; height:100%; display:flex; align-items:center; justify-content:center; background:${it.bg||'var(--surface)'}; color:${it.fg||'var(--primary)'};">${escapeHtml(it.data)}</div>`;
      html += `<div style="aspect-ratio:1; border-radius:10px; overflow:hidden; position:relative; cursor:pointer;" onclick="mbDel('${it.id}')">${content}<div style="position:absolute; top:4px; right:4px; background:rgba(0,0,0,0.6); color:white; width:20px; height:20px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:11px;">✗</div></div>`;
    });
    html += '</div>';
  }
  document.getElementById('moodboard-content').innerHTML = html;
}
function mbAdd() {
  const choice = prompt('Type :\n1. Image\n2. Couleur\n3. Mot/Phrase');
  if (!choice) return;
  const items = getMoodBoard();
  if (items.length >= 30) { toast('Max 30 items'); return; }
  if (choice === '1') {
    const inp = document.createElement('input');
    inp.type = 'file'; inp.accept = 'image/*';
    inp.onchange = (e) => {
      const f = e.target.files[0];
      if (!f) return;
      if (f.size > 800*1024) { toast('Max 800Ko'); return; }
      const reader = new FileReader();
      reader.onload = () => {
        items.unshift({ id: 'mb_'+Date.now(), type: 'image', data: reader.result });
        saveMoodBoard(items); renderMoodBoard();
      };
      reader.readAsDataURL(f);
    };
    inp.click();
  } else if (choice === '2') {
    const c = prompt('Couleur (#FF6FA3 ou nom CSS) :', '#FF6FA3');
    if (!c) return;
    items.unshift({ id: 'mb_'+Date.now(), type: 'color', data: c });
    saveMoodBoard(items); renderMoodBoard();
  } else if (choice === '3') {
    const t = prompt('Mot ou phrase courte :');
    if (!t) return;
    const bg = prompt('Couleur fond (optionnel) :', '#FFE0EC') || '#FFE0EC';
    const fg = prompt('Couleur texte :', '#FF1493') || '#FF1493';
    items.unshift({ id: 'mb_'+Date.now(), type: 'word', data: t, bg, fg });
    saveMoodBoard(items); renderMoodBoard();
  }
}
function mbDel(id) {
  if (!confirm('Supprimer ?')) return;
  saveMoodBoard(getMoodBoard().filter(i => i.id !== id));
  renderMoodBoard();
}

// === 10. POLAROID MAKER ===
let _polaroidImg = null;
function renderPolaroid() {
  let html = `<div style="background:linear-gradient(135deg,#FFE0EC,#FFC8DD); color:#4A1A2C; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">📸</div>
    <div style="font-size:16px; font-weight:800;">Polaroid maker</div>
    <div style="font-size:11px;">Transforme ta photo en polaroid vintage</div>
  </div>
  <button class="btn primary full" onclick="polUpload()" style="margin-top:14px;">📸 Choisir une photo</button>
  <span class="label" style="margin-top:14px;">✏️ Légende</span>
  <input type="text" class="input" id="pol-caption" placeholder="best summer ever ✨" oninput="polRender()" maxlength="40">
  <span class="label" style="margin-top:8px;">📅 Date (optionnel)</span>
  <input type="text" class="input" id="pol-date" placeholder="Été 2024" oninput="polRender()" maxlength="20">
  <div id="pol-preview" style="margin-top:18px; text-align:center;"></div>
  <button class="btn primary full" onclick="polDownload()" id="pol-dl-btn" style="margin-top:10px; display:none;">💾 Télécharger</button>`;
  document.getElementById('polaroid-content').innerHTML = html;
  polRender();
}
function polUpload() {
  const inp = document.createElement('input');
  inp.type = 'file'; inp.accept = 'image/*';
  inp.onchange = (e) => {
    const f = e.target.files[0]; if (!f) return;
    const reader = new FileReader();
    reader.onload = () => { _polaroidImg = reader.result; polRender(); };
    reader.readAsDataURL(f);
  };
  inp.click();
}
function polRender() {
  const cap = document.getElementById('pol-caption')?.value || '';
  const dt = document.getElementById('pol-date')?.value || '';
  const el = document.getElementById('pol-preview');
  if (!_polaroidImg) {
    el.innerHTML = `<div style="background:white; padding:14px 14px 60px; border-radius:6px; box-shadow:0 4px 16px rgba(0,0,0,0.2); display:inline-block; max-width:280px; transform:rotate(-2deg);">
      <div style="aspect-ratio:1; background:#E0E0E0; display:flex; align-items:center; justify-content:center; color:#999;">📸 Choisis une photo</div>
    </div>`;
    document.getElementById('pol-dl-btn').style.display = 'none';
    return;
  }
  el.innerHTML = `<div id="pol-card" style="background:white; padding:14px 14px 50px; border-radius:6px; box-shadow:0 4px 20px rgba(0,0,0,0.25); display:inline-block; max-width:280px; transform:rotate(-2deg);">
    <img src="${_polaroidImg}" style="width:100%; aspect-ratio:1; object-fit:cover; display:block;">
    ${cap || dt ? `<div style="margin-top:14px; font-family:'Caveat', cursive, sans-serif; font-size:18px; color:#333; text-align:center;">${escapeHtml(cap)}${dt && cap?'<br>':''}<span style="font-size:14px; color:#999;">${escapeHtml(dt)}</span></div>` : '<div style="margin-top:30px;"></div>'}
  </div>`;
  document.getElementById('pol-dl-btn').style.display = 'block';
}
function polDownload() {
  if (!_polaroidImg) return;
  const cap = document.getElementById('pol-caption')?.value || '';
  const dt = document.getElementById('pol-date')?.value || '';
  // Render to canvas
  const c = document.createElement('canvas');
  c.width = 600; c.height = 700;
  const ctx = c.getContext('2d');
  // White polaroid bg
  ctx.fillStyle = 'white';
  ctx.fillRect(0, 0, c.width, c.height);
  // Image area
  const img = new Image();
  img.onload = () => {
    const padding = 30;
    const imgSize = c.width - 2 * padding;
    ctx.drawImage(img, padding, padding, imgSize, imgSize);
    // Caption
    ctx.fillStyle = '#333';
    ctx.font = '32px cursive, "Caveat", sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(cap, c.width/2, c.height - 100);
    if (dt) {
      ctx.fillStyle = '#999';
      ctx.font = '24px cursive, sans-serif';
      ctx.fillText(dt, c.width/2, c.height - 60);
    }
    c.toBlob(b => {
      const a = document.createElement('a');
      a.href = URL.createObjectURL(b);
      a.download = `polaroid-${Date.now()}.png`;
      a.click();
    });
  };
  img.src = _polaroidImg;
}

