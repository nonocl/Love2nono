  am:'#FF8C42', ae:'#FFD166', tm:'#5DD6E5', pm:'#A78BFA', mt:'#9CA3AF',
  nm:'#7BC47F', hl:'#5B8DEF', gn:'#FF6FA3', la:'#C77DFF', ac:'#FF6B7A'
};
const FAMILY_NAMES = {
  am:'Alcalin', ae:'Alcalino-terreux', tm:'Métal de transition', pm:'Métal pauvre', mt:'Métalloïde',
  nm:'Non-métal', hl:'Halogène', gn:'Gaz noble', la:'Lanthanide', ac:'Actinide'
};
function renderPeriodic() {
  const el = document.getElementById('periodic-grid');
  el.innerHTML = '';
  // Build a 18-col x 9-row grid (lanthanides/actinides go on rows 8-9)
  const grid = document.createElement('div');
  grid.style.cssText = 'display:grid; grid-template-columns:repeat(18, 1fr); gap:1px; max-width:100%; overflow-x:auto;';
  // Place elements
  const positions = {};
  for (const e of ELEMENTS) {
    let row = e[5], col = e[4];
    if (e[6] === 'la') { row = 8; col = 3 + (e[0] - 57); }
    else if (e[6] === 'ac') { row = 9; col = 3 + (e[0] - 89); }
    positions[`${row}-${col}`] = e;
  }
  for (let r=1; r<=9; r++) {
    for (let c=1; c<=18; c++) {
      const e = positions[`${r}-${c}`];
      const cell = document.createElement('button');
      cell.style.cssText = `aspect-ratio:1; padding:0; border:none; font-size:8px; line-height:1.1; cursor:pointer; border-radius:2px; ${e ? `background:${FAMILY_COLORS[e[6]]}; color:white; font-weight:700;` : 'background:transparent;'}`;
      if (e) {
        cell.innerHTML = `<div style="font-size:6px;">${e[0]}</div><div style="font-size:11px; font-weight:900;">${e[1]}</div>`;
        cell.onclick = () => showElement(e);
      }
      grid.appendChild(cell);
    }
  }
  el.appendChild(grid);
  // Legend
  const legend = document.createElement('div');
  legend.style.cssText = 'margin-top:14px; display:flex; flex-wrap:wrap; gap:4px; font-size:10px;';
  for (const [k, name] of Object.entries(FAMILY_NAMES)) {
    legend.insertAdjacentHTML('beforeend', `<span style="background:${FAMILY_COLORS[k]}; color:white; padding:3px 6px; border-radius:6px;">${name}</span>`);
  }
  el.appendChild(legend);
}
function showElement(e) {
  document.getElementById('elem-detail').innerHTML = `
    <div style="text-align:center; padding:20px; background:${FAMILY_COLORS[e[6]]}; border-radius:14px; color:white; margin-bottom:10px;">
      <div style="font-size:14px;">${e[0]}</div>
      <div style="font-size:64px; font-weight:900; line-height:1;">${e[1]}</div>
      <div style="font-size:18px; margin-top:4px;">${e[2]}</div>
      <div style="font-size:12px; margin-top:8px;">${FAMILY_NAMES[e[6]]}</div>
    </div>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; font-size:13px;">
      <div style="background:var(--surfaceAlt); padding:10px; border-radius:8px;"><div style="color:var(--textSec); font-size:10px;">Numéro</div><strong>${e[0]}</strong></div>
      <div style="background:var(--surfaceAlt); padding:10px; border-radius:8px;"><div style="color:var(--textSec); font-size:10px;">Masse atomique</div><strong>${e[3]}</strong></div>
      <div style="background:var(--surfaceAlt); padding:10px; border-radius:8px;"><div style="color:var(--textSec); font-size:10px;">Groupe</div><strong>${e[4]}</strong></div>
      <div style="background:var(--surfaceAlt); padding:10px; border-radius:8px;"><div style="color:var(--textSec); font-size:10px;">Période</div><strong>${e[5]}</strong></div>
    </div>
  `;
  openModal('modal-element');
}

