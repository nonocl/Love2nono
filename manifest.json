}
let _rnHistory = [];
function rnGen() {
  const min = parseInt(document.getElementById('rn-min').value) || 0;
  const max = parseInt(document.getElementById('rn-max').value) || 100;
  if (max < min) { toast('Max < Min'); return; }
  const n = Math.floor(Math.random() * (max - min + 1)) + min;
  document.getElementById('rn-result').textContent = n;
  _rnHistory.unshift(n);
  _rnHistory = _rnHistory.slice(0, 20);
  document.getElementById('rn-history').innerHTML = `<div style="font-size:11px; color:var(--textSec);">Historique :</div><div style="font-size:13px; margin-top:4px;">${_rnHistory.join(' · ')}</div>`;
  if (navigator.vibrate) navigator.vibrate(10);
}

