function getDreams() { try { return JSON.parse(localStorage.getItem('nw_dreams') || '[]'); } catch { return []; } }
function saveDreams(d) { localStorage.setItem('nw_dreams', JSON.stringify(d)); }
function renderDreamJournal() {
  const dreams = getDreams();
  let html = `<div style="background:linear-gradient(135deg,#5DADE2,#5D2E8C); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">💤</div>
    <div style="font-size:16px; font-weight:800;">Journal de rêves</div>
    <div style="font-size:11px; opacity:0.9;">${dreams.length} rêves notés</div>
  </div>
  <p style="font-size:11px; color:var(--textSec); margin-top:10px;">💡 Note ton rêve dès le réveil. Je détecte les symboles courants et te donne leur signification.</p>`;
  
  if (!dreams.length) html += '<p style="text-align:center; color:var(--textSec); padding:20px;">Aucun rêve. Tap + pour ajouter.</p>';
  
  dreams.forEach(dr => {
    const date = new Date(dr.created).toLocaleDateString('fr-FR');
    // Detect symbols
    const text = (dr.title + ' ' + dr.body).toLowerCase();
    const detected = Object.keys(DREAM_SYMBOLS).filter(s => text.includes(s));
    
    html += `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:8px; border-left:3px solid #5DADE2;">
      <div style="display:flex; justify-content:space-between; align-items:flex-start;">
        <div style="flex:1;">
          <div style="font-size:14px; font-weight:700;">💤 ${escapeHtml(dr.title || 'Sans titre')}</div>
          <div style="font-size:10px; color:var(--textSec);">${date}</div>
          <div style="font-size:13px; line-height:1.5; margin-top:6px; white-space:pre-wrap; color:var(--textSec);">${escapeHtml(dr.body)}</div>
          ${detected.length ? `<div style="margin-top:10px; padding-top:10px; border-top:1px dashed var(--border);">
            <div style="font-size:11px; font-weight:700; color:var(--primary); margin-bottom:6px;">✨ Symboles détectés</div>
            ${detected.map(s => `<div style="background:var(--bg); padding:6px 8px; border-radius:6px; margin-top:3px; font-size:11px;"><strong>${escapeHtml(s)}</strong> · ${escapeHtml(DREAM_SYMBOLS[s])}</div>`).join('')}
          </div>` : ''}
        </div>
        <button onclick="dreamDel('${dr.id}')" style="background:none; border:none; color:var(--danger); font-size:18px;">✗</button>
      </div>
    </div>`;
  });
  document.getElementById('dreamjournal-content').innerHTML = html;
}
function dreamAdd() {
  const title = prompt('Titre du rêve (court) :');
  if (!title) return;
  const body = prompt('Raconte ton rêve :');
  if (!body) return;
  const dreams = getDreams();
  dreams.unshift({ id: 'dr_'+Date.now(), title, body, created: Date.now() });
  saveDreams(dreams); renderDreamJournal();
}
function dreamDel(id) {
  if (!confirm('Supprimer ce rêve ?')) return;
  saveDreams(getDreams().filter(d => d.id !== id));
  renderDreamJournal();
}

