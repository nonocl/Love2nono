const EXP_CATS = {
  food: { label:'🍔 Nourriture', color:'#FF8C42' },
  fun: { label:'🎮 Loisirs', color:'#7B61FF' },
  clothes: { label:'👕 Vêtements', color:'#FF6FA3' },
  transport: { label:'🚌 Transport', color:'#5B8DEF' },
  school: { label:'📚 Scolaire', color:'#5DD68F' },
  gift: { label:'🎁 Cadeau', color:'#C77DFF' },
  other: { label:'💼 Autre', color:'#9CA3AF' },
};
let _editingExpense = null;

async function renderExpenses() {
  const exps = await dbAll('expenses');
  const now = new Date();
  const yyyy = now.getFullYear(), mm = now.getMonth();
  document.getElementById('exp-month-label').textContent = now.toLocaleDateString('fr-FR', {month:'long', year:'numeric'});
  // This month
  const thisMonth = exps.filter(e => {
    const d = new Date(e.date);
    return d.getFullYear() === yyyy && d.getMonth() === mm;
  });
  const total = thisMonth.reduce((s,e)=>s+e.amount, 0);
  document.getElementById('exp-total').textContent = total.toFixed(2) + ' €';
  // By cat
  const byCat = {};
  for (const e of thisMonth) {
    byCat[e.cat] = (byCat[e.cat] || 0) + e.amount;
  }
  const el = document.getElementById('exp-by-cat');
  el.innerHTML = '';
  if (Object.keys(byCat).length === 0) {
    el.innerHTML = '<p style="color:var(--textSec); font-size:13px; text-align:center;">Pas de dépense ce mois-ci</p>';
  }
  for (const [cat, amt] of Object.entries(byCat).sort((a,b)=>b[1]-a[1])) {
    const meta = EXP_CATS[cat] || EXP_CATS.other;
    const pct = (amt / total) * 100;
    const row = document.createElement('div');
    row.style.cssText = 'margin-bottom:8px;';
    row.innerHTML = `
      <div style="display:flex; justify-content:space-between; font-size:13px; margin-bottom:4px;">
        <span>${meta.label}</span>
        <span style="font-weight:700;">${amt.toFixed(2)} €</span>
      </div>
      <div style="height:8px; background:var(--surfaceAlt); border-radius:4px; overflow:hidden;">
        <div style="height:100%; background:${meta.color}; width:${pct}%;"></div>
      </div>
    `;
    el.appendChild(row);
  }
  // Recent list
  const list = document.getElementById('exp-list');
  list.innerHTML = '';
  exps.sort((a,b) => (b.date||'').localeCompare(a.date||''));
  if (exps.length === 0) {
    list.innerHTML = `<div class="empty"><div class="icon">💰</div><h3>Aucune dépense</h3><p>Track tes dépenses pour mieux gérer ton budget.</p></div>`;
    return;
  }
  for (const e of exps.slice(0, 50)) {
    const meta = EXP_CATS[e.cat] || EXP_CATS.other;
    const row = document.createElement('button');
    row.style.cssText = 'display:flex; align-items:center; gap:10px; padding:10px 14px; background:var(--surface); border-radius:12px; margin-bottom:4px; width:100%; text-align:left;';
    row.innerHTML = `
      <div style="width:8px; height:32px; background:${meta.color}; border-radius:4px;"></div>
      <div style="flex:1; min-width:0;">
        <div style="font-size:14px; font-weight:600;">${escapeHtml(e.name||'(sans nom)')}</div>
        <div style="font-size:11px; color:var(--textSec);">${meta.label} · ${e.date ? new Date(e.date).toLocaleDateString('fr-FR') : ''}</div>
      </div>
      <div style="font-size:15px; font-weight:700; color:var(--primary);">${e.amount.toFixed(2)} €</div>
    `;
    row.onclick = () => openExpenseModal(e);
    list.appendChild(row);
  }
}

