  <button class="btn primary full" onclick="urlScannerCheck()" style="margin-top:10px; padding:14px;">🔍 Scanner</button>
  <div id="urlsc-result" style="margin-top:14px;"></div>`;
  document.getElementById('urlscanner-content').innerHTML = html;
}
function urlScannerPaste() {
  navigator.clipboard.readText().then(t => { document.getElementById('urlsc-input').value = t; urlScannerCheck(); }).catch(() => toast('Erreur'));
}
function urlScannerExample() {
  const examples = ['https://amaz0n-secure-login.tk/verify', 'https://laposte-colis-bloque.fr', 'https://www.google.com', 'https://192.168.1.1/admin', 'https://раураl.com/signin', 'https://impots-gouv-rembourse.cn/form'];
  document.getElementById('urlsc-input').value = examples[Math.floor(Math.random() * examples.length)];
  urlScannerCheck();
}
function urlScannerCheck() {
  const raw = document.getElementById('urlsc-input').value.trim();
  if (!raw) { document.getElementById('urlsc-result').innerHTML = ''; return; }
  
  const flags = [];
  const oks = [];
  let url, urlObj;
  
  // Parse URL
  url = raw;
  if (!url.match(/^https?:\/\//i)) url = 'https://' + url;
  try {
    urlObj = new URL(url);
  } catch (e) {
    document.getElementById('urlsc-result').innerHTML = `<div style="background:#E14D6B; color:white; padding:14px; border-radius:12px;">❌ URL invalide</div>`;
    return;
  }
  
  const host = urlObj.hostname.toLowerCase();
  const proto = urlObj.protocol.slice(0, -1);
  
  // CHECK 1: HTTPS
  if (proto === 'http') flags.push({ sev: 'med', msg: '⚠️ Connexion non chiffrée (HTTP)', detail: 'Le site n\'utilise pas HTTPS, tes données peuvent être interceptées' });
  else oks.push('🔒 HTTPS chiffré');
  
  // CHECK 2: IP au lieu de domaine
  if (/^\d+\.\d+\.\d+\.\d+$/.test(host)) flags.push({ sev: 'high', msg: '🚨 IP brute au lieu de domaine', detail: 'Très suspect, les vrais sites ont un nom de domaine' });
  
  // CHECK 3: Sous-domaines excessifs
  const parts = host.split('.');
  if (parts.length > 4) flags.push({ sev: 'med', msg: `⚠️ ${parts.length - 1} sous-domaines (suspect)`, detail: 'Les phishings utilisent souvent ex: paypal.fake-domain.evil.tk' });
  
  // CHECK 4: TLDs suspects
  const suspicious_tlds = ['.tk', '.ml', '.ga', '.cf', '.gq', '.xyz', '.top', '.click', '.icu', '.cn'];
  for (const tld of suspicious_tlds) {
    if (host.endsWith(tld)) {
      flags.push({ sev: 'high', msg: `🚨 TLD suspect (${tld})`, detail: 'Domaine gratuit ou souvent associé à du phishing/spam' });
      break;
    }
  }
  
  // CHECK 5: Typosquat (homoglyphes / typos sur marques connues)
  for (const brand of KNOWN_BRANDS) {
    if (host.includes(brand)) {
      // Exact match: ok
      const root = host.replace(/^www\./, '').split('.')[0];
      if (root === brand || host.endsWith('.' + brand + '.com') || host.endsWith('.' + brand + '.fr')) {
        oks.push(`✓ Marque reconnue : ${brand}`);
      } else if (host.includes(brand + '-') || host.includes('-' + brand)) {
        flags.push({ sev: 'high', msg: `🚨 "${brand}" mais pas le vrai domaine`, detail: `Probable typosquat. Le vrai site est ${brand}.com ou .fr` });
      }
    }
    // Détection de typo (1 lettre swap)
    const variants = makeTyposquats(brand);
    for (const v of variants) {
      if (host.includes(v) && !host.includes(brand)) {
        flags.push({ sev: 'high', msg: `🚨 Typosquat de "${brand}"`, detail: `Le domaine "${v}" imite "${brand}". C'est une arnaque classique` });
        break;
      }
    }
  }
  
  // CHECK 6: Caractères Unicode suspects (homoglyphes cyrilliques)
  if (/[а-яА-Я]/.test(host)) flags.push({ sev: 'high', msg: '🚨 Caractères cyrilliques dans l\'URL', detail: 'Technique courante : "раураl" avec a/p cyrilliques au lieu de "paypal"' });
  if (/[\u0080-\uFFFF]/.test(host) && !/[а-яА-Я]/.test(host)) flags.push({ sev: 'med', msg: '⚠️ Caractères Unicode dans le domaine', detail: 'Vérifie qu\'il s\'agit bien d\'un IDN légitime' });
  
  // CHECK 7: URL très longue
  if (raw.length > 100) flags.push({ sev: 'low', msg: `📏 URL très longue (${raw.length} char)`, detail: 'Pas forcément suspect mais à vérifier' });
  
  // CHECK 8: Mots-clés suspects dans path/query
  const fullUrl = raw.toLowerCase();
  const susWords = ['login','signin','verify','update','secure','account','bank','password','confirm','validate','suspended','locked','urgent','rembours','colis-bloque','tracking-livraison','gagne','winner','prize','free-money'];
  const found = susWords.filter(w => fullUrl.includes(w));
  if (found.length >= 3) flags.push({ sev: 'high', msg: '🚨 Mots-clés alarmants combinés', detail: `Trouvés : ${found.slice(0, 5).join(', ')}` });
  else if (found.length >= 1 && (host.includes('.tk') || host.includes('.xyz') || host.includes('-') )) flags.push({ sev: 'med', msg: '⚠️ Mots-clés sensibles + domaine louche', detail: `Mots : ${found.join(', ')}` });
  
  // CHECK 9: Port non standard
  if (urlObj.port && urlObj.port !== '80' && urlObj.port !== '443') flags.push({ sev: 'med', msg: `⚠️ Port non standard (${urlObj.port})`, detail: 'Les sites légitimes utilisent 80 (HTTP) ou 443 (HTTPS)' });
  
  // CHECK 10: @ dans URL (technique de phishing)
  if (raw.includes('@')) flags.push({ sev: 'high', msg: '🚨 Caractère @ dans l\'URL', detail: 'Technique : tout avant @ est ignoré, le vrai domaine est après' });
  
  // CHECK 11: Tirets multiples
  if ((host.match(/-/g) || []).length >= 3) flags.push({ sev: 'med', msg: '⚠️ Beaucoup de tirets dans le domaine', detail: 'Ex: amazon-prime-secure-login = pattern phishing' });
  
  // SCORE
  let highCount = flags.filter(f => f.sev === 'high').length;
  let medCount = flags.filter(f => f.sev === 'med').length;
  let lowCount = flags.filter(f => f.sev === 'low').length;
  let score = 100 - (highCount * 30 + medCount * 12 + lowCount * 4);
  if (score < 0) score = 0;
  
  let verdict, color, icon;
  if (highCount >= 1 || score < 40) { verdict = 'DANGEREUX'; color = '#E14D6B'; icon = '🚨'; }
  else if (medCount >= 2 || score < 70) { verdict = 'SUSPECT'; color = '#FFC542'; icon = '⚠️'; }
  else { verdict = 'PROBABLEMENT SÛR'; color = '#5DD68F'; icon = '✅'; }
  
  let html = `<div style="background:${color}; color:white; padding:18px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">${icon}</div>
    <div style="font-size:18px; font-weight:900; margin-top:4px;">${verdict}</div>
    <div style="font-size:13px; opacity:0.9; margin-top:4px;">Score : ${score}/100</div>
  </div>
  <div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-top:10px; font-size:11px; word-break:break-all;">
    <div style="color:var(--textSec); margin-bottom:4px;">Domaine analysé :</div>
    <div style="font-weight:700; font-family:monospace;">${escapeHtml(host)}</div>
  </div>`;
  
  if (flags.length > 0) {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">🚩 ${flags.length} drapeau${flags.length > 1 ? 'x' : ''}</h3>`;
    flags.forEach(f => {
      const flagColor = f.sev === 'high' ? '#E14D6B' : f.sev === 'med' ? '#FFC542' : '#5DADE2';
      html += `<div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-top:6px; border-left:4px solid ${flagColor};">
        <div style="font-size:12px; font-weight:700;">${escapeHtml(f.msg)}</div>
        <div style="font-size:10px; color:var(--textSec); margin-top:3px; line-height:1.4;">${escapeHtml(f.detail)}</div>
      </div>`;
    });
  }
  if (oks.length > 0) {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">✅ Points OK</h3>`;
    oks.forEach(o => {
      html += `<div style="background:var(--surface); padding:8px 12px; border-radius:8px; margin-top:4px; font-size:11px;">${escapeHtml(o)}</div>`;
    });
  }
  
  document.getElementById('urlsc-result').innerHTML = html;
}
function makeTyposquats(brand) {
  const variants = [];
  if (brand.length < 4) return variants;
  // Lettre 0 → similar
  const swaps = { 'o': '0', 'i': '1', 'l': '1', 'a': '@', 'e': '3', 's': '5' };
  for (let i = 0; i < brand.length; i++) {
    const c = brand[i];
    if (swaps[c]) variants.push(brand.slice(0, i) + swaps[c] + brand.slice(i + 1));
  }
  // Doublement de lettre
  for (let i = 0; i < brand.length; i++) {
    variants.push(brand.slice(0, i) + brand[i] + brand[i] + brand.slice(i + 1));
  }
  // Suppression d'une lettre (sauf très court)
  if (brand.length > 5) {
    for (let i = 1; i < brand.length - 1; i++) {
      variants.push(brand.slice(0, i) + brand.slice(i + 1));
    }
  }
  return variants;
}

