function ptRender(filter = '') {
  let html = '';
  const filtered = filter ? v52_ELEMENTS.filter(e => 
    e.s.toLowerCase().includes(filter.toLowerCase()) ||
    e.n.toLowerCase().includes(filter.toLowerCase()) ||
    String(e.z) === filter
  ) : v52_ELEMENTS;
  filtered.forEach(e => {
    html += `<button onclick="ptShow(${e.z})" style="background:${e.col}; color:white; padding:6px 4px; border:none; border-radius:8px; aspect-ratio:1; cursor:pointer; display:flex; flex-direction:column; align-items:center; justify-content:center;">
      <div style="font-size:9px; opacity:0.8;">${e.z}</div>
      <div style="font-size:18px; font-weight:900;">${e.s}</div>
      <div style="font-size:8px; opacity:0.8;">${e.m}</div>
    </button>`;
  });
  document.getElementById('pt-grid').innerHTML = html;
}
function ptSearch() {
  const v = document.getElementById('pt-search').value.trim();
  ptRender(v);
}
function ptShow(z) {
  const e = v52_ELEMENTS.find(x => x.z === z);
  if (!e) return;
  document.getElementById('pt-detail').innerHTML = `<div style="background:${e.col}; color:white; padding:24px; border-radius:18px; text-align:center;">
    <div style="font-size:11px; opacity:0.9;">N° ${e.z}</div>
    <div style="font-size:64px; font-weight:900; line-height:1;">${e.s}</div>
    <div style="font-size:18px; font-weight:700; margin-top:8px;">${e.n}</div>
    <div style="font-size:11px; opacity:0.9; margin-top:4px;">Masse : ${e.m} g/mol · Catégorie : ${e.c}</div>
  </div>`;
}

