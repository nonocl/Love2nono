    document.getElementById('ig-bio').value = d.bio;
    document.getElementById('ig-link').value = d.link || '';
    document.getElementById('ig-posts').value = d.posts;
    document.getElementById('ig-followers').value = d.followers;
    document.getElementById('ig-following').value = d.following;
    document.getElementById('ig-verified').checked = !!d.verified;
    document.getElementById('ig-private').checked = !!d.private;
    document.getElementById('ig-story-active').checked = !!d.storyActive;
    document.getElementById('ig-highlights').value = d.highlights || '';
    document.getElementById('ig-posts-emojis').value = d.postsEmojis || '';
    renderInsta();
  } else if (net === 'tiktok') {
    document.getElementById('tt-handle').value = d.handle;
    document.getElementById('tt-name').value = d.name;
    document.getElementById('tt-bio').value = d.bio;
    document.getElementById('tt-link').value = d.link || '';
    document.getElementById('tt-following').value = d.following;
    document.getElementById('tt-followers').value = d.followers;
    document.getElementById('tt-likes').value = d.likes;
    document.getElementById('tt-verified').checked = !!d.verified;
    document.getElementById('tt-vids-emojis').value = d.vidsEmojis || '';
    document.getElementById('tt-pin-views').value = d.pinViews || '';
    renderTiktok();
  } else if (net === 'x') {
    document.getElementById('x-name').value = d.name;
    document.getElementById('x-handle').value = d.handle;
    document.getElementById('x-bio').value = d.bio;
    document.getElementById('x-location').value = d.location;
    document.getElementById('x-since').value = d.since;
    document.getElementById('x-following').value = d.following;
    document.getElementById('x-followers').value = d.followers;
    setXCheck(d.check || 'none', true);
    renderXP();
  } else if (net === 'snapchat') {
    document.getElementById('sc-name').value = d.name;
    document.getElementById('sc-handle').value = d.handle;
    document.getElementById('sc-score').value = d.score;
    document.getElementById('sc-sent').value = d.sent;
    document.getElementById('sc-received').value = d.received;
    document.getElementById('sc-streak').value = d.streak;
    document.getElementById('sc-zodiac').value = d.zodiac || '';
    renderSnap();
  }
}

// Discord color presets - 14 couleurs pré-définies cliquables
function renderDiscColorPresets() {
  const presets = ['#5865f2','#eb459e','#fee75c','#57f287','#ed4245','#ff8c42','#9b59b6','#3498db','#1abc9c','#e91e63','#000000','#1e1f22','#ff73fa','#8b5cf6'];
  const el = document.getElementById('disc-color-presets');
  if (!el) return;
  el.innerHTML = '';
  for (const c of presets) {
    const dot = document.createElement('button');
    dot.style.cssText = `width:30px; height:30px; border-radius:50%; background:${c}; border:2px solid var(--border); padding:0; cursor:pointer;`;
    dot.onclick = () => {
      document.getElementById('disc-color1').value = c;
      window.simData.discord.color1 = c;
      renderDiscord();
    };
    el.appendChild(dot);
  }
}

// ============================================================
// DISCORD
// ============================================================
const DISC_BADGES = [
  { id:'nitro', icon:'💜', label:'Nitro', nitro:true },
  { id:'boost', icon:'🚀', label:'Server Booster', nitro:true },
  { id:'staff', icon:'🛡️', label:'Staff' },
  { id:'partner', icon:'🤝', label:'Partner' },
  { id:'hypesquad', icon:'⚡', label:'HypeSquad' },
  { id:'hsbravery', icon:'💜', label:'Bravery' },
  { id:'hsbril', icon:'💛', label:'Brilliance' },
  { id:'hsbalance', icon:'💚', label:'Balance' },
  { id:'bug', icon:'🐛', label:'Bug Hunter' },
  { id:'early', icon:'⏰', label:'Early Supporter' },
  { id:'verified', icon:'✓', label:'Verified Bot Dev' },
  { id:'active', icon:'🌟', label:'Active Developer' },
];

function setDiscNitro(on, silent) {
  window.simData.discord.nitro = on;
  document.getElementById('disc-mode-norm').className = on ? 'btn alt' : 'btn primary';
  document.getElementById('disc-mode-nitro').className = on ? 'btn primary' : 'btn alt';
  document.getElementById('disc-nitro-only').style.display = on ? 'block' : 'none';
  document.getElementById('disc-standard-info').style.display = on ? 'none' : 'block';
  if (!silent) { renderDiscBadgePicker(); renderDiscord(); }
}
function setDiscBannerType(t, silent) {
  window.simData.discord.bannerType = t;
  document.querySelectorAll('[data-disc-banner-type]').forEach(b => {
    b.className = b.dataset.discBannerType === t ? 'btn primary' : 'btn alt';
  });
  document.getElementById('disc-banner-solid-fields').style.display = t === 'solid' ? 'block' : 'none';
  document.getElementById('disc-banner-gradient-fields').style.display = t === 'gradient' ? 'block' : 'none';
  document.getElementById('disc-banner-image-fields').style.display = t === 'image' ? 'block' : 'none';
  if (!silent) renderDiscord();
}
function syncGradColors() {
  // Sync color1 entre solid et gradient input
  document.getElementById('disc-color1').value = document.getElementById('disc-color1-grad').value;
  renderDiscord();
}
function setDiscStatus(s, silent) {
  window.simData.discord.status = s;
  document.querySelectorAll('[data-disc-status]').forEach(b => {
    b.className = b.dataset.discStatus === s ? 'btn primary' : 'btn alt';
  });
  if (!silent) renderDiscord();
}
function renderDiscBadgePicker() {
  const el = document.getElementById('disc-badge-picker');
  el.innerHTML = '';
  const d = window.simData.discord;
  for (const b of DISC_BADGES) {
    if (b.nitro && !d.nitro) continue;
    const on = (d.badges||[]).includes(b.id);
    const btn = document.createElement('button');
    btn.className = on ? 'btn primary' : 'btn alt';
    btn.style.cssText = 'padding:6px 10px; font-size:12px;';
    btn.innerHTML = `${b.icon} ${b.label}`;
    btn.onclick = () => {
      d.badges = d.badges || [];
      if (on) d.badges = d.badges.filter(x => x !== b.id); else d.badges.push(b.id);
      renderDiscBadgePicker(); renderDiscord();
    };
    el.appendChild(btn);
  }
}
function renderDiscord() {
  const d = window.simData.discord;
  d.name = document.getElementById('disc-name').value;
  d.handle = document.getElementById('disc-handle').value;
  d.bio = document.getElementById('disc-bio').value;
  d.pronouns = document.getElementById('disc-pronouns').value;
  d.since = document.getElementById('disc-since').value;
  d.activity = document.getElementById('disc-activity').value;
  d.activityType = document.getElementById('disc-activity-type').value;
  d.customstatus = document.getElementById('disc-customstatus').value;
  d.color1 = document.getElementById('disc-color1').value;
  d.color2 = document.getElementById('disc-color2').value;
  d.gradAngle = parseInt(document.getElementById('disc-grad-angle').value) || 135;
  d.effect = document.getElementById('disc-effect').value;
  d.deco = document.getElementById('disc-deco').value;
  d.plate = document.getElementById('disc-plate').value;
  d.plateColor = document.getElementById('disc-plate-color').value;
  const statusColors = { online:'#23a55a', idle:'#f0b232', dnd:'#f23f43', offline:'#80848e' };
  const statusLabels = { online:'En ligne', idle:'Inactif', dnd:'Ne pas déranger', offline:'Hors ligne' };
  const initial = (d.name || d.handle || '?').slice(0,1).toUpperCase();

  // --- BANNIÈRE ---
  // Standard : couleur dérivée AUTOMATIQUEMENT de l'avatar (autoColor) ou couleur Discord par défaut
  // Nitro : selon bannerType : solid (color1), gradient (color1→color2), image (banner)
  let bannerStyle;
  if (d.nitro) {
    if (d.bannerType === 'image' && d.banner) {
      bannerStyle = `background-image:url('${d.banner}'); background-size:cover; background-position:center;`;
    } else if (d.bannerType === 'solid') {
      bannerStyle = `background:${d.color1};`;
    } else {
      // gradient (default)
      bannerStyle = `background:linear-gradient(${d.gradAngle}deg, ${d.color1}, ${d.color2});`;
    }
  } else {
    // STANDARD : la bannière S'ADAPTE auto à la couleur de l'avatar
    const autoBg = d.autoColor || '#5865f2';
    bannerStyle = `background:${autoBg};`;
  }

  // --- AVATAR (background fallback si pas d'image) ---
  let avatarBg = d.nitro ? d.color1 : (d.autoColor || '#5865f2');

  // --- DÉCORATION D'AVATAR (Nitro uniquement) ---
  const decoMap = {
    dragon:'🐲', cat:'🐱', fire:'🔥', crown:'👑', halo:'😇',
    butterfly:'🦋', flowers:'🌹', stars:'⭐', ghost:'👻', bow:'🎀'
  };
  let decoEl = '';
  if (d.nitro && d.deco && decoMap[d.deco]) {
    if (d.deco === 'crown' || d.deco === 'halo' || d.deco === 'bow') {
      // Au-dessus de la tête
      decoEl = `<div style="position:absolute; top:-12px; left:50%; transform:translateX(-50%); font-size:32px; filter:drop-shadow(0 2px 4px rgba(0,0,0,0.5)); pointer-events:none;">${decoMap[d.deco]}</div>`;
    } else {
      // Cadre flottant haut-droite
      decoEl = `<div style="position:absolute; top:-8px; right:-8px; font-size:30px; filter:drop-shadow(0 2px 4px rgba(0,0,0,0.5)); pointer-events:none;">${decoMap[d.deco]}</div>`;
    }
  }

  // --- EFFETS NITRO ---
  const effectMap = {
    confetti:'🎉', hearts:'💕', sparkles:'✨', bubbles:'🫧',
    snow:'❄️', fireworks:'🎆', leaves:'🍃', petals:'🌸'
  };
  let effectEl = '';
  if (d.nitro && d.effect && effectMap[d.effect]) {
    let particles = '';
    for (let i=0; i<10; i++) {
      const left = Math.random()*100;
      const top = Math.random()*100;
      const size = 12 + Math.random()*16;
      const rot = Math.random()*360;
      particles += `<span style="position:absolute; left:${left}%; top:${top}%; font-size:${size}px; opacity:0.7; pointer-events:none; transform:rotate(${rot}deg);">${effectMap[d.effect]}</span>`;
    }
    effectEl = `<div style="position:absolute; inset:0; pointer-events:none; overflow:hidden;">${particles}</div>`;
  }

  // --- BADGES ---
  const badgesHtml = (d.badges||[]).map(id => {
    const b = DISC_BADGES.find(x => x.id === id);
    return b ? `<span class="disc-badge" title="${b.label}" style="background:#1e1f22;">${b.icon}</span>` : '';
  }).join('');

  // --- PLAQUE / CLAN TAG (Nitro uniquement) ---
  let plateHtml = '';
  if (d.nitro && d.plate) {
    plateHtml = `<span style="display:inline-flex; align-items:center; gap:3px; margin-left:6px; padding:1px 6px; background:${d.plateColor}; color:white; border-radius:5px; font-size:11px; font-weight:800; letter-spacing:0.5px; vertical-align:middle;">▰ ${escapeHtml(d.plate.toUpperCase())}</span>`;
  }

  // --- ACTIVITÉ ---
  let activityHtml = '';
  if (d.activity && d.activityType) {
    const acts = {
      playing: { icon:'🎮', label:'Joue à', bg:'#1e1f22' },
      spotify: { icon:'🟢', label:'Écoute Spotify', bg:'#1db954' },
      streaming: { icon:'🟣', label:'Stream', bg:'#593695' },
      watching: { icon:'📺', label:'Regarde', bg:'#1e1f22' },
      custom: { icon:'💬', label:'', bg:'#1e1f22' }
    };
    const a = acts[d.activityType];
    if (a) {
      activityHtml = `<div style="margin-top:8px; padding:10px 12px; background:${a.bg}; border-radius:8px; font-size:13px; color:white;">
        <span style="color:rgba(255,255,255,0.6); font-size:10px; text-transform:uppercase; letter-spacing:0.4px; font-weight:700;">${a.label}</span>
        <div style="margin-top:2px;">${a.icon} ${escapeHtml(d.activity)}</div>
      </div>`;
    }
  }

  // --- STATUT CUSTOM ---
  let customStatusHtml = '';
  if (d.customstatus) {
    customStatusHtml = `<div style="display:inline-block; margin-bottom:6px; padding:5px 10px; background:#1e1f22; border-radius:10px; font-size:13px; color:#dbdee1;">${escapeHtml(d.customstatus)}</div>`;
  }

  // --- BODY BACKGROUND ---
  // Standard : léger gradient depuis autoColor (effet Discord vrai)
  let bodyBg = '';
  if (!d.nitro && d.autoColor) {
    bodyBg = `background:linear-gradient(180deg, ${d.autoColor}22, transparent 100px);`;
  } else if (d.nitro && d.bannerType === 'solid') {
    bodyBg = `background:linear-gradient(180deg, ${d.color1}22, transparent 100px);`;
  }

  const html = `
    <div class="disc-card" style="position:relative;">
      ${d.nitro ? '<div class="disc-nitro-banner">✨ NITRO</div>' : ''}
      <div class="disc-banner" style="${bannerStyle} position:relative;">${effectEl}</div>
      <div style="position:relative;">
        <div class="disc-avatar-wrap" style="position:absolute; bottom:-46px; left:14px; padding:6px; background:#2b2d31; border-radius:50%;">
          <div class="disc-avatar" style="background:${avatarBg};">
            ${d.avatar ? `<img src="${d.avatar}" alt="">` : escapeHtml(initial)}
          </div>
          <span class="disc-status-dot" style="background:${statusColors[d.status]};"></span>
          ${decoEl}
        </div>
      </div>
      <div class="disc-body" style="${bodyBg}">
        ${customStatusHtml}
        <div class="disc-username">${escapeHtml(d.name || 'Pseudo')}${plateHtml}</div>
        <div class="disc-handle">${d.handle ? escapeHtml(d.handle) : 'identifiant'}${d.nitro && d.pronouns ? ' • ' + escapeHtml(d.pronouns) : ''}</div>
        ${badgesHtml ? `<div class="disc-badges">${badgesHtml}</div>` : ''}
        ${activityHtml}
        ${d.bio ? `<div class="disc-section"><div class="disc-section-title">À propos de moi</div><div class="disc-bio">${escapeHtml(d.bio)}</div></div>` : ''}
        ${d.since ? `<div class="disc-section"><div class="disc-section-title">Membre Discord depuis</div><div class="disc-bio">${escapeHtml(d.since)}</div></div>` : ''}
        <div style="margin-top:8px; font-size:11px; color:#80848e;">Statut : ${statusLabels[d.status]}</div>
      </div>
    </div>
  `;
  document.getElementById('disc-preview').innerHTML = html;
}

