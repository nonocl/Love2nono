  <div id="su-double" style="background:var(--surface); padding:12px; border-radius:10px; cursor:pointer;" onclick="copyText(document.getElementById('su-double').textContent)"></div>
  
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">S̷l̷a̷s̷h̷</h3>
  <div id="su-slash" style="background:var(--surface); padding:12px; border-radius:10px; cursor:pointer;" onclick="copyText(document.getElementById('su-slash').textContent)"></div>
  
  <p style="font-size:11px; color:var(--textSec); margin-top:10px; text-align:center;">Tap pour copier 📋</p>`;
  document.getElementById('strikeunder-content').innerHTML = html;
  suUpdate();
}
function suUpdate() {
  const t = document.getElementById('su-input')?.value || 'Hello world';
  document.getElementById('su-strike').textContent = applyCombiningMark(t, '\u0336');
  document.getElementById('su-under').textContent = applyCombiningMark(t, '\u0332');
  document.getElementById('su-over').textContent = applyCombiningMark(t, '\u0305');
  document.getElementById('su-double').textContent = applyCombiningMark(t, '\u0333');
  document.getElementById('su-slash').textContent = applyCombiningMark(t, '\u0337');
}



