let _mmImg = null;
function mmLoad(input) {
  const f = (input.files || [])[0]; if (!f) return;
  const r = new FileReader();
  r.onload = e => {
    const img = new Image();
    img.onload = () => {
      _mmImg = img;
      const c = document.getElementById('mm-canvas');
      const max = 800;
      let w = img.width, h = img.height;
      if (w > max) { const r = max/w; w = max; h = h*r; }
      c.width = w; c.height = h;
      document.getElementById('mm-canvas-wrap').style.display = '';
      document.getElementById('mm-controls').style.display = '';
      mmDraw();
    };
    img.src = e.target.result;
  };
  r.readAsDataURL(f);
}
function mmDraw() {
  if (!_mmImg) return;
  const c = document.getElementById('mm-canvas');
  const ctx = c.getContext('2d');
  ctx.drawImage(_mmImg, 0, 0, c.width, c.height);
  const top = document.getElementById('mm-top').value.toUpperCase();
  const bot = document.getElementById('mm-bot').value.toUpperCase();
  const size = parseInt(document.getElementById('mm-size').value);
  ctx.font = `900 ${size}px Impact, Arial Black, sans-serif`;
  ctx.textAlign = 'center';
  ctx.fillStyle = 'white';
  ctx.strokeStyle = 'black';
  ctx.lineWidth = Math.max(3, size/12);
  ctx.lineJoin = 'round';
  if (top) {
    const lines = mmWrap(ctx, top, c.width - 40);
    lines.forEach((line, i) => {
      const y = size + 10 + i*size*1.1;
      ctx.strokeText(line, c.width/2, y);
      ctx.fillText(line, c.width/2, y);
    });
  }
  if (bot) {
    const lines = mmWrap(ctx, bot, c.width - 40);
    lines.forEach((line, i) => {
      const y = c.height - 20 - (lines.length-1-i)*size*1.1;
      ctx.strokeText(line, c.width/2, y);
      ctx.fillText(line, c.width/2, y);
    });
  }
}
function mmWrap(ctx, text, maxW) {
  const words = text.split(' ');
  const lines = []; let cur = '';
  for (const w of words) {
    const test = cur + (cur?' ':'') + w;
    if (ctx.measureText(test).width > maxW && cur) { lines.push(cur); cur = w; }
    else cur = test;
  }
  if (cur) lines.push(cur);
  return lines;
}
function mmExport() {
  const c = document.getElementById('mm-canvas');
  c.toBlob(b => {
    const a = document.createElement('a');
    a.href = URL.createObjectURL(b); a.download = `meme-${Date.now()}.png`; a.click();
    toast('📥 Mème exporté !');
  });
}

// ============================================================
// AUDIO CONTEXT (partagé)
// ============================================================
let _ac = null;
function getAC() {
  if (!_ac) _ac = new (window.AudioContext || window.webkitAudioContext)();
  if (_ac.state === 'suspended') _ac.resume();
  return _ac;
}
function playTone(freq, duration = 0.3, type = 'sine', volume = 0.3) {
  const ac = getAC();
  const osc = ac.createOscillator();
  const gain = ac.createGain();
  osc.type = type;
  osc.frequency.setValueAtTime(freq, ac.currentTime);
  gain.gain.setValueAtTime(volume, ac.currentTime);
  gain.gain.exponentialRampToValueAtTime(0.001, ac.currentTime + duration);
  osc.connect(gain); gain.connect(ac.destination);
  osc.start(ac.currentTime);
  osc.stop(ac.currentTime + duration);
}

