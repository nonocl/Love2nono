}

/* === EASTER EGG #7 : COTTAGECORE GARDEN ===
   theme cottagecore + vibe-glass = jardin doux */
body[data-theme="cottagecore"].vibe-glass {
  background: linear-gradient(180deg, #F3EBDD 0%, #E5D9C5 50%, #D7C9B0 100%) fixed !important;
}
