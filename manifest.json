// === Back navigation using history ===
function goBack() {
  // V60 — version SIMPLE et ROBUSTE
  // Règle UNIVERSELLE : 
  //   - Sur une feature listée dans PAGE_INDEX → retour à 'all' (filtré si possible)
  //   - Sinon (home, settings, all, recent, etc.) → retour à 'home'
  
  // Récupérer la page actuelle de la façon la plus fiable possible
  let currentPage = null;
  try { currentPage = state && state.page; } catch(e) {}
  if (!currentPage) {
    // Fallback : lire depuis le DOM
    const activeEl = document.querySelector('.page.active');
    if (activeEl && activeEl.id) {
      currentPage = activeEl.id.replace('page-', '');
    }
  }
  if (!currentPage) {
    // Vraiment rien trouvé → retour home par défaut
    try { goTo('home'); } catch(e) {}
    return;
  }
  
  // Pages système → toujours home
  const systemPages = ['home', 'all', 'recent', 'search', 'menu', 'settings', 'custom-theme', 'palette', 'profile', 'about', 'backup'];
  if (systemPages.indexOf(currentPage) !== -1) {
    try { goTo('home'); } catch(e) {}
    return;
  }
  
  // Cherche la catégorie de la feature
  let targetCat = null;
  try {
    if (typeof PAGE_INDEX !== 'undefined') {
      const item = PAGE_INDEX.find(function(p) { return p.page === currentPage; });
      if (item && item.cat) targetCat = item.cat;
    }
  } catch(e) {}
  
  // Si on a trouvé la cat → goTo('all') puis filtre
  if (targetCat) {
    try { goTo('all'); } catch(e) {}
    setTimeout(function() {
      try {
        if (typeof filterCat === 'function') filterCat(targetCat);
      } catch(e) {}
    }, 150);
    return;
  }
  
  // Pas de cat trouvée → retour à 'all' sans filtre
  try { goTo('all'); } catch(e) {
    try { goTo('home'); } catch(e2) {}
  }
}

function goTo(page) {
  // === Nav history ===
  if (typeof window._navHistory === 'undefined') window._navHistory = [];
  // Don't push if going back, OR if same page, OR if previous push was identical
  const isGoingBack = window._goingBack === true;
  window._goingBack = false; // reset flag
  if (!isGoingBack && state && state.page && state.page !== page) {
    // Avoid duplicate consecutive entries
    const lastInHistory = window._navHistory[window._navHistory.length - 1];
    if (lastInHistory !== state.page) {
      window._navHistory.push(state.page);
      if (window._navHistory.length > 50) window._navHistory.shift();
    }
  }

  const targetEl = document.getElementById('page-' + page);
  if (!targetEl) {
    console.warn('Page introuvable:', page);
    toast('⚠️ Page "' + page + '" introuvable');
    return;
