function statsAppCount(page) {
  if (!page || page === 'home') return;
  try {
    const s = JSON.parse(localStorage.getItem('nw_stats_pages') || '{}');
    s[page] = (s[page] || 0) + 1;
    localStorage.setItem('nw_stats_pages', JSON.stringify(s));
  } catch {}
}
function renderStatsApp() {
  let stats;
  try { stats = JSON.parse(localStorage.getItem('nw_stats_pages') || '{}'); } catch { stats = {}; }
  const sorted = Object.entries(stats).sort((a,b) => b[1] - a[1]);
  const total = sorted.reduce((s, [,v]) => s + v, 0);
  let html = `<div style="background:linear-gradient(135deg, var(--primary), var(--accent)); color:white; padding:18px; border-radius:14px; text-align:center; margin-bottom:14px;">
    <div style="font-size:11px; opacity:0.85;">Total navigations</div>
    <div style="font-size:36px; font-weight:900;">${total}</div>
    <div style="font-size:12px;">${sorted.length} outils différents utilisés</div>
  </div>`;
  if (!sorted.length) {
    html += '<p style="text-align:center; color:var(--textSec);">Pas encore de stats. Utilise l\'app pour voir tes outils favoris !</p>';
  } else {
    html += '<h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-top:8px;">🏆 Top outils</h3>';
    const max = sorted[0][1];
    html += sorted.slice(0, 15).map(([page, n], i) => {
      const meta = (typeof PAGE_INDEX !== 'undefined' && PAGE_INDEX) ? PAGE_INDEX.find(p => p.page === page) : null;
      const name = meta?.name || page;
      const ico = meta?.ico || '·';
      const pct = (n / max) * 100;
      return `<div style="margin-bottom:6px;">
        <div style="display:flex; justify-content:space-between; font-size:12px; margin-bottom:2px;">
          <span><strong>${i+1}.</strong> ${ico} ${escapeHtml(name)}</span>
          <span style="color:var(--primary); font-weight:700;">${n}×</span>
        </div>
        <div style="background:var(--surfaceAlt); height:6px; border-radius:3px; overflow:hidden;">
          <div style="background:linear-gradient(90deg, var(--primary), var(--accent)); height:100%; width:${pct}%;"></div>
        </div>
      </div>`;
    }).join('');
  }
  document.getElementById('stats-app-content').innerHTML = html;
}
function statsAppReset() {
  if (!confirm('Effacer toutes les stats d\'usage ?')) return;
  localStorage.removeItem('nw_stats_pages');
  renderStatsApp();
}

