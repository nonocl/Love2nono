// SHIP NAME
// ============================================================
function renderShipNames() {
  const a = document.getElementById('ship-1').value.trim();
  const b = document.getElementById('ship-2').value.trim();
  if (!a || !b) { document.getElementById('ship-output').innerHTML = ''; return; }
  // Génère 5 variantes
  const variants = [];
  // 1. début de A + fin de B
  variants.push(a.slice(0, Math.ceil(a.length/2)) + b.slice(Math.floor(b.length/2)));
  // 2. début de B + fin de A
  variants.push(b.slice(0, Math.ceil(b.length/2)) + a.slice(Math.floor(a.length/2)));
  // 3. premières syllabes
  variants.push(a.slice(0,2) + b.slice(0,3));
  // 4. premier de A + tout de B sans premier
  variants.push(a[0] + b.slice(1).toLowerCase());
  // 5. tout A + tout B (composé)
  variants.push(a + b);
  const out = document.getElementById('ship-output');
  out.innerHTML = '';
  const set = [...new Set(variants.map(v => v.charAt(0).toUpperCase() + v.slice(1).toLowerCase()))];
  set.forEach(v => {
    const card = document.createElement('div');
    card.style.cssText = 'background:linear-gradient(135deg,#FF6FA3,#C77DFF); color:white; padding:14px 18px; border-radius:14px; margin-bottom:6px; cursor:pointer; text-align:center; font-size:18px; font-weight:700;';
    card.innerHTML = `💕 ${escapeHtml(v)} 💕`;
    card.onclick = () => { navigator.clipboard.writeText(v).then(() => toast('📋 Copié !')); };
    out.appendChild(card);
  });
}

// ============================================================
// COMPATIBILITY
// ============================================================
function renderCompat() {
  const a = document.getElementById('comp-1').value.trim();
  const b = document.getElementById('comp-2').value.trim();
  if (!a || !b) { document.getElementById('comp-output').innerHTML = ''; return; }
  // Hash basé sur les lettres
  const combined = (a + b).toLowerCase();
  let hash = 0;
  for (let i=0; i<combined.length; i++) {
    hash = ((hash << 5) - hash + combined.charCodeAt(i)) | 0;
  }
  const score = Math.abs(hash % 101); // 0-100
  let label, color, desc;
  if (score >= 90) { label = 'Soulmates 💕'; color = '#FF6FA3'; desc = 'C\'est écrit dans les étoiles ✨'; }
  else if (score >= 75) { label = 'Très bonne match 🔥'; color = '#FF8C42'; desc = 'Vous avez vraiment du potentiel'; }
  else if (score >= 60) { label = 'Bonne entente 💞'; color = '#C77DFF'; desc = 'Belle énergie entre vous'; }
  else if (score >= 40) { label = 'Pas mal 🌸'; color = '#5DD6E5'; desc = 'Y\'a quelque chose à creuser'; }
  else if (score >= 20) { label = 'Compliqué 🤔'; color = '#FFD166'; desc = 'Faut bosser un peu'; }
  else { label = 'Mieux vaut amis 😅'; color = '#80848e'; desc = 'L\'amitié c\'est cool aussi'; }
  document.getElementById('comp-output').innerHTML = `
    <div style="text-align:center; padding:24px; background:linear-gradient(135deg, ${color}, ${color}aa); color:white; border-radius:18px;">
      <div style="font-size:14px; opacity:0.9;">${escapeHtml(a)} 💕 ${escapeHtml(b)}</div>
      <div style="font-size:64px; font-weight:900; margin:14px 0;">${score}<span style="font-size:32px;">%</span></div>
      <div style="font-size:18px; font-weight:700;">${label}</div>
      <div style="font-size:12px; margin-top:6px; opacity:0.9;">${desc}</div>
    </div>
    <p style="font-size:11px; color:var(--textSec); text-align:center; margin-top:8px;">⚠️ Calcul basé sur les lettres juste pour le fun, c'est pas sérieux MEK</p>
  `;
}

