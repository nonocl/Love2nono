function qfSuggest() {
  const time = parseInt(document.getElementById('qf-time').value);
  const mood = document.getElementById('qf-mood').value;
  let candidates = QF_ACTIVITIES.filter(a => a.time <= time);
  if (mood !== 'any') candidates = candidates.filter(a => a.mood.includes(mood) || a.mood.includes('any'));
  if (!candidates.length) candidates = QF_ACTIVITIES.filter(a => a.time <= time);
  const choice = candidates[Math.floor(Math.random() * candidates.length)];
  document.getElementById('qf-result').innerHTML = `<div style="background:linear-gradient(135deg, var(--primary), var(--accent)); color:white; padding:24px; border-radius:14px; text-align:center;">
    <div style="font-size:64px;">${choice.emoji}</div>
    <div style="font-size:18px; font-weight:700; margin-top:14px; line-height:1.4;">${escapeHtml(choice.text)}</div>
    <button class="btn alt" onclick="qfSuggest()" style="margin-top:14px; background:rgba(255,255,255,0.2); color:white; border-color:rgba(255,255,255,0.3);">🔄 Une autre idée</button>
  </div>`;
}

