// === Drag-drop sections (édition accueil) ===
let _editMode = false;
function toggleEditMode() {
  _editMode = !_editMode;
  document.querySelectorAll('.home-section').forEach(s => s.classList.toggle('edit-mode', _editMode));
  if (_editMode) {
    toast('✎ Mode édition : drag les sections pour les réordonner');
    setupDragSections();
  } else {
    toast('✓ Ordre sauvegardé');
    saveSectionOrder();
  }
}
function setupDragSections() {
  const sections = document.querySelectorAll('.home-section');
  sections.forEach(sec => {
    if (sec._dragSetup) return;
    sec._dragSetup = true;
    const header = sec.querySelector('.home-section-header');
    if (!header) return;
    header.setAttribute('draggable', 'true');
    header.addEventListener('dragstart', (e) => {
      if (!_editMode) return;
      sec.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
    });
    header.addEventListener('dragend', () => {
      sec.classList.remove('dragging');
      document.querySelectorAll('.drag-over').forEach(s => s.classList.remove('drag-over'));
    });
    sec.addEventListener('dragover', (e) => {
      if (!_editMode) return;
      e.preventDefault();
      const dragging = document.querySelector('.dragging');
      if (dragging && dragging !== sec) sec.classList.add('drag-over');
    });
    sec.addEventListener('dragleave', () => sec.classList.remove('drag-over'));
    sec.addEventListener('drop', (e) => {
      if (!_editMode) return;
      e.preventDefault();
      sec.classList.remove('drag-over');
      const dragging = document.querySelector('.dragging');
      if (!dragging || dragging === sec) return;
      const parent = sec.parentNode;
      const rect = sec.getBoundingClientRect();
      const after = e.clientY > rect.top + rect.height / 2;
      parent.insertBefore(dragging, after ? sec.nextSibling : sec);
    });
  });
}
function saveSectionOrder() {
  const order = Array.from(document.querySelectorAll('.home-section'))
    .map(s => s.querySelector('.title-txt')?.textContent)
    .filter(Boolean);
  localStorage.setItem('nw_secOrder', JSON.stringify(order));
}
function applySectionOrder() {
  try {
    const order = JSON.parse(localStorage.getItem('nw_secOrder') || '[]');
    if (!order.length) return;
    const home = document.getElementById('page-home');
    const sections = Array.from(document.querySelectorAll('.home-section'));
    const map = {};
    sections.forEach(s => {
      const t = s.querySelector('.title-txt')?.textContent;
      if (t) map[t] = s;
    });
    // Find anchor: insert after .home-tabs or .home-search-results
    const anchor = document.getElementById('home-tabs') || document.getElementById('home-search-results');
    if (!anchor) return;
    let cursor = anchor;
    for (const t of order) {
      if (map[t]) {
        cursor.parentNode.insertBefore(map[t], cursor.nextSibling);
        cursor = map[t];
      }
    }
  } catch {}
}

