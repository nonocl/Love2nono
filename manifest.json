function pwAuditAnalyze(pw) {
  const len = pw.length;
  const hasLower = /[a-z]/.test(pw);
  const hasUpper = /[A-Z]/.test(pw);
  const hasNum = /[0-9]/.test(pw);
  const hasSym = /[^a-zA-Z0-9]/.test(pw);
  const charset = (hasLower ? 26 : 0) + (hasUpper ? 26 : 0) + (hasNum ? 10 : 0) + (hasSym ? 33 : 0);
  const entropy = len * Math.log2(charset || 1);
  
  const flags = [];
  const wins = [];
  
  if (len < 8) flags.push({ sev: 'high', msg: 'Trop court (< 8 caractères)' });
  else if (len < 12) flags.push({ sev: 'med', msg: 'Court (< 12 caractères) — vise 14+' });
  else if (len >= 14) wins.push(`Bonne longueur (${len} car)`);
  
  if (!hasLower) flags.push({ sev: 'med', msg: 'Pas de minuscules' });
  if (!hasUpper) flags.push({ sev: 'med', msg: 'Pas de majuscules' });
  if (!hasNum) flags.push({ sev: 'low', msg: 'Pas de chiffres' });
  if (!hasSym) flags.push({ sev: 'low', msg: 'Pas de symboles (!@#$...)' });
  if (hasLower && hasUpper && hasNum && hasSym) wins.push('Tous les types de caractères');
  
  // Common password
  if (COMMON_PWDS.includes(pw.toLowerCase())) flags.push({ sev: 'high', msg: 'Dans la liste des 100 mots de passe les + utilisés !' });
  
  // Sequence
  if (/123|234|345|456|567|678|789|abc|qwe|aze|asd/i.test(pw)) flags.push({ sev: 'high', msg: 'Contient une séquence évidente (123, abc, azerty...)' });
  
  // Repeated chars
  if (/(.)\1{2,}/.test(pw)) flags.push({ sev: 'med', msg: 'Caractères répétés (aaa, 111...)' });
  
  // Year
  if (/(19|20)\d{2}/.test(pw)) flags.push({ sev: 'med', msg: 'Contient une année — facile à deviner' });
  
  // Just lowercase + numbers
  if (hasLower && hasNum && !hasUpper && !hasSym && len < 14) flags.push({ sev: 'med', msg: 'Que des minuscules + chiffres' });
  
  // Crack time estimation
  const guessesPerSec = 1e10; // 10 milliards/sec (GPU moderne)
  const totalGuesses = Math.pow(charset, len) / 2;
  const seconds = totalGuesses / guessesPerSec;
  let crackTime = '';
  if (seconds < 1) crackTime = 'Instantané ⚡';
  else if (seconds < 60) crackTime = `${Math.round(seconds)} sec`;
  else if (seconds < 3600) crackTime = `${Math.round(seconds / 60)} min`;
  else if (seconds < 86400) crackTime = `${Math.round(seconds / 3600)} h`;
  else if (seconds < 31536000) crackTime = `${Math.round(seconds / 86400)} jours`;
  else if (seconds < 31536000 * 100) crackTime = `${Math.round(seconds / 31536000)} ans`;
  else if (seconds < 31536000 * 1e6) crackTime = `${Math.round(seconds / 31536000 / 1000)} milliers d'années`;
  else if (seconds < 31536000 * 1e9) crackTime = `${Math.round(seconds / 31536000 / 1e6)} millions d'années`;
  else crackTime = `> ${Math.round(seconds / 31536000 / 1e9)} milliards d'années 🛡️`;
  
  // Score
  let score = Math.min(100, entropy * 1.5);
  if (flags.some(f => f.sev === 'high')) score = Math.min(score, 30);
  score = Math.round(score);
  
  let strength, color;
  if (score < 30) { strength = 'TRÈS FAIBLE'; color = '#E14D6B'; }
  else if (score < 50) { strength = 'FAIBLE'; color = '#FF8C42'; }
  else if (score < 70) { strength = 'MOYEN'; color = '#FFC542'; }
  else if (score < 85) { strength = 'FORT'; color = '#5DD68F'; }
  else { strength = 'EXCELLENT'; color = '#06FFA5'; }
  
  return { len, charset, entropy, flags, wins, crackTime, score, strength, color };
}
function pwAuditRender(pw, breachData) {
  const a = pwAuditAnalyze(pw);
  let html = `<div style="background:${a.color}; color:white; padding:18px; border-radius:14px; text-align:center;">
