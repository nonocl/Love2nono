let _pmrgFiles = [];
function pmrgLoad(input) {
  _pmrgFiles = Array.from(input.files || []);
  document.getElementById('pmrg-btn').disabled = _pmrgFiles.length < 2;
  const list = document.getElementById('pmrg-list');
  if (!_pmrgFiles.length) { list.innerHTML = ''; return; }
  list.innerHTML = '<div style="font-size:12px; color:var(--textSec); margin-bottom:6px;">Ordre :</div>';
  _pmrgFiles.forEach((f, i) => {
    const div = document.createElement('div');
    div.style.cssText = 'background:var(--surface); padding:10px; border-radius:8px; margin-bottom:4px; display:flex; gap:8px; align-items:center;';
    div.innerHTML = `<span style="color:var(--primary); font-weight:700;">${i+1}.</span><span style="flex:1; font-size:13px;">${f.name}</span><button class="btn alt" style="padding:4px 8px; font-size:12px;" ${i===0?'disabled':''} onclick="pmrgMove(${i},-1)">↑</button><button class="btn alt" style="padding:4px 8px; font-size:12px;" ${i===_pmrgFiles.length-1?'disabled':''} onclick="pmrgMove(${i},1)">↓</button>`;
    list.appendChild(div);
  });
  if (_pmrgFiles.length < 2) setStatus('pmrg-status', 'Sélectionne au moins 2 PDFs.', 'info');
  else setStatus('pmrg-status', '', 'info');
}
function pmrgMove(idx, dir) {
  const newIdx = idx + dir;
  if (newIdx < 0 || newIdx >= _pmrgFiles.length) return;
  [_pmrgFiles[idx], _pmrgFiles[newIdx]] = [_pmrgFiles[newIdx], _pmrgFiles[idx]];
  // Re-render
  const list = document.getElementById('pmrg-list');
  list.innerHTML = '<div style="font-size:12px; color:var(--textSec); margin-bottom:6px;">Ordre :</div>';
  _pmrgFiles.forEach((f, i) => {
    const div = document.createElement('div');
    div.style.cssText = 'background:var(--surface); padding:10px; border-radius:8px; margin-bottom:4px; display:flex; gap:8px; align-items:center;';
    div.innerHTML = `<span style="color:var(--primary); font-weight:700;">${i+1}.</span><span style="flex:1; font-size:13px;">${f.name}</span><button class="btn alt" style="padding:4px 8px; font-size:12px;" ${i===0?'disabled':''} onclick="pmrgMove(${i},-1)">↑</button><button class="btn alt" style="padding:4px 8px; font-size:12px;" ${i===_pmrgFiles.length-1?'disabled':''} onclick="pmrgMove(${i},1)">↓</button>`;
    list.appendChild(div);
  });
}
async function pmrgRun() {
  if (_pmrgFiles.length < 2) return;
  setStatus('pmrg-status', 'Chargement de la lib...', 'loading');
  try {
    const PDFLib = await ensurePdfLib();
    const merged = await PDFLib.PDFDocument.create();
    for (let i=0; i<_pmrgFiles.length; i++) {
      setStatus('pmrg-status', `Fusion ${i+1}/${_pmrgFiles.length}...`, 'loading');
      const buf = await _pmrgFiles[i].arrayBuffer();
      const src = await PDFLib.PDFDocument.load(buf);
      const pages = await merged.copyPages(src, src.getPageIndices());
      pages.forEach(p => merged.addPage(p));
    }
    const bytes = await merged.save();
    dlBlob(new Blob([bytes], { type:'application/pdf' }), `fusion-${Date.now()}.pdf`);
    setStatus('pmrg-status', '✅ PDFs fusionnés !', 'success');
  } catch (e) {
    console.error(e); setStatus('pmrg-status', '❌ ' + e.message, 'error');
  }
}

