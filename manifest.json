}

// ----- Library -----
async function renderMusicLibrary() {
  const tracks = await dbAll('tracks');
  const playlists = await dbAll('playlists');
  const cats = await dbAll('music_cats');
  const trackCats = await dbAll('track_cats');
  // Chips
  const chips = document.getElementById('music-chips');
  chips.innerHTML = '';
  chips.appendChild(createChip(`Toutes (${tracks.length})`, '🎵', null, player.filter==='all', () => { player.filter='all'; renderMusicLibrary(); }));
  const favCount = tracks.filter(t => t.is_favorite).length;
  chips.appendChild(createChip(`Favoris (${favCount})`, '♥', null, player.filter==='fav', () => { player.filter='fav'; renderMusicLibrary(); }));
  for (const c of cats.sort((a,b)=>a.name.localeCompare(b.name))) {
    const count = trackCats.filter(l => l.cat_id === c.id).length;
    chips.appendChild(createChip(`${c.name} (${count})`, c.icon, c.color, player.filter==='cat:'+c.id, () => { player.filter='cat:'+c.id; renderMusicLibrary(); }));
  }
  // Filter
  let list = tracks.slice();
  if (player.filter === 'fav') list = list.filter(t => t.is_favorite);
  else if (player.filter && player.filter.startsWith('cat:')) {
    const catId = parseInt(player.filter.split(':')[1]);
    const ids = new Set(trackCats.filter(l => l.cat_id === catId).map(l => l.track_id));
    list = list.filter(t => ids.has(t.id));
  }
  list.sort((a,b) => (a.title||'').localeCompare(b.title||''));
  // Render
  const el = document.getElementById('music-list');
  el.innerHTML = '';
  document.getElementById('music-empty').style.display = list.length === 0 ? 'block' : 'none';
  for (const t of list) {
    const row = document.createElement('button');
    row.className = 'track-row' + (player.currentTrack && player.currentTrack.id === t.id ? ' playing' : '');
    row.innerHTML = `
      <div class="track-cover" style="background-image:url('${t.cover || (typeof v60_generateCoverFallback==='function' ? v60_generateCoverFallback(t.title, t.artist) : '')}')">${t.cover ? '' : ''}</div>
      <div class="track-info">
        <div class="track-title">${escapeHtml(t.title)}</div>
        <div class="track-meta">${escapeHtml(t.artist || 'Artiste inconnu')}${t.is_favorite?' · ♥':''}</div>
      </div>
      <div class="track-actions">
        <button class="track-btn" data-act="menu">⋯</button>
      </div>
    `;
    row.onclick = (ev) => {
      if (ev.target.dataset.act === 'menu') { openTrackMenu(t.id); return; }
      playFromLibrary(t.id, list.map(x => x.id));
    };
    el.appendChild(row);
  }
}

// ----- Playback -----
async function getTrackBlobUrl(trackId) {
  if (player.blobUrls.has(trackId)) return player.blobUrls.get(trackId);
  const t = await dbGet('tracks', trackId);
  if (!t) return null;
  const url = URL.createObjectURL(t.blob);
  player.blobUrls.set(trackId, url);
  return url;
}

async function playFromLibrary(trackId, trackIds) {
  player.queue = trackIds.slice();
  player.origQueue = trackIds.slice();
  if (player.shuffle) shuffleQueue();
  player.index = player.queue.indexOf(trackId);
  await playCurrent();
}

async function playFromQueue(ids, startIndex=0) {
  player.queue = ids.slice();
  player.origQueue = ids.slice();
  if (player.shuffle) shuffleQueue();
  player.index = startIndex;
  await playCurrent();
}

async function playCurrent() {
  if (player.index < 0 || player.index >= player.queue.length) return;
  const id = player.queue[player.index];
  const track = await dbGet('tracks', id);
  if (!track) { nextTrack(); return; }
  player.currentTrack = track;
  const url = await getTrackBlobUrl(id);
  audioEl.src = url;
  try {
    await audioEl.play();
  } catch (e) { console.warn('play err', e); }
  updatePlayerUI();
  updateMediaSession();
}

function togglePlay() {
  if (!player.currentTrack) {
    if (player.queue.length > 0) { playCurrent(); return; }
    // No track loaded, try first track in library
    dbAll('tracks').then(tracks => {
      if (tracks.length > 0) {
        const sorted = tracks.slice().sort((a,b)=>(a.title||'').localeCompare(b.title||''));
        playFromLibrary(sorted[0].id, sorted.map(t => t.id));
      }
    });
    return;
  }
  if (audioEl.paused) audioEl.play().catch(e=>console.warn(e));
  else audioEl.pause();
}

function nextTrack() {
  if (player.queue.length === 0) return;
  if (player.loop === 'one') { audioEl.currentTime = 0; audioEl.play(); return; }
  player.index++;
  if (player.index >= player.queue.length) {
    if (player.loop === 'all') player.index = 0;
    else { audioEl.pause(); player.index = player.queue.length - 1; return; }
  }
  playCurrent();
}

function prevTrack() {
  if (player.queue.length === 0) return;
  if (audioEl.currentTime > 3) { audioEl.currentTime = 0; return; }
  player.index--;
  if (player.index < 0) player.index = player.loop === 'all' ? player.queue.length - 1 : 0;
  playCurrent();
}

function seekRel(seconds) {
  if (!player.currentTrack) return;
  audioEl.currentTime = Math.max(0, Math.min(audioEl.duration || 0, audioEl.currentTime + seconds));
}

function shuffleQueue() {
  if (!player.currentTrack) {
    // Just shuffle
    for (let i = player.queue.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i+1));
      [player.queue[i], player.queue[j]] = [player.queue[j], player.queue[i]];
    }
    return;
  }
  const currentId = player.queue[player.index];
  const others = player.queue.filter((_, i) => i !== player.index);
  for (let i = others.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i+1));
    [others[i], others[j]] = [others[j], others[i]];
  }
  player.queue = [currentId, ...others];
  player.index = 0;
}

function toggleShuffle() {
  player.shuffle = !player.shuffle;
  if (player.shuffle) shuffleQueue();
  else {
    // Restore original order
    if (player.currentTrack) {
      const idx = player.origQueue.indexOf(player.currentTrack.id);
      player.queue = player.origQueue.slice();
      player.index = idx >= 0 ? idx : 0;
    }
  }
  updatePlayerUI();
  toast(player.shuffle ? 'Aléatoire activé 🔀' : 'Aléatoire désactivé');
}

function toggleLoop() {
  player.loop = player.loop === 'none' ? 'all' : (player.loop === 'all' ? 'one' : 'none');
  updatePlayerUI();
  toast(player.loop === 'all' ? 'Répéter tout 🔁' : (player.loop === 'one' ? 'Répéter cette piste 🔂' : 'Répéter désactivé'));
}

async function toggleTrackFav() {
  if (!player.currentTrack) return;
  const t = await dbGet('tracks', player.currentTrack.id);
  t.is_favorite = t.is_favorite ? 0 : 1;
  await dbPut('tracks', t);
  player.currentTrack = t;
  updatePlayerUI();
}

// Audio element events
audioEl.addEventListener('play', () => { updatePlayerUI(); document.body.classList.add('has-miniplayer'); });
audioEl.addEventListener('pause', () => updatePlayerUI());
audioEl.addEventListener('ended', () => nextTrack());
audioEl.addEventListener('timeupdate', () => updateProgress());
audioEl.addEventListener('loadedmetadata', () => updateProgress());

// Progress bar interaction
document.getElementById('progress-bar').addEventListener('click', (e) => {
  if (!player.currentTrack || !audioEl.duration) return;
  const rect = e.currentTarget.getBoundingClientRect();
  const ratio = (e.clientX - rect.left) / rect.width;
  audioEl.currentTime = ratio * audioEl.duration;
});

function updateProgress() {
  const cur = audioEl.currentTime || 0;
  const dur = audioEl.duration || 0;
  const pct = dur > 0 ? (cur / dur) * 100 : 0;
  document.getElementById('progress-fill').style.width = pct + '%';
  document.getElementById('time-current').textContent = fmtTime(cur);
  document.getElementById('time-total').textContent = fmtTime(dur);
}

function fmtTime(s) {
  if (!isFinite(s)) return '0:00';
  const m = Math.floor(s / 60);
  const sec = Math.floor(s % 60);
  return `${m}:${String(sec).padStart(2,'0')}`;
}

function updatePlayerUI() {
  const t = player.currentTrack;
  const playing = !audioEl.paused;
  const playIcon = playing ? '⏸' : '▶';
  document.getElementById('play-btn').textContent = playIcon;
  document.getElementById('mp-play').textContent = playIcon;
  if (t) {
    document.getElementById('player-title').textContent = t.title;
    document.getElementById('player-artist').textContent = t.artist || 'Artiste inconnu';
    document.getElementById('mp-title').textContent = t.title;
    document.getElementById('mp-meta').textContent = t.artist || 'Artiste inconnu';
    const cover = document.getElementById('player-cover');
    const mpCover = document.getElementById('mp-cover');
    if (t.cover) {
      cover.style.backgroundImage = `url('${t.cover}')`;
      cover.textContent = '';
      mpCover.style.backgroundImage = `url('${t.cover}')`;
      mpCover.textContent = '';
    } else if (typeof v60_generateCoverFallback === 'function') {
      const fb = v60_generateCoverFallback(t.title, t.artist);
      cover.style.backgroundImage = `url('${fb}')`;
      cover.textContent = '';
      mpCover.style.backgroundImage = `url('${fb}')`;
      mpCover.textContent = '';
    } else {
      cover.style.backgroundImage = '';
      cover.textContent = '🎵';
      mpCover.style.backgroundImage = '';
      mpCover.textContent = '🎵';
    }
    document.getElementById('mini-player').classList.add('show');
    document.body.classList.add('has-miniplayer');
    document.getElementById('ext-fav').classList.toggle('active', !!t.is_favorite);
    document.querySelector('#ext-fav .ico').textContent = t.is_favorite ? '♥' : '♡';
  }
  document.getElementById('ext-shuffle').classList.toggle('active', player.shuffle);
  const loopBtn = document.getElementById('ext-loop');
  loopBtn.classList.toggle('active', player.loop !== 'none');
  loopBtn.querySelector('.ico').textContent = player.loop === 'one' ? '🔂' : '🔁';
  // Re-render library to show "playing" highlight
  if (state.page === 'music') renderMusicLibrary();
}

function renderPlayer() {
  updatePlayerUI();
  updateProgress();
}

// Hide mini-player when nothing loaded (initial)
function maybeHideMini() {
  if (!player.currentTrack) {
    document.getElementById('mini-player').classList.remove('show');
    document.body.classList.remove('has-miniplayer');
  }
}

// ----- MediaSession API (lock screen / background controls) -----
function updateMediaSession() {
  if (!('mediaSession' in navigator)) return;
  const t = player.currentTrack;
  if (!t) return;
  const meta = {
    title: t.title,
    artist: t.artist || 'Inconnu',
    album: t.album || "Love2nono",
  };
  if (t.cover) {
    meta.artwork = [
      { src: t.cover, sizes: '512x512', type: 'image/jpeg' },
      { src: t.cover, sizes: '256x256', type: 'image/jpeg' },
      { src: t.cover, sizes: '128x128', type: 'image/jpeg' },
    ];
  } else {
    meta.artwork = [{ src: 'icon-512.png', sizes: '512x512', type: 'image/png' }];
  }
  navigator.mediaSession.metadata = new MediaMetadata(meta);
  navigator.mediaSession.setActionHandler('play', () => audioEl.play());
  navigator.mediaSession.setActionHandler('pause', () => audioEl.pause());
  navigator.mediaSession.setActionHandler('previoustrack', () => prevTrack());
  navigator.mediaSession.setActionHandler('nexttrack', () => nextTrack());
  try {
    navigator.mediaSession.setActionHandler('seekbackward', () => seekRel(-10));
    navigator.mediaSession.setActionHandler('seekforward', () => seekRel(10));
    navigator.mediaSession.setActionHandler('seekto', (d) => { if (d.seekTime) audioEl.currentTime = d.seekTime; });
  } catch (e) {}
}

// ----- Track menu -----
function openTrackMenu(trackId) {
  player.trackMenuId = trackId;
  dbGet('tracks', trackId).then(t => {
    document.getElementById('track-menu-title').textContent = t.title;
    openModal('modal-track-menu');
  });
}

function openPlayerMenu() {
  if (!player.currentTrack) return;
  player.trackMenuId = player.currentTrack.id;
  document.getElementById('track-menu-title').textContent = player.currentTrack.title;
  openModal('modal-track-menu');
}

async function renameCurrentTrack() {
  const t = await dbGet('tracks', player.trackMenuId);
  closeModal('modal-track-menu');
  promptInput('Renommer la piste', t.title, async (val) => {
    val = val.trim();
    if (!val) return;
    t.title = val;
    await dbPut('tracks', t);
    if (player.currentTrack && player.currentTrack.id === t.id) player.currentTrack = t;
    updatePlayerUI();
    renderMusicLibrary();
  });
}

async function editTrackArtist() {
  const t = await dbGet('tracks', player.trackMenuId);
  closeModal('modal-track-menu');
  promptInput('Artiste', t.artist || '', async (val) => {
    t.artist = val.trim() || null;
    await dbPut('tracks', t);
    if (player.currentTrack && player.currentTrack.id === t.id) player.currentTrack = t;
    updatePlayerUI();
    renderMusicLibrary();
  });
}

async function deleteCurrentTrack() {
  if (!confirm('Supprimer cette piste ?')) return;
  const tid = player.trackMenuId;
  // Remove from playlist links
  const links = await dbAll('playlist_tracks');
  for (const l of links.filter(x => x.track_id === tid)) await dbDel('playlist_tracks', l.key);
  // Remove from category links
  const catLinks = await dbAll('track_cats');
  for (const l of catLinks.filter(x => x.track_id === tid)) await dbDel('track_cats', l.key);
  await dbDel('tracks', tid);
  // If currently playing, skip
  if (player.currentTrack && player.currentTrack.id === tid) {
    audioEl.pause();
    audioEl.src = '';
    player.currentTrack = null;
    player.queue = player.queue.filter(x => x !== tid);
    if (player.queue.length > 0) {
      player.index = Math.min(player.index, player.queue.length - 1);
      playCurrent();
    } else {
      maybeHideMini();
    }
  }
  if (player.blobUrls.has(tid)) { URL.revokeObjectURL(player.blobUrls.get(tid)); player.blobUrls.delete(tid); }
  closeModal('modal-track-menu');
  renderMusicLibrary();
  toast('Piste supprimée');
}

// ----- Playlists -----
async function renderPlaylists() {
  const playlists = await dbAll('playlists');
  const links = await dbAll('playlist_tracks');
  const el = document.getElementById('playlists-list');
  el.innerHTML = '';
  if (playlists.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">📃</div><h3>Aucune playlist</h3><p>Crée des playlists pour organiser tes pistes par humeur, vibe, moment...</p></div>`;
    return;
  }
  for (const p of playlists.sort((a,b)=>a.name.localeCompare(b.name))) {
    const count = links.filter(l => l.playlist_id === p.id).length;
    const row = document.createElement('button');
    row.className = 'list-row';
    row.innerHTML = `
      <div style="width:42px; height:42px; border-radius:10px; background:linear-gradient(135deg, var(--primary), var(--accent)); display:flex; align-items:center; justify-content:center; font-size:20px; color:white;">📃</div>
      <div class="info">
        <div class="name">${escapeHtml(p.name)}</div>
        <div class="sub">${count} piste${count>1?'s':''}${p.description?' · '+escapeHtml(p.description):''}</div>
      </div>
      <span style="color:var(--textSec); font-size:20px;">›</span>
    `;
    row.onclick = () => openPlaylistDetail(p);
