// === HOOK SETTINGS PAGE ===
function v56_injectVibePickerInSettings() {
  const settings = document.getElementById('page-settings');
  if (!settings) return;
  // Vérifier qu'on n'a pas déjà injecté
  if (document.getElementById('v56-vibe-picker-block')) return;
  // Trouver un bon endroit : après le premier h3 ou en haut du content
  const block = document.createElement('div');
  block.id = 'v56-vibe-picker-block';
  block.style = 'background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:14px; margin:14px 16px;';
  v56_renderVibePicker(block);
  // Insérer en haut du content
  const firstChild = settings.querySelector('.topbar');
  if (firstChild && firstChild.nextSibling) {
    settings.insertBefore(block, firstChild.nextSibling);
  } else {
    settings.appendChild(block);
  }
}

// === KEYBOARD SHORTCUT ===
document.addEventListener('keydown', function(e) {
  if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
    e.preventDefault();
    v56_openSearch();
  }
  if (e.key === 'Escape') {
    v56_closeSearch();
  }
});

// === BOOT ===
function v56_boot() {
  // Activer V56 par défaut
  v56_enable();
  // Injecter vibe picker dans settings (à chaque ouverture de la page settings)
  // On hook un MutationObserver pour ça
  const settingsPage = document.getElementById('page-settings');
  if (settingsPage) {
    const obs = new MutationObserver(() => {
      if (settingsPage.classList.contains('active')) {
        setTimeout(v56_injectVibePickerInSettings, 100);
      }
    });
    obs.observe(settingsPage, { attributes: true, attributeFilter: ['class'] });
    // Et tout de suite si déjà active
    if (settingsPage.classList.contains('active')) v56_injectVibePickerInSettings();
  }
}

// Run when DOM ready
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', v56_boot);
} else {
  // Attendre 200ms que le reste de l'app soit init
  setTimeout(v56_boot, 200);
}

