}
function counterAdd() {
  const name = prompt('Nom du compteur :');
  if (!name) return;
  const c = getCounters();
  c.push({ name: name.slice(0, 30), value: 0 });
  saveCounters(c);
  renderCounter();
}
function counterChange(i, delta) {
  const c = getCounters();
  if (delta === 0) c[i].value = 0;
  else c[i].value += delta;
  saveCounters(c);
