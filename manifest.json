body[data-theme="cottagecore"].vibe-glass .v56-card {
  background: rgba(255, 250, 240, 0.5) !important;
  backdrop-filter: blur(16px) !important;
  -webkit-backdrop-filter: blur(16px) !important;
  border: 1px solid rgba(168, 192, 154, 0.4) !important;
  box-shadow: 0 4px 20px rgba(139, 111, 71, 0.15) !important;
}

/* === EASTER EGG #8 : GALAXY DREAM ===
   theme galaxy/aurora + vibe-glass = espace flottant */
body[data-theme="galaxy"].vibe-glass,
body[data-theme="aurora"].vibe-glass {
  background: linear-gradient(155deg, #2D1B69 0%, #7B61FF 40%, #FF6FA3 80%, #FFD93D 100%) fixed !important;
}
body[data-theme="galaxy"].vibe-glass .v56-greeting,
body[data-theme="aurora"].vibe-glass .v56-greeting,
body[data-theme="galaxy"].vibe-glass .v56-card,
body[data-theme="aurora"].vibe-glass .v56-card {
  background: rgba(20, 25, 55, 0.4) !important;
  backdrop-filter: blur(24px) saturate(180%) !important;
  -webkit-backdrop-filter: blur(24px) saturate(180%) !important;
  border: 1px solid rgba(167, 139, 250, 0.3) !important;
  box-shadow: 0 8px 32px rgba(123, 97, 255, 0.4), 0 0 0 1px rgba(255, 255, 255, 0.1) inset !important;
}
body[data-theme="galaxy"].vibe-glass .v56-greeting::before,
body[data-theme="aurora"].vibe-glass .v56-greeting::before {
  content: '✨';
  position: absolute;
  top: 8px; right: 12px;
  font-size: 16px;
  animation: v57_starTwinkle 3s ease-in-out infinite;
}
@keyframes v57_starTwinkle {
  0%,100% { opacity: 0.4; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.3); }
}

/* === EASTER EGG #9 : VAPORWAVE NIGHTS ===
   theme vaporwave + design-vogue = aesthetic 80s magazine */
body[data-theme="vaporwave"].design-vogue {
  background: linear-gradient(160deg, #FF6FA3 0%, #9B59B6 40%, #5DADE2 70%, #FFD166 100%) fixed !important;
