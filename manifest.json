function renderEarTraining() {
  let html = `<div style="background:linear-gradient(135deg,#FFD166,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">👂</div><div style="font-size:16px; font-weight:800;">Ear training</div>
    <div style="font-size:11px; opacity:0.9;">Devine l'intervalle entre 2 notes</div>
  </div>
  <button class="btn primary full" onclick="etPlay()" style="margin-top:14px; padding:18px;">🔊 Jouer un nouvel intervalle</button>
  <div id="et-options" style="margin-top:14px;"></div>
  <div id="et-result" style="margin-top:10px; text-align:center; font-weight:700;"></div>`;
  document.getElementById('eartraining-content').innerHTML = html;
}
let _etInt = null;
const INTERVALS = [
  { n:'Unisson', s:0 }, { n:'2nde mineure', s:1 }, { n:'2nde majeure', s:2 },
  { n:'3ce mineure', s:3 }, { n:'3ce majeure', s:4 }, { n:'4te juste', s:5 },
  { n:'Triton', s:6 }, { n:'5te juste', s:7 }, { n:'6te mineure', s:8 },
  { n:'6te majeure', s:9 }, { n:'7e mineure', s:10 }, { n:'7e majeure', s:11 }, { n:'Octave', s:12 }
];
function etPlay() {
  const i = INTERVALS[Math.floor(Math.random() * INTERVALS.length)];
  _etInt = i;
  // Note de base aléatoire
  const baseFreq = 261.63; // C4
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    function tone(f, t, dur) {
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.frequency.value = f; osc.type = 'sine';
      gain.gain.setValueAtTime(0, t);
      gain.gain.linearRampToValueAtTime(0.3, t + 0.05);
      gain.gain.linearRampToValueAtTime(0, t + dur);
      osc.connect(gain); gain.connect(ctx.destination);
      osc.start(t); osc.stop(t + dur);
    }
    const t0 = ctx.currentTime;
    tone(baseFreq, t0, 0.8);
    tone(baseFreq * Math.pow(2, i.s/12), t0 + 0.9, 0.8);
  } catch (e) { toast('❌ Audio non supporté'); }
  // Afficher 4 options dont la bonne
  const wrong = INTERVALS.filter(x => x.n !== i.n).sort(() => Math.random() - 0.5).slice(0, 3);
  const opts = [...wrong, i].sort(() => Math.random() - 0.5);
  let html = '<div style="display:grid; grid-template-columns:1fr 1fr; gap:6px;">';
  opts.forEach(o => html += `<button class="btn alt" onclick="etAns('${escapeJs(o.n)}')" style="padding:14px;">${escapeHtml(o.n)}</button>`);
  html += '</div>';
  document.getElementById('et-options').innerHTML = html;
  document.getElementById('et-result').innerHTML = '';
}
function etAns(picked) {
  if (!_etInt) return;
  if (picked === _etInt.n) { document.getElementById('et-result').innerHTML = '✅ Bravo !'; if (navigator.vibrate) navigator.vibrate(10); }
  else document.getElementById('et-result').innerHTML = '❌ C\'était : ' + _etInt.n;
}

