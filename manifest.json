// === 21. LETTRES AU FUTUR TOI ===
function getFutureLetters() { try { return JSON.parse(localStorage.getItem('nw_future_letters') || '[]'); } catch { return []; } }
function saveFutureLetters(l) { localStorage.setItem('nw_future_letters', JSON.stringify(l)); }
function renderFutureLetters() {
  const letters = getFutureLetters();
  const today = new Date().toISOString().slice(0, 10);
  const inFuture = letters.filter(l => l.openDate > today);
  const ready = letters.filter(l => l.openDate <= today);
  let html = `<div style="background:linear-gradient(135deg,#9B59B6,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">📨</div><div style="font-size:16px; font-weight:800;">Lettres au futur toi</div>
    <div style="font-size:11px; opacity:0.9;">${inFuture.length} en attente · ${ready.length} prêtes</div>
  </div>
  <div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:14px;">
    <h3 style="font-size:13px; font-weight:700; color:var(--primary);">✍️ Écris à ton futur toi</h3>
    <textarea id="fl-text" class="input" rows="5" placeholder="Cher moi du futur..." style="margin-top:6px;"></textarea>
    <label style="font-size:11px; color:var(--textSec); margin-top:6px; display:block;">📅 À ouvrir le :</label>
    <input type="date" id="fl-date" class="input" style="margin-top:4px;">
    <button class="btn primary full" onclick="flAdd()" style="margin-top:6px;">📨 Sceller</button>
  </div>`;
  if (ready.length > 0) {
    html += `<h3 style="font-size:13px; font-weight:700; color:#5DD68F; margin-top:14px;">✅ Prêtes à ouvrir</h3>`;
    ready.forEach(l => {
      const i = letters.indexOf(l);
      html += `<details style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px; border-left:3px solid #5DD68F;">
        <summary style="cursor:pointer; font-size:12px;">📨 Écrite le ${new Date(l.created).toLocaleDateString('fr-FR')} · à ouvrir : ${new Date(l.openDate).toLocaleDateString('fr-FR')}</summary>
        <div style="margin-top:10px; padding-top:10px; border-top:1px solid var(--border); font-size:13px; line-height:1.6; white-space:pre-wrap;">${escapeHtml(l.text)}</div>
        <button class="btn alt" onclick="flDel(${i})" style="margin-top:8px; font-size:11px;">🗑 Supprimer</button>
      </details>`;
    });
  }
  if (inFuture.length > 0) {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">🔒 En attente</h3>`;
    inFuture.forEach(l => {
      const days = Math.ceil((new Date(l.openDate) - new Date()) / 86400000);
      html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px;">
        <div style="font-size:13px; font-weight:700;">📨 J-${days} avant ouverture</div>
        <div style="font-size:11px; color:var(--textSec); margin-top:4px;">À ouvrir le ${new Date(l.openDate).toLocaleDateString('fr-FR')}</div>
      </div>`;
    });
  }
  document.getElementById('futureletters-content').innerHTML = html;
}
function flAdd() {
  const text = document.getElementById('fl-text').value.trim();
  const date = document.getElementById('fl-date').value;
  if (!text || !date) { toast('Texte + date requis'); return; }
  const letters = getFutureLetters();
  letters.push({ text, openDate: date, created: Date.now() });
  saveFutureLetters(letters);
  document.getElementById('fl-text').value = '';
  toast('📨 Lettre scellée !');
  renderFutureLetters();
}
function flDel(i) {
  if (!confirm('Supprimer ?')) return;
  const l = getFutureLetters();
  l.splice(i, 1); saveFutureLetters(l);
  renderFutureLetters();
}

