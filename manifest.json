// COURSES
// ============================================================
function getCourses() { try { return JSON.parse(localStorage.getItem('nw_courses') || '[]'); } catch { return []; } }
function saveCourses(c) { localStorage.setItem('nw_courses', JSON.stringify(c)); }
function coursesAdd() {
  const v = document.getElementById('courses-input').value.trim();
  if (!v) return;
  const c = getCourses();
  // Ne pas dupliquer
  if (!c.some(x => x.text.toLowerCase() === v.toLowerCase())) {
    c.push({ id: 'c_'+Date.now(), text: v, done: false });
    saveCourses(c);
  }
  document.getElementById('courses-input').value = '';
  renderCourses();
}
function coursesQuickAdd(items) {
  const c = getCourses();
  for (const it of items) {
    if (!c.some(x => x.text.toLowerCase() === it.toLowerCase())) {
      c.push({ id: 'c_'+Date.now()+Math.random(), text: it, done: false });
    }
  }
  saveCourses(c);
  renderCourses();
}
function coursesToggle(id) {
  const c = getCourses();
  const it = c.find(x => x.id === id);
  if (it) { it.done = !it.done; saveCourses(c); renderCourses(); }
}
function coursesDel(id) {
  saveCourses(getCourses().filter(x => x.id !== id));
  renderCourses();
}
function coursesClearDone() {
  if (!confirm('Effacer les articles cochés ?')) return;
  saveCourses(getCourses().filter(x => !x.done));
  renderCourses();
}
function renderCourses() {
  const c = getCourses();
  if (!c.length) { document.getElementById('courses-list').innerHTML = '<p style="text-align:center; color:var(--textSec); padding:20px;">Liste vide</p>'; return; }
  c.sort((a,b) => (a.done ? 1 : 0) - (b.done ? 1 : 0));
  document.getElementById('courses-list').innerHTML = c.map(it => `
    <div onclick="coursesToggle('${it.id}')" style="display:flex; gap:10px; align-items:center; padding:10px 12px; background:var(--surface); border-radius:8px; margin-bottom:4px; cursor:pointer; ${it.done ? 'opacity:0.5;' : ''}">
      <div style="width:20px; height:20px; border:2px solid var(--primary); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:12px; color:var(--primary);">${it.done ? '✓' : ''}</div>
      <div style="flex:1; font-size:14px; ${it.done ? 'text-decoration:line-through;' : ''}">${escapeHtml(it.text)}</div>
      <button onclick="event.stopPropagation(); coursesDel('${it.id}')" style="background:transparent; border:none; color:var(--textSec); font-size:18px; cursor:pointer;">×</button>
    </div>
  `).join('');
}

// ============================================================
// BOÎTE À DÉCISIONS
// ============================================================
let _decPour = [], _decContre = [];
function decAdd(side) {
  const text = document.getElementById(`dec-${side}-text`).value.trim();
  const w = parseInt(document.getElementById(`dec-${side}-w`).value) || 3;
  if (!text) return;
  if (side === 'pour') _decPour.push({ text, w });
  else _decContre.push({ text, w });
  document.getElementById(`dec-${side}-text`).value = '';
  decRender();
}
function decDel(side, i) {
  if (side === 'pour') _decPour.splice(i, 1);
  else _decContre.splice(i, 1);
  decRender();
}
function decRender() {
  document.getElementById('dec-pour-list').innerHTML = _decPour.map((a, i) => 
    `<div style="background:var(--surface); padding:8px 12px; border-radius:8px; margin-bottom:4px; display:flex; gap:8px; align-items:center; border-left:3px solid var(--success);">
      <span style="flex:1; font-size:13px;">${escapeHtml(a.text)}</span>
      <span style="background:var(--success); color:white; padding:2px 8px; border-radius:8px; font-size:11px; font-weight:700;">+${a.w}</span>
      <button onclick="decDel('pour', ${i})" style="background:transparent; border:none; color:var(--textSec); cursor:pointer;">×</button>
    </div>`
  ).join('');
  document.getElementById('dec-contre-list').innerHTML = _decContre.map((a, i) => 
    `<div style="background:var(--surface); padding:8px 12px; border-radius:8px; margin-bottom:4px; display:flex; gap:8px; align-items:center; border-left:3px solid var(--danger);">
      <span style="flex:1; font-size:13px;">${escapeHtml(a.text)}</span>
      <span style="background:var(--danger); color:white; padding:2px 8px; border-radius:8px; font-size:11px; font-weight:700;">-${a.w}</span>
      <button onclick="decDel('contre', ${i})" style="background:transparent; border:none; color:var(--textSec); cursor:pointer;">×</button>
    </div>`
  ).join('');
}
function decCalc() {
  if (!_decPour.length && !_decContre.length) return toast('Ajoute des arguments');
  const pour = _decPour.reduce((s, a) => s + a.w, 0);
  const contre = _decContre.reduce((s, a) => s + a.w, 0);
  const net = pour - contre;
  let msg, col, em;
  if (net >= 5) { msg = 'Vas-y franchement, c\'est clairement bénéfique.'; col = 'var(--success)'; em = '✅✅'; }
  else if (net >= 2) { msg = 'Plutôt favorable, t\'as l\'air de plus à gagner qu\'à perdre.'; col = 'var(--success)'; em = '✅'; }
  else if (net >= -1) { msg = 'C\'est trop équilibré pour décider, écoute ton intuition.'; col = 'orange'; em = '🤷'; }
  else if (net >= -4) { msg = 'Plutôt défavorable, demande-toi si ça vaut vraiment le coup.'; col = 'var(--danger)'; em = '⚠️'; }
  else { msg = 'Clairement non, les inconvénients pèsent trop lourd.'; col = 'var(--danger)'; em = '❌'; }
  document.getElementById('dec-result').innerHTML = `<div style="background:var(--surface); padding:18px; border-radius:14px; text-align:center; border-top:4px solid ${col};">
    <div style="font-size:48px;">${em}</div>
    <div style="font-size:24px; font-weight:900; color:${col}; margin-top:8px;">Score : ${net > 0 ? '+' : ''}${net}</div>
    <div style="font-size:13px; margin-top:8px;">Pour : <strong>${pour}</strong> · Contre : <strong>${contre}</strong></div>
    <p style="font-size:13px; margin-top:14px; line-height:1.5;">${msg}</p>
  </div>`;
}

