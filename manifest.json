// Extrait la couleur dominante d'une image (pour Discord standard banner = couleur PP)
function extractDominantColor(dataUrl, callback) {
  const img = new Image();
  img.onload = () => {
    const canvas = document.createElement('canvas');
    const size = 50;
    canvas.width = size; canvas.height = size;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(img, 0, 0, size, size);
    try {
      const data = ctx.getImageData(0, 0, size, size).data;
      // Bins par bucket de 32 pour réduire variations
      const buckets = {};
      let maxCount = 0; let dominant = '#5865f2';
      for (let i=0; i<data.length; i+=4) {
        const a = data[i+3];
        if (a < 128) continue; // skip transparent
        const r = data[i] >> 5 << 5;
        const g = data[i+1] >> 5 << 5;
        const b = data[i+2] >> 5 << 5;
        // Skip noir/blanc/gris pur (faible saturation)
        const max = Math.max(r,g,b), min = Math.min(r,g,b);
        if (max - min < 30) continue;
        const key = `${r},${g},${b}`;
        buckets[key] = (buckets[key]||0) + 1;
        if (buckets[key] > maxCount) {
          maxCount = buckets[key];
          dominant = `rgb(${r+16},${g+16},${b+16})`;
        }
      }
      // Si rien d'intéressant trouvé (ex: image très neutre), fallback first non-white pixel
      if (maxCount === 0) {
        for (let i=0; i<data.length; i+=4) {
          const a = data[i+3];
          if (a < 128) continue;
          const r = data[i], g = data[i+1], b = data[i+2];
          dominant = `rgb(${r},${g},${b})`;
          break;
        }
      }
      callback(dominant);
    } catch (err) {
      console.warn('color extract failed', err);
      callback('#5865f2');
    }
  };
  img.onerror = () => callback('#5865f2');
  img.src = dataUrl;
}
