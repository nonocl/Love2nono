  animation: v57_oceanFlow 8s ease-in-out infinite;
}
@keyframes v57_oceanFlow {
  0%,100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

/* === EASTER EGG #12 : POKEMON QUEST ===
   design-pokemon + vibe-brut = console pokémon style cartouche */
body.design-pokemon.vibe-brut .v56-greeting,
body.design-pokemon.vibe-brut .v56-card,
body.design-pokemon.vibe-brut .home-tile,
body.design-pokemon.vibe-brut .v56-stat {
  background: #FFFFFF !important;
  border: 4px solid #2C2C2C !important;
  border-radius: 0 !important;
  box-shadow: 0 4px 0 #FFCC02, 4px 8px 0 #2C2C2C !important;
  font-family: 'Courier New', monospace !important;
}
