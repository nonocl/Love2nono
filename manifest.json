// === CORBEILLE ===
function getTrash() { try { return JSON.parse(localStorage.getItem('nw_trash') || '[]'); } catch { return []; } }
function saveTrash(d) { localStorage.setItem('nw_trash', JSON.stringify(d)); }
function trashAdd(item, type) {
  const trash = getTrash();
  trash.unshift({ id: 'tr_'+Date.now(), type, item, deleted: Date.now() });
  // Keep only last 100
  if (trash.length > 100) trash.length = 100;
  saveTrash(trash);
}
function renderTrash() {
  const trash = getTrash();
  // Auto-purge older than 30 days
  const now = Date.now();
  const cleaned = trash.filter(t => now - t.deleted < 30*24*60*60*1000);
  if (cleaned.length !== trash.length) saveTrash(cleaned);
  
  let html = `<div style="background:linear-gradient(135deg,#95A5A6,#7F8C8D); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🗑️</div>
    <div style="font-size:16px; font-weight:800; margin-top:4px;">Corbeille</div>
    <div style="font-size:11px; opacity:0.9; margin-top:2px;">${cleaned.length} éléments · auto-suppression après 30j</div>
  </div>`;
  if (!cleaned.length) html += '<p style="text-align:center; color:var(--textSec); padding:30px;">Corbeille vide</p>';
  cleaned.forEach(t => {
    const days = Math.floor((now - t.deleted) / (24*60*60*1000));
    const icons = {note:'📝', todo:'✅', homework:'📚', wishlist:'⭐', other:'📦'};
    const preview = t.item.title || t.item.text || t.item.name || JSON.stringify(t.item).slice(0,60);
    html += `<div style="background:var(--surface); padding:12px; border-radius:12px; margin-top:6px;">
      <div style="display:flex; gap:10px; align-items:center;">
        <div style="font-size:24px;">${icons[t.type] || '📦'}</div>
        <div style="flex:1;">
          <div style="font-size:13px; font-weight:700;">${escapeHtml(preview).slice(0, 60)}</div>
          <div style="font-size:10px; color:var(--textSec);">${escapeHtml(t.type)} · supprimé il y a ${days}j</div>
        </div>
        <button onclick="trashRestore('${t.id}')" style="background:none; border:none; color:var(--success); font-size:18px;">↩</button>
        <button onclick="trashDelForever('${t.id}')" style="background:none; border:none; color:var(--danger); font-size:18px;">✗</button>
      </div>
    </div>`;
  });
  document.getElementById('trash-content').innerHTML = html;
}
function trashRestore(id) {
  const trash = getTrash();
  const t = trash.find(x => x.id === id); if (!t) return;
  toast('↩ Restaurer dans la liste correspondante (manuel pour l\'instant)');
  // Show item to copy
  alert('Élément à recopier :\n\n' + JSON.stringify(t.item, null, 2));
  saveTrash(trash.filter(x => x.id !== id));
  renderTrash();
}
function trashDelForever(id) {
  if (!confirm('Supprimer définitivement ?')) return;
  saveTrash(getTrash().filter(t => t.id !== id));
  renderTrash();
}
function trashEmpty() {
  if (!confirm('Vider toute la corbeille ?')) return;
  saveTrash([]);
  toast('🗑 Vidée');
  renderTrash();
}

// === VERSIONS NOTES ===
async function renderNoteVersions() {
  const versions = JSON.parse(localStorage.getItem('nw_note_versions') || '{}');
  const ids = Object.keys(versions);
  let html = `<p style="font-size:11px; color:var(--textSec);">Garde les <strong>5 dernières versions</strong> de chaque note. Tu peux revenir à une ancienne version.</p>`;
  if (!ids.length) html += '<p style="text-align:center; color:var(--textSec); padding:30px;">Aucune version sauvegardée. Édite des notes pour créer un historique.</p>';
  
  for (const noteId of ids) {
    const vs = versions[noteId];
    if (!vs.length) continue;
    html += `<div style="background:var(--surface); padding:12px; border-radius:12px; margin-top:8px;">
      <div style="font-size:13px; font-weight:700;">📝 Note ${escapeHtml(noteId.slice(0,15))}...</div>
      <div style="font-size:10px; color:var(--textSec); margin-top:2px;">${vs.length} versions sauvegardées</div>`;
    vs.forEach((v, i) => {
      const d = new Date(v.ts).toLocaleString('fr-FR');
      html += `<div style="background:var(--bg); padding:8px; border-radius:8px; margin-top:5px; font-size:11px;">
        <strong>v${vs.length - i}</strong> · ${d}<br>
        <span style="color:var(--textSec); font-style:italic;">${escapeHtml((v.text || '').slice(0,80))}...</span>
        <div style="margin-top:4px; display:flex; gap:4px;">
          <button class="btn alt" onclick="noteVersionShow('${escapeHtml(noteId)}', ${i})" style="font-size:10px; padding:3px 8px;">👁 Voir</button>
        </div>
      </div>`;
    });
    html += `</div>`;
  }
  document.getElementById('noteversions-content').innerHTML = html;
}
function noteVersionShow(noteId, i) {
  const versions = JSON.parse(localStorage.getItem('nw_note_versions') || '{}');
  const v = versions[noteId]?.[i]; if (!v) return;
  alert(`Version du ${new Date(v.ts).toLocaleString('fr-FR')}\n\n${v.text || '(vide)'}`);
}
// Hook : appelle ceci avant de sauvegarder une note pour archiver l'ancienne
function archiveNoteVersion(noteId, oldText) {
  if (!oldText) return;
  const versions = JSON.parse(localStorage.getItem('nw_note_versions') || '{}');
  if (!versions[noteId]) versions[noteId] = [];
  versions[noteId].unshift({ text: oldText, ts: Date.now() });
  if (versions[noteId].length > 5) versions[noteId].length = 5;
  localStorage.setItem('nw_note_versions', JSON.stringify(versions));
}

// === TAGS ===
function getTags() { try { return JSON.parse(localStorage.getItem('nw_tags') || '[]'); } catch { return []; } }
function saveTagsList(d) { localStorage.setItem('nw_tags', JSON.stringify(d)); }
function getItemTags() { try { return JSON.parse(localStorage.getItem('nw_item_tags') || '{}'); } catch { return {}; } }
function saveItemTags(d) { localStorage.setItem('nw_item_tags', JSON.stringify(d)); }
function renderTags() {
  const tags = getTags();
  const itemTags = getItemTags();
  let html = `<p style="font-size:11px; color:var(--textSec);">Crée des tags personnalisés. Pour les associer : tap sur l'élément dans la page concernée.</p>`;
  if (!tags.length) html += '<p style="text-align:center; color:var(--textSec); padding:20px;">Aucun tag. Tap + pour créer.</p>';
  tags.forEach(t => {
    // Compte usages
    const count = Object.values(itemTags).flat().filter(tg => tg === t.id).length;
    html += `<div style="background:var(--surface); padding:10px 14px; border-radius:10px; margin-top:5px; display:flex; gap:10px; align-items:center;">
      <span style="background:${t.color}; color:white; padding:4px 10px; border-radius:8px; font-size:12px; font-weight:700;">${escapeHtml(t.icon || '🏷️')} ${escapeHtml(t.name)}</span>
      <span style="flex:1; font-size:10px; color:var(--textSec);">${count} usages</span>
      <button onclick="tagDel('${t.id}')" style="background:none; border:none; color:var(--danger); font-size:16px;">✗</button>
    </div>`;
  });
  document.getElementById('tags-content').innerHTML = html;
}
function tagAdd() {
  const name = prompt('Nom du tag (ex: Urgent, Idée, Plus tard) :');
  if (!name) return;
  const colors = ['#FF4757','#FF8C42','#FFD166','#5DD68F','#5DADE2','#9B59B6','#FF6FA3'];
  const tags = getTags();
  tags.push({
    id: 'tg_'+Date.now(), name, 
    color: colors[Math.floor(Math.random()*colors.length)],
    icon: prompt('Emoji (optionnel) :', '🏷️') || '🏷️'
  });
  saveTagsList(tags);
  renderTags();
}
function tagDel(id) {
  if (!confirm('Supprimer ce tag ?')) return;
  saveTagsList(getTags().filter(t => t.id !== id));
  // Remove from items
  const it = getItemTags();
  Object.keys(it).forEach(k => { it[k] = (it[k] || []).filter(x => x !== id); });
  saveItemTags(it);
  renderTags();
}

// === TEMPLATES ===
const DEFAULT_TEMPLATES = [
  { id:'tpl_cours', name:'Fiche de cours', icon:'📘', body:'# {{matière}}\n\n## Date : {{date}}\n## Chapitre : {{chapitre}}\n\n## 🎯 Objectifs\n- \n- \n\n## 📝 Notions clés\n- \n\n## 💡 Exemples\n\n\n## ❓ À retenir\n' },
  { id:'tpl_revis', name:'Fiche de révision', icon:'📚', body:'# Révision {{matière}}\n\n## Date interro : {{date}}\n\n## 📖 Notions à savoir\n1. \n2. \n3. \n\n## 🎯 Mots-clés\n\n## 💪 Exercices types\n\n## ❌ Erreurs fréquentes' },
  { id:'tpl_journal', name:'Journal du jour', icon:'📓', body:'# {{date}}\n\n## 😊 Mood\n\n## 🎉 Bons moments\n- \n\n## 😔 Moments difficiles\n- \n\n## 🙏 Gratitude\n- \n\n## 🎯 Objectif demain\n- ' },
  { id:'tpl_recipe', name:'Recette', icon:'🍳', body:'# {{nom de la recette}}\n\n## 👥 Pour {{nb}} personnes\n## ⏱️ {{temps}} minutes\n\n## 🛒 Ingrédients\n- \n- \n\n## 👨‍🍳 Étapes\n1. \n2. \n3. \n\n## 💡 Astuces' },
  { id:'tpl_idee', name:'Brainstorm', icon:'💡', body:'# Idée : {{titre}}\n\n## 🎯 Objectif\n\n## ✅ Avantages\n- \n\n## ⚠️ Inconvénients\n- \n\n## 📋 Étapes\n1. \n2. \n\n## 🚀 Premier pas' }
];
function getTemplates() {
  let tpls;
  try { tpls = JSON.parse(localStorage.getItem('nw_templates') || 'null'); } catch { tpls = null; }
  if (!tpls) {
    tpls = DEFAULT_TEMPLATES;
    localStorage.setItem('nw_templates', JSON.stringify(tpls));
  }
  return tpls;
}
function saveTemplates(d) { localStorage.setItem('nw_templates', JSON.stringify(d)); }
function renderTemplates() {
  const tpls = getTemplates();
  let html = `<p style="font-size:11px; color:var(--textSec);">Modèles prêts à coller dans tes notes. Variables : <code>{{date}}</code>, <code>{{matière}}</code>, etc.</p>`;
  tpls.forEach(t => {
    html += `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:8px;">
      <div style="font-size:14px; font-weight:700;">${escapeHtml(t.icon)} ${escapeHtml(t.name)}</div>
      <pre style="background:var(--bg); padding:10px; border-radius:8px; margin-top:8px; font-size:10px; max-height:120px; overflow:auto; white-space:pre-wrap; line-height:1.4;">${escapeHtml(t.body)}</pre>
      <div style="display:flex; gap:6px; margin-top:8px;">
        <button class="btn primary full" onclick="tplCopy('${t.id}')" style="font-size:11px;">📋 Copier</button>
        <button class="btn alt" onclick="tplDel('${t.id}')" style="font-size:11px; color:var(--danger);">✗</button>
      </div>
    </div>`;
  });
  document.getElementById('templates-content').innerHTML = html;
}
function tplCopy(id) {
  const t = getTemplates().find(x => x.id === id); if (!t) return;
  // Replace variables
  let body = t.body.replace(/\{\{date\}\}/g, new Date().toLocaleDateString('fr-FR'));
  body = body.replace(/\{\{nb\}\}/g, '4');
  navigator.clipboard?.writeText(body);
  toast('📋 Template copié !');
}
function tplAdd() {
  const name = prompt('Nom du template :'); if (!name) return;
  const icon = prompt('Emoji :', '📝') || '📝';
  const body = prompt('Contenu (utilise \\n pour saut de ligne) :');
  if (!body) return;
  const tpls = getTemplates();
  tpls.push({ id:'tpl_'+Date.now(), name, icon, body: body.replace(/\\n/g, '\n') });
  saveTemplates(tpls); renderTemplates();
}
function tplDel(id) {
  if (!confirm('Supprimer ce template ?')) return;
  saveTemplates(getTemplates().filter(t => t.id !== id));
  renderTemplates();
}

// === CHECKLISTS RÉUTILISABLES ===
function getChecklists() { try { return JSON.parse(localStorage.getItem('nw_checklists') || '[]'); } catch { return []; } }
function saveCl(d) { localStorage.setItem('nw_checklists', JSON.stringify(d)); }
function renderChecklists() {
  const lists = getChecklists();
  let html = `<p style="font-size:11px; color:var(--textSec);">Listes réutilisables (sac de gym, voyage...). Tu peux cocher puis reset au prochain usage.</p>`;
  if (!lists.length) html += '<p style="text-align:center; color:var(--textSec); padding:20px;">Aucune liste. Tap + pour créer.</p>';
  lists.forEach(l => {
    const done = l.items.filter(i => i.done).length;
    html += `<div style="background:var(--surface); padding:12px; border-radius:12px; margin-top:8px;">
      <div style="display:flex; justify-content:space-between; align-items:center; cursor:pointer;" onclick="clToggle('${l.id}')">
        <div><div style="font-size:14px; font-weight:700;">${escapeHtml(l.icon || '✓')} ${escapeHtml(l.name)}</div>
        <div style="font-size:10px; color:var(--textSec);">${done}/${l.items.length}</div></div>
        <div style="display:flex; gap:4px;">
          <button onclick="event.stopPropagation(); clReset('${l.id}')" title="Reset" style="background:none; border:none; color:var(--primary); font-size:18px;">↻</button>
          <button onclick="event.stopPropagation(); clDel('${l.id}')" style="background:none; border:none; color:var(--danger); font-size:18px;">✗</button>
        </div>
      </div>
      <div id="cl-${l.id}" style="display:none; margin-top:10px;">
        ${l.items.map((it, i) => `<div onclick="clCheck('${l.id}', ${i})" style="background:var(--bg); padding:8px 10px; border-radius:6px; margin-top:4px; display:flex; gap:8px; align-items:center; cursor:pointer; ${it.done?'opacity:0.6;':''}">
          <span style="width:18px; height:18px; border-radius:4px; border:2px solid var(--primary); background:${it.done?'var(--primary)':'transparent'}; color:white; display:inline-flex; align-items:center; justify-content:center; font-size:11px;">${it.done?'✓':''}</span>
          <span style="${it.done?'text-decoration:line-through;':''}">${escapeHtml(it.text)}</span>
        </div>`).join('')}
        <button class="btn alt full" onclick="clAddItem('${l.id}')" style="margin-top:8px; font-size:11px;">+ Ajouter</button>
      </div>
    </div>`;
  });
  document.getElementById('checklists-content').innerHTML = html;
}
function clToggle(id) { const el = document.getElementById('cl-'+id); el.style.display = el.style.display === 'none' ? 'block' : 'none'; }
function clAdd() {
  const name = prompt('Nom (ex: Sac de gym) :'); if (!name) return;
  const icon = prompt('Emoji :', '✓') || '✓';
  const items = (prompt('Items (un par ligne avec \\n) :') || '').split('\n').filter(s => s.trim()).map(t => ({ text: t.trim(), done: false }));
  const lists = getChecklists();
  lists.unshift({ id:'cl_'+Date.now(), name, icon, items });
  saveCl(lists); renderChecklists();
}
function clCheck(id, i) {
  const lists = getChecklists();
  const l = lists.find(x => x.id === id); if (!l) return;
  l.items[i].done = !l.items[i].done;
  saveCl(lists); renderChecklists();
  document.getElementById('cl-'+id).style.display = 'block';
}
function clReset(id) {
  const lists = getChecklists();
  const l = lists.find(x => x.id === id); if (!l) return;
  l.items.forEach(it => it.done = false);
  saveCl(lists); renderChecklists();
  toast('↻ Reset');
}
function clDel(id) {
  if (!confirm('Supprimer cette liste ?')) return;
  saveCl(getChecklists().filter(l => l.id !== id));
  renderChecklists();
}
function clAddItem(id) {
  const txt = prompt('Item :'); if (!txt) return;
  const lists = getChecklists();
  const l = lists.find(x => x.id === id); if (!l) return;
  l.items.push({ text: txt, done: false });
  saveCl(lists); renderChecklists();
  document.getElementById('cl-'+id).style.display = 'block';
}

// === CETTE SEMAINE ===
async function renderWeek() {
  const now = new Date();
  const dayOfWeek = now.getDay() || 7;
  const monday = new Date(now); monday.setDate(now.getDate() - dayOfWeek + 1);
  monday.setHours(0,0,0,0);
  
  let html = `<div style="background:linear-gradient(135deg,#5DADE2,#3498DB); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">📅</div>
    <div style="font-size:16px; font-weight:800; margin-top:4px;">Semaine du ${monday.toLocaleDateString('fr-FR', {day:'numeric', month:'long'})}</div>
  </div>`;
  
  // Devoirs cette semaine
  try {
    const hw = await dbAll('homework') || [];
    const sun = new Date(monday); sun.setDate(monday.getDate() + 6);
    const sunStr = sun.toISOString().slice(0,10);
    const monStr = monday.toISOString().slice(0,10);
    const weekHw = hw.filter(h => h.due >= monStr && h.due <= sunStr);
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📝 Devoirs (${weekHw.length})</h3>`;
    if (!weekHw.length) html += '<p style="font-size:11px; color:var(--textSec); padding:10px;">Aucun devoir cette semaine 🎉</p>';
    weekHw.sort((a,b) => a.due.localeCompare(b.due)).forEach(h => {
      const d = new Date(h.due);
      html += `<div style="background:var(--surface); padding:10px 14px; border-radius:10px; margin-top:5px; display:flex; gap:8px; ${h.done?'opacity:0.6;':''}">
        <div style="font-size:18px;">${h.done ? '✅' : '📝'}</div>
        <div style="flex:1;">
          <div style="font-size:13px; font-weight:600; ${h.done?'text-decoration:line-through;':''}">${escapeHtml(h.title || h.subject || 'Devoir')}</div>
          <div style="font-size:10px; color:var(--textSec);">${d.toLocaleDateString('fr-FR', {weekday:'short', day:'numeric'})}</div>
        </div>
      </div>`;
    });
  } catch {}
  
  // Mood des 7 derniers jours
  try {
    const moods = JSON.parse(localStorage.getItem('nw_moods') || '{}');
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">🌈 Mood semaine</h3>
      <div style="display:flex; gap:4px; margin-top:6px;">`;
    for (let i = 0; i < 7; i++) {
      const d = new Date(monday); d.setDate(monday.getDate() + i);
      const k = d.toISOString().slice(0,10);
      const m = moods[k];
      const isFut = d > now;
      const isToday = k === new Date().toISOString().slice(0,10);
      html += `<div style="flex:1; background:var(--surface); padding:8px 4px; border-radius:8px; text-align:center; ${isToday?'border:2px solid var(--primary);':''} ${isFut?'opacity:0.4;':''}">
        <div style="font-size:9px; color:var(--textSec);">${d.toLocaleDateString('fr-FR', {weekday:'short'}).slice(0,3)}</div>
        <div style="font-size:22px; margin-top:2px;">${m ? ['😢','😞','😐','🙂','😊','😄','🤩','🥰'][m.level] : '·'}</div>
      </div>`;
    }
    html += `</div>`;
  } catch {}
  
  // Habits semaine
  try {
    const habits = await dbAll('habits') || [];
    const logs = await dbAll('habit_logs') || [];
    if (habits.length) {
      html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">🔁 Habitudes</h3>`;
      habits.forEach(h => {
        let count = 0;
        for (let i = 0; i < 7; i++) {
          const d = new Date(monday); d.setDate(monday.getDate() + i);
          const k = d.toISOString().slice(0,10);
          if (logs.find(l => l.habitId === h.id && l.date === k)) count++;
        }
        const pct = Math.round((count / 7) * 100);
        html += `<div style="background:var(--surface); padding:10px 14px; border-radius:10px; margin-top:5px;">
          <div style="display:flex; justify-content:space-between; font-size:12px;">
            <span>${escapeHtml(h.icon || '🔁')} ${escapeHtml(h.name)}</span>
            <span style="font-weight:700;">${count}/7</span>
          </div>
          <div style="background:var(--bg); height:6px; border-radius:3px; margin-top:5px; overflow:hidden;">
            <div style="background:var(--primary); height:100%; width:${pct}%;"></div>
          </div>
        </div>`;
      });
    }
  } catch {}
  
  document.getElementById('week-content').innerHTML = html;
}

// === HISTORIQUE UNIVERSEL ===
function logHist(action, page, details) {
  const log = JSON.parse(localStorage.getItem('nw_history') || '[]');
  log.unshift({ ts: Date.now(), action, page, details: details || '' });
  if (log.length > 200) log.length = 200;
  localStorage.setItem('nw_history', JSON.stringify(log));
}
function renderHistory() {
  const log = JSON.parse(localStorage.getItem('nw_history') || '[]');
  let html = `<p style="font-size:11px; color:var(--textSec);">Liste des ${log.length} dernières actions (max 200).</p>`;
  if (!log.length) html += '<p style="text-align:center; color:var(--textSec); padding:30px;">Aucune action enregistrée pour le moment.</p>';
  log.slice(0, 100).forEach(l => {
    const d = new Date(l.ts);
    html += `<div style="background:var(--surface); padding:8px 12px; border-radius:8px; margin-top:4px; font-size:12px;">
      <div style="color:var(--primary); font-weight:600;">${escapeHtml(l.action)} ${l.page ? `<span style="color:var(--textSec); font-weight:normal;">→ ${escapeHtml(l.page)}</span>` : ''}</div>
      ${l.details ? `<div style="font-size:10px; color:var(--textSec);">${escapeHtml(l.details)}</div>` : ''}
      <div style="font-size:9px; color:var(--textSec); margin-top:2px;">${d.toLocaleString('fr-FR')}</div>
    </div>`;
  });
  document.getElementById('history-content').innerHTML = html;
}
function histClear() {
  if (!confirm('Vider l\'historique ?')) return;
  localStorage.removeItem('nw_history');
  toast('🗑 Vidé');
  renderHistory();
}

// === ROUTINES MATIN/SOIR ===
function getRoutines() {
  let r;
  try { r = JSON.parse(localStorage.getItem('nw_routines') || 'null'); } catch { r = null; }
  if (!r) {
    r = {
      morning: [
        { text: '💧 Boire un verre d\'eau', done: false },
        { text: '✨ Skincare AM', done: false },
        { text: '🍳 Petit-déjeuner', done: false },
        { text: '📝 Définir 3 missions du jour', done: false },
        { text: '📅 Vérifier l\'EDT du jour', done: false }
      ],
      evening: [
        { text: '✨ Skincare PM', done: false },
        { text: '📝 Préparer mon sac', done: false },
        { text: '📓 Journal / réflexion 5 min', done: false },
        { text: '🙏 1 gratitude', done: false },
        { text: '💤 Pas de tel 30 min avant dodo', done: false }
      ],
      lastReset: new Date().toISOString().slice(0,10)
    };
    localStorage.setItem('nw_routines', JSON.stringify(r));
  }
  // Auto-reset si nouveau jour
  if (r.lastReset !== new Date().toISOString().slice(0,10)) {
    r.morning.forEach(i => i.done = false);
    r.evening.forEach(i => i.done = false);
    r.lastReset = new Date().toISOString().slice(0,10);
    localStorage.setItem('nw_routines', JSON.stringify(r));
  }
  return r;
}
function saveRoutines(r) { localStorage.setItem('nw_routines', JSON.stringify(r)); }
function renderRoutines() {
  const r = getRoutines();
  const mDone = r.morning.filter(i => i.done).length;
  const eDone = r.evening.filter(i => i.done).length;
  let html = `<div style="background:linear-gradient(135deg,#FFD166,#FF8C42); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🌅</div>
    <div style="font-size:16px; font-weight:800;">Matin · ${mDone}/${r.morning.length}</div>
  </div>
  <div style="margin-top:10px;">`;
  r.morning.forEach((it, i) => {
    html += `<div onclick="routineCheck('morning', ${i})" style="background:var(--surface); padding:12px 14px; border-radius:10px; margin-top:5px; display:flex; gap:10px; align-items:center; cursor:pointer; ${it.done?'opacity:0.6;':''}">
      <span style="width:24px; height:24px; border-radius:6px; border:2px solid var(--primary); background:${it.done?'var(--primary)':'transparent'}; color:white; display:inline-flex; align-items:center; justify-content:center; font-size:14px; flex-shrink:0;">${it.done?'✓':''}</span>
      <span style="font-size:14px; ${it.done?'text-decoration:line-through;':''}">${escapeHtml(it.text)}</span>
    </div>`;
  });
  html += `</div>
  <div style="display:flex; gap:6px; margin-top:8px;">
    <button class="btn alt full" onclick="routineAddItem('morning')" style="font-size:11px;">+ Étape matin</button>
  </div>
  
  <div style="background:linear-gradient(135deg,#34495E,#5D2E8C); color:white; padding:14px; border-radius:14px; margin-top:18px; text-align:center;">
    <div style="font-size:36px;">🌙</div>
    <div style="font-size:16px; font-weight:800;">Soir · ${eDone}/${r.evening.length}</div>
  </div>
  <div style="margin-top:10px;">`;
  r.evening.forEach((it, i) => {
    html += `<div onclick="routineCheck('evening', ${i})" style="background:var(--surface); padding:12px 14px; border-radius:10px; margin-top:5px; display:flex; gap:10px; align-items:center; cursor:pointer; ${it.done?'opacity:0.6;':''}">
      <span style="width:24px; height:24px; border-radius:6px; border:2px solid var(--accent); background:${it.done?'var(--accent)':'transparent'}; color:white; display:inline-flex; align-items:center; justify-content:center; font-size:14px; flex-shrink:0;">${it.done?'✓':''}</span>
      <span style="font-size:14px; ${it.done?'text-decoration:line-through;':''}">${escapeHtml(it.text)}</span>
    </div>`;
  });
  html += `</div>
  <div style="display:flex; gap:6px; margin-top:8px;">
    <button class="btn alt full" onclick="routineAddItem('evening')" style="font-size:11px;">+ Étape soir</button>
  </div>
  <p style="font-size:10px; color:var(--textSec); text-align:center; margin-top:14px;">↻ Reset auto chaque jour</p>`;
  document.getElementById('routines-content').innerHTML = html;
}
function routineCheck(period, i) {
  const r = getRoutines();
  r[period][i].done = !r[period][i].done;
  saveRoutines(r); renderRoutines();
}
function routineAddItem(period) {
  const txt = prompt('Étape :'); if (!txt) return;
  const r = getRoutines();
  r[period].push({ text: txt, done: false });
  saveRoutines(r); renderRoutines();
}

