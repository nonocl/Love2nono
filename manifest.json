  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">Accordage standard E A D G B E</h3>`;
  GUITAR_NOTES.forEach(n => {
    html += `<button onclick="tunerPlay(${n.f})" style="display:flex; gap:14px; align-items:center; width:100%; background:var(--surface); padding:14px; border-radius:12px; margin-top:6px; border:none; cursor:pointer; text-align:left;">
