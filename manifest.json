  <div id="ff-result" style="margin-top:14px;"></div>`;
  document.getElementById('fanfic-content').innerHTML = html;
}
function ffGen() {
  const g = FANFIC_GENRES[Math.floor(Math.random()*FANFIC_GENRES.length)];
  const h = FANFIC_HOOKS[Math.floor(Math.random()*FANFIC_HOOKS.length)];
  const t = FANFIC_TWISTS[Math.floor(Math.random()*FANFIC_TWISTS.length)];
  document.getElementById('ff-result').innerHTML = `<div style="background:var(--surface); padding:18px; border-radius:14px;">
