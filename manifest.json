];
let _irregMode = 'list'; // list, quiz
let _irregQuiz = null;
function irregMode() {
  _irregMode = (_irregMode === 'list') ? 'quiz' : 'list';
  if (_irregMode === 'quiz') irregNewQuiz();
  else renderIrreg();
}
function renderIrreg() {
  if (_irregMode === 'list') renderIrregList();
  else renderIrregQuiz();
}
function renderIrregList() {
  let html = `<div style="background:linear-gradient(135deg, #C8102E, #FFFFFF, #012169); color:white; padding:14px; border-radius:14px; text-align:center; text-shadow:0 1px 4px rgba(0,0,0,0.5);">
    <div style="font-size:24px;">🇬🇧</div>
    <div style="font-size:16px; font-weight:800;">76 verbes irréguliers</div>
    <div style="font-size:11px; opacity:0.95; margin-top:2px;">Mode liste · Tap 🎯 pour quiz</div>
  </div>
  <input type="text" class="searchbar" id="irreg-search" placeholder="🔍 Chercher un verbe..." oninput="renderIrregFilter()" style="margin-top:10px;">
  <div style="background:var(--surface); padding:8px; border-radius:10px; margin-top:10px;">
    <div style="display:grid; grid-template-columns:1.2fr 1.2fr 1.2fr 1.5fr; gap:4px; font-size:10px; font-weight:700; color:var(--primary); padding:4px; border-bottom:1px solid var(--border);">
      <div>Base</div><div>Past</div><div>Past part.</div><div>FR</div>
    </div>
    <div id="irreg-list" style="max-height:60vh; overflow-y:auto;"></div>
  </div>`;
  document.getElementById('irreg-content').innerHTML = html;
  renderIrregFilter();
}
function renderIrregFilter() {
  const q = (document.getElementById('irreg-search')?.value || '').toLowerCase();
  const filtered = IRREG_VERBS.filter(v => !q || v.some(w => w.toLowerCase().includes(q)));
  document.getElementById('irreg-list').innerHTML = filtered.map(v => `<div style="display:grid; grid-template-columns:1.2fr 1.2fr 1.2fr 1.5fr; gap:4px; font-size:11px; padding:6px 4px; border-bottom:1px solid var(--border);">
    <div style="font-weight:700;">${escapeHtml(v[0])}</div>
    <div>${escapeHtml(v[1])}</div>
    <div>${escapeHtml(v[2])}</div>
    <div style="color:var(--textSec); font-style:italic;">${escapeHtml(v[3])}</div>
  </div>`).join('') || '<div style="text-align:center; color:var(--textSec); padding:20px;">Aucun résultat</div>';
}
function irregNewQuiz() {
  const verb = IRREG_VERBS[Math.floor(Math.random() * IRREG_VERBS.length)];
  const askField = Math.floor(Math.random() * 3) + 1; // 0=base, 1=past, 2=pp, 3=fr
  // On donne 2 forms et on demande la 3eme
  const showFields = [0,1,2,3].filter(i => i !== askField);
  // Mais on garde toujours le FR (idx 3) en aide
  if (!showFields.includes(3)) showFields.push(3);
  // Et on demande random parmi 0,1,2
  const ask = Math.floor(Math.random() * 3);
  _irregQuiz = { verb, ask, attempts: 0, score: parseInt(localStorage.getItem('nw_irreg_score') || '0'), total: parseInt(localStorage.getItem('nw_irreg_total') || '0') };
  renderIrregQuiz();
}
function renderIrregQuiz() {
  if (!_irregQuiz) { irregNewQuiz(); return; }
  const labels = ['Base form', 'Past simple (V2)', 'Past participle (V3)'];
  const verb = _irregQuiz.verb;
  const ask = _irregQuiz.ask;
  
  let html = `<div style="background:linear-gradient(135deg, #C8102E, #012169); color:white; padding:14px; border-radius:14px;">
    <div style="font-size:11px; opacity:0.85;">🎯 Quiz · Score : ${_irregQuiz.score}/${_irregQuiz.total}</div>
    <div style="font-size:11px; opacity:0.85; margin-top:6px;">Sens : <strong>${escapeHtml(verb[3])}</strong></div>
    <div style="margin-top:10px;">`;
  for (let i = 0; i < 3; i++) {
    if (i === ask) {
      html += `<div style="margin-top:6px;">
        <div style="font-size:11px; opacity:0.85;">${labels[i]} :</div>
        <input type="text" id="irreg-ans" class="input" placeholder="?" style="margin-top:4px; background:rgba(255,255,255,0.2); border-color:rgba(255,255,255,0.4); color:white; font-weight:700;" oninput="this.value = this.value.toLowerCase();" autocomplete="off" autocorrect="off" spellcheck="false">
      </div>`;
    } else {
      html += `<div style="margin-top:6px; font-size:13px;"><span style="opacity:0.7;">${labels[i]} :</span> <strong>${escapeHtml(verb[i])}</strong></div>`;
    }
  }
  html += `</div></div>
  <div style="display:flex; gap:6px; margin-top:14px;">
    <button class="btn primary full" onclick="irregCheck()">✓ Valider</button>
    <button class="btn alt full" onclick="irregNewQuiz()">↷ Passer</button>
  </div>
  <div id="irreg-feedback" style="margin-top:10px; min-height:30px;"></div>
  <button class="btn alt full" onclick="irregMode()" style="margin-top:14px;">← Retour à la liste</button>`;
  document.getElementById('irreg-content').innerHTML = html;
  setTimeout(() => document.getElementById('irreg-ans')?.focus(), 100);
  
  // Enter to validate
  document.getElementById('irreg-ans')?.addEventListener('keypress', e => {
    if (e.key === 'Enter') irregCheck();
  });
}
function irregCheck() {
  const inp = document.getElementById('irreg-ans');
  if (!inp || !_irregQuiz) return;
  const ans = inp.value.trim().toLowerCase();
  if (!ans) return;
  const correct = _irregQuiz.verb[_irregQuiz.ask].toLowerCase();
  // Accepte les variantes (split sur /)
  const validAnswers = correct.split('/').map(s => s.trim());
  const isCorrect = validAnswers.includes(ans);
  _irregQuiz.total++;
  if (isCorrect) _irregQuiz.score++;
  localStorage.setItem('nw_irreg_score', _irregQuiz.score);
  localStorage.setItem('nw_irreg_total', _irregQuiz.total);
  
  const fb = document.getElementById('irreg-feedback');
  if (isCorrect) {
    fb.innerHTML = `<div style="background:#5DD68F; color:white; padding:10px; border-radius:10px; text-align:center; font-weight:700;">✓ Bravo !</div>`;
    setTimeout(() => irregNewQuiz(), 1000);
  } else {
    fb.innerHTML = `<div style="background:var(--danger); color:white; padding:10px; border-radius:10px; text-align:center; font-weight:700;">✗ Faux. La bonne réponse était <strong>${escapeHtml(correct)}</strong></div>`;
    setTimeout(() => irregNewQuiz(), 2200);
  }
}

