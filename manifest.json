  }
  const item = _aqState.deck[_aqState.q];
  document.getElementById('article-quiz').innerHTML = `
    <div style="background:var(--surface); padding:18px; border-radius:14px; margin-top:14px; text-align:center;">
      <div style="font-size:11px; color:var(--textSec);">Quiz article défini · ${_aqState.q+1}/${_aqState.deck.length}</div>
      <div style="font-size:24px; font-weight:800; margin:14px 0;">__ ${item.word}</div>
      <div style="display:flex; gap:6px; flex-wrap:wrap; justify-content:center;">
