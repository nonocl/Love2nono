function renderBase64() {
  let html = `<div style="background:linear-gradient(135deg,#787C7E,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🔤</div><div style="font-size:16px; font-weight:800;">Base64 encoder/decoder</div>
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📝 Texte clair</h3>
  <textarea id="b64-plain" class="input" rows="4" placeholder="Hello world" oninput="b64Encode()"></textarea>
  <div style="text-align:center; margin:10px 0; font-size:18px; color:var(--primary);">↕</div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary);">🔐 Base64</h3>
  <textarea id="b64-encoded" class="input" rows="4" placeholder="SGVsbG8gd29ybGQ=" oninput="b64Decode()"></textarea>
  <div id="b64-error" style="color:#E14D6B; font-size:11px; margin-top:6px;"></div>
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:14px;">
    <button class="btn alt" onclick="b64Copy('plain')" style="font-size:12px;">📋 Copier clair</button>
    <button class="btn alt" onclick="b64Copy('encoded')" style="font-size:12px;">📋 Copier b64</button>
  </div>`;
  document.getElementById('base64-content').innerHTML = html;
}
function b64Encode() {
  try {
    const t = document.getElementById('b64-plain').value;
    const enc = btoa(unescape(encodeURIComponent(t)));
    document.getElementById('b64-encoded').value = enc;
    document.getElementById('b64-error').textContent = '';
  } catch (e) { document.getElementById('b64-error').textContent = e.message; }
}
function b64Decode() {
  try {
    const t = document.getElementById('b64-encoded').value.trim();
    if (!t) { document.getElementById('b64-plain').value = ''; document.getElementById('b64-error').textContent = ''; return; }
    const dec = decodeURIComponent(escape(atob(t)));
    document.getElementById('b64-plain').value = dec;
    document.getElementById('b64-error').textContent = '';
  } catch (e) { document.getElementById('b64-error').textContent = 'Base64 invalide'; }
}
function b64Copy(which) {
  const v = document.getElementById('b64-' + which).value;
  navigator.clipboard.writeText(v).then(() => toast('📋 Copié'));
}

