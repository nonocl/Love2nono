  <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:4px;">
    <button class="btn primary" onclick="_stkShape='circle'; stkRender()" id="stk-circle">⭕ Cercle</button>
    <button class="btn alt" onclick="_stkShape='square'; stkRender()" id="stk-square">⬜ Carré</button>
    <button class="btn alt" onclick="_stkShape='heart'; stkRender()" id="stk-heart">💗 Cœur</button>
  </div>
  
  <div id="stk-preview" style="margin-top:18px; text-align:center;"></div>
  <button class="btn primary full" onclick="stkDownload()" style="margin-top:10px;">💾 Télécharger</button>`;
  document.getElementById('stickermk-content').innerHTML = html;
  stkRender();
}
function stkRender() {
  ['circle','square','heart'].forEach(s => {
    const el = document.getElementById('stk-'+s);
    if (el) el.className = s === _stkShape ? 'btn primary' : 'btn alt';
  });
  let shape = '';
  if (_stkShape === 'circle') shape = 'border-radius:50%;';
  else if (_stkShape === 'square') shape = 'border-radius:24px;';
  else shape = 'border-radius:50% 50% 50% 50% / 60% 60% 40% 40%; transform:rotate(-3deg);';
  
  document.getElementById('stk-preview').innerHTML = `<div id="stk-card" style="display:inline-block; width:200px; height:200px; background:${_stkBg}; ${shape} display:flex; flex-direction:column; align-items:center; justify-content:center; color:${_stkColor}; box-shadow:0 6px 20px rgba(0,0,0,0.15); border:4px solid white;">
    <div style="font-size:60px;">${escapeHtml(_stkEmoji)}</div>
    <div style="font-size:18px; font-weight:900; margin-top:4px;">${escapeHtml(_stkText)}</div>
  </div>`;
}
function stkDownload() {
  const c = document.createElement('canvas');
  c.width = 600; c.height = 600;
  const ctx = c.getContext('2d');
  ctx.fillStyle = 'transparent';
  if (_stkShape === 'circle') {
    ctx.beginPath();
    ctx.arc(300, 300, 280, 0, 2*Math.PI);
    ctx.fillStyle = 'white'; ctx.fill();
    ctx.strokeStyle = 'white'; ctx.lineWidth = 12; ctx.stroke();
    ctx.beginPath(); ctx.arc(300, 300, 274, 0, 2*Math.PI);
    ctx.fillStyle = _stkBg; ctx.fill();
  } else if (_stkShape === 'square') {
    ctx.fillStyle = 'white'; ctx.fillRect(20, 20, 560, 560);
    ctx.fillStyle = _stkBg; ctx.fillRect(32, 32, 536, 536);
  } else {
    ctx.fillStyle = _stkBg;
    ctx.fillRect(20, 20, 560, 560);
  }
  ctx.fillStyle = _stkColor;
  ctx.textAlign = 'center';
  ctx.font = '180px sans-serif';
  ctx.fillText(_stkEmoji, 300, 320);
  ctx.font = '900 48px sans-serif';
  ctx.fillText(_stkText, 300, 420);
  c.toBlob(b => {
    const a = document.createElement('a');
    a.href = URL.createObjectURL(b);
    a.download = `sticker-${Date.now()}.png`;
    a.click();
  });
}

