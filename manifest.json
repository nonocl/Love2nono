// === 1. MISSION DU JOUR ===
function getMission() {
  const today = todayKey();
  let m;
  try { m = JSON.parse(localStorage.getItem('nw_mission_'+today) || 'null'); } catch { m = null; }
  if (!m) m = { goals: ['', '', ''], done: [false, false, false] };
  return m;
}
function saveMission(m) {
  localStorage.setItem('nw_mission_'+todayKey(), JSON.stringify(m));
}
function renderMission() {
  const m = getMission();
  const today = new Date();
  const dateStr = today.toLocaleDateString('fr-FR', { weekday:'long', day:'numeric', month:'long' });
  const completed = m.done.filter(Boolean).length;
  const allFilled = m.goals.every(g => g.trim());
  
  // Streak
  let streak = 0;
  for (let i = 0; i < 365; i++) {
    const d = new Date(); d.setDate(d.getDate() - i);
    const k = d.toISOString().slice(0,10);
    let log; try { log = JSON.parse(localStorage.getItem('nw_mission_'+k) || 'null'); } catch { log = null; }
    if (log && log.done && log.done.filter(Boolean).length === 3 && log.goals.every(g => g.trim())) streak++;
    else if (i > 0) break;
  }
  
  let html = `<div style="background:linear-gradient(135deg, #FF4757, #FF8C42); color:white; padding:16px; border-radius:18px; text-align:center;">
    <div style="font-size:11px; opacity:0.85; text-transform:capitalize;">${dateStr}</div>
    <div style="font-size:28px; font-weight:900; margin-top:4px;">🎯 Mission du jour</div>
    <div style="font-size:13px; opacity:0.9; margin-top:4px;">${completed}/3 complétées${streak > 0 ? ` · 🔥 streak ${streak}j` : ''}</div>
  </div>
  <p style="font-size:11px; color:var(--textSec); margin-top:10px;">Définis 3 objectifs concrets pour aujourd'hui. Cocher = victoire.</p>`;
  
  for (let i = 0; i < 3; i++) {
    const isDone = m.done[i];
    html += `<div style="background:var(--surface); padding:12px; border-radius:14px; margin-top:10px; ${isDone ? 'opacity:0.6;' : ''} display:flex; gap:10px; align-items:center;">
      <button onclick="missionToggle(${i})" style="width:34px; height:34px; border-radius:50%; background:${isDone ? 'var(--success)' : 'transparent'}; border:2px solid ${isDone ? 'var(--success)' : 'var(--border)'}; color:white; font-size:18px; cursor:pointer; flex-shrink:0;">${isDone ? '✓' : ''}</button>
      <input type="text" value="${escapeHtml(m.goals[i])}" placeholder="Objectif ${i+1}..." oninput="missionEdit(${i}, this.value)" style="flex:1; background:transparent; border:none; color:var(--text); font-size:14px; font-weight:600; outline:none; ${isDone ? 'text-decoration:line-through;' : ''}">
    </div>`;
  }
  
  if (completed === 3 && allFilled) {
    html += `<div style="background:linear-gradient(135deg, #5DD68F, #06FFA5); color:white; padding:18px; border-radius:14px; margin-top:14px; text-align:center;">
      <div style="font-size:36px;">🏆</div>
      <div style="font-size:16px; font-weight:800; margin-top:6px;">Mission accomplie !</div>
      <div style="font-size:12px; opacity:0.95; margin-top:4px;">+ ${streak > 0 ? streak + 'e' : '1er'} jour de streak</div>
    </div>`;
  }
  
  html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:18px;">💡 Idées d'objectifs</h3>
    <div style="font-size:11px; color:var(--textSec); line-height:1.7; background:var(--surface); padding:10px; border-radius:10px; margin-top:6px;">
    • Faire ${(typeof PAGE_INDEX !== 'undefined') ? '20 min de révisions Italien' : '20 min de révisions'}<br>
    • Boire 2L d'eau<br>
    • Finir mes devoirs de maths<br>
    • Aller courir 30 min<br>
    • Lire 20 pages<br>
    • Méditer 10 min<br>
    • Appeler quelqu'un que j'aime
    </div>`;
  
  document.getElementById('mission-content').innerHTML = html;
}
function missionToggle(i) {
  const m = getMission();
  m.done[i] = !m.done[i];
  saveMission(m); renderMission();
  if (m.done[i] && m.done.filter(Boolean).length === 3 && m.goals.every(g => g.trim())) {
    if (navigator.vibrate) navigator.vibrate([100,50,100,50,200]);
    toast('🏆 Mission accomplie !');
  }
}
function missionEdit(i, val) {
  const m = getMission();
  m.goals[i] = val;
  saveMission(m);
  // Pas de re-render pour pas perdre le focus
}
function missionReset() {
  if (!confirm('Réinitialiser tes 3 objectifs du jour ?')) return;
  saveMission({ goals:['','',''], done:[false,false,false] });
  renderMission();
}

// === 5. BILAN AUTO ===
async function renderBilan() {
  const today = todayKey();
  const now = new Date();
  
  // Récolte des données
  const data = {};
  
  // Mission du jour
  let mission; try { mission = JSON.parse(localStorage.getItem('nw_mission_'+today) || 'null'); } catch { mission = null; }
  if (mission) data.mission = mission.done.filter(Boolean).length;
  
  // Devoirs faits
  try {
    const hw = (await dbAll('homework')) || [];
    data.hwTotal = hw.length;
    data.hwDone = hw.filter(h => h.done).length;
    data.hwUrgent = hw.filter(h => !h.done && h.due && h.due <= today).length;
  } catch {}
  
  // Habits
  try {
    const habits = (await dbAll('habits')) || [];
    const logs = (await dbAll('habit_logs')) || [];
    const todayLogs = logs.filter(l => l.date === today);
    data.habitsTotal = habits.length;
    data.habitsDone = todayLogs.length;
  } catch {}
  
  // Hydra
  try {
    const hyd = JSON.parse(localStorage.getItem('nw_hydra') || '{}')[today] || 0;
    data.hyd = hyd;
    data.hydGoal = parseInt(localStorage.getItem('nw_hydra_goal') || 2000);
  } catch {}
  
  // Mood
  try {
    const moods = JSON.parse(localStorage.getItem('nw_moods') || '{}');
    if (moods[today]?.level !== undefined) data.mood = moods[today].level;
  } catch {}
  
  // Sport (muscu / fit)
  try {
    const fit = JSON.parse(localStorage.getItem('nw_fit') || '{}')[today] || {};
    data.fitCount = Object.values(fit).reduce((s, v) => s + v, 0);
    const muscu = JSON.parse(localStorage.getItem('nw_muscu_log') || '[]');
    data.muscuToday = muscu.filter(l => l.date && l.date.startsWith(today)).length;
  } catch {}
  
  // Focus
  try {
    const focusData = JSON.parse(localStorage.getItem('nw_focus') || '[]');
    data.focusMins = focusData.filter(s => s.date && s.date.startsWith(today)).reduce((s,x) => s + x.duration, 0);
  } catch {}
  
  // Skincare
  try {
    const skin = JSON.parse(localStorage.getItem('nw_skin') || '{"log":{}}');
    const todaySkin = skin.log[today];
    if (todaySkin) data.skinDone = (todaySkin.am || []).length + (todaySkin.pm || []).length;
  } catch {}
  
  // Score auto
  let score = 0;
  if (data.mission) score += data.mission * 5;
  if (data.hwDone) score += data.hwDone * 3;
  if (data.habitsDone) score += data.habitsDone * 4;
  if (data.hyd && data.hydGoal && data.hyd / data.hydGoal >= 0.8) score += 10;
  if (data.fitCount > 30) score += 8;
  if (data.muscuToday > 0) score += 12;
  if (data.focusMins >= 60) score += 8;
  if (data.skinDone >= 3) score += 5;
  
  let mood;
  if (score >= 50) mood = { color:'#5DD68F', emoji:'🚀', text:'Journée exceptionnelle !' };
  else if (score >= 30) mood = { color:'#06FFA5', emoji:'✨', text:'Excellente journée' };
  else if (score >= 15) mood = { color:'#FFD166', emoji:'👍', text:'Journée correcte' };
  else if (score >= 5) mood = { color:'#FF8C42', emoji:'😐', text:'Demain mieux' };
  else mood = { color:'#FF4757', emoji:'😴', text:'Journée chill' };
  
  let html = `<div style="background:linear-gradient(135deg, ${mood.color}, ${mood.color}AA); color:white; padding:18px; border-radius:18px; text-align:center;">
    <div style="font-size:60px;">${mood.emoji}</div>
    <div style="font-size:32px; font-weight:900;">${score} pts</div>
    <div style="font-size:14px; opacity:0.9; margin-top:4px;">${mood.text}</div>
    <div style="font-size:10px; opacity:0.7; margin-top:6px;">${now.toLocaleDateString('fr-FR', {weekday:'long', day:'numeric', month:'long'})}</div>
  </div>`;
  
  html += `<h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-top:18px;">📊 Détails</h3>`;
  
  const items = [];
  if (data.mission !== undefined) items.push({ico:'🎯', name:'Mission du jour', val:`${data.mission}/3`, ok:data.mission >= 2});
  if (data.hwTotal) items.push({ico:'📝', name:'Devoirs', val:`${data.hwDone}/${data.hwTotal}`, ok:data.hwUrgent === 0});
  if (data.habitsTotal) items.push({ico:'🔁', name:'Habitudes', val:`${data.habitsDone}/${data.habitsTotal}`, ok:data.habitsDone >= data.habitsTotal/2});
  if (data.hyd !== undefined) items.push({ico:'💧', name:'Hydratation', val:`${data.hyd}/${data.hydGoal}ml`, ok:data.hyd >= data.hydGoal*0.8});
  if (data.mood !== undefined) items.push({ico:'🌈', name:'Humeur', val:['😢','😞','😐','🙂','😊','😄','🤩','🥰'][data.mood] || '?', ok:data.mood >= 3});
  if (data.fitCount) items.push({ico:'💪', name:'Sport (compteurs)', val:data.fitCount, ok:data.fitCount > 30});
  if (data.muscuToday) items.push({ico:'🏋️', name:'Séance muscu', val:'✓', ok:true});
  if (data.focusMins) items.push({ico:'🎯', name:'Focus', val:`${data.focusMins} min`, ok:data.focusMins >= 60});
  if (data.skinDone) items.push({ico:'✨', name:'Skincare', val:data.skinDone + ' étapes', ok:data.skinDone >= 3});
  
  if (!items.length) {
    html += `<div style="background:var(--surface); padding:18px; border-radius:14px; text-align:center; color:var(--textSec); font-size:13px;">Pas encore de données aujourd'hui. Lance-toi sur quelques fonctionnalités pour avoir un bilan !</div>`;
  } else {
    items.forEach(it => {
      html += `<div style="background:var(--surface); padding:10px 14px; border-radius:10px; margin-bottom:4px; display:flex; gap:10px; align-items:center; border-left:3px solid ${it.ok ? 'var(--success)' : 'var(--danger)'};">
        <div style="font-size:22px;">${it.ico}</div>
        <div style="flex:1;">
          <div style="font-size:13px; font-weight:600;">${escapeHtml(it.name)}</div>
        </div>
        <div style="font-size:14px; font-weight:800; color:${it.ok ? 'var(--success)' : 'var(--textSec)'};">${escapeHtml(String(it.val))}</div>
      </div>`;
    });
  }
  
  // Histoire des 7 derniers jours
  html += `<h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-top:18px;">📅 7 derniers jours</h3>
    <div style="display:flex; gap:4px; margin-top:8px;">`;
  for (let i = 6; i >= 0; i--) {
    const d = new Date(); d.setDate(d.getDate() - i);
    const k = d.toISOString().slice(0,10);
    let dayMood; try { 
      const moods = JSON.parse(localStorage.getItem('nw_moods') || '{}');
      dayMood = moods[k]?.level;
    } catch {}
    const dayName = d.toLocaleDateString('fr-FR', {weekday:'short'}).slice(0,3);
    html += `<div style="flex:1; background:var(--surface); padding:8px 4px; border-radius:8px; text-align:center;">
      <div style="font-size:9px; color:var(--textSec);">${dayName}</div>
      <div style="font-size:22px; margin-top:2px;">${dayMood !== undefined ? ['😢','😞','😐','🙂','😊','😄','🤩','🥰'][dayMood] : '·'}</div>
    </div>`;
  }
  html += `</div>`;
  
  document.getElementById('bilan-content').innerHTML = html;
}

// === 21. SOLVEUR D'ÉQUATIONS ===
function eqSolve() {
  const inp = document.getElementById('eq-input').value.trim();
  const out = document.getElementById('eq-result');
  if (!inp) { out.innerHTML = ''; return; }
  
  const result = solveEquation(inp);
  if (result.error) {
    out.innerHTML = `<div style="background:var(--surface); padding:12px; border-radius:10px; color:var(--danger); font-size:12px;">⚠️ ${escapeHtml(result.error)}</div>`;
    return;
  }
  
  let html = `<div style="background:linear-gradient(135deg, var(--primary), var(--accent)); color:white; padding:14px; border-radius:14px;">
    <div style="font-size:11px; opacity:0.85;">Type : ${escapeHtml(result.type)}</div>
    <div style="font-size:13px; font-family:monospace; margin-top:4px;">${escapeHtml(result.equation)}</div>
    <div style="font-size:11px; opacity:0.85; margin-top:8px;">Solution${result.solutions.length > 1 ? 's' : ''} :</div>`;
  result.solutions.forEach(s => {
    html += `<div style="font-size:22px; font-weight:900; margin-top:2px;">${escapeHtml(s)}</div>`;
  });
  html += `</div>`;
  
  if (result.steps && result.steps.length) {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📝 Étapes</h3>`;
    result.steps.forEach((s, i) => {
      html += `<div style="background:var(--surface); padding:10px 14px; border-radius:10px; margin-top:4px;">
        <div style="font-size:10px; color:var(--textSec); font-weight:700;">Étape ${i+1}</div>
        <div style="font-size:13px; font-family:monospace; margin-top:2px;">${escapeHtml(s)}</div>
      </div>`;
    });
  }
  
  out.innerHTML = html;
}

function solveEquation(input) {
  // Normalise
  let eq = input.replace(/\s/g, '').replace(/²/g, '^2').replace(/³/g, '^3');
  // Doit contenir =
  if (!eq.includes('=')) return { error: 'L\'équation doit contenir un signe =' };
  const parts = eq.split('=');
  if (parts.length !== 2) return { error: 'Une seule équation à la fois' };
  
  // Tout passer à gauche : left - right = 0
  // On parse left et right en termes
  function parseTerms(side) {
    // Remplace -- par +, +- par -, etc. 
    side = side.replace(/--/g, '+').replace(/\+-/g, '-').replace(/-\+/g, '-').replace(/\+\+/g, '+');
    // Insère + devant si commence pas par +/-
    if (!/^[\+\-]/.test(side)) side = '+' + side;
    // Tokenize
    const tokens = side.match(/[\+\-][^\+\-]+/g) || [];
    let a2 = 0, a1 = 0, a0 = 0;
    for (let t of tokens) {
      const sign = t[0] === '-' ? -1 : 1;
      let term = t.substring(1);
      if (!term) continue;
      // Cherche x^2 ou x²
      if (term.includes('x^2') || term.includes('x²')) {
        const coef = term.replace('x^2', '').replace('x²', '').replace('*', '');
        a2 += sign * (coef === '' ? 1 : parseFloat(coef));
      } else if (term.includes('x')) {
        const coef = term.replace('x', '').replace('*', '');
        a1 += sign * (coef === '' ? 1 : parseFloat(coef));
      } else {
        a0 += sign * parseFloat(term);
      }
    }
    return { a2, a1, a0 };
  }
  
  let left, right;
  try {
    left = parseTerms(parts[0]);
    right = parseTerms(parts[1]);
  } catch (e) {
    return { error: 'Impossible de parser l\'équation' };
  }
  
  const a = left.a2 - right.a2;
  const b = left.a1 - right.a1;
  const c = left.a0 - right.a0;
  
  if (Math.abs(a) < 1e-10) {
    // Linéaire : bx + c = 0
    if (Math.abs(b) < 1e-10) {
      if (Math.abs(c) < 1e-10) return { error: '0 = 0 : infinité de solutions' };
      return { error: 'Pas de solution' };
    }
    const x = -c / b;
    return {
      type: 'Équation linéaire',
      equation: `${b}x ${c >= 0 ? '+' : ''} ${c} = 0`,
      solutions: ['x = ' + (Math.abs(x - Math.round(x)) < 1e-9 ? Math.round(x) : x.toFixed(4).replace(/\.?0+$/, ''))],
      steps: [
        `${b}x + ${c} = 0`,
        `${b}x = ${-c}`,
        `x = ${-c} / ${b}`,
        `x = ${(Math.abs(x - Math.round(x)) < 1e-9 ? Math.round(x) : x.toFixed(4).replace(/\.?0+$/, ''))}`
      ]
    };
  } else {
    // Second degré : ax² + bx + c = 0
    const disc = b*b - 4*a*c;
    const eqStr = `${a}x² ${b >= 0 ? '+' : ''} ${b}x ${c >= 0 ? '+' : ''} ${c} = 0`;
    if (disc < 0) {
      return {
        type: 'Équation du 2nd degré',
        equation: eqStr,
        solutions: ['Pas de solution réelle (Δ < 0)'],
        steps: [`Δ = b² - 4ac = ${b}² - 4·${a}·${c} = ${disc.toFixed(2)}`, 'Δ < 0 donc pas de solution réelle']
      };
    } else if (Math.abs(disc) < 1e-10) {
      const x = -b / (2*a);
      return {
        type: 'Équation du 2nd degré',
        equation: eqStr,
        solutions: ['x = ' + (Math.abs(x - Math.round(x)) < 1e-9 ? Math.round(x) : x.toFixed(4).replace(/\.?0+$/, '')) + ' (double)'],
        steps: [`Δ = ${disc.toFixed(2)} = 0`, `Solution double : x = -b/2a = ${(-b)}/${(2*a)} = ${x}`]
      };
    } else {
      const sd = Math.sqrt(disc);
      const x1 = (-b - sd) / (2*a);
      const x2 = (-b + sd) / (2*a);
      const fmt = x => Math.abs(x - Math.round(x)) < 1e-9 ? Math.round(x) : x.toFixed(4).replace(/\.?0+$/, '');
      return {
        type: 'Équation du 2nd degré',
        equation: eqStr,
        solutions: [`x₁ = ${fmt(x1)}`, `x₂ = ${fmt(x2)}`],
        steps: [
          `Δ = b² - 4ac = ${b*b} - 4·${a}·${c} = ${disc.toFixed(2)}`,
          `Δ > 0 → 2 solutions`,
          `x₁ = (-b - √Δ)/(2a) = (${-b} - ${sd.toFixed(3)})/${2*a} = ${fmt(x1)}`,
          `x₂ = (-b + √Δ)/(2a) = (${-b} + ${sd.toFixed(3)})/${2*a} = ${fmt(x2)}`
        ]
      };
    }
  }
}

function eqRenderExamples() {
  const examples = ['2x+5=15', 'x²-5x+6=0', '3x-7=2x+5', 'x²=9', '4(x-2)=12', '2x²+8x=0'];
  document.getElementById('eq-examples').innerHTML = examples.map(e => 
    `<button class="btn alt" onclick="document.getElementById('eq-input').value='${e}'; eqSolve();" style="font-family:monospace; font-size:12px; padding:8px;">${e}</button>`
  ).join('');
}

// === 34. VITESSE-DISTANCE-TEMPS ===
function vdtCalc(changed) {
  const v = parseFloat(document.getElementById('vdt-v').value);
  const d = parseFloat(document.getElementById('vdt-d').value);
  const t = parseFloat(document.getElementById('vdt-t').value);
  
  let result = '';
  let calculatedField = null, calculatedValue = null;
  
  if (changed === 'v') {
    if (!isNaN(v) && !isNaN(d)) {
      const newT = d / v;
      document.getElementById('vdt-t').value = newT.toFixed(2);
      calculatedField = 't'; calculatedValue = newT;
    } else if (!isNaN(v) && !isNaN(t)) {
      const newD = v * t;
      document.getElementById('vdt-d').value = newD.toFixed(2);
      calculatedField = 'd'; calculatedValue = newD;
    }
  } else if (changed === 'd') {
    if (!isNaN(d) && !isNaN(v)) {
      const newT = d / v;
      document.getElementById('vdt-t').value = newT.toFixed(2);
      calculatedField = 't'; calculatedValue = newT;
    } else if (!isNaN(d) && !isNaN(t)) {
      const newV = d / t;
      document.getElementById('vdt-v').value = newV.toFixed(2);
      calculatedField = 'v'; calculatedValue = newV;
    }
  } else if (changed === 't') {
    if (!isNaN(t) && !isNaN(d)) {
      const newV = d / t;
      document.getElementById('vdt-v').value = newV.toFixed(2);
      calculatedField = 'v'; calculatedValue = newV;
    } else if (!isNaN(t) && !isNaN(v)) {
      const newD = v * t;
      document.getElementById('vdt-d').value = newD.toFixed(2);
      calculatedField = 'd'; calculatedValue = newD;
    }
  }
  
  if (calculatedField) {
    const labels = {v:'Vitesse', d:'Distance', t:'Temps'};
    const units = {v:'km/h', d:'km', t:'h'};
    let extra = '';
    if (calculatedField === 'v') extra = ` (${(calculatedValue/3.6).toFixed(2)} m/s)`;
    if (calculatedField === 't') {
      const h = Math.floor(calculatedValue);
      const m = Math.round((calculatedValue - h) * 60);
      extra = ` (${h}h ${m}min)`;
    }
    result = `<div style="background:linear-gradient(135deg, var(--primary), var(--accent)); color:white; padding:14px; border-radius:14px;">
      <div style="font-size:11px; opacity:0.85;">Calculé automatiquement</div>
      <div style="font-size:24px; font-weight:900;">${labels[calculatedField]} = ${calculatedValue.toFixed(2)} ${units[calculatedField]}${extra}</div>
    </div>`;
  }
  document.getElementById('vdt-result').innerHTML = result;
}
function vdtReset() {
  ['vdt-v','vdt-d','vdt-t'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('vdt-result').innerHTML = '';
}

// === 35. DILUTION ===
function dilCalc(changed) {
  const c1 = parseFloat(document.getElementById('dil-c1').value);
  const v1 = parseFloat(document.getElementById('dil-v1').value);
  const c2 = parseFloat(document.getElementById('dil-c2').value);
  const v2 = parseFloat(document.getElementById('dil-v2').value);
  
  // C1V1 = C2V2 → résoudre celui qui est vide
  let result = '';
  const filled = [c1, v1, c2, v2].filter(v => !isNaN(v)).length;
  if (filled !== 3) {
    document.getElementById('dil-result').innerHTML = filled < 3 ? `<div style="font-size:11px; color:var(--textSec); text-align:center;">Remplis encore ${3-filled} valeur${3-filled>1?'s':''}</div>` : '';
    return;
  }
  
  let label = '', value = 0, unit = '';
  if (isNaN(c1)) { value = (c2 * v2) / v1; label = 'C₁'; unit = 'mol/L'; document.getElementById('dil-c1').value = value.toFixed(4); }
  else if (isNaN(v1)) { value = (c2 * v2) / c1; label = 'V₁'; unit = 'mL'; document.getElementById('dil-v1').value = value.toFixed(2); }
  else if (isNaN(c2)) { value = (c1 * v1) / v2; label = 'C₂'; unit = 'mol/L'; document.getElementById('dil-c2').value = value.toFixed(4); }
  else if (isNaN(v2)) { value = (c1 * v1) / c2; label = 'V₂'; unit = 'mL'; document.getElementById('dil-v2').value = value.toFixed(2); }
  
  result = `<div style="background:linear-gradient(135deg, var(--primary), var(--accent)); color:white; padding:14px; border-radius:14px;">
    <div style="font-size:11px; opacity:0.85;">C₁V₁ = C₂V₂</div>
    <div style="font-size:24px; font-weight:900;">${label} = ${value.toFixed(4)} ${unit}</div>`;
  if (label.startsWith('V') && value > 0) {
    const eauAjoutee = (label === 'V₂') ? value - (v1 || 0) : (v2 || 0) - value;
    if (!isNaN(eauAjoutee) && eauAjoutee > 0) result += `<div style="font-size:11px; opacity:0.85; margin-top:4px;">💧 Eau à ajouter : ${eauAjoutee.toFixed(2)} mL</div>`;
  }
  result += `</div>`;
  document.getElementById('dil-result').innerHTML = result;
}
function dilReset() {
  ['dil-c1','dil-v1','dil-c2','dil-v2'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('dil-result').innerHTML = '';
}
function concCalc() {
  const n = parseFloat(document.getElementById('conc-n').value);
  const v = parseFloat(document.getElementById('conc-v').value);
  if (isNaN(n) || isNaN(v) || v === 0) { document.getElementById('conc-result').innerHTML = ''; return; }
  const c = n / v;
  document.getElementById('conc-result').innerHTML = `<strong style="color:var(--primary);">C = ${c.toFixed(4)} mol/L</strong>`;
}



