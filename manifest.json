// ============================================================
// BACKUP
// ============================================================
async function exportFullBackup() {
  try {
    const data = { exported:new Date().toISOString(), version:'1.0', stores:{} };
    const stores = ['pfps','categories','albums','pfp_cats','pfp_albums','counters','countdowns','bdays','habits','habit_logs','wishes','quotes','moods','notes','palettes','tracks','playlists','playlist_tracks','watchlist','music_cats','track_cats','grades','homework','classes','decks','cards','friends','expenses','vault','videos','wallet_tx','events','game_scores','sobriety','sleep_log','weight_log','wheels','kv'];
    for (const s of stores) {
      try { data.stores[s] = await dbAll(s); } catch {}
    }
    // localStorage
    data.localStorage = {};
    for (let i=0; i<localStorage.length; i++) {
      const k = localStorage.key(i);
      if (k && k.startsWith('nw_')) data.localStorage[k] = localStorage.getItem(k);
    }
    const blob = new Blob([JSON.stringify(data, null, 2)], { type:'application/json' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `nono-backup-${new Date().toISOString().slice(0,10)}.json`;
    a.click();
    localStorage.setItem('nw_lastBkp', new Date().toISOString());
    document.getElementById('bkp-status').innerHTML = `<span style="color:var(--success);">✅ Backup créé !</span>`;
  } catch (e) {
    document.getElementById('bkp-status').innerHTML = `<span style="color:var(--danger);">❌ ${e.message}</span>`;
  }
}
async function importFullBackup() {
  const f = document.getElementById('bkp-file').files[0];
  if (!f) { toast('Choisis un fichier'); return; }
  if (!confirm('⚠️ Cela va REMPLACER toutes tes données actuelles. Continuer ?')) return;
  try {
    const text = await f.text();
    const data = JSON.parse(text);
    for (const [s, items] of Object.entries(data.stores || {})) {
      if (!Array.isArray(items)) continue;
      try {
        const tx = db.transaction(s, 'readwrite');
        const store = tx.objectStore(s);
        await new Promise(r => { const req = store.clear(); req.onsuccess = r; req.onerror = r; });
        for (const item of items) try { store.add(item); } catch {}
      } catch {}
    }
    if (data.localStorage) for (const [k,v] of Object.entries(data.localStorage)) localStorage.setItem(k, v);
    document.getElementById('bkp-status').innerHTML = `<span style="color:var(--success);">✅ Restauré ! Recharge l'app.</span>`;
    toast('Backup restauré ✅');
  } catch (e) {
    document.getElementById('bkp-status').innerHTML = `<span style="color:var(--danger);">❌ ${e.message}</span>`;
  }
}
function toggleAutoBackup() {
  const on = document.getElementById('bkp-auto-on').checked;
  localStorage.setItem('nw_bkpAuto', on ? '1' : '0');
}
function checkBackupReminder() {
  if (localStorage.getItem('nw_bkpAuto') !== '1') return;
  const last = localStorage.getItem('nw_lastBkp');
  if (!last) return;
  const days = (Date.now() - new Date(last)) / (1000*60*60*24);
  const lastEl = document.getElementById('bkp-last');
  if (lastEl) lastEl.textContent = `Dernier backup : ${new Date(last).toLocaleDateString('fr-FR')} (il y a ${Math.floor(days)} jours)`;
}



// ============================================================
// MIND MAP
// ============================================================
function renderMindmap() {
  const text = document.getElementById('mm-text').value;
  const lines = text.split('\n').filter(l => l.trim());
  let html = '<ul style="list-style:none; padding-left:0; margin:0;">';
  let prevIndent = -1;
  for (const line of lines) {
    const indent = (line.match(/^(\s*)/)[1] || '').length;
    const content = line.replace(/^\s*-?\s*/, '').trim();
    if (!content) continue;
    while (prevIndent >= indent) { html += '</ul></li>'; prevIndent -= 2; }
    html += `<li style="padding:6px 10px; margin:4px 0; background:linear-gradient(90deg, var(--primary), transparent); color:white; border-radius:8px; padding-left:${indent*8 + 10}px; font-weight:${indent === 0 ? '700' : '500'}; font-size:${indent === 0 ? '15' : indent === 2 ? '13' : '12'}px;">${escapeHtml(content)}<ul style="list-style:none; padding-left:0; margin:0;">`;
    prevIndent = indent;
  }
  while (prevIndent >= 0) { html += '</ul></li>'; prevIndent -= 2; }
  html += '</ul>';
  document.getElementById('mm-tree').innerHTML = html;
}
function newMindmap() {
  document.getElementById('mm-text').value = '- Nouveau sujet\n  - Idée 1\n  - Idée 2';
  renderMindmap();
}

// ============================================================
// KANBAN
// ============================================================
function getKanban() {
  try { return JSON.parse(localStorage.getItem('nw_kanban') || '{"todo":[],"doing":[],"done":[]}'); } catch { return { todo:[], doing:[], done:[] }; }
}
function saveKanban(k) { localStorage.setItem('nw_kanban', JSON.stringify(k)); }
function addKanbanCard() {
  const v = document.getElementById('kan-input').value.trim();
  if (!v) return;
  const k = getKanban();
  k.todo.push({ id: Date.now(), text: v });
  saveKanban(k);
  document.getElementById('kan-input').value = '';
  renderKanban();
}
function moveKanban(id, from, to) {
  const k = getKanban();
  const idx = k[from].findIndex(c => c.id === id);
  if (idx === -1) return;
  const card = k[from].splice(idx, 1)[0];
  k[to].push(card);
  saveKanban(k);
  renderKanban();
}
function deleteKanban(id, col) {
  const k = getKanban();
  k[col] = k[col].filter(c => c.id !== id);
  saveKanban(k);
  renderKanban();
}
function renderKanban() {
  const k = getKanban();
  const cols = [
    { id:'todo', label:'📌 À faire', color:'var(--primary)', next:'doing' },
    { id:'doing', label:'⚡ En cours', color:'#FFD166', next:'done' },
    { id:'done', label:'✅ Fini', color:'var(--success)', next:null },
  ];
  document.getElementById('kan-board').innerHTML = cols.map(c => `
    <div style="background:var(--surface); padding:10px; border-radius:10px; border-top:3px solid ${c.color};">
      <h3 style="font-size:12px; font-weight:700; margin-bottom:8px; text-align:center;">${c.label}</h3>
      ${k[c.id].map(card => `
        <div style="background:var(--surfaceAlt); padding:8px; border-radius:6px; margin-bottom:4px; font-size:11px;">
          ${escapeHtml(card.text)}
          <div style="display:flex; gap:2px; margin-top:4px;">
            ${c.id !== 'todo' ? `<button class="btn alt" style="padding:2px 4px; font-size:10px;" onclick="moveKanban(${card.id}, '${c.id}', '${c.id==='done'?'doing':'todo'}')">←</button>` : ''}
            ${c.next ? `<button class="btn alt" style="padding:2px 4px; font-size:10px; flex:1;" onclick="moveKanban(${card.id}, '${c.id}', '${c.next}')">→</button>` : ''}
            <button class="btn alt" style="padding:2px 4px; font-size:10px;" onclick="deleteKanban(${card.id}, '${c.id}')">🗑</button>
          </div>
        </div>
      `).join('')}
    </div>
  `).join('');
}

