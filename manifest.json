// === GARANTIES ===
function getWarranties() { try { return JSON.parse(localStorage.getItem('nw_warranty') || '[]'); } catch { return []; } }
function saveWar(d) { localStorage.setItem('nw_warranty', JSON.stringify(d)); }
function renderWarranty() {
  const items = getWarranties();
  const now = Date.now();
  let html = `<p style="font-size:11px; color:var(--textSec);">Tracker tes garanties d'appareils + factures.</p>`;
  if (!items.length) html += '<p style="text-align:center; color:var(--textSec); padding:20px;">Aucune garantie. Tap +.</p>';
  items.forEach(it => {
    const end = new Date(it.endDate).getTime();
    const daysLeft = Math.ceil((end - now) / (24*60*60*1000));
    const expired = daysLeft < 0;
    const soon = daysLeft >= 0 && daysLeft < 30;
    const color = expired ? '#FF4757' : (soon ? '#FF8C42' : '#5DD68F');
    html += `<div style="background:var(--surface); padding:12px; border-radius:12px; margin-top:6px; border-left:3px solid ${color};">
      <div style="display:flex; justify-content:space-between; align-items:flex-start;">
        <div style="flex:1;">
          <div style="font-size:14px; font-weight:700;">📦 ${escapeHtml(it.name)}</div>
          <div style="font-size:11px; color:var(--textSec); margin-top:2px;">${escapeHtml(it.brand || '')}</div>
          <div style="font-size:11px; margin-top:4px;">Achat : ${new Date(it.startDate).toLocaleDateString('fr-FR')}</div>
          <div style="font-size:11px;">Fin garantie : <strong style="color:${color};">${new Date(it.endDate).toLocaleDateString('fr-FR')}</strong> ${expired ? '· expirée' : `· ${daysLeft}j restants`}</div>
          ${it.price ? `<div style="font-size:11px;">Prix : ${it.price}€</div>` : ''}
