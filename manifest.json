function getIbx() { try { return JSON.parse(localStorage.getItem('nw_inbox') || '[]'); } catch { return []; } }
function saveIbx(d) { localStorage.setItem('nw_inbox', JSON.stringify(d)); }
function ibxAdd() {
  const v = document.getElementById('ibx-input').value.trim();
  if (!v) return;
  const d = getIbx();
  d.unshift({ id: 'i_'+Date.now(), text: v, t: Date.now(), done: false });
  saveIbx(d);
  document.getElementById('ibx-input').value = '';
  renderIbx();
}
async function ibxToNote(id) {
  const it = getIbx().find(x => x.id === id); if (!it) return;
  await dbAdd('notes', {
    title: it.text.split('\n')[0].slice(0, 60) || 'Note',
    content: it.text, color: 'yellow', cat: 'Inbox',
    created_at: new Date().toISOString(), updated_at: new Date().toISOString()
  });
  saveIbx(getIbx().filter(x => x.id !== id));
  toast('📝 Convertie en note');
  renderIbx();
}
async function ibxToTodo(id) {
  const it = getIbx().find(x => x.id === id); if (!it) return;
  // Ajoute à courses... ou plus généralement on store sur localStorage 'todos' simple
  let todos = []; try { todos = JSON.parse(localStorage.getItem('nw_todos') || '[]'); } catch {}
  todos.push({ id:'t_'+Date.now(), text: it.text, done: false });
  localStorage.setItem('nw_todos', JSON.stringify(todos));
  saveIbx(getIbx().filter(x => x.id !== id));
  toast('✅ Ajouté aux todos');
  renderIbx();
}
function ibxDel(id) {
  if (!confirm('Supprimer ?')) return;
  saveIbx(getIbx().filter(x => x.id !== id));
  renderIbx();
}
function ibxClearDone() {
  if (!confirm('Effacer tous les éléments triés ?')) return;
  saveIbx(getIbx().filter(x => !x.done));
  renderIbx();
}
function renderIbx() {
  const d = getIbx();
  if (!d.length) { document.getElementById('ibx-list').innerHTML = '<p style="text-align:center; color:var(--textSec); padding:30px;">Inbox vide ✨</p>'; return; }
  document.getElementById('ibx-list').innerHTML = d.map(it => `
    <div style="background:var(--surface); padding:12px 14px; border-radius:10px; margin-bottom:6px;">
      <div style="font-size:13px; line-height:1.5; word-wrap:break-word;">${escapeHtml(it.text)}</div>
      <div style="font-size:10px; color:var(--textSec); margin-top:6px;">${new Date(it.t).toLocaleDateString('fr-FR')} ${new Date(it.t).toLocaleTimeString('fr-FR', {hour:'2-digit',minute:'2-digit'})}</div>
      <div style="display:flex; gap:4px; margin-top:8px; flex-wrap:wrap;">
        <button class="btn alt" onclick="ibxToNote('${it.id}')" style="font-size:11px; padding:4px 10px;">📝 Note</button>
        <button class="btn alt" onclick="ibxToTodo('${it.id}')" style="font-size:11px; padding:4px 10px;">✅ Todo</button>
        <button class="btn alt" onclick="ibxDel('${it.id}')" style="font-size:11px; padding:4px 10px; color:var(--danger);">🗑</button>
      </div>
    </div>
  `).join('');
}

// ============================================================
// AUJOURD'HUI
// ============================================================
async function renderToday() {
  const el = document.getElementById('today-content');
  let html = '';
  const now = new Date();
  const today = now.toISOString().slice(0, 10);
  const dayName = now.toLocaleDateString('fr-FR', { weekday:'long', day:'numeric', month:'long' });
  html += `<div style="background:linear-gradient(135deg, var(--primary), var(--accent)); color:white; padding:18px; border-radius:14px; margin-bottom:14px;">
    <div style="font-size:11px; opacity:0.85;">${dayName}</div>
    <div style="font-size:22px; font-weight:800; margin-top:4px;">☀️ Aujourd'hui</div>
  </div>`;
  // Devoirs du jour ou en retard ou à venir 7j
  try {
    const hw = await dbAll('homework');
    const dueToday = hw.filter(h => !h.done && h.due === today);
    const overdue = hw.filter(h => !h.done && h.due && h.due < today);
    const upcoming = hw.filter(h => !h.done && h.due && h.due > today && h.due <= new Date(Date.now()+7*864e5).toISOString().slice(0,10));
    if (dueToday.length || overdue.length) {
      html += `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-bottom:8px; border-left:4px solid ${overdue.length ? 'var(--danger)' : 'var(--primary)'};">
        <h3 style="font-size:14px; font-weight:700; margin:0;">📝 Devoirs ${overdue.length ? '<span style="color:var(--danger);">(en retard !)</span>' : ''}</h3>`;
      [...overdue, ...dueToday].forEach(h => {
        const isLate = h.due < today;
        html += `<div style="padding:6px 0; font-size:13px; ${isLate ? 'color:var(--danger);' : ''}">• ${escapeHtml(h.subject || '')} : ${escapeHtml(h.title)} ${isLate ? '(en retard)' : ''}</div>`;
      });
      html += `<button class="btn alt full" onclick="goTo('homework')" style="margin-top:8px; font-size:12px; padding:6px;">Voir tous →</button></div>`;
    }
    if (upcoming.length) {
      html += `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-bottom:8px;">
        <h3 style="font-size:13px; font-weight:700; margin:0; color:var(--textSec);">📅 À venir (7 prochains jours)</h3>`;
      upcoming.slice(0, 5).forEach(h => {
        const d = new Date(h.due);
        html += `<div style="padding:4px 0; font-size:12px; color:var(--textSec);">• ${d.toLocaleDateString('fr-FR', { weekday:'short', day:'numeric' })} : ${escapeHtml(h.title)}</div>`;
      });
      html += `</div>`;
    }
  } catch {}
  // Anniversaires aujourd'hui ou cette semaine
  try {
    const bdays = await dbAll('bdays');
    const todayMD = (now.getMonth()+1).toString().padStart(2,'0') + '-' + now.getDate().toString().padStart(2,'0');
    const todayBdays = bdays.filter(b => b.date && b.date.slice(5) === todayMD);
    if (todayBdays.length) {
      html += `<div style="background:linear-gradient(135deg, #FF6FA3, #FFD166); color:white; padding:14px; border-radius:12px; margin-bottom:8px;">
        <h3 style="font-size:14px; font-weight:700; margin:0;">🎂 Anniversaires aujourd'hui !</h3>`;
      todayBdays.forEach(b => html += `<div style="padding:4px 0; font-size:14px;">${escapeHtml(b.name)}</div>`);
      html += `</div>`;
    }
  } catch {}
  // Habitudes du jour
  try {
    const habits = await dbAll('habits');
    const logs = await dbAll('habit_logs');
    if (habits.length) {
      const todayLogs = logs.filter(l => l.date === today).map(l => l.habit_id);
      const done = habits.filter(h => todayLogs.includes(h.id)).length;
      html += `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-bottom:8px;">
        <h3 style="font-size:13px; font-weight:700; margin:0;">🎯 Habitudes <span style="color:var(--primary);">${done}/${habits.length}</span></h3>
        <div style="background:var(--surfaceAlt); height:6px; border-radius:3px; overflow:hidden; margin-top:8px;">
          <div style="background:linear-gradient(90deg, var(--primary), var(--accent)); height:100%; width:${habits.length ? done/habits.length*100 : 0}%;"></div>
        </div>
        <button class="btn alt full" onclick="goTo('habits')" style="margin-top:8px; font-size:12px; padding:6px;">Voir mes habitudes →</button>
      </div>`;
    }
  } catch {}
  // Hydratation
  try {
    const hyd = JSON.parse(localStorage.getItem('nw_hydra') || '{}')[today] || 0;
    const goal = parseInt(localStorage.getItem('nw_hydra_goal') || 2000);
    html += `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-bottom:8px;">
      <h3 style="font-size:13px; font-weight:700; margin:0;">💧 Hydratation <span style="color:var(--primary);">${hyd}/${goal}ml</span></h3>
      <div style="background:var(--surfaceAlt); height:6px; border-radius:3px; overflow:hidden; margin-top:8px;">
        <div style="background:linear-gradient(90deg, #5DADE2, #06FFA5); height:100%; width:${Math.min(100, hyd/goal*100)}%;"></div>
      </div>
      <button class="btn alt full" onclick="goTo('hydra')" style="margin-top:8px; font-size:12px; padding:6px;">+ Ajouter →</button>
    </div>`;
  } catch {}
  // Compte à rebours bac
  try {
    const bacDate = localStorage.getItem('nw_bac_date');
    if (bacDate) {
      const bd = new Date(bacDate); bd.setHours(0,0,0,0);
      const tn = new Date(); tn.setHours(0,0,0,0);
      const days = Math.floor((bd - tn) / 86400000);
      if (days > 0) html += `<div style="background:linear-gradient(135deg, #5DADE2, #A78BFA); color:white; padding:14px; border-radius:12px; margin-bottom:8px; text-align:center;">
        <div style="font-size:11px; opacity:0.85;">🎓 Bac dans</div>
        <div style="font-size:32px; font-weight:900;">${days} jour${days>1?'s':''}</div>
      </div>`;
    }
  } catch {}
  // Citation du jour
  try {
    if (typeof CITATIONS !== 'undefined' && CITATIONS.length) {
      const seed = parseInt(today.replace(/-/g,''));
      const c = CITATIONS[seed % CITATIONS.length];
      html += `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-bottom:8px;">
        <h3 style="font-size:13px; font-weight:700; margin:0; color:var(--primary);">💭 Citation du jour</h3>
        <p style="font-style:italic; font-size:13px; line-height:1.5; margin-top:8px;">« ${escapeHtml(c.texte)} »</p>
        <div style="font-size:11px; text-align:right; color:var(--primary); font-weight:700; margin-top:4px;">— ${escapeHtml(c.auteur)}</div>
      </div>`;
    }
  } catch {}
  // Que faire ? quick
  html += `<button class="btn primary full" onclick="goTo('quefaire')" style="margin-top:14px;">🤔 Que faire maintenant ?</button>`;
  el.innerHTML = html;
}

// ============================================================
// JOURNAL DE GRATITUDE
// ============================================================
function getGrat() { try { return JSON.parse(localStorage.getItem('nw_grat') || '{}'); } catch { return {}; } }
function saveGrat(d) { localStorage.setItem('nw_grat', JSON.stringify(d)); }
function gratLoadToday() {
  const data = getGrat();
  const k = todayKey();
  const t = data[k] || {};
  document.getElementById('grat-1').value = t['1'] || '';
  document.getElementById('grat-2').value = t['2'] || '';
  document.getElementById('grat-3').value = t['3'] || '';
  document.getElementById('grat-date').textContent = '📅 ' + new Date().toLocaleDateString('fr-FR', {weekday:'long', day:'numeric', month:'long'});
  // History
  const entries = Object.entries(data).filter(([d]) => d !== k).sort((a,b) => b[0].localeCompare(a[0]));
  document.getElementById('grat-count').textContent = `(${Object.keys(data).length} jours)`;
  if (!entries.length) {
    document.getElementById('grat-history').innerHTML = '<p style="text-align:center; color:var(--textSec); font-size:12px; padding:14px;">Pas encore d\'historique</p>';
    return;
  }
  document.getElementById('grat-history').innerHTML = entries.slice(0, 30).map(([d, vals]) => {
    const dt = new Date(d);
    return `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-bottom:6px;">
      <div style="font-size:11px; color:var(--primary); font-weight:700;">${dt.toLocaleDateString('fr-FR', {weekday:'long', day:'numeric', month:'short'})}</div>
      ${vals['1'] ? `<div style="font-size:12px; margin-top:4px;">💚 ${escapeHtml(vals['1'])}</div>` : ''}
      ${vals['2'] ? `<div style="font-size:12px; margin-top:2px;">💙 ${escapeHtml(vals['2'])}</div>` : ''}
      ${vals['3'] ? `<div style="font-size:12px; margin-top:2px;">💛 ${escapeHtml(vals['3'])}</div>` : ''}
    </div>`;
  }).join('');
}
function gratSave() {
  const data = getGrat();
  const k = todayKey();
  data[k] = {
    '1': document.getElementById('grat-1').value.trim(),
    '2': document.getElementById('grat-2').value.trim(),
    '3': document.getElementById('grat-3').value.trim(),
  };
  if (!data[k]['1'] && !data[k]['2'] && !data[k]['3']) { delete data[k]; }
  saveGrat(data);
  toast('🙏 Sauvegardé');
  if (typeof badgeUnlock === 'function') badgeUnlock('grateful');
  if (Object.keys(data).length >= 7 && typeof badgeUnlock === 'function') badgeUnlock('grateful_week');
  if (Object.keys(data).length >= 30 && typeof badgeUnlock === 'function') badgeUnlock('grateful_month');
  gratLoadToday();
}

// ============================================================
// CAPSULES TEMPORELLES
// ============================================================
function getCaps() { try { return JSON.parse(localStorage.getItem('nw_capsules') || '[]'); } catch { return []; } }
function saveCaps(d) { localStorage.setItem('nw_capsules', JSON.stringify(d)); }
function renderCapsules() {
  const list = getCaps();
  if (!list.length) {
    document.getElementById('cap-list').innerHTML = '<p style="text-align:center; color:var(--textSec); padding:30px;">Aucune capsule. Tap + pour en sceller une ⏳</p>';
    return;
  }
  list.sort((a,b) => a.openDate.localeCompare(b.openDate));
  const today = todayKey();
  document.getElementById('cap-list').innerHTML = list.map(c => {
    const open = c.openDate <= today;
    const d = new Date(c.openDate);
    const days = Math.ceil((d - new Date()) / 86400000);
    return `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-bottom:6px; border-left:4px solid ${open ? 'var(--success)' : 'var(--primary)'};">
      <div style="font-size:11px; color:var(--textSec);">Sealed ${new Date(c.created).toLocaleDateString('fr-FR')}</div>
      <div style="font-size:15px; font-weight:700; margin-top:4px;">${open ? '🔓' : '🔒'} ${escapeHtml(c.title)}</div>
      ${open ? `<div style="font-size:13px; line-height:1.5; margin-top:8px; padding:10px; background:var(--surfaceAlt); border-radius:8px; white-space:pre-wrap;">${escapeHtml(c.msg)}</div>
        <button class="btn alt" onclick="capDelete('${c.id}')" style="font-size:11px; padding:4px 10px; margin-top:8px;">🗑 Supprimer</button>` :
        `<div style="font-size:12px; color:var(--primary); margin-top:6px;">🕓 Ouvre dans ${days} jour${days > 1 ? 's' : ''} (${d.toLocaleDateString('fr-FR')})</div>`}
    </div>`;
  }).join('');
}
function capNew() {
  document.getElementById('cap-title').value = '';
  document.getElementById('cap-date').value = '';
  document.getElementById('cap-msg').value = '';
  goTo('capsule-edit');
}
function capSave() {
  const title = document.getElementById('cap-title').value.trim();
  const date = document.getElementById('cap-date').value;
  const msg = document.getElementById('cap-msg').value.trim();
  if (!title || !date || !msg) return toast('Remplis tous les champs');
  if (date <= todayKey()) return toast('La date doit être dans le futur');
  const list = getCaps();
  list.push({ id:'cap_'+Date.now(), title, openDate:date, msg, created:Date.now() });
  saveCaps(list);
  toast('🔒 Capsule scellée !');
  if (typeof badgeUnlock === 'function') badgeUnlock('time_traveler');
  goTo('capsule');
}
function capDelete(id) {
  if (!confirm('Supprimer cette capsule ?')) return;
  saveCaps(getCaps().filter(c => c.id !== id));
  renderCapsules();
}

// ============================================================
// COMMAND PALETTE Ctrl+K
// ============================================================
let _cmdkOpenedFromKey = false;
function openCmdk() {
  _cmdkOpenedFromKey = true;
  goTo('cmdk');
  setTimeout(() => {
    const el = document.getElementById('cmdk-search');
    if (el) { el.value = ''; el.focus(); }
    renderCmdk();
  }, 100);
}
function renderCmdk() {
  const q = (document.getElementById('cmdk-search').value || '').toLowerCase().trim();
  let pages = (typeof PAGE_INDEX !== 'undefined') ? PAGE_INDEX.slice() : [];
  if (q) {
    pages = pages.filter(p => 
      (p.name||'').toLowerCase().includes(q) ||
      (p.kw||'').toLowerCase().includes(q) ||
      (p.cat||'').toLowerCase().includes(q)
    );
  }
  pages = pages.slice(0, 30);
  if (!pages.length) {
    document.getElementById('cmdk-results').innerHTML = '<p style="text-align:center; color:var(--textSec); padding:20px;">Aucun résultat</p>';
    return;
  }
  document.getElementById('cmdk-results').innerHTML = pages.map(p =>
    `<div onclick="goTo('${p.page}')" style="display:flex; gap:10px; align-items:center; padding:10px 12px; background:var(--surface); border-radius:8px; margin-bottom:4px; cursor:pointer;">
      <div style="font-size:20px;">${p.ico||'·'}</div>
      <div style="flex:1; min-width:0;">
        <div style="font-weight:600; font-size:14px;">${escapeHtml(p.name)}</div>
        <div style="font-size:11px; color:var(--textSec);">${escapeHtml(p.cat||'')}</div>
      </div>
      <div style="font-size:14px; color:var(--textSec);">↵</div>
    </div>`
  ).join('');
}
// Hook clavier global
document.addEventListener('keydown', (e) => {
  if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
    e.preventDefault();
    openCmdk();
  }
});

