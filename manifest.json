const PIANO_NOTES = [
  { name:'C', freq:261.63, white:true, key:'z' },
  { name:'C#', freq:277.18, white:false, key:'s' },
  { name:'D', freq:293.66, white:true, key:'x' },
  { name:'D#', freq:311.13, white:false, key:'d' },
  { name:'E', freq:329.63, white:true, key:'c' },
  { name:'F', freq:349.23, white:true, key:'v' },
  { name:'F#', freq:369.99, white:false, key:'g' },
  { name:'G', freq:392.00, white:true, key:'b' },
  { name:'G#', freq:415.30, white:false, key:'h' },
  { name:'A', freq:440.00, white:true, key:'n' },
  { name:'A#', freq:466.16, white:false, key:'j' },
  { name:'B', freq:493.88, white:true, key:'m' },
];
const PIANO_MELODIES = {
  'Au clair de la lune': [['C',0.4],['C',0.4],['C',0.4],['D',0.4],['E',0.8],['D',0.8],['C',0.4],['E',0.4],['D',0.4],['D',0.4],['C',1.2]],
  'Joyeux anniversaire': [['C',0.3],['C',0.3],['D',0.6],['C',0.6],['F',0.6],['E',1.2],['C',0.3],['C',0.3],['D',0.6],['C',0.6],['G',0.6],['F',1.2]],
  'Frère Jacques': [['C',0.4],['D',0.4],['E',0.4],['C',0.4],['C',0.4],['D',0.4],['E',0.4],['C',0.4],['E',0.4],['F',0.4],['G',0.8],['E',0.4],['F',0.4],['G',0.8]],
  'Twinkle Twinkle': [['C',0.4],['C',0.4],['G',0.4],['G',0.4],['A',0.4],['A',0.4],['G',0.8],['F',0.4],['F',0.4],['E',0.4],['E',0.4],['D',0.4],['D',0.4],['C',0.8]],
};
let _pianoOctave = 4;
function pianoOct(d) { _pianoOctave = Math.max(2, Math.min(6, _pianoOctave + d)); document.getElementById('piano-oct').textContent = _pianoOctave; }
function pianoFreq(name, oct = _pianoOctave) {
  const note = PIANO_NOTES.find(n => n.name === name);
  return note.freq * Math.pow(2, oct - 4);
}
function renderPiano() {
  const el = document.getElementById('piano-keys');
  const whites = PIANO_NOTES.filter(n => n.white);
  const wW = 100 / whites.length;
  let html = '';
  whites.forEach((n, i) => {
    html += `<button onmousedown="pianoPlay('${n.name}')" ontouchstart="event.preventDefault(); pianoPlay('${n.name}')" style="position:absolute; left:${i*wW}%; width:${wW}%; height:100%; background:white; border:1px solid #888; border-radius:0 0 6px 6px; color:#444; font-size:10px; padding-bottom:6px; display:flex; align-items:flex-end; justify-content:center; cursor:pointer;">${n.name}</button>`;
  });
  PIANO_NOTES.filter(n => !n.white).forEach(n => {
    const idx = PIANO_NOTES.indexOf(n);
    const whiteIdx = whites.findIndex(w => PIANO_NOTES.indexOf(w) > idx);
    const left = (whiteIdx === -1 ? whites.length : whiteIdx) * wW - wW * 0.3;
    html += `<button onmousedown="pianoPlay('${n.name}')" ontouchstart="event.preventDefault(); pianoPlay('${n.name}')" style="position:absolute; left:${left}%; width:${wW*0.6}%; height:60%; background:#1a1a1a; border:1px solid #000; border-radius:0 0 4px 4px; color:white; font-size:9px; padding-bottom:4px; display:flex; align-items:flex-end; justify-content:center; cursor:pointer; z-index:2;">${n.name}</button>`;
  });
  el.innerHTML = html;
  document.getElementById('piano-melodies').innerHTML = Object.keys(PIANO_MELODIES).map(k => 
    `<button class="btn alt" onclick="pianoPlayMelody('${k}')" style="font-size:11px; padding:6px 10px;">▶ ${k}</button>`
  ).join('');
  // Keyboard
  document.removeEventListener('keydown', _pianoKeyHandler);
  document.addEventListener('keydown', _pianoKeyHandler);
}
function _pianoKeyHandler(e) {
  if (state.page !== 'piano') return;
  const note = PIANO_NOTES.find(n => n.key === e.key.toLowerCase());
  if (note) pianoPlay(note.name);
}
function pianoPlay(name) {
  const vol = parseInt(document.getElementById('piano-vol')?.value || 50) / 100;
  playTone(pianoFreq(name), 0.5, 'triangle', vol * 0.4);
}
function pianoPlayMelody(name) {
  const m = PIANO_MELODIES[name];
  let t = 0;
  for (const [note, dur] of m) {
    setTimeout(() => pianoPlay(note), t * 1000);
    t += dur;
  }
}

