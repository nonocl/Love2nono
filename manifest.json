// === 52. TIER LIST MAKER ===
function getTiers() { try { return JSON.parse(localStorage.getItem('nw_tiers') || '[]'); } catch { return []; } }
function saveTiers(d) { localStorage.setItem('nw_tiers', JSON.stringify(d)); }
let _curTier = null;
function tierMenu() {
  const tiers = getTiers();
  let opts = 'Choisis :\n\n1. ➕ Nouvelle tier list';
  tiers.forEach((t, i) => opts += `\n${i+2}. ${escapeHtml(t.name)} (${(t.items || []).length} items)`);
  opts += '\n0. Annuler';
  const ch = prompt(opts);
  if (!ch || ch === '0') return;
  const n = parseInt(ch);
  if (n === 1) tierNew();
  else if (n >= 2 && n <= tiers.length + 1) tierOpen(tiers[n-2].id);
}
function tierNew() {
  const name = prompt('Nom de la tier list :\n(Ex: Mes animes 2024, Personnages préférés)');
  if (!name) return;
  const tiers = getTiers();
  const t = {
    id: 't_' + Date.now(),
    name,
    levels: [
      { letter:'S', color:'#FF4757', items:[] },
      { letter:'A', color:'#FF8C42', items:[] },
      { letter:'B', color:'#FFD166', items:[] },
      { letter:'C', color:'#5DD68F', items:[] },
      { letter:'D', color:'#5DADE2', items:[] },
      { letter:'F', color:'#9B59B6', items:[] }
    ],
    pool: []
  };
  tiers.unshift(t);
  saveTiers(tiers);
  _curTier = t.id;
  renderTier();
}
function tierOpen(id) { _curTier = id; renderTier(); }
function tierGet() { return getTiers().find(t => t.id === _curTier); }
function tierSave() {
  const all = getTiers();
  const t = tierGet();
  if (!t) return;
  const idx = all.findIndex(x => x.id === _curTier);
  all[idx] = t;
  saveTiers(all);
}
function renderTier() {
  if (!_curTier) {
    const tiers = getTiers();
    let html = `<div style="background:linear-gradient(135deg, #FF4757, #A78BFA); color:white; padding:14px; border-radius:14px; text-align:center;">
      <div style="font-size:36px;">📊</div>
      <div style="font-size:18px; font-weight:800; margin-top:6px;">Tier List Maker</div>
      <div style="font-size:11px; opacity:0.9;">Classe tes persos, jeux, animes, musiques...</div>
    </div>
    <button class="btn primary full" onclick="tierNew()" style="margin-top:14px;">➕ Nouvelle tier list</button>
    <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:18px;">📚 Mes tier lists</h3>`;
    if (!tiers.length) html += '<p style="text-align:center; color:var(--textSec); padding:14px;">Aucune tier list. Tap ci-dessus pour créer.</p>';
    tiers.forEach(t => {
      const totalItems = t.levels.reduce((s,l) => s+l.items.length, 0) + (t.pool || []).length;
      html += `<div onclick="tierOpen('${t.id}')" style="background:var(--surface); padding:12px 14px; border-radius:12px; margin-bottom:6px; cursor:pointer;">
        <div style="font-size:14px; font-weight:700;">📋 ${escapeHtml(t.name)}</div>
        <div style="font-size:10px; color:var(--textSec); margin-top:2px;">${totalItems} items</div>
      </div>`;
    });
    document.getElementById('tier-content').innerHTML = html;
    return;
  }
  
  const t = tierGet();
  if (!t) { _curTier = null; renderTier(); return; }
  
  let html = `<div style="display:flex; gap:6px; align-items:center;">
    <button class="btn alt" onclick="_curTier=null; renderTier();" style="font-size:11px; padding:4px 10px;">← Liste</button>
    <div style="flex:1; font-size:14px; font-weight:700;">${escapeHtml(t.name)}</div>
    <button class="btn alt" onclick="tierExport()" style="font-size:11px; padding:4px 8px;">📥</button>
    <button class="btn alt" onclick="tierDel()" style="font-size:11px; padding:4px 8px; color:var(--danger);">🗑</button>
  </div>`;
  
  // Tier rows
  t.levels.forEach((lvl, li) => {
    html += `<div style="display:flex; gap:0; margin-top:6px; align-items:stretch; min-height:60px; background:var(--surface); border-radius:10px; overflow:hidden;">
      <div style="background:${lvl.color}; color:white; width:50px; display:flex; align-items:center; justify-content:center; font-size:24px; font-weight:900; cursor:pointer;" onclick="tierEditLetter(${li})">${escapeHtml(lvl.letter)}</div>
      <div style="flex:1; padding:6px; display:flex; flex-wrap:wrap; gap:4px; align-content:flex-start;">
    `;
    lvl.items.forEach((item, ii) => {
      html += `<button onclick="tierMoveItem(${li}, ${ii}, 'pool')" style="background:var(--bg); border:1px solid var(--border); padding:4px 8px; border-radius:6px; font-size:11px; cursor:pointer; color:var(--text);">${escapeHtml(item)}</button>`;
    });
    html += `</div></div>`;
  });
  
  // Pool
  html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📦 Pool (à classer)</h3>`;
  html += `<div style="display:flex; gap:6px; margin-top:6px;">
    <input type="text" class="input" id="tier-add-input" placeholder="Ajouter un item..." onkeypress="if(event.key==='Enter')tierAddItem()">
    <button class="btn primary" onclick="tierAddItem()" style="padding:8px 14px;">+</button>
  </div>`;
  if (!t.pool || !t.pool.length) {
    html += `<p style="text-align:center; color:var(--textSec); font-size:11px; padding:10px;">Ajoute des items à classer</p>`;
  } else {
    html += `<div style="background:var(--surface); padding:10px; border-radius:10px; margin-top:8px; display:flex; flex-wrap:wrap; gap:4px;">`;
    t.pool.forEach((item, pi) => {
      html += `<div style="position:relative; display:inline-flex; align-items:center; background:var(--bg); border:1px solid var(--border); padding:6px 10px; border-radius:8px; font-size:11px;">
        ${escapeHtml(item)}
        <select onchange="tierMoveFromPool(${pi}, this.value)" style="margin-left:6px; background:transparent; color:var(--primary); border:none; font-size:10px; cursor:pointer; outline:none;">
          <option value="">→</option>${t.levels.map((l,li) => `<option value="${li}">→ ${l.letter}</option>`).join('')}
          <option value="del">🗑</option>
        </select>
      </div>`;
    });
    html += `</div>`;
  }
  
  document.getElementById('tier-content').innerHTML = html;
}
function tierAddItem() {
  const inp = document.getElementById('tier-add-input');
  const v = inp.value.trim();
  if (!v) return;
  const t = tierGet();
  if (!t.pool) t.pool = [];
  v.split(',').map(s => s.trim()).filter(Boolean).forEach(name => t.pool.push(name));
  tierSave();
  inp.value = '';
  renderTier();
}
function tierMoveFromPool(pi, dest) {
  if (dest === '') return;
  const t = tierGet();
  const item = t.pool[pi];
  t.pool.splice(pi, 1);
  if (dest === 'del') {} 
  else { t.levels[parseInt(dest)].items.push(item); }
  tierSave(); renderTier();
}
function tierMoveItem(li, ii, dest) {
  const t = tierGet();
  const item = t.levels[li].items[ii];
  t.levels[li].items.splice(ii, 1);
  if (dest === 'pool') { t.pool = t.pool || []; t.pool.push(item); }
  tierSave(); renderTier();
}
function tierEditLetter(li) {
  const t = tierGet();
  const v = prompt('Lettre du tier :', t.levels[li].letter);
  if (!v) return;
  t.levels[li].letter = v.slice(0, 3);
  tierSave(); renderTier();
}
function tierExport() {
  const t = tierGet();
  let txt = `📊 ${t.name}\n\n`;
  t.levels.forEach(l => {
    txt += `${l.letter} : ${l.items.join(', ') || '(vide)'}\n`;
  });
  if (navigator.share) navigator.share({ text: txt });
  else { navigator.clipboard?.writeText(txt); toast('📋 Copié'); }
}
function tierDel() {
  if (!confirm('Supprimer cette tier list ?')) return;
  saveTiers(getTiers().filter(t => t.id !== _curTier));
  _curTier = null;
  renderTier();
}

// === 63. PITY GACHA ===
const PITY_GAMES = {
  genshin5: { name:'Genshin · 5★', soft:74, hard:90, type:'5-star' },
  genshin4: { name:'Genshin · 4★', soft:8, hard:10, type:'4-star' },
  hsr5: { name:'Star Rail · 5★', soft:74, hard:90, type:'5-star' },
  hsr4: { name:'Star Rail · 4★', soft:8, hard:10, type:'4-star' },
  zzz5: { name:'Zenless · S-rank', soft:74, hard:90, type:'S-rank' },
  wuwa5: { name:'Wuthering · 5★', soft:65, hard:80, type:'5-star' },
  fgo5: { name:'FGO · 5★ SSR', soft:0, hard:0, type:'SSR (no pity)' },
  hi3: { name:'Honkai Impact · S-rank', soft:90, hard:100, type:'S-rank' },
  custom: { name:'Custom', soft:50, hard:90, type:'Item' }
};
function getPity() { try { return JSON.parse(localStorage.getItem('nw_pity') || '[]'); } catch { return []; } }
function savePity(d) { localStorage.setItem('nw_pity', JSON.stringify(d)); }
function pityAdd() {
  const opts = Object.entries(PITY_GAMES).map(([k,g], i) => `${i+1}. ${g.name}`).join('\n');
  const ch = prompt(`Choisis le jeu :\n\n${opts}\n\n0. Annuler`);
  if (!ch) return;
  const idx = parseInt(ch) - 1;
  const keys = Object.keys(PITY_GAMES);
  if (idx < 0 || idx >= keys.length) return;
  const key = keys[idx];
  const cfg = PITY_GAMES[key];
  let name = cfg.name;
  if (key === 'custom') {
    name = prompt('Nom du compteur :') || 'Custom';
    const soft = parseInt(prompt('Soft pity à partir de combien de tirages ? (laisse vide si pas de soft)', '50')) || 0;
    const hard = parseInt(prompt('Hard pity (garanti) à combien de tirages ?', '90')) || 90;
    cfg.soft = soft; cfg.hard = hard;
  }
  const cur = parseInt(prompt(`Compteur actuel pour "${name}" ? (0 si tu débutes)`, '0')) || 0;
  const all = getPity();
  all.unshift({
    id: 'p_' + Date.now(),
    game: key, name, soft: cfg.soft, hard: cfg.hard, type: cfg.type,
    pulls: cur, lastPull: 0, history: [], guaranteed: false
  });
  savePity(all);
  renderPity();
}
function renderPity() {
  const all = getPity();
  let html = `<div style="background:linear-gradient(135deg, #9B59B6, #FF4757); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🎰</div>
    <div style="font-size:18px; font-weight:800; margin-top:4px;">Pity tracker</div>
    <div style="font-size:11px; opacity:0.9;">Genshin, HSR, Zenless, Wuwa & co</div>
  </div>`;
  if (!all.length) {
    html += '<p style="text-align:center; color:var(--textSec); padding:30px;">Aucun compteur. Tap + pour ajouter.</p>';
  }
  all.forEach(p => {
    const pct = p.hard ? Math.min(100, (p.pulls / p.hard) * 100) : 0;
    let zone = 'safe';
    if (p.soft && p.pulls >= p.soft - 5) zone = 'soft';
    if (p.pulls >= p.hard - 5) zone = 'hard';
    const zoneColors = { safe:'#5DD68F', soft:'#FFD166', hard:'#FF4757' };
    const remaining = p.hard - p.pulls;
    html += `<div style="background:var(--surface); padding:14px; border-radius:14px; margin-top:10px;">
      <div style="display:flex; justify-content:space-between; align-items:center;">
        <div>
          <div style="font-size:14px; font-weight:700;">🎰 ${escapeHtml(p.name)}</div>
          <div style="font-size:10px; color:var(--textSec); margin-top:2px;">${escapeHtml(p.type)}${p.guaranteed ? ' · 🎯 Garanti next' : ''}</div>
        </div>
        <button onclick="pityDel('${p.id}')" style="background:none; border:none; color:var(--danger); font-size:16px;">✗</button>
      </div>
      <div style="margin-top:10px;">
        <div style="display:flex; justify-content:space-between; font-size:11px;">
          <span style="color:var(--textSec);">Pulls : <strong style="color:${zoneColors[zone]};">${p.pulls}/${p.hard}</strong></span>
          <span style="color:${zoneColors[zone]}; font-weight:700;">${remaining > 0 ? `${remaining} restants` : '🎉 Garanti !'}</span>
        </div>
        <div style="background:var(--surfaceAlt); height:8px; border-radius:4px; margin-top:6px; overflow:hidden;">
          <div style="background:linear-gradient(90deg, ${zoneColors[zone]}, ${zoneColors[zone]}AA); height:100%; width:${pct}%;"></div>
        </div>
        ${p.soft ? `<div style="font-size:10px; color:var(--textSec); margin-top:4px;">Soft pity : ${p.soft} pulls</div>` : ''}
      </div>
      <div style="display:flex; gap:4px; margin-top:10px; flex-wrap:wrap;">
        <button class="btn alt" onclick="pityPull('${p.id}', 1)" style="font-size:11px; padding:5px 10px;">+1 pull</button>
        <button class="btn alt" onclick="pityPull('${p.id}', 10)" style="font-size:11px; padding:5px 10px;">+10 pulls</button>
        <button class="btn alt" onclick="pityWon('${p.id}')" style="font-size:11px; padding:5px 10px; color:var(--success);">🎉 Won !</button>
        <button class="btn alt" onclick="pityLost('${p.id}')" style="font-size:11px; padding:5px 10px;">💔 Lost 50/50</button>
        <button class="btn alt" onclick="pityCustomCount('${p.id}')" style="font-size:11px; padding:5px 10px;">✎</button>
      </div>
      ${p.history && p.history.length ? `<div style="font-size:10px; color:var(--textSec); margin-top:8px;">📜 Dernières : ${p.history.slice(-5).map(h => h.won ? `🌟 (${h.pulls})` : `💔 (${h.pulls})`).join(' · ')}</div>` : ''}
    </div>`;
  });
  document.getElementById('pity-content').innerHTML = html;
}
function pityPull(id, n) {
  const all = getPity();
  const p = all.find(x => x.id === id); if (!p) return;
  p.pulls += n;
  if (p.pulls >= p.hard) {
    if (confirm(`🎉 Hard pity atteint à ${p.pulls} pulls ! Tu as obtenu ton ${p.type} ?`)) {
      pityWon(id, false);
      return;
    }
  }
  savePity(all); renderPity();
}
function pityWon(id, ask = true) {
  const all = getPity();
  const p = all.find(x => x.id === id); if (!p) return;
  if (ask && !confirm(`🎉 Tu as obtenu ${p.type} ?\n\nReset le compteur à 0.`)) return;
  if (!p.history) p.history = [];
  // Distinction si rate-up : si garanti déjà, c'était "won 50/50" ; sinon...
  const isGuaranteed = p.guaranteed;
  p.history.push({ pulls: p.pulls, won: true, date: Date.now() });
  p.pulls = 0;
  p.guaranteed = false; // après win, garanti devient false
  savePity(all);
  toast('🎉 Compteur reset !');
  renderPity();
}
function pityLost(id) {
  const all = getPity();
  const p = all.find(x => x.id === id); if (!p) return;
  if (!confirm(`💔 Tu as obtenu un personnage standard (perdu le 50/50) ?\n\nReset le compteur, prochain ${p.type} sera garanti rate-up.`)) return;
  if (!p.history) p.history = [];
  p.history.push({ pulls: p.pulls, won: false, date: Date.now() });
  p.pulls = 0;
  p.guaranteed = true;
  savePity(all);
  toast('💔 Garanti pour le prochain rate-up');
  renderPity();
}
function pityCustomCount(id) {
  const all = getPity();
  const p = all.find(x => x.id === id); if (!p) return;
  const v = parseInt(prompt(`Nouveau compteur pour ${p.name} :`, p.pulls));
  if (isNaN(v) || v < 0) return;
  p.pulls = v;
  savePity(all); renderPity();
}
function pityDel(id) {
  if (!confirm('Supprimer ce compteur ?')) return;
  savePity(getPity().filter(p => p.id !== id));
  renderPity();
}

// === 67-68. TVA & SOLDES ===
function saleCalc() {
  const p = parseFloat(document.getElementById('sale-p').value);
  const r = parseFloat(document.getElementById('sale-r').value);
  if (isNaN(p) || isNaN(r)) { document.getElementById('sale-result').innerHTML = ''; return; }
  const reduction = p * r / 100;
  const final = p - reduction;
  document.getElementById('sale-result').innerHTML = `<div style="display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid var(--border);">
    <span style="color:var(--textSec);">Tu économises</span><strong style="color:var(--success);">−${reduction.toFixed(2)} €</strong>
  </div>
  <div style="display:flex; justify-content:space-between; padding:8px 0; font-size:18px;">
    <span style="font-weight:700;">Prix final</span><strong style="color:var(--primary); font-size:22px;">${final.toFixed(2)} €</strong>
  </div>`;
}
let _tvaType = 'ttc';
function tvaSetType(t) {
  _tvaType = t;
  document.getElementById('tva-ttc-btn').className = 'btn full ' + (t === 'ttc' ? 'primary' : 'alt');
  document.getElementById('tva-ht-btn').className = 'btn full ' + (t === 'ht' ? 'primary' : 'alt');
  ['tva-ttc-btn','tva-ht-btn'].forEach(id => document.getElementById(id).style.cssText = 'font-size:11px;');
  tvaCalc();
}
function tvaCalc() {
  const a = parseFloat(document.getElementById('tva-amount').value);
  const r = parseFloat(document.getElementById('tva-rate').value);
  if (isNaN(a) || isNaN(r)) { document.getElementById('tva-result').innerHTML = ''; return; }
  let ht, ttc, tva;
  if (_tvaType === 'ttc') {
    ht = a; tva = ht * r / 100; ttc = ht + tva;
  } else {
    ttc = a; ht = ttc / (1 + r/100); tva = ttc - ht;
  }
  document.getElementById('tva-result').innerHTML = `<div style="display:flex; justify-content:space-between; padding:6px 0;"><span style="color:var(--textSec);">HT</span><strong>${ht.toFixed(2)} €</strong></div>
    <div style="display:flex; justify-content:space-between; padding:6px 0; border-top:1px solid var(--border); border-bottom:1px solid var(--border);"><span style="color:var(--textSec);">TVA (${r}%)</span><strong>${tva.toFixed(2)} €</strong></div>
    <div style="display:flex; justify-content:space-between; padding:6px 0; font-size:18px;"><span style="font-weight:700;">TTC</span><strong style="color:var(--primary); font-size:20px;">${ttc.toFixed(2)} €</strong></div>`;
}

