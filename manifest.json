const WORDLE_WORDS = ['MAISON','CHAMP','VOITURE','PIERRE','POUVOIR','CHEVAL','MARCHE','FENETRE','ECRIRE','LIVRES','BLANCH','GAGNER','VOLEUR','ROUTES','BOULON','CRAYON','CHANCE','MUSIQU','OREILL','ROULER','SOLEIL','PLANTE','GIRAFE','BISCUI','VOYAGE','ANIMAL','BATEAU','CINEMA','DANSER','EQUIPE','FACILE','MIROIR','NUAGES','PILOTE','REPOSE','SECOND','TROUVE','URBAIN','VICTOR','WAGONS','YACHTS','GUITAR','MARCHE','POESIE','RIVERA','SAVANT','TENNIS','WARNED','XYLENE','MERCRE','AVEUGL','BIDONS','CLOCHE'];
let _wordle = null;
function initWordle() {
  const word = WORDLE_WORDS[Math.floor(Math.random() * WORDLE_WORDS.length)].toUpperCase().slice(0,6);
  _wordle = { word, attempts: [], current: '', maxAttempts: 6, length: word.length, won: false, over: false };
  renderWordle();
}
function renderWordle() {
  const grid = document.getElementById('wordle-grid');
  grid.innerHTML = '';
  for (let i=0; i<_wordle.maxAttempts; i++) {
    const row = document.createElement('div');
    row.style.cssText = `display:grid; grid-template-columns:repeat(${_wordle.length},1fr); gap:4px;`;
    const attempt = i < _wordle.attempts.length ? _wordle.attempts[i] : (i === _wordle.attempts.length ? _wordle.current : '');
    for (let j=0; j<_wordle.length; j++) {
      const cell = document.createElement('div');
      const ch = attempt[j] || '';
      let bg = 'var(--surfaceAlt)', color = 'var(--text)';
      if (i < _wordle.attempts.length) {
        // Already submitted
        if (ch === _wordle.word[j]) { bg = '#5DD68F'; color = 'white'; }
        else if (_wordle.word.includes(ch)) { bg = '#FFD166'; color = 'white'; }
        else { bg = '#666'; color = 'white'; }
      }
      cell.style.cssText = `aspect-ratio:1; background:${bg}; color:${color}; display:flex; align-items:center; justify-content:center; font-size:24px; font-weight:800; border-radius:6px;`;
      cell.textContent = ch;
      row.appendChild(cell);
    }
    grid.appendChild(row);
  }
  // Keyboard
  const kb = document.getElementById('wordle-keyboard');
  kb.innerHTML = '';
  const rows = ['QWERTYUIOP','ASDFGHJKL','ZXCVBNM'];
  for (let ri=0; ri<rows.length; ri++) {
    const row = document.createElement('div');
    row.style.cssText = 'display:flex; gap:3px; justify-content:center;';
    if (ri === 2) {
      const ent = document.createElement('button');
      ent.className = 'btn alt';
      ent.style.cssText = 'flex:1.5; padding:10px 4px; font-size:11px;';
      ent.textContent = 'ENTRER';
      ent.onclick = wordleSubmit;
      row.appendChild(ent);
    }
    for (const k of rows[ri]) {
      const b = document.createElement('button');
      b.className = 'btn alt';
      // Color from previous attempts
      let bg = '';
      for (const att of _wordle.attempts) {
        for (let i=0; i<att.length; i++) {
          if (att[i] === k) {
            if (k === _wordle.word[i]) bg = '#5DD68F';
            else if (_wordle.word.includes(k) && bg !== '#5DD68F') bg = '#FFD166';
            else if (!_wordle.word.includes(k) && !bg) bg = '#666';
          }
        }
      }
      b.style.cssText = `flex:1; padding:10px 0; font-size:14px; ${bg?`background:${bg}; color:white;`:''}`;
      b.textContent = k;
      b.onclick = () => wordleType(k);
      row.appendChild(b);
    }
    if (ri === 2) {
      const back = document.createElement('button');
      back.className = 'btn alt';
      back.style.cssText = 'flex:1.5; padding:10px 4px; font-size:14px;';
      back.textContent = '⌫';
      back.onclick = wordleBack;
      row.appendChild(back);
    }
    kb.appendChild(row);
  }
}
function wordleType(c) {
  if (_wordle.over) return;
  if (_wordle.current.length < _wordle.length) { _wordle.current += c; renderWordle(); }
}
function wordleBack() {
  if (_wordle.over) return;
  _wordle.current = _wordle.current.slice(0, -1); renderWordle();
}
function wordleSubmit() {
  if (_wordle.over) return;
  if (_wordle.current.length !== _wordle.length) {
    document.getElementById('wordle-msg').textContent = `Il faut ${_wordle.length} lettres`;
    return;
  }
  _wordle.attempts.push(_wordle.current);
  if (_wordle.current === _wordle.word) {
    _wordle.won = true; _wordle.over = true;
    document.getElementById('wordle-msg').innerHTML = `<span style="color:var(--success);">🎉 Trouvé en ${_wordle.attempts.length} essais !</span>`;
  } else if (_wordle.attempts.length >= _wordle.maxAttempts) {
    _wordle.over = true;
    document.getElementById('wordle-msg').innerHTML = `<span style="color:var(--danger);">😬 C'était : ${_wordle.word}</span>`;
  } else {
    document.getElementById('wordle-msg').textContent = '';
  }
  _wordle.current = '';
  renderWordle();
}

