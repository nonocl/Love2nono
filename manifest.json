        ${e.items.filter(Boolean).map((it, i) => `<div style="font-size:12px; margin-top:2px;">✨ ${escapeHtml(it)}</div>`).join('')}
      </div>`;
    });
  }
  document.getElementById('gratitude-content').innerHTML = html;
}
function v51_gratSave() {
  const items = [
    document.getElementById('grat-1').value.trim(),
    document.getElementById('grat-2').value.trim(),
    document.getElementById('grat-3').value.trim()
  ];
  if (items.every(i => !i)) { toast('Écris au moins une chose'); return; }
  const today = new Date().toISOString().slice(0, 10);
