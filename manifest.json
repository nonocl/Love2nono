let _pat = null;
function patternInit() {
  _pat = { level: 1, sequence: [], userSeq: [], showing: false };
  document.getElementById('pat-level').textContent = '1';
  document.getElementById('pat-best').textContent = localStorage.getItem('nw_pattern_best') || '1';
  patternRender();
  document.getElementById('pattern-msg').textContent = 'Tap "Démarrer" pour commencer';
}
function patternRender() {
  const grid = document.getElementById('pattern-grid');
  let html = '';
  for (let i = 0; i < 16; i++) {
    html += `<div id="pat-cell-${i}" onclick="patternClick(${i})" style="background:var(--surface); border-radius:8px; cursor:pointer; aspect-ratio:1; transition:all 0.2s;"></div>`;
  }
  grid.innerHTML = html;
}
function patternStart() {
  if (!_pat) patternInit();
  _pat.sequence = [];
  _pat.level = 1;
  document.getElementById('pat-level').textContent = '1';
  patternNextLevel();
}
async function patternNextLevel() {
  _pat.userSeq = [];
  _pat.sequence.push(Math.floor(Math.random() * 16));
  _pat.showing = true;
  document.getElementById('pattern-msg').textContent = '👀 Mémorise...';
  await new Promise(r => setTimeout(r, 500));
  for (const i of _pat.sequence) {
    const cell = document.getElementById('pat-cell-' + i);
    cell.style.background = 'var(--primary)';
    cell.style.transform = 'scale(0.95)';
    await new Promise(r => setTimeout(r, 500));
    cell.style.background = 'var(--surface)';
    cell.style.transform = 'scale(1)';
    await new Promise(r => setTimeout(r, 200));
  }
  _pat.showing = false;
  document.getElementById('pattern-msg').textContent = '✋ À toi !';
}
function patternClick(i) {
  if (!_pat || _pat.showing || !_pat.sequence.length) return;
  _pat.userSeq.push(i);
  const cell = document.getElementById('pat-cell-' + i);
  cell.style.background = 'var(--accent)';
  setTimeout(() => cell.style.background = 'var(--surface)', 200);
  
  // Check progress
  const idx = _pat.userSeq.length - 1;
  if (_pat.userSeq[idx] !== _pat.sequence[idx]) {
    document.getElementById('pattern-msg').textContent = `❌ Game Over ! Niveau ${_pat.level}`;
    const best = parseInt(localStorage.getItem('nw_pattern_best') || '1');
    if (_pat.level > best) localStorage.setItem('nw_pattern_best', _pat.level);
    _pat.sequence = [];
    return;
  }
  
  if (_pat.userSeq.length === _pat.sequence.length) {
    _pat.level++;
    document.getElementById('pat-level').textContent = _pat.level;
    document.getElementById('pattern-msg').textContent = '✓ Niveau suivant !';
    setTimeout(() => patternNextLevel(), 800);
  }
}

