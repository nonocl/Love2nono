// === 20. SHIP NAME GENERATOR ===
function renderShipName() {
  let html = `<div style="background:linear-gradient(135deg,#FF6FA3,#FFAFCC); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">💕</div><div style="font-size:16px; font-weight:800;">Ship name generator</div>
    <div style="font-size:11px; opacity:0.9;">Combine 2 prénoms en couple name</div>
  </div>
  <input type="text" id="ship-1" class="input" placeholder="Prénom 1 (ex: Brad)" oninput="shipGen()" style="margin-top:14px;">
  <input type="text" id="ship-2" class="input" placeholder="Prénom 2 (ex: Angelina)" oninput="shipGen()" style="margin-top:6px;">
  <div id="ship-result" style="margin-top:14px;"></div>`;
  document.getElementById('shipnameV53-content').innerHTML = html;
}
function shipGen() {
  const a = document.getElementById('ship-1').value.trim();
  const b = document.getElementById('ship-2').value.trim();
  if (!a || !b) { document.getElementById('ship-result').innerHTML = ''; return; }
  // Plusieurs combinaisons
  const ah = Math.ceil(a.length/2), bh = Math.ceil(b.length/2);
  const c1 = (a.slice(0, ah) + b.slice(bh)).toLowerCase();
  const c2 = (b.slice(0, bh) + a.slice(ah)).toLowerCase();
  const c3 = (a.slice(0, 1) + b.slice(0, 1) + a.slice(1, 3) + b.slice(1, 3)).toLowerCase();
  const c4 = (b.slice(0, 1) + a.slice(0, 1) + b.slice(1, 3) + a.slice(1, 3)).toLowerCase();
  const cap = s => s.charAt(0).toUpperCase() + s.slice(1);
  document.getElementById('ship-result').innerHTML = `<div style="background:linear-gradient(135deg,#FF6FA3,#FFAFCC); color:white; padding:24px; border-radius:18px; text-align:center;">
    <div style="font-size:14px;">${escapeHtml(a)} 💕 ${escapeHtml(b)}</div>
    <div style="font-size:32px; font-weight:900; margin-top:10px;">${escapeHtml(cap(c1))}</div>
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">✨ Autres combinaisons</h3>
  ${[c2, c3, c4].map(c => `<div style="background:var(--surface); padding:10px 14px; border-radius:10px; margin-top:5px; font-size:14px; font-weight:700;">${escapeHtml(cap(c))}</div>`).join('')}`;
}
