// === 4. TEXTE MIROIR ===
const MIRROR_MAP = {
  'a':'ɒ','b':'d','c':'ↄ','d':'b','e':'ɘ','f':'Ꮈ','g':'ǫ','h':'ʜ','i':'i','j':'ꞁ','k':'ʞ','l':'l','m':'m','n':'n','o':'o','p':'q','q':'p','r':'ɿ','s':'ƨ','t':'ƚ','u':'u','v':'v','w':'w','x':'x','y':'y','z':'z',
  'A':'A','B':'ᙠ','C':'Ↄ','D':'ᗡ','E':'Ǝ','F':'ꟻ','G':'ᗭ','H':'H','I':'I','J':'Ꞁ','K':'ꓘ','L':'⅃','M':'M','N':'И','O':'O','P':'ꟼ','Q':'Ọ','R':'Я','S':'Ƨ','T':'T','U':'U','V':'V','W':'W','X':'X','Y':'Y','Z':'Ƹ'
};
const FLIP_MAP = {
  'a':'ɐ','b':'q','c':'ɔ','d':'p','e':'ǝ','f':'ɟ','g':'ƃ','h':'ɥ','i':'ᴉ','j':'ɾ','k':'ʞ','l':'l','m':'ɯ','n':'u','o':'o','p':'d','q':'b','r':'ɹ','s':'s','t':'ʇ','u':'n','v':'ʌ','w':'ʍ','x':'x','y':'ʎ','z':'z',
  'A':'∀','B':'B','C':'Ɔ','D':'D','E':'Ǝ','F':'Ⅎ','G':'פ','H':'H','I':'I','J':'ſ','K':'K','L':'˥','M':'W','N':'N','O':'O','P':'Ԁ','Q':'Q','R':'R','S':'S','T':'┴','U':'∩','V':'Λ','W':'M','X':'X','Y':'⅄','Z':'Z',
  '?':'¿','!':'¡','.':'˙',',':"'",'\'':',','"':',,','&':'⅋','(':')',')':'(','[':']',']':'[','{':'}','}':'{','<':'>','>':'<','_':'‾'
};
function mirrorText(text, mode) {
  if (mode === 'mirror') {
    return Array.from(text).map(c => MIRROR_MAP[c] || c).reverse().join('');
  } else if (mode === 'flip') {
    return Array.from(text).map(c => FLIP_MAP[c] || c).reverse().join('');
  } else if (mode === 'reverse') {
    return Array.from(text).reverse().join('');
  }
  return text;
}
function renderMirrorText() {
  let html = `<div style="background:linear-gradient(135deg,#5DADE2,#9B59B6); color:white; padding:14px; border-radius:14px; text-align:center;">
