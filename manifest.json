function renderBacCnt() {
  const today = new Date();
  // Bac Français écrit Première - mi-juin
  // Bac Première - février et juin
  // Bac Terminale - mars et juin
  const events = [
    { n:'Bac Français écrit (1ère)', d:'2026-06-12' },
    { n:'Bac Français oral (1ère)', d:'2026-07-01' },
    { n:'Épreuves spécialités Terminale', d:'2026-03-16' },
    { n:'Philosophie Terminale', d:'2026-06-15' },
    { n:'Grand oral Terminale', d:'2026-06-22' },
    { n:'Brevet 3ème', d:'2026-06-26' },
  ];
  const futureEvents = events.filter(e => new Date(e.d) > today).sort((a,b) => new Date(a.d) - new Date(b.d));
  if (futureEvents.length === 0) {
    document.getElementById('bac-cnt-output').innerHTML = `<p style="text-align:center; color:var(--textSec); padding:30px;">Tous les examens ont eu lieu pour cette année !</p>`;
    return;
  }
  document.getElementById('bac-cnt-output').innerHTML = futureEvents.map(e => {
    const target = new Date(e.d);
    const diffMs = target - today;
    const days = Math.floor(diffMs / (1000*60*60*24));
    const hours = Math.floor((diffMs % (1000*60*60*24)) / (1000*60*60));
    return `
      <div style="background:linear-gradient(135deg, var(--primary), var(--accent)); color:white; padding:18px; border-radius:14px; margin-bottom:8px;">
        <div style="font-size:11px; opacity:0.85;">${target.toLocaleDateString('fr-FR', { weekday:'long', day:'numeric', month:'long', year:'numeric' })}</div>
        <h3 style="font-size:16px; font-weight:700; margin:4px 0;">${escapeHtml(e.n)}</h3>
        <div style="font-size:32px; font-weight:900; margin-top:6px;">${days} <span style="font-size:14px;">jours</span></div>
        ${days < 30 ? `<div style="font-size:11px; opacity:0.85;">+ ${hours}h</div>` : ''}
      </div>
    `;
  }).join('');
}



// ============================================================
// CROP IMAGE
// ============================================================
const _crop = { img:null, ratio:[1,1], ox:0, oy:0, scale:1 };
function cropLoadImg(input) {
  const f = input.files && input.files[0]; if (!f) return;
  const r = new FileReader();
  r.onload = e => {
    const img = new Image();
    img.onload = () => { _crop.img = img; _crop.ox = 0; _crop.oy = 0; _crop.scale = 1; drawCrop(); };
    img.src = e.target.result;
  };
  r.readAsDataURL(f);
}
function setCropRatio(w, h) {
  _crop.ratio = [w, h];
  drawCrop();
}
function drawCrop() {
  if (!_crop.img) return;
  const c = document.getElementById('crop-canvas');
  const W = 320, H = 320;
  c.width = W; c.height = H;
  const ctx = c.getContext('2d');
  ctx.fillStyle = '#000'; ctx.fillRect(0,0,W,H);
  // Compute crop rect
  const [rw, rh] = _crop.ratio;
  let cw, ch;
  if (rw / rh > W / H) { cw = W * 0.85; ch = cw * rh / rw; }
  else { ch = H * 0.85; cw = ch * rw / rh; }
  const cx = (W - cw)/2, cy = (H - ch)/2;
  // Image fit
  const ir = _crop.img.width / _crop.img.height;
  let iw, ih;
  if (ir > 1) { iw = cw * 1.5; ih = iw / ir; }
  else { ih = ch * 1.5; iw = ih * ir; }
  ctx.save();
  ctx.globalAlpha = 0.5;
  ctx.drawImage(_crop.img, cx + cw/2 - iw/2 + _crop.ox, cy + ch/2 - ih/2 + _crop.oy, iw, ih);
  ctx.restore();
  // Draw bright crop area on top
  ctx.save();
  ctx.beginPath();
  ctx.rect(cx, cy, cw, ch);
  ctx.clip();
  ctx.drawImage(_crop.img, cx + cw/2 - iw/2 + _crop.ox, cy + ch/2 - ih/2 + _crop.oy, iw, ih);
  ctx.restore();
  // Outline
  ctx.strokeStyle = '#fff';
  ctx.lineWidth = 2;
  ctx.strokeRect(cx, cy, cw, ch);
  _crop._rect = { cx, cy, cw, ch, iw, ih };
  // Drag
  c.onmousedown = e => {
    const rect = c.getBoundingClientRect();
    let lastX = e.clientX, lastY = e.clientY;
    const move = ev => { _crop.ox += ev.clientX - lastX; _crop.oy += ev.clientY - lastY; lastX = ev.clientX; lastY = ev.clientY; drawCrop(); };
    const up = () => { document.removeEventListener('mousemove', move); document.removeEventListener('mouseup', up); };
    document.addEventListener('mousemove', move);
    document.addEventListener('mouseup', up);
  };
  c.ontouchstart = e => {
    e.preventDefault();
    let lastX = e.touches[0].clientX, lastY = e.touches[0].clientY;
    const move = ev => { ev.preventDefault(); _crop.ox += ev.touches[0].clientX - lastX; _crop.oy += ev.touches[0].clientY - lastY; lastX = ev.touches[0].clientX; lastY = ev.touches[0].clientY; drawCrop(); };
    const up = () => { c.removeEventListener('touchmove', move); c.removeEventListener('touchend', up); };
    c.addEventListener('touchmove', move, { passive:false });
    c.addEventListener('touchend', up);
  };
}
function cropExport() {
  if (!_crop.img || !_crop._rect) return;
  const r = _crop._rect;
  const out = document.createElement('canvas');
  // Output at higher res
  const outW = 800, outH = Math.round(800 * _crop.ratio[1] / _crop.ratio[0]);
  out.width = outW; out.height = outH;
  const ctx = out.getContext('2d');
  // Map source area
  const sx = (r.cw / r.iw) * _crop.img.width;
  const sy = (r.ch / r.ih) * _crop.img.height;
  // Compute source x,y in image based on offset
  const offX = (-_crop.ox - (r.iw - r.cw)/2);
  const offY = (-_crop.oy - (r.ih - r.ch)/2);
  const srcX = (offX / r.iw) * _crop.img.width;
  const srcY = (offY / r.ih) * _crop.img.height;
  ctx.drawImage(_crop.img, srcX, srcY, sx, sy, 0, 0, outW, outH);
  out.toBlob(b => {
    const a = document.createElement('a');
    a.href = URL.createObjectURL(b);
    a.download = `crop-${_crop.ratio[0]}x${_crop.ratio[1]}.png`;
    a.click();
  });
}

