// ============================================================
const SHAKE_A = ['Misérable','Insolent','Vil','Putride','Vile','Bouseuse','Lourdaud','Dégoûtante','Hideux','Pestilentielle','Pitoyable','Fétide','Détestable','Mielleuse','Bâtard','Lâche'];
const SHAKE_B = ['ânon','crapaud','cloporte','souillon','brigand','vaurien','fripon','lèche-bottes','crâne creux','idiot','beauf','rustre','goujat','poltron','rustaud','fripouille'];
