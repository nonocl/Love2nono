// === 4. FAUX CALCULATRICE ===
let _fakecalcDisplay = '0';
let _fakecalcInput = '';
function renderFakeCalc() {
  let html = `<div style="background:#FF8C42; color:white; padding:12px; border-radius:12px; font-size:11px; line-height:1.5;">
    💡 Cette calc est <strong>fonctionnelle</strong>. Si tu tapes ton PIN suivi de "=", l'app se déverrouille en mode admin.
    Sinon, c'est juste une calc (pour cacher l'app à un parent qui regarde par-dessus).
  </div>
  <div style="background:#1A1A1A; color:white; padding:18px; border-radius:18px; margin-top:10px;">
    <div id="fc-display" style="text-align:right; font-size:36px; font-family:monospace; min-height:50px; padding:10px;">${escapeHtml(_fakecalcDisplay)}</div>
    <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:6px; margin-top:8px;">`;
  const keys = [['C','±','%','÷'], ['7','8','9','×'], ['4','5','6','−'], ['1','2','3','+'], ['0','.','⌫','=']];
  keys.forEach(row => {
    row.forEach(k => {
      const isOp = ['÷','×','−','+','='].includes(k);
      const isSpec = ['C','±','%','⌫'].includes(k);
      const bg = isOp ? '#FF8C42' : (isSpec ? '#404040' : '#2A2A2A');
      html += `<button onclick="fcKey('${k}')" style="background:${bg}; color:white; border:none; padding:18px 0; border-radius:50%; font-size:20px; font-weight:600;${k==='0'?' grid-column:span 1;':''}">${k}</button>`;
    });
  });
  html += `</div></div>`;
  document.getElementById('fakecalc-content').innerHTML = html;
}
async function fcKey(k) {
  if (k === 'C') { _fakecalcDisplay = '0'; _fakecalcInput = ''; }
  else if (k === '⌫') { _fakecalcInput = _fakecalcInput.slice(0, -1); _fakecalcDisplay = _fakecalcInput || '0'; }
  else if (k === '±') { _fakecalcInput = _fakecalcInput.startsWith('-') ? _fakecalcInput.slice(1) : '-' + _fakecalcInput; _fakecalcDisplay = _fakecalcInput || '0'; }
  else if (k === '=') {
    // Check si _fakecalcInput est un PIN valide (juste chiffres)
    if (/^\d{4,8}$/.test(_fakecalcInput)) {
      const h = await sha256(_fakecalcInput + '_nw_salt_v1');
      if (h === localStorage.getItem('nw_pin_hash')) {
        toast('🔓 Déverrouillage admin !');
        _privUnlocked = true;
        _fakecalcInput = '';
        _fakecalcDisplay = '0';
        renderFakeCalc();
        setTimeout(() => goTo('home'), 800);
        return;
      }
    }
    // Sinon, calc normal
    try {
      const expr = _fakecalcInput.replace(/×/g,'*').replace(/÷/g,'/').replace(/−/g,'-');
      // Simple safe eval (only digits and operators)
      if (/^[\d+\-*/.()% ]+$/.test(expr)) {
        const r = eval(expr);
        _fakecalcDisplay = String(r);
        _fakecalcInput = String(r);
      } else {
        _fakecalcDisplay = 'Error'; _fakecalcInput = '';
      }
    } catch { _fakecalcDisplay = 'Error'; _fakecalcInput = ''; }
  }
  else {
    const map = { '×':'×', '÷':'÷', '−':'−', '+':'+', '%':'%' };
    _fakecalcInput += k;
    _fakecalcDisplay = _fakecalcInput;
  }
  renderFakeCalc();
}

