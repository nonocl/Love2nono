function serAdd() {
  const name = document.getElementById('ser-name').value.trim();
  const s = parseInt(document.getElementById('ser-s').value) || 1;
  const e = parseInt(document.getElementById('ser-e').value) || 1;
  if (!name) return;
  const series = getSeries();
  series.push({ name: name.slice(0, 60), s, e });
  saveSeries(series);
  document.getElementById('ser-name').value = '';
  renderSeries();
}
function serNext(i) { const s = getSeries(); s[i].e++; saveSeries(s); renderSeries(); }
function serNextS(i) { const s = getSeries(); s[i].s++; s[i].e = 1; saveSeries(s); renderSeries(); }
function serDel(i) { if (!confirm('Supprimer ?')) return; const s = getSeries(); s.splice(i,1); saveSeries(s); renderSeries(); }

