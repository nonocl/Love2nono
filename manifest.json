}
function dpGen() {
  const sub = document.getElementById('dp-subject').value.trim() || '[Ton sujet]';
  const type = document.getElementById('dp-type').value;
  let html = `<div style="background:var(--surface); padding:14px; border-radius:12px;">
    <div style="font-size:11px; color:var(--textSec); margin-bottom:8px;">📌 Sujet</div>
    <div style="font-size:13px; font-weight:700; font-style:italic;">${escapeHtml(sub)}</div>
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📄 Introduction</h3>
  <div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px; font-size:12px; line-height:1.6;">
    <strong>1. Phrase d'accroche</strong> — citation, anecdote, fait d'actualité<br>
    <strong>2. Présentation du sujet</strong> — reformuler la question<br>
    <strong>3. Définition des termes</strong> — préciser le vocabulaire clé<br>
    <strong>4. Problématique</strong> — la question centrale<br>
    <strong>5. Annonce du plan</strong> — les 3 grandes parties
  </div>`;
  if (type === 'dialectique') {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📄 Plan dialectique</h3>
    <div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px; font-size:12px; line-height:1.7;">
      <strong style="color:#5DD68F;">I. Thèse — On peut soutenir que...</strong><br>
      &nbsp;&nbsp;A. Argument 1 + exemple<br>
      &nbsp;&nbsp;B. Argument 2 + exemple<br>
      &nbsp;&nbsp;C. Argument 3 + exemple<br>
      <em>Transition : "Cependant, cette thèse a ses limites..."</em><br><br>
      <strong style="color:#FF6FA3;">II. Antithèse — Mais on peut aussi penser que...</strong><br>
      &nbsp;&nbsp;A. Contre-argument 1 + exemple<br>
      &nbsp;&nbsp;B. Contre-argument 2 + exemple<br>
      &nbsp;&nbsp;C. Contre-argument 3 + exemple<br>
      <em>Transition : "Au-delà de ces deux positions..."</em><br><br>
      <strong style="color:#5DADE2;">III. Synthèse — Au final...</strong><br>
      &nbsp;&nbsp;A. Dépassement de la contradiction<br>
      &nbsp;&nbsp;B. Vision nuancée + exemple<br>
      &nbsp;&nbsp;C. Élargissement
    </div>`;
  } else if (type === 'thematique') {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📄 Plan thématique</h3>
    <div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px; font-size:12px; line-height:1.7;">
      <strong style="color:#5DD68F;">I. Premier axe</strong><br>
      &nbsp;&nbsp;A. ...<br>&nbsp;&nbsp;B. ...<br>&nbsp;&nbsp;C. ...<br><br>
      <strong style="color:#FF6FA3;">II. Deuxième axe</strong><br>
      &nbsp;&nbsp;A. ...<br>&nbsp;&nbsp;B. ...<br>&nbsp;&nbsp;C. ...<br><br>
      <strong style="color:#5DADE2;">III. Troisième axe (le plus fort)</strong><br>
      &nbsp;&nbsp;A. ...<br>&nbsp;&nbsp;B. ...<br>&nbsp;&nbsp;C. ...
    </div>`;
  } else {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📄 Plan analytique</h3>
    <div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px; font-size:12px; line-height:1.7;">
      <strong style="color:#5DD68F;">I. Constat / Causes</strong><br>
      &nbsp;&nbsp;A. ...<br>&nbsp;&nbsp;B. ...<br>&nbsp;&nbsp;C. ...<br><br>
      <strong style="color:#FF6FA3;">II. Conséquences</strong><br>
      &nbsp;&nbsp;A. ...<br>&nbsp;&nbsp;B. ...<br>&nbsp;&nbsp;C. ...<br><br>
      <strong style="color:#5DADE2;">III. Solutions / Perspectives</strong><br>
      &nbsp;&nbsp;A. ...<br>&nbsp;&nbsp;B. ...<br>&nbsp;&nbsp;C. ...
    </div>`;
  }
  html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📄 Conclusion</h3>
    <div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px; font-size:12px; line-height:1.6;">
      <strong>1. Synthèse</strong> — résumer les arguments principaux<br>
      <strong>2. Réponse à la problématique</strong> — répondre clairement<br>
      <strong>3. Ouverture</strong> — élargir vers une question nouvelle (sujet d'actualité, autre œuvre...)
    </div>`;
  document.getElementById('dp-result').innerHTML = html;
}

// === 5. ORTHOGRAPHE / VOLTAIRE ===
const ORTHO_QUESTIONS = [
  { q:'Le panier qu\'il a __ est lourd', opts:['acheté','achetés','achetée'], r:0, expl:'Le COD ("qu\'") est masc sing → accord avec "panier"' },
  { q:'Les fleurs que j\'ai __ sont belles', opts:['cueilli','cueillis','cueillies'], r:2, expl:'COD "que" (les fleurs) avant l\'auxiliaire avoir → accord fém pluriel' },
  { q:'Elle s\'est __ les mains', opts:['lavé','lavée','lavées'], r:0, expl:'Verbe pronominal + COD "les mains" APRÈS = pas d\'accord' },
  { q:'Elle s\'est __ ce matin', opts:['lavé','lavée','lavées'], r:1, expl:'Pas de COD = accord avec sujet (elle = fém sing)' },
  { q:'__ sont les livres', opts:['Quelles','Quels','Quel'], r:1, expl:'"livres" est masc pluriel → quels' },
  { q:'__ que tu sois', opts:['Quoique','Quoi que'], r:0, expl:'"Quoique" = bien que. "Quoi que" = peu importe ce que' },
  { q:'__ tu fasses, je viens', opts:['Quoique','Quoi que'], r:1, expl:'Ici "peu importe ce que" → quoi que (en deux mots)' },
  { q:'Je ne sais pas où il __', opts:['va','vas','vat'], r:0, expl:'Il + 3e personne sing → va' },
  { q:'__ les amis !', opts:['Salut','Salu','Saluts'], r:0, expl:'Interjection = invariable' },
  { q:'Il y a __ étudiants', opts:['quelque','quelques'], r:1, expl:'Devant un nom pluriel = quelques avec s' },
  { q:'Il faut __ allés', opts:['quil sois','qu\'il soit','qu\'il soient'], r:1, expl:'Subjonctif sing = soit (et non "soient" qui est pluriel)' },
  { q:'Je leur ai __ une carte', opts:['envoyé','envoyée','envoyés'], r:0, expl:'COI "leur" + COD "carte" APRÈS = pas d\'accord avec leur' },
  { q:'__ vous a-t-il fait ?', opts:['Que','Qu\'est-ce qu\''], r:0, expl:'"Que" + inversion = correct. "Qu\'est-ce que" + sans inversion' },
  { q:'C\'est __ qui __', opts:['moi/sais','moi/sait','toi/sais'], r:0, expl:'C\'est moi → 1ère personne (sais)' },
  { q:'Il a __ l\'examen', opts:['réussi','réussit','réussis'], r:0, expl:'Participe passé invariable avec avoir sans COD avant' }
];
function renderOrtho() {
  let stats; try { stats = JSON.parse(localStorage.getItem('nw_ortho') || '{"ok":0,"ko":0}'); } catch { stats = {ok:0,ko:0}; }
  const q = ORTHO_QUESTIONS[Math.floor(Math.random() * ORTHO_QUESTIONS.length)];
  let html = `<div style="background:linear-gradient(135deg,#FF8C42,#FFD166); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">✏️</div><div style="font-size:16px; font-weight:800;">Orthographe / Voltaire</div>
    <div style="font-size:11px; opacity:0.9;">${stats.ok} / ${stats.ok+stats.ko} · ${stats.ok+stats.ko>0?Math.round(stats.ok/(stats.ok+stats.ko)*100):0}%</div>
  </div>
  <div style="background:var(--surface); padding:18px; border-radius:14px; margin-top:14px;">
    <div style="font-size:11px; color:var(--textSec);">Complète :</div>
    <div style="font-size:16px; font-weight:700; margin-top:6px; line-height:1.6;">${escapeHtml(q.q)}</div>
  </div>
  <div style="display:grid; gap:6px; margin-top:14px;">`;
  q.opts.forEach((o, i) => {
    html += `<button class="btn alt" onclick="orthoAnswer(${i},${q.r},${JSON.stringify(q.expl).replace(/'/g,'&apos;')})" style="padding:14px 12px; text-align:left;">${escapeHtml(o)}</button>`;
  });
  html += `</div>`;
  document.getElementById('ortho-content').innerHTML = html;
}
function orthoAnswer(picked, correct, expl) {
  let stats; try { stats = JSON.parse(localStorage.getItem('nw_ortho') || '{"ok":0,"ko":0}'); } catch { stats = {ok:0,ko:0}; }
  if (picked === correct) {
    stats.ok++;
    toast('✓ Correct !');
    if (navigator.vibrate) navigator.vibrate(10);
  } else {
    stats.ko++;
    alert('✗ Faux\n\n' + expl);
    if (navigator.vibrate) navigator.vibrate([20,50,20]);
  }
  localStorage.setItem('nw_ortho', JSON.stringify(stats));
  renderOrtho();
}

