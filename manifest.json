const v52_PRONOMS = ['je','tu','il/elle','nous','vous','ils/elles'];
function renderConjugFr() {
  let html = `<div style="background:linear-gradient(135deg,#5DADE2,#06FFA5); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🇫🇷</div><div style="font-size:16px; font-weight:800;">Conjugueur français</div>
    <div style="font-size:11px; opacity:0.9;">12 verbes irréguliers + groupes 1 et 2</div>
  </div>
  <input type="text" id="cfr-verb" class="input" placeholder="Tape un verbe (parler, finir, être, avoir, aller...)" oninput="cfrConjugate()" style="margin-top:14px;" autocomplete="off" autocapitalize="off">
  <div id="cfr-result" style="margin-top:14px;"></div>
  <p style="font-size:10px; color:var(--textSec); margin-top:14px;">💡 Verbes irréguliers gérés : être, avoir, aller, faire, dire, voir, pouvoir, vouloir, savoir, venir, prendre, mettre, partir. Pour les autres, on conjugue par règle générale -er ou -ir.</p>`;
  document.getElementById('conjugfr-content').innerHTML = html;
}
function cfrConjugate() {
  const verb = document.getElementById('cfr-verb').value.trim().toLowerCase();
  if (!verb) { document.getElementById('cfr-result').innerHTML = ''; return; }
  let conj;
  if (FR_IRREG[verb]) {
    conj = FR_IRREG[verb];
  } else if (verb.endsWith('er')) {
    const stem = verb.slice(0, -2);
    conj = {};
    for (const t in v52_FR_VERBS.er) conj[t] = v52_FR_VERBS.er[t].map(s => stem + s);
  } else if (verb.endsWith('ir')) {
    const stem = verb.slice(0, -2);
    conj = {};
    for (const t in v52_FR_VERBS.ir) conj[t] = v52_FR_VERBS.ir[t].map(s => stem + s);
  } else {
    document.getElementById('cfr-result').innerHTML = '<div style="background:var(--surface); padding:14px; border-radius:12px; color:var(--textSec); font-size:12px;">Verbe non reconnu. Essaie un verbe en -er, -ir, ou un irrégulier (être, avoir, aller...)</div>';
    return;
  }
  let html = '';
  const tenseLabels = { présent: 'Présent', imparfait: 'Imparfait', passé_simple: 'Passé simple', futur: 'Futur', cond: 'Conditionnel', subj: 'Subjonctif présent' };
  for (const t in tenseLabels) {
    if (!conj[t]) continue;
    html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px;">
      <div style="font-size:11px; font-weight:700; color:var(--primary); margin-bottom:4px;">${tenseLabels[t]}</div>`;
    for (let i = 0; i < 6; i++) {
      html += `<div style="font-size:13px; display:flex; gap:8px; margin-top:2px;"><span style="color:var(--textSec); min-width:60px;">${v52_PRONOMS[i]}</span><strong>${escapeHtml(conj[t][i])}</strong></div>`;
    }
    html += '</div>';
  }
  document.getElementById('cfr-result').innerHTML = html;
}

