const AB_DECOS = {
  dreamy: { sym: ['☁️','✿','⊹','｡','˚','✧','⋆','⌗','♡','꒰','꒱'], emojis: ['🌸','💌','🤍','✨','🌙','💭'], frames:['꒰ ',' ꒱', '⊹ ',' ⊹', '✿ ',' ✿'] },
  dark: { sym: ['☾','✦','✧','‧','˚','♱','꙰','⊹','✞'], emojis: ['🖤','🥀','🕯️','📜','🌑','🐍'], frames:['✦ ',' ✦', '⊹ ',' ⊹', '☾ ',' ☾'] },
  cute: { sym: ['♡','˚','˖','⋆','｡','✿','꒱','꒰','⌗'], emojis: ['🍓','🌷','🍡','🐰','💗','🧁'], frames:['꒰ ',' ꒱', '♡ ',' ♡'] },
  celestial: { sym: ['☆','★','✧','⋆','✦','⭒','˚','✺'], emojis: ['🌟','☀️','🌙','🌠','💫','🌌'], frames:['✦ ',' ✦', '☆ ',' ☆'] },
  vintage: { sym: ['✦','✧','✩','◦','〰','✁','◖'], emojis: ['📜','🕰️','🍂','📷','🪶','🥀'], frames:['❀ ',' ❀', '◇ ',' ◇'] },
  fairy: { sym: ['✿','❀','❁','✧','⋆','꙳','˖'], emojis: ['🍄','🦋','🌿','🧚','🌷','🌳'], frames:['✿ ',' ✿', '❀ ',' ❀'] },
  cyber: { sym: ['╳','◢','◣','▒','▓','░','♢','◆'], emojis: ['💾','💿','🖥️','💜','✨','⚡'], frames:['◤ ',' ◥', '▓ ',' ▓'] },
  goth: { sym: ['☽','✟','✞','✠','♱','֍','✦'], emojis: ['🦇','🕷️','🥀','⚰️','💀','🖤'], frames:['☽ ',' ☾', '✞ ',' ✞'] },
};
function rerollAestheticBio() {
  const style = document.getElementById('ab-style').value;
  const name = document.getElementById('ab-name').value.trim() || 'name';
  const age = document.getElementById('ab-age').value.trim();
  const keywords = document.getElementById('ab-keywords').value.split(',').map(s=>s.trim()).filter(Boolean);
  const deco = AB_DECOS[style];
  const out = document.getElementById('ab-output');
  out.innerHTML = '';
  for (let i=0; i<5; i++) {
    const f = deco.frames[Math.floor(Math.random()*deco.frames.length)];
    const sym = deco.sym[Math.floor(Math.random()*deco.sym.length)];
    const em = deco.emojis[Math.floor(Math.random()*deco.emojis.length)];
    let bio = '';
    const variant = i % 5;
    if (variant === 0) {
      bio = `${f.split(',')[0]||f}${name}${f.split(',')[1]||''}\n${age ? age + ' '+sym+' ' : ''}${keywords.join(' '+sym+' ')}\n${em} ${deco.emojis[(Math.floor(Math.random()*deco.emojis.length))]}`;
    } else if (variant === 1) {
      bio = `${em} ${name} ${em}\n${sym} ${keywords.join(' '+sym+' ')} ${sym}${age ? '\n'+age+' ans' : ''}`;
    } else if (variant === 2) {
      bio = `${name.toLowerCase()} ${sym}\n${keywords.map(k => sym + ' ' + k).join('\n')}\n${em}`;
    } else if (variant === 3) {
      const decoLine = Array(8).fill(0).map(() => deco.sym[Math.floor(Math.random()*deco.sym.length)]).join(' ');
      bio = `${decoLine}\n${em} ${name}${age ? ', '+age : ''} ${em}\n${keywords.join(' · ')}\n${decoLine}`;
    } else {
      bio = `┊ ${name}\n┊ ${age ? age + ' ' + sym + ' ' : ''}${em}\n${keywords.map(k => '┊ '+k).join('\n')}\n┊ ${sym}${sym}${sym}`;
    }
    const card = document.createElement('div');
    card.style.cssText = 'background:var(--surface); padding:14px; border-radius:12px; margin-bottom:8px; cursor:pointer; white-space:pre-wrap; font-family:monospace; line-height:1.5; font-size:13px;';
    card.textContent = bio;
    card.onclick = () => { navigator.clipboard.writeText(bio).then(() => toast('📋 Copié !')); };
    out.appendChild(card);
  }
}

