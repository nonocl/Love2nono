/* ============================================================
   FIXES UNIVERSELS DESIGNS - COHÉRENCE & RESPONSIVE
   ============================================================ */

/* Force que les body backgrounds des designs prennent le pas sur tout thème */
body[class*="design-"] { background-color: var(--bg) !important; color: var(--text) !important; }

/* Search bar : force le padding-left correct et visibilité de la loupe partout */

/* Force les emojis des tuiles à rester visibles dans TOUS les designs */
body[class*="design-"] .home-tile .ico {
  font-size: 26px !important;
  display: block !important;
  filter: none !important;
  opacity: 1 !important;
  margin-bottom: 4px;
}
/* Sauf Vogue où on veut le côté minimal en niveaux de gris */
body.design-vogue .home-tile .ico {
  filter: grayscale(100%) contrast(1.2) !important;
  opacity: 0.85 !important;
}
/* Et Terminal/Cyberpunk avec teinte */
body.design-terminal .home-tile .ico { filter: hue-rotate(85deg) saturate(1.5) brightness(1.1) !important; }
body.design-gameboy .home-tile .ico { filter: sepia(1) saturate(2) hue-rotate(40deg) brightness(0.8) !important; }

/* Force que les .home-tile soient assez grandes pour le contenu (responsive iPhone) */
.home-tile {
  min-height: 70px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 10px 4px;
}
.home-tile .lbl {
  font-size: 11px;
  line-height: 1.2;
  word-wrap: break-word;
  hyphens: auto;
  max-width: 100%;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

/* Section header : empêche le débordement du nom de section */
.home-section-header .title-txt {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Tuiles dans Vogue : couleur de label adaptative */
body.design-vogue .home-tile { 
  background: var(--surface, #FFF) !important; 
  color: var(--text, #1A1A1A) !important;
}
body.design-vogue .home-tile .lbl { 
  color: var(--text, #1A1A1A) !important;
}

/* Pour TOUS les designs : si le user a un theme dark de fond, qu'on garde de la lisibilité */
body.design-vogue, body.design-paper, body.design-brutalist, body.design-manga, body.design-pokemon {
  /* Designs "clairs" -> force fond clair */
  --bg-override: var(--bg) !important;
}

/* Fix tabs scrollables sur petit écran */
.home-tabs {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  white-space: nowrap;
  scrollbar-width: none;
}
.home-tabs::-webkit-scrollbar { display: none; }
.home-tab { flex-shrink: 0; }

/* Top bar : empêche débordement du titre */
.topbar .title { 
  flex: 1; 
  min-width: 0; 
  overflow: hidden; 
  text-overflow: ellipsis; 
  white-space: nowrap;
}

/* Page header : pareil */
.page-title {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

/* Responsive très petit écran (< 360px iPhone SE) */
@media (max-width: 360px) {
  .home-grid { grid-template-columns: repeat(3, 1fr) !important; }
  .home-tile { min-height: 64px; padding: 8px 2px; }
  .home-tile .lbl { font-size: 10px !important; }
  .home-tile .ico { font-size: 22px !important; }
  body.preset-compact .home-grid { grid-template-columns: repeat(4, 1fr) !important; }
}

/* Vogue spécifique : force fond clair quoi qu'il arrive */
body.design-vogue { background: #FAFAFA !important; color: #1A1A1A !important; }
body.design-vogue .home-tab { background: #FFF !important; color: #1A1A1A !important; border-color: #1A1A1A22 !important; }
body.design-vogue .home-tab.active { background: #1A1A1A !important; color: #FAFAFA !important; }
body.design-vogue .topbar { background: #FFF !important; }
body.design-vogue .topbar .title, body.design-vogue .topbar { color: #1A1A1A !important; }
body.design-vogue .bottom-nav { background: #FFF !important; border-color: #1A1A1A33 !important; }
body.design-vogue .bottom-nav-btn { color: #666 !important; }
body.design-vogue .bottom-nav-btn.active { color: #1A1A1A !important; }

/* Pareil Brutalist (jaune fluo doit rester) */
body.design-brutalist { background: #FFFF00 !important; color: #000 !important; }
body.design-brutalist .home-tab { background: #FFF !important; color: #000 !important; border: 2px solid #000 !important; border-radius: 0 !important; }
body.design-brutalist .home-tab.active { background: #000 !important; color: #FFFF00 !important; }
body.design-brutalist .topbar { background: #FFFF00 !important; }
body.design-brutalist .topbar .title { color: #000 !important; }

/* Papier vintage : fond clair même si theme dark */
body.design-paper { background: #F4ECD8 !important; color: #3E2A1F !important; }
body.design-paper .home-tab { background: #FAF3DD !important; color: #3E2A1F !important; }
body.design-paper .home-tab.active { background: #8B4513 !important; color: #FAF3DD !important; }

/* Manga shōnen */
body.design-manga { background-color: #FFF !important; color: #000 !important; }
body.design-manga .home-tab { background: #FFF !important; color: #000 !important; border: 2px solid #000 !important; }
body.design-manga .home-tab.active { background: #000 !important; color: #FFF !important; }

/* Pokémon fond clair */
body.design-pokemon { color: #2A2A2A !important; }
body.design-pokemon .home-tab { background: #FFF !important; color: #2A2A2A !important; border: 2px solid #2A2A2A !important; }
body.design-pokemon .home-tab.active { background: #DC0A2D !important; color: #FFF !important; }

