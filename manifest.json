  {sign:'sagittaire', start:[11,22], end:[12,21], emoji:'♐', name:'Sagittaire', traits:'Aventurière, optimiste, libre'}
];
function getZodiacBy(month, day) {
  for (const z of ZODIAC) {
    if (z.start[0] === month && day >= z.start[1]) return z;
    if (z.end[0] === month && day <= z.end[1]) return z;
  }
  return ZODIAC[0]; // capricorne fallback
}
const HOROSCOPES = {
