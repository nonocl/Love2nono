// ============================================================
// PALETTE GENERATOR
// ============================================================
document.getElementById('palette-input').addEventListener('change', async (e) => {
  const f = e.target.files?.[0];
  if (!f) return;
  const reader = new FileReader();
  reader.onload = () => {
    const img = new Image();
    img.onload = () => {
      document.getElementById('palette-preview').src = reader.result;
      document.getElementById('palette-preview-wrap').style.display = 'block';
      const colors = extractPalette(img, 5);
      state.paletteColors = colors;
      renderPaletteResult(colors);
    };
    img.src = reader.result;
  };
  reader.readAsDataURL(f);
  e.target.value = '';
});

function extractPalette(img, n) {
  const c = document.createElement('canvas');
  const ctx = c.getContext('2d');
  const size = 100;
  c.width = size; c.height = size;
  ctx.drawImage(img, 0, 0, size, size);
  const data = ctx.getImageData(0,0,size,size).data;
  // Quantification: regrouper par cubes de 32
  const buckets = {};
  for (let i=0; i<data.length; i+=4) {
    const r = data[i]>>5<<5, g = data[i+1]>>5<<5, b = data[i+2]>>5<<5;
    const k = `${r},${g},${b}`;
    buckets[k] = (buckets[k]||0)+1;
  }
  const sorted = Object.entries(buckets).sort((a,b)=>b[1]-a[1]).slice(0, n*2);
  // Filtrer les couleurs trop similaires
  const result = [];
  for (const [k] of sorted) {
    const [r,g,b] = k.split(',').map(Number);
    if (result.every(c => Math.abs(c.r-r)+Math.abs(c.g-g)+Math.abs(c.b-b) > 60)) {
      result.push({r,g,b});
      if (result.length >= n) break;
    }
  }
  return result.map(({r,g,b}) => `#${[r,g,b].map(x=>x.toString(16).padStart(2,'0')).join('').toUpperCase()}`);
}

function renderPaletteResult(colors) {
  const el = document.getElementById('palette-colors');
  el.innerHTML = '';
  for (const c of colors) {
    const d = document.createElement('div');
    d.className = 'palette-color';
    d.style.background = c;
    d.textContent = c;
    d.onclick = () => { navigator.clipboard?.writeText(c); toast(`${c} copié`); };
    el.appendChild(d);
  }
}

