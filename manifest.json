  fr: ['MAISON','POMME','VOITURE','CHAPEAU','OISEAU','CHEVAL','PRINTEMPS','MONTAGNE','LECTURE','MUSIQUE','NUAGE','POESIE','CHATEAU','LAVANDE','TOURNESOL','CHOCOLAT','BIBLIOTHEQUE','PARAPLUIE','OCEAN','PLANETE','REVE','BOUGIE','VENTILATEUR','SILENCE','TONNERRE'],
  it: ['CASA','MELA','GATTO','CANE','ALBERO','MONTAGNA','MARE','SOLE','LUNA','STELLA','LIBRO','SCUOLA','AMICO','CIOCCOLATO','PIZZA','PASTA','GELATO','VIAGGIO','CITTA','FAMIGLIA','MUSICA','CINEMA','CALCIO','POESIA','BICICLETTA'],
  en: ['HOUSE','APPLE','TRAVEL','BOOK','SCHOOL','FRIEND','OCEAN','MOUNTAIN','SUNSET','RAINBOW','CHOCOLATE','LIBRARY','MIRROR','GUITAR','THUNDER','LANTERN','CASTLE','FOREST','PUZZLE','POETRY','HARMONY','WHISPER','MEMORY','UMBRELLA','PLANET'],
};
const STICK_FRAMES = [
  '  +---+\n      |\n      |\n      |\n      |\n=========',
  '  +---+\n  O   |\n      |\n      |\n      |\n=========',
  '  +---+\n  O   |\n  |   |\n      |\n      |\n=========',
  '  +---+\n  O   |\n /|   |\n      |\n      |\n=========',
  '  +---+\n  O   |\n /|\\  |\n      |\n      |\n=========',
  '  +---+\n  O   |\n /|\\  |\n /    |\n      |\n=========',
  '  +---+\n  O   |\n /|\\  |\n / \\  |\n      |\n========='
];
let _hang = null;
function newHangman(lang) {
  lang = lang || _hang?.lang || 'fr';
  document.querySelectorAll('[data-hl]').forEach(b => b.className = b.dataset.hl === lang ? 'btn primary' : 'btn alt');
  const words = HANG_WORDS[lang];
  _hang = {
    lang, word: words[Math.floor(Math.random()*words.length)],
    guessed: new Set(), errors: 0, max: 6, won: false, lost: false
  };
  renderHangman();
}
function renderHangman() {
  document.getElementById('hang-stick').textContent = STICK_FRAMES[_hang.errors];
  // Display word
  const display = _hang.word.split('').map(c => _hang.guessed.has(c) ? c : '_').join(' ');
  document.getElementById('hang-word').textContent = display;
  // Win check
  if (!_hang.lost && _hang.word.split('').every(c => _hang.guessed.has(c))) {
    _hang.won = true;
    document.getElementById('hang-status').innerHTML = `<span style="color:var(--success);">🎉 Bravo ! Mot trouvé en ${_hang.errors} erreurs.</span>`;
  } else if (_hang.errors >= _hang.max) {
    _hang.lost = true;
    document.getElementById('hang-status').innerHTML = `<span style="color:var(--danger);">💀 Pendu. C'était : ${_hang.word}</span>`;
  } else {
    document.getElementById('hang-status').textContent = `Erreurs : ${_hang.errors}/${_hang.max}`;
  }
  // Keyboard
  const kb = document.getElementById('hang-keyboard');
  kb.innerHTML = '';
  const alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  for (const c of alphabet) {
    const btn = document.createElement('button');
    const guessed = _hang.guessed.has(c);
    const correct = guessed && _hang.word.includes(c);
    btn.className = guessed ? 'btn alt' : 'btn alt';
    btn.style.cssText = `width:28px; height:34px; padding:0; font-size:13px; font-weight:700; ${guessed ? (correct ? 'background:#5DD68F; color:white;' : 'background:#666; color:white; opacity:0.5;') : ''}`;
    btn.textContent = c;
    btn.disabled = guessed || _hang.won || _hang.lost;
    btn.onclick = () => guessHang(c);
    kb.appendChild(btn);
  }
}
function guessHang(c) {
  if (_hang.won || _hang.lost || _hang.guessed.has(c)) return;
  _hang.guessed.add(c);
  if (!_hang.word.includes(c)) _hang.errors++;
  renderHangman();
}

// ============================================================
// JEU: BATAILLE NAVALE
// ============================================================
const NAVAL_SIZE = 8;
const NAVAL_SHIPS = [{ size:4, count:1 }, { size:3, count:2 }, { size:2, count:2 }];
let _naval = null;
function newNaval() {
  _naval = {
    enemy: makeNavalGrid(), enemyShots: makeNavalGrid(), // shots tracks player's hits/misses on enemy
    mine: makeNavalGrid(), aiShots: makeNavalGrid(),
    enemyShips: [], myShips: [],
    turn: 'player', over: false
  };
  placeShipsRandom(_naval.enemy, _naval.enemyShips);
  placeShipsRandom(_naval.mine, _naval.myShips);
  renderNaval();
}
function makeNavalGrid() {
  return Array.from({length:NAVAL_SIZE}, () => Array(NAVAL_SIZE).fill(0));
}
function placeShipsRandom(grid, ships) {
  for (const s of NAVAL_SHIPS) {
    for (let c=0; c<s.count; c++) {
      let placed = false;
      while (!placed) {
        const horiz = Math.random() < 0.5;
        const r = Math.floor(Math.random()*NAVAL_SIZE);
        const col = Math.floor(Math.random()*NAVAL_SIZE);
        if (horiz && col + s.size > NAVAL_SIZE) continue;
        if (!horiz && r + s.size > NAVAL_SIZE) continue;
        let ok = true;
        for (let i=0; i<s.size; i++) {
          const rr = horiz ? r : r+i, cc = horiz ? col+i : col;
          if (grid[rr][cc]) { ok = false; break; }
        }
        if (!ok) continue;
        const ship = { cells: [], hits: 0, size: s.size };
        for (let i=0; i<s.size; i++) {
          const rr = horiz ? r : r+i, cc = horiz ? col+i : col;
          grid[rr][cc] = 1;
          ship.cells.push([rr, cc]);
        }
        ships.push(ship);
        placed = true;
      }
    }
  }
}
function renderNaval() {
  // Enemy grid (player tape pour viser)
  const ene = document.getElementById('naval-enemy');
  ene.innerHTML = '';
  for (let r=0; r<NAVAL_SIZE; r++) for (let c=0; c<NAVAL_SIZE; c++) {
    const cell = document.createElement('button');
    const shot = _naval.enemyShots[r][c]; // 0=non, 1=miss, 2=hit, 3=sunk
    let bg = 'var(--surfaceAlt)', symbol = '';
    if (shot === 1) { bg = '#5DD6E5'; symbol = '🔵'; }
    else if (shot === 2) { bg = '#FF8C42'; symbol = '🟧'; }
    else if (shot === 3) { bg = '#FF6B7A'; symbol = '🟥'; }
    cell.style.cssText = `width:28px; height:28px; padding:0; background:${bg}; border:1px solid var(--border); cursor:${shot ? 'default' : 'pointer'};`;
    cell.disabled = !!shot || _naval.over || _naval.turn !== 'player';
    cell.textContent = symbol;
    cell.onclick = () => navalShoot(r, c);
    ene.appendChild(cell);
  }
  // My grid
  const mine = document.getElementById('naval-mine');
  mine.innerHTML = '';
  for (let r=0; r<NAVAL_SIZE; r++) for (let c=0; c<NAVAL_SIZE; c++) {
    const cell = document.createElement('div');
    const has = _naval.mine[r][c];
    const shot = _naval.aiShots[r][c]; // 0=non, 1=miss, 2=hit, 3=sunk
    let bg = has ? '#5b8def' : 'var(--surfaceAlt)';
    let symbol = '';
    if (shot === 1) { bg = '#5DD6E5'; symbol = '🔵'; }
    else if (shot === 2) { bg = '#FF8C42'; symbol = '🟧'; }
    else if (shot === 3) { bg = '#FF6B7A'; symbol = '🟥'; }
    cell.style.cssText = `width:28px; height:28px; background:${bg}; border:1px solid var(--border); display:flex; align-items:center; justify-content:center; font-size:11px;`;
    cell.textContent = symbol;
    mine.appendChild(cell);
  }
}
function navalShoot(r, c) {
  if (_naval.turn !== 'player' || _naval.over) return;
  if (_naval.enemy[r][c]) {
    // Find ship
    const ship = _naval.enemyShips.find(s => s.cells.some(([sr,sc]) => sr===r && sc===c));
    ship.hits++;
    if (ship.hits === ship.size) {
      ship.cells.forEach(([sr,sc]) => _naval.enemyShots[sr][sc] = 3);
    } else {
      _naval.enemyShots[r][c] = 2;
    }
  } else {
    _naval.enemyShots[r][c] = 1;
  }
  // Win?
  if (_naval.enemyShips.every(s => s.hits === s.size)) {
    _naval.over = true;
    document.getElementById('naval-status').textContent = '🎉 Tu as gagné !';
    renderNaval();
    return;
  }
  _naval.turn = 'ai';
  document.getElementById('naval-status').textContent = '🤖 IA réfléchit...';
  renderNaval();
  setTimeout(navalAiTurn, 700);
}
function navalAiTurn() {
  // IA simple : random hits sans répétition
  let r, c;
  do {
    r = Math.floor(Math.random()*NAVAL_SIZE);
    c = Math.floor(Math.random()*NAVAL_SIZE);
  } while (_naval.aiShots[r][c]);
  if (_naval.mine[r][c]) {
    const ship = _naval.myShips.find(s => s.cells.some(([sr,sc]) => sr===r && sc===c));
    ship.hits++;
    if (ship.hits === ship.size) {
      ship.cells.forEach(([sr,sc]) => _naval.aiShots[sr][sc] = 3);
    } else {
      _naval.aiShots[r][c] = 2;
    }
  } else {
    _naval.aiShots[r][c] = 1;
  }
  if (_naval.myShips.every(s => s.hits === s.size)) {
    _naval.over = true;
    document.getElementById('naval-status').textContent = '😬 IA a gagné !';
    renderNaval();
    return;
  }
  _naval.turn = 'player';
  document.getElementById('naval-status').textContent = '🎯 À ton tour !';
  renderNaval();
}

