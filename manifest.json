function renderTiktok() {
  const d = window.simData.tiktok;
  d.handle = document.getElementById('tt-handle').value;
  d.name = document.getElementById('tt-name').value;
  d.bio = document.getElementById('tt-bio').value;
  d.link = document.getElementById('tt-link').value;
  d.following = document.getElementById('tt-following').value;
  d.followers = document.getElementById('tt-followers').value;
  d.likes = document.getElementById('tt-likes').value;
  d.verified = document.getElementById('tt-verified').checked;
  d.vidsEmojis = document.getElementById('tt-vids-emojis').value;
  d.pinViews = document.getElementById('tt-pin-views').value;
  const initial = (d.handle || d.name || '?').slice(0,1).toUpperCase();

  // Grid vidéos
  const emojis = (d.vidsEmojis || '').split('').filter(c => c.trim());
  let vidsHtml = '<div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1px; margin-top:8px;">';
  for (let i=0; i<9; i++) {
    const e = emojis[i] || '🎵';
    const pinned = i === 0 && d.pinViews;
    const fakeViews = ['12.4K','3.2K','892','45.1K','5.6K','1.8K','234','7.7K','911'];
    const views = pinned ? d.pinViews : fakeViews[i];
    const colors = ['#1a1a1a','#252525','#1f1f1f'];
    vidsHtml += `<div style="aspect-ratio:9/16; background:${colors[i%3]}; display:flex; flex-direction:column; align-items:center; justify-content:center; position:relative; font-size:38px;">
      ${pinned ? '<div style="position:absolute; top:4px; left:4px; background:rgba(0,0,0,0.6); color:white; font-size:9px; padding:2px 5px; border-radius:3px; font-weight:700;">📌 ÉPINGLÉE</div>' : ''}
      <span>${e}</span>
      <div style="position:absolute; bottom:6px; left:6px; color:white; font-size:11px; font-weight:600; text-shadow:0 1px 2px rgba(0,0,0,0.8);">▶ ${escapeHtml(views)}</div>
    </div>`;
  }
  vidsHtml += '</div>';

  const linkHtml = d.link ? `<div style="padding:0 14px 6px; font-size:13px; color:#5DD6E5;">🔗 ${escapeHtml(d.link)}</div>` : '';

  document.getElementById('tt-preview').innerHTML = `
    <div class="tt-card">
      <div class="tt-header">
        <div class="tt-avatar"><div class="tt-avatar-inner">${d.avatar ? `<img src="${d.avatar}" alt="">` : `<div style="font-size:38px; color:white; font-weight:700;">${escapeHtml(initial)}</div>`}</div></div>
        <div class="tt-handle">@${escapeHtml(d.handle || 'username')} ${d.verified ? '<span style="display:inline-block; width:14px; height:14px; background:#20d5ec; border-radius:50%; color:white; font-size:9px; font-weight:900; line-height:14px; text-align:center; vertical-align:middle;">✓</span>' : ''}</div>
        ${d.name ? `<div class="tt-name">${escapeHtml(d.name)}</div>` : ''}
