// TEXTE → PDF
// ============================================================
async function t2pCreate() {
  const title = document.getElementById('t2p-title').value.trim();
  const content = document.getElementById('t2p-content').value;
  if (!content.trim()) return setStatus('t2p-status', 'Tape au moins un peu de texte', 'error');
  setStatus('t2p-status', 'Création...', 'loading');
  try {
    const jsPDF = await ensureJsPdf();
    const size = parseInt(document.getElementById('t2p-size').value);
    const doc = new jsPDF({ unit:'mm', format:'a4' });
    let y = 20;
    if (title) {
      doc.setFontSize(20);
      doc.setFont(undefined, 'bold');
      doc.text(title, 20, y);
      y += 12;
      doc.setLineWidth(0.5);
      doc.line(20, y, 190, y);
      y += 8;
    }
    doc.setFontSize(size);
    doc.setFont(undefined, 'normal');
    const lineHeight = size * 0.5;
    const maxWidth = 170;
    const paragraphs = content.split(/\n\s*\n/);
    for (const para of paragraphs) {
      const lines = doc.splitTextToSize(para.trim(), maxWidth);
      for (const line of lines) {
        if (y > 280) { doc.addPage(); y = 20; }
        doc.text(line, 20, y);
        y += lineHeight;
      }
      y += lineHeight * 0.6;
    }
    const blob = doc.output('blob');
    dlBlob(blob, `${(title || 'document').replace(/[^\w\-]/g,'_')}-${Date.now()}.pdf`);
    setStatus('t2p-status', '✅ PDF créé !', 'success');
  } catch (e) {
    console.error(e); setStatus('t2p-status', '❌ ' + e.message, 'error');
  }
}

