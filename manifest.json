let _editingWeight = null;

async function renderWeight() {
  const logs = await dbAll('weight_log');
  if (logs.length > 0) {
    logs.sort((a,b) => (a.date||'').localeCompare(b.date||''));
    const last = logs[logs.length-1];
    document.getElementById('weight-current').textContent = last.value.toFixed(1) + ' kg';
    if (logs.length >= 2) {
      const diff = last.value - logs[logs.length-2].value;
      const sign = diff >= 0 ? '+' : '';
      const color = Math.abs(diff) < 0.3 ? 'var(--textSec)' : (diff > 0 ? 'var(--danger)' : 'var(--success)');
      document.getElementById('weight-trend').innerHTML = `Précédent : <strong style="color:${color};">${sign}${diff.toFixed(1)} kg</strong>`;
    }
  } else {
    document.getElementById('weight-current').textContent = '— kg';
    document.getElementById('weight-trend').textContent = 'Aucune pesée';
  }
  // Graph last 30 days
  drawWeightGraph(logs);
  // List
  const el = document.getElementById('weight-list');
  el.innerHTML = '';
  if (logs.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">⚖️</div><h3>Aucune pesée</h3><p>Enregistre tes pesées pour suivre ton poids dans le temps.</p></div>`;
    return;
  }
  for (const l of logs.slice().reverse()) {
    const row = document.createElement('button');
    row.style.cssText = 'display:flex; align-items:center; gap:10px; padding:10px 14px; background:var(--surface); border-radius:12px; margin-bottom:4px; width:100%; text-align:left;';
    row.innerHTML = `
      <div style="flex:1; min-width:0;">
        <div style="font-size:14px; font-weight:600;">${new Date(l.date).toLocaleDateString('fr-FR', {weekday:'short', day:'numeric', month:'short', year:'numeric'})}</div>
        ${l.note ? `<div style="font-size:11px; color:var(--textSec);">${escapeHtml(l.note)}</div>` : ''}
      </div>
      <div style="font-size:18px; font-weight:800; color:var(--primary);">${l.value.toFixed(1)} kg</div>
    `;
    row.onclick = () => openWeightModal(l);
    el.appendChild(row);
  }
}

function drawWeightGraph(logs) {
  const c = document.getElementById('weight-canvas');
  if (!c) return;
  const ctx = c.getContext('2d');
  const W = c.width, H = c.height;
  ctx.clearRect(0,0,W,H);
  if (logs.length < 2) {
    ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--textSec').trim();
    ctx.font = '12px sans-serif'; ctx.textAlign = 'center';
    ctx.fillText('Pas assez de données', W/2, H/2);
    return;
  }
  const cutoff = Date.now() - 30*86400000;
  const recent = logs.filter(l => new Date(l.date).getTime() >= cutoff);
  if (recent.length < 2) { drawWeightGraph2(ctx, logs.slice(-30), W, H); return; }
  drawWeightGraph2(ctx, recent, W, H);
}

function drawWeightGraph2(ctx, points, W, H) {
  const minV = Math.min(...points.map(p=>p.value)) - 0.5;
  const maxV = Math.max(...points.map(p=>p.value)) + 0.5;
  const range = maxV - minV || 1;
  const x0 = 30, y0 = H - 16, plotW = W - 40, plotH = H - 32;
  ctx.strokeStyle = getComputedStyle(document.documentElement).getPropertyValue('--primary').trim();
  ctx.lineWidth = 2;
  ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--primary').trim();
  ctx.beginPath();
  for (let i=0; i<points.length; i++) {
    const x = x0 + (i/(points.length-1)) * plotW;
    const y = 16 + plotH - ((points[i].value - minV) / range) * plotH;
    if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
  }
  ctx.stroke();
  // Dots
  for (let i=0; i<points.length; i++) {
    const x = x0 + (i/(points.length-1)) * plotW;
    const y = 16 + plotH - ((points[i].value - minV) / range) * plotH;
    ctx.beginPath(); ctx.arc(x, y, 3, 0, Math.PI*2); ctx.fill();
  }
  // Labels min/max
  ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--textSec').trim();
  ctx.font = '10px sans-serif'; ctx.textAlign = 'left';
  ctx.fillText(maxV.toFixed(1), 2, 18);
  ctx.fillText(minV.toFixed(1), 2, H-4);
}

function openWeightModal(l) {
  _editingWeight = l;
  document.getElementById('wgt-modal-title').textContent = l ? 'Modifier' : 'Nouvelle pesée';
  document.getElementById('wgt-date-input').value = l ? l.date : new Date().toISOString().split('T')[0];
  document.getElementById('wgt-value-input').value = l ? l.value : '';
