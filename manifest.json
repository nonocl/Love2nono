let _flag = null;
async function initFlags() {
  const best = await getScore('flags');
  _flag = { score:0, best:best?best.value:0, current:null };
  document.getElementById('flag-best').textContent = _flag.best;
  document.getElementById('flag-score').textContent = '0';
  nextFlag();
}

function nextFlag() {
  const idx = Math.floor(Math.random()*FLAGS.length);
  _flag.current = FLAGS[idx];
  document.getElementById('flag-display').textContent = _flag.current[0];
  // 4 options
  const options = [_flag.current[1]];
  while (options.length < 4) {
    const o = FLAGS[Math.floor(Math.random()*FLAGS.length)][1];
    if (!options.includes(o)) options.push(o);
  }
  options.sort(() => Math.random()-0.5);
  const optEl = document.getElementById('flag-options');
  optEl.innerHTML = '';
  for (const o of options) {
    const b = document.createElement('button');
    b.className = 'btn alt';
    b.style.cssText = 'padding:14px 8px; font-size:13px;';
    b.textContent = o;
    b.onclick = () => answerFlag(o);
    optEl.appendChild(b);
  }
  document.getElementById('flag-result').textContent = '';
}

function answerFlag(answer) {
  const result = document.getElementById('flag-result');
  if (answer === _flag.current[1]) {
    _flag.score++;
    document.getElementById('flag-score').textContent = _flag.score;
    if (_flag.score > _flag.best) { _flag.best = _flag.score; setScore('flags', _flag.score); document.getElementById('flag-best').textContent = _flag.best; }
    result.textContent = '✓ Bien !';
    result.style.color = 'var(--success)';
    setTimeout(nextFlag, 500);
  } else {
    result.textContent = `✗ C'était ${_flag.current[1]}`;
    result.style.color = 'var(--danger)';
    setTimeout(() => { _flag.score = 0; document.getElementById('flag-score').textContent = '0'; nextFlag(); }, 1500);
  }
}


