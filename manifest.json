const ZODIAC2 = [
  { name: "Capricorne", emoji: "♑", start: [12,22], end: [1,19], elem: "Terre", trait: "Ambitieux, discipliné" },
  { name: "Verseau", emoji: "♒", start: [1,20], end: [2,18], elem: "Air", trait: "Original, indépendant" },
  { name: "Poissons", emoji: "♓", start: [2,19], end: [3,20], elem: "Eau", trait: "Sensible, intuitif" },
  { name: "Bélier", emoji: "♈", start: [3,21], end: [4,19], elem: "Feu", trait: "Énergique, pionnier" },
  { name: "Taureau", emoji: "♉", start: [4,20], end: [5,20], elem: "Terre", trait: "Stable, gourmand" },
  { name: "Gémeaux", emoji: "♊", start: [5,21], end: [6,20], elem: "Air", trait: "Curieux, communicant" },
  { name: "Cancer", emoji: "♋", start: [6,21], end: [7,22], elem: "Eau", trait: "Émotionnel, protecteur" },
  { name: "Lion", emoji: "♌", start: [7,23], end: [8,22], elem: "Feu", trait: "Charismatique, fier" },
  { name: "Vierge", emoji: "♍", start: [8,23], end: [9,22], elem: "Terre", trait: "Précis, analytique" },
  { name: "Balance", emoji: "♎", start: [9,23], end: [10,22], elem: "Air", trait: "Diplomate, esthète" },
  { name: "Scorpion", emoji: "♏", start: [10,23], end: [11,21], elem: "Eau", trait: "Intense, mystérieux" },
  { name: "Sagittaire", emoji: "♐", start: [11,22], end: [12,21], elem: "Feu", trait: "Aventureux, philosophe" }
];
function getZodiac2(month, day) {
  for (const z of ZODIAC2) {
    if (z.start[0] === z.end[0]) {
      if (month === z.start[0] && day >= z.start[1] && day <= z.end[1]) return z;
    } else {
      if ((month === z.start[0] && day >= z.start[1]) || (month === z.end[0] && day <= z.end[1])) return z;
    }
  }
  return ZODIAC2[0];
}
function renderNatalChart() {
  let html = `<div style="background:linear-gradient(135deg,#5D2E8C,#1A1A2E); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">⭐</div>
    <div style="font-size:16px; font-weight:800;">Charte natale</div>
    <div style="font-size:11px; opacity:0.9;">Soleil, Lune et Ascendant</div>
  </div>
  <span class="label" style="margin-top:14px;">📅 Date de naissance</span>
  <input type="date" class="input" id="nat-date" oninput="natCalc()">
  <span class="label" style="margin-top:8px;">🕐 Heure (HH:MM, optionnel)</span>
  <input type="time" class="input" id="nat-time" oninput="natCalc()">
  <span class="label" style="margin-top:8px;">📍 Ville (pour ascendant approximatif)</span>
  <input type="text" class="input" id="nat-city" placeholder="Paris, Roma, Tokyo..." oninput="natCalc()">
  <div id="nat-result" style="margin-top:14px;"></div>
  <p style="font-size:10px; color:var(--textSec); margin-top:10px;">⚠️ Charte simplifiée. Pour une charte complète et précise, utilise un logiciel pro (astro.com).</p>`;
  document.getElementById('natalchart-content').innerHTML = html;
}
function natCalc() {
  const d = document.getElementById('nat-date').value;
  if (!d) return;
  const dt = new Date(d);
  const month = dt.getMonth() + 1;
  const day = dt.getDate();
  const sun = getZodiac2(month, day);
  
  // Lune approximée par cycle de 2.5 jours par signe
  const epoch = new Date('2000-01-01').getTime();
  const days = (dt.getTime() - epoch) / (1000 * 60 * 60 * 24);
  const moonIdx = Math.floor((days * 13.176 / 360) % 12 + 12) % 12;
  const moon = ZODIAC2[moonIdx];
  
  // Asc approximé selon heure (1 signe par 2h en moyenne)
  let asc = null;
  const t = document.getElementById('nat-time').value;
  if (t) {
    const [h, m] = t.split(':').map(Number);
    const hour = h + m / 60;
    const sunIdx = ZODIAC2.indexOf(sun);
    const ascIdx = (sunIdx + Math.floor(hour / 2)) % 12;
    asc = ZODIAC2[ascIdx];
  }
  
  let html = `<div style="background:linear-gradient(135deg,#FFD166,#FF8C42); color:white; padding:18px; border-radius:14px; text-align:center;">
    <div style="font-size:11px; opacity:0.9;">☀️ SOLEIL</div>
    <div style="font-size:48px;">${sun.emoji}</div>
    <div style="font-size:18px; font-weight:800;">${escapeHtml(sun.name)}</div>
    <div style="font-size:11px; opacity:0.9;">${escapeHtml(sun.elem)} · ${escapeHtml(sun.trait)}</div>
  </div>
  <div style="background:linear-gradient(135deg,#5DADE2,#5D2E8C); color:white; padding:18px; border-radius:14px; text-align:center; margin-top:8px;">
    <div style="font-size:11px; opacity:0.9;">🌙 LUNE</div>
    <div style="font-size:48px;">${moon.emoji}</div>
    <div style="font-size:18px; font-weight:800;">${escapeHtml(moon.name)}</div>
    <div style="font-size:11px; opacity:0.9;">${escapeHtml(moon.elem)} · ${escapeHtml(moon.trait)}</div>
  </div>`;
  if (asc) {
    html += `<div style="background:linear-gradient(135deg,#FF6FA3,#FFD166); color:white; padding:18px; border-radius:14px; text-align:center; margin-top:8px;">
      <div style="font-size:11px; opacity:0.9;">⬆️ ASCENDANT</div>
      <div style="font-size:48px;">${asc.emoji}</div>
      <div style="font-size:18px; font-weight:800;">${escapeHtml(asc.name)}</div>
      <div style="font-size:11px; opacity:0.9;">${escapeHtml(asc.elem)} · ${escapeHtml(asc.trait)}</div>
    </div>`;
  } else {
    html += `<p style="font-size:11px; color:var(--textSec); text-align:center; margin-top:10px;">⬆️ Renseigne ton heure de naissance pour voir ton Ascendant</p>`;
  }
  document.getElementById('nat-result').innerHTML = html;
}

// === 6. LUNE EN COURS ===
function getMoonPhase(date) {
  const lp = 2551443; // synodic period in seconds
  const newMoonRef = new Date(1970, 0, 7, 20, 35, 0).getTime() / 1000;
  const phase = ((date.getTime() / 1000 - newMoonRef) % lp) / lp;
  return phase; // 0 = new, 0.5 = full, etc.
}
function moonPhaseInfo(phase) {
  const phases = [
    { range: [0, 0.04], emoji: "🌑", name: "Nouvelle Lune", advice: "Plante tes intentions. C'est le moment de poser les bases d'un nouveau cycle." },
    { range: [0.04, 0.21], emoji: "🌒", name: "Croissant Croissant", advice: "Action. Lance tes projets, prends des initiatives." },
    { range: [0.21, 0.29], emoji: "🌓", name: "Premier Quartier", advice: "Décisions. Surmonte les obstacles, ajuste ta direction." },
    { range: [0.29, 0.46], emoji: "🌔", name: "Gibbeuse Croissante", advice: "Affine. Persévère, peaufine ton plan." },
    { range: [0.46, 0.54], emoji: "🌕", name: "Pleine Lune", advice: "Manifestation. Énergie maximale, célèbre tes accomplissements." },
    { range: [0.54, 0.71], emoji: "🌖", name: "Gibbeuse Décroissante", advice: "Gratitude. Récolte ce que tu as semé, partage." },
    { range: [0.71, 0.79], emoji: "🌗", name: "Dernier Quartier", advice: "Lâche prise. Élimine ce qui ne sert plus." },
    { range: [0.79, 0.96], emoji: "🌘", name: "Croissant Décroissant", advice: "Repos. Introspection, soin de soi, recul." },
    { range: [0.96, 1.0], emoji: "🌑", name: "Nouvelle Lune (proche)", advice: "Préparation. Le nouveau cycle commence bientôt." }
  ];
  for (const p of phases) {
    if (phase >= p.range[0] && phase < p.range[1]) return p;
  }
  return phases[0];
}
function renderLunaph() {
  const now = new Date();
  const phase = getMoonPhase(now);
  const info = moonPhaseInfo(phase);
  const pct = Math.round(phase * 100);
  
  // Next full moon
  let next = new Date(now);
  for (let i = 0; i < 30; i++) {
    next.setDate(next.getDate() + 1);
    if (Math.abs(getMoonPhase(next) - 0.5) < 0.04) break;
  }
  let nextNew = new Date(now);
  for (let i = 0; i < 30; i++) {
    nextNew.setDate(nextNew.getDate() + 1);
    const p = getMoonPhase(nextNew);
    if (p < 0.04 || p > 0.96) break;
  }
  
  let html = `<div style="background:linear-gradient(135deg,#1A1A2E,#5D2E8C); color:white; padding:24px; border-radius:18px; text-align:center;">
    <div style="font-size:11px; opacity:0.7; letter-spacing:2px;">PHASE LUNAIRE</div>
    <div style="font-size:120px; line-height:1; margin:14px 0;">${info.emoji}</div>
    <div style="font-size:20px; font-weight:900;">${escapeHtml(info.name)}</div>
    <div style="font-size:11px; opacity:0.9; margin-top:4px;">Cycle : ${pct}%</div>
    <div style="background:rgba(255,255,255,0.1); padding:14px; border-radius:12px; margin-top:14px; font-size:13px; font-style:italic;">
      ✨ ${escapeHtml(info.advice)}
    </div>
  </div>
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:14px;">
    <div style="background:var(--surface); padding:14px; border-radius:12px; text-align:center;">
      <div style="font-size:11px; color:var(--textSec);">🌕 Prochaine pleine lune</div>
      <div style="font-size:14px; font-weight:700; margin-top:4px;">${next.toLocaleDateString('fr-FR', {day:'numeric', month:'long'})}</div>
    </div>
    <div style="background:var(--surface); padding:14px; border-radius:12px; text-align:center;">
      <div style="font-size:11px; color:var(--textSec);">🌑 Prochaine nouvelle lune</div>
      <div style="font-size:14px; font-weight:700; margin-top:4px;">${nextNew.toLocaleDateString('fr-FR', {day:'numeric', month:'long'})}</div>
    </div>
  </div>`;
  document.getElementById('lunaph-content').innerHTML = html;
}

