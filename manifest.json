  { word:'tavolo', ans:'il' }, { word:'macchina', ans:'la' }, { word:'orologio', ans:"l'" },
  { word:'specchio', ans:'lo' }, { word:'sole', ans:'il' }, { word:'isola', ans:"l'" },
];
let _aqState = null;
function newArticleQuiz() {
  _aqState = { q: 0, correct: 0, deck: ARTICLE_QUIZ.slice().sort(() => Math.random()-0.5) };
  showArticleQuiz();
}
function showArticleQuiz() {
  if (!_aqState || _aqState.q >= _aqState.deck.length) {
    document.getElementById('article-quiz').innerHTML = `<div style="background:var(--surface); padding:20px; border-radius:14px; text-align:center; margin-top:14px;"><h3 style="color:var(--primary);">🎉 Fini !</h3><p>Score : ${_aqState?.correct || 0}/${ARTICLE_QUIZ.length}</p><button class="btn primary full" onclick="newArticleQuiz()" style="margin-top:10px;">Recommencer</button></div>`;
