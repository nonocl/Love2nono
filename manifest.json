// === 1. COMPTEUR GÉNÉRIQUE ===
function getCounters() { try { return JSON.parse(localStorage.getItem('nw_counters') || '[]'); } catch { return []; } }
function saveCounters(c) { localStorage.setItem('nw_counters', JSON.stringify(c)); }
function renderCounter() {
  const counters = getCounters();
