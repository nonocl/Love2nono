function v52_capAnswer(picked, correct) {
  let stats; try { stats = JSON.parse(localStorage.getItem('nw_capquiz') || '{"ok":0,"ko":0}'); } catch { stats = {ok:0,ko:0}; }
  if (picked === correct) { stats.ok++; toast('✓'); if (navigator.vibrate) navigator.vibrate(10); }
  else { stats.ko++; toast('✗ C\'était : ' + correct); if (navigator.vibrate) navigator.vibrate([20,50,20]); }
