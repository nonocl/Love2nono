let _currentPack = 'aesthetic';
function widgetSetPack(pk) {
  _currentPack = pk;
  renderWidgetGrid();
}
function renderWidgetGrid() {
  // Onglets packs
  const tabs = document.getElementById('widget-tabs');
  if (tabs) {
    tabs.innerHTML = Object.entries(WIDGET_PACKS).map(([k, p]) =>
      `<button onclick="widgetSetPack('${k}')" class="btn ${_currentPack === k ? 'primary' : 'alt'}" style="font-size:12px; padding:6px 12px; flex-shrink:0;">${p.emoji} ${escapeHtml(p.name)}</button>`
    ).join('');
  }
  const grid = document.getElementById('widget-grid');
  if (!grid) return;
  const pack = WIDGET_PACKS[_currentPack];
  if (!pack) return;
  grid.innerHTML = `<div style="font-size:11px; color:var(--textSec); margin-bottom:8px;">${escapeHtml(pack.desc)}</div>`;
  grid.innerHTML += '<div style="display:grid; grid-template-columns:repeat(2,1fr); gap:8px;">' +
    pack.widgets.map(w => `<div style="background:var(--surface); padding:8px; border-radius:12px; text-align:center;">
      <canvas id="wpv-${w.id}" width="200" height="200" style="width:100%; aspect-ratio:1; border-radius:10px;"></canvas>
      <div style="font-size:11px; font-weight:700; margin-top:6px;">${escapeHtml(w.name)}</div>
      <button class="btn primary" onclick="widgetExport('${_currentPack}', '${w.id}')" style="font-size:11px; padding:4px 10px; margin-top:6px;">📥 Télécharger</button>
    </div>`).join('') + '</div>';
  // Render all previews
  setTimeout(() => {
    pack.widgets.forEach(w => {
      const c = document.getElementById('wpv-' + w.id);
      if (c) {
        const ctx = c.getContext('2d');
        ctx.save(); ctx.scale(200/512, 200/512); w.draw(ctx); ctx.restore();
      }
    });
  }, 50);
  // Pack export button
  const peb = document.getElementById('widget-pack-btn');
  if (peb) peb.textContent = `📦 Télécharger TOUT le pack "${pack.name}" (${pack.widgets.length} widgets)`;
}
function widgetExport(packKey, wid) {
  const w = WIDGET_PACKS[packKey].widgets.find(x => x.id === wid);
  if (!w) return;
  const c = document.createElement('canvas');
  c.width = 512; c.height = 512;
  w.draw(c.getContext('2d'));
  c.toBlob(b => {
    const a = document.createElement('a');
    a.href = URL.createObjectURL(b);
    a.download = `widget-${packKey}-${wid}.png`;
    a.click();
    toast('📥 Widget téléchargé !');
  }, 'image/png');
}
async function widgetExportPack() {
  const pack = WIDGET_PACKS[_currentPack];
  if (!pack) return;
  toast('📦 Génération du pack...');
  // Télécharge un par un (avec petit délai pour pas saturer)
  for (let i = 0; i < pack.widgets.length; i++) {
    const w = pack.widgets[i];
    const c = document.createElement('canvas'); c.width = 512; c.height = 512;
    w.draw(c.getContext('2d'));
    await new Promise(res => c.toBlob(b => {
      const a = document.createElement('a'); a.href = URL.createObjectURL(b);
      a.download = `widget-${_currentPack}-${w.id}.png`; a.click();
      setTimeout(res, 250);
    }, 'image/png'));
  }
  toast(`📦 Pack "${pack.name}" téléchargé !`);
}

// ============================================================
// GÉNÉRATEUR WIDGET CUSTOM
// ============================================================
let _wgCustom = {
  bgType: 'gradient',
  bgColor1: '#FF6FA3',
  bgColor2: '#A78BFA',
  bgImage: null,
  text: 'nono',
  textSize: 80,
  textColor: '#FFFFFF',
  textFont: 'Georgia',
  textStyle: 'italic',
  textWeight: '900',
  overlay: 'none',
  shadow: true,
  border: 'none'
};
function wgRender() {
  const c = document.getElementById('wg-canvas');
  if (!c) return;
  c.width = 512; c.height = 512;
  const ctx = c.getContext('2d');
  // BG
  if (_wgCustom.bgType === 'solid') {
    ctx.fillStyle = _wgCustom.bgColor1; ctx.fillRect(0,0,512,512);
  } else if (_wgCustom.bgType === 'gradient') {
    const g = ctx.createLinearGradient(0,0,512,512);
    g.addColorStop(0, _wgCustom.bgColor1); g.addColorStop(1, _wgCustom.bgColor2);
    ctx.fillStyle = g; ctx.fillRect(0,0,512,512);
  } else if (_wgCustom.bgType === 'radial') {
    const g = ctx.createRadialGradient(256,256,0,256,256,360);
    g.addColorStop(0, _wgCustom.bgColor1); g.addColorStop(1, _wgCustom.bgColor2);
    ctx.fillStyle = g; ctx.fillRect(0,0,512,512);
  } else if (_wgCustom.bgType === 'image' && _wgCustom.bgImage) {
    const img = _wgCustom.bgImage;
    const s = Math.min(img.width, img.height);
    const sx = (img.width - s)/2, sy = (img.height - s)/2;
    ctx.drawImage(img, sx, sy, s, s, 0, 0, 512, 512);
    // dim
    ctx.fillStyle = 'rgba(0,0,0,0.3)'; ctx.fillRect(0,0,512,512);
  }
  // Overlay
  if (_wgCustom.overlay === 'noise') {
    for (let i = 0; i < 1500; i++) {
      ctx.fillStyle = `rgba(0,0,0,${Math.random()*0.1})`;
      ctx.fillRect(Math.random()*512, Math.random()*512, 1, 1);
    }
  } else if (_wgCustom.overlay === 'sparkle') {
    for (let i = 0; i < 30; i++) {
      ctx.fillStyle = `rgba(255,255,255,${0.5+Math.random()*0.5})`;
      const s = 4 + Math.random()*8;
      const x = Math.random()*512, y = Math.random()*512;
      ctx.beginPath(); ctx.moveTo(x, y-s); ctx.lineTo(x+s/3, y-s/3); ctx.lineTo(x+s, y);
      ctx.lineTo(x+s/3, y+s/3); ctx.lineTo(x, y+s); ctx.lineTo(x-s/3, y+s/3);
      ctx.lineTo(x-s, y); ctx.lineTo(x-s/3, y-s/3); ctx.closePath(); ctx.fill();
    }
  } else if (_wgCustom.overlay === 'scanlines') {
    ctx.fillStyle = 'rgba(0,0,0,0.15)';
    for (let y = 0; y < 512; y += 4) ctx.fillRect(0, y, 512, 2);
  } else if (_wgCustom.overlay === 'dots') {
    ctx.fillStyle = 'rgba(255,255,255,0.2)';
    for (let y = 20; y < 512; y += 30) {
      for (let x = 20; x < 512; x += 30) {
        ctx.beginPath(); ctx.arc(x, y, 3, 0, Math.PI*2); ctx.fill();
      }
    }
  } else if (_wgCustom.overlay === 'frame') {
    ctx.strokeStyle = _wgCustom.textColor; ctx.lineWidth = 4;
    ctx.strokeRect(20, 20, 472, 472);
    ctx.lineWidth = 1;
    ctx.strokeRect(35, 35, 442, 442);
  }
  // Texte
  if (_wgCustom.text) {
    ctx.fillStyle = _wgCustom.textColor;
    let style = '';
    if (_wgCustom.textStyle === 'italic') style += 'italic ';
    style += _wgCustom.textWeight + ' ' + _wgCustom.textSize + 'px ' + _wgCustom.textFont;
    ctx.font = style;
    ctx.textAlign = 'center';
    if (_wgCustom.shadow) {
      ctx.shadowColor = 'rgba(0,0,0,0.4)'; ctx.shadowBlur = 12; ctx.shadowOffsetY = 4;
    }
    // Multi-line
    const lines = _wgCustom.text.split('\n');
    const lineH = _wgCustom.textSize * 1.1;
    const total = lines.length * lineH;
    const start = 256 - total/2 + lineH*0.7;
    lines.forEach((line, i) => ctx.fillText(line, 256, start + i*lineH));
    ctx.shadowBlur = 0; ctx.shadowOffsetY = 0;
  }
  // Border
  if (_wgCustom.border === 'thick') {
    ctx.strokeStyle = _wgCustom.textColor; ctx.lineWidth = 16;
    ctx.strokeRect(0, 0, 512, 512);
  } else if (_wgCustom.border === 'thin') {
    ctx.strokeStyle = _wgCustom.textColor; ctx.lineWidth = 4;
    ctx.strokeRect(8, 8, 496, 496);
  } else if (_wgCustom.border === 'rounded') {
    // simulate rounded by drawing on outer transparent
    const tmp = ctx.getImageData(0,0,512,512);
    ctx.clearRect(0,0,512,512);
    const c2 = document.createElement('canvas'); c2.width = 512; c2.height = 512;
    c2.getContext('2d').putImageData(tmp, 0, 0);
    ctx.beginPath();
    const r = 60; ctx.moveTo(r, 0);
    ctx.arcTo(512, 0, 512, r, r); ctx.arcTo(512, 512, 512-r, 512, r);
    ctx.arcTo(0, 512, 0, 512-r, r); ctx.arcTo(0, 0, r, 0, r);
    ctx.closePath(); ctx.clip();
    ctx.drawImage(c2, 0, 0);
  }
}
function wgUpdate() {
  _wgCustom.bgType = document.getElementById('wg-bgtype').value;
  _wgCustom.bgColor1 = document.getElementById('wg-bg1').value;
  _wgCustom.bgColor2 = document.getElementById('wg-bg2').value;
  _wgCustom.text = document.getElementById('wg-text').value;
  _wgCustom.textSize = parseInt(document.getElementById('wg-tsize').value);
  document.getElementById('wg-tsize-v').textContent = _wgCustom.textSize;
  _wgCustom.textColor = document.getElementById('wg-tcolor').value;
  _wgCustom.textFont = document.getElementById('wg-tfont').value;
  _wgCustom.textStyle = document.getElementById('wg-tstyle').value;
  _wgCustom.textWeight = document.getElementById('wg-tweight').value;
  _wgCustom.overlay = document.getElementById('wg-overlay').value;
  _wgCustom.shadow = document.getElementById('wg-shadow').checked;
  _wgCustom.border = document.getElementById('wg-border').value;
  wgRender();
}
function wgLoadImage(input) {
  const f = (input.files || [])[0]; if (!f) return;
  const r = new FileReader();
  r.onload = e => {
    const img = new Image();
    img.onload = () => { _wgCustom.bgImage = img; document.getElementById('wg-bgtype').value = 'image'; wgUpdate(); };
    img.src = e.target.result;
  };
  r.readAsDataURL(f);
}
async function wgFromPFP() {
  let pfps = [];
  try { pfps = await dbAll('pfps'); } catch { return toast('Galerie PFP vide'); }
  if (!pfps.length) return toast('Galerie PFP vide');
  const grid = document.getElementById('wg-pfp-grid');
  if (!grid) return;
  grid.innerHTML = pfps.slice(0, 60).map(p => {
    const url = p.dataUrl || (p.blob ? URL.createObjectURL(p.blob) : '');
    if (!url) return '';
    return `<div onclick="wgChoosePFP('${url.replace(/'/g, "\\'")}', this)" style="cursor:pointer; aspect-ratio:1;">
      <img src="${url}" style="width:100%; height:100%; object-fit:cover; border-radius:8px;">
    </div>`;
  }).join('');
  document.getElementById('wg-pfp-section').style.display = '';
}
function wgChoosePFP(url) {
  const img = new Image();
  img.onload = () => {
    _wgCustom.bgImage = img;
    document.getElementById('wg-bgtype').value = 'image';
    document.getElementById('wg-pfp-section').style.display = 'none';
    wgUpdate();
  };
  img.src = url;
}
function wgExport() {
  const c = document.getElementById('wg-canvas');
  c.toBlob(b => {
    const a = document.createElement('a');
    a.href = URL.createObjectURL(b); a.download = `widget-custom-${Date.now()}.png`;
    a.click();
    toast('📥 Widget téléchargé !');
  }, 'image/png');
}
function wgRandomize() {
  const palettes = [
    ['#FF6FA3', '#A78BFA'], ['#5DADE2', '#A78BFA'], ['#FFD166', '#FF8C42'],
    ['#5DD68F', '#5DADE2'], ['#FF4757', '#FFD700'], ['#000000', '#7400b8'],
    ['#FFB3D9', '#B3E5FF']
  ];
  const fonts = ['Georgia', 'Helvetica', 'Bangers', 'Playfair Display', 'IBM Plex Mono', 'Caveat'];
  const overlays = ['none', 'sparkle', 'noise', 'dots'];
  const p = palettes[Math.floor(Math.random()*palettes.length)];
  document.getElementById('wg-bg1').value = p[0];
  document.getElementById('wg-bg2').value = p[1];
  document.getElementById('wg-tfont').value = fonts[Math.floor(Math.random()*fonts.length)];
  document.getElementById('wg-overlay').value = overlays[Math.floor(Math.random()*overlays.length)];
  document.getElementById('wg-bgtype').value = ['solid','gradient','radial'][Math.floor(Math.random()*3)];
  wgUpdate();
}



