const TYPER_TEXTS = [
  'La curiosité est un défaut qui peut sauver le monde des ténèbres.',
  'Apprendre une langue c\'est avoir une fenêtre de plus sur le monde.',
  'Tous les hommes pensent que le bonheur se trouve au sommet de la montagne, alors qu\'il réside dans la façon de la gravir.',
  'L\'imagination est plus importante que le savoir.',
  'Le courage n\'est pas l\'absence de peur, mais la capacité de vaincre ce qui fait peur.',
  'Cogito ergo sum : je pense donc je suis.',
  'Une journée sans rire est une journée perdue.',
  'L\'éducation est l\'arme la plus puissante pour changer le monde.',
];
let _typer = null;
function newTyper() {
  const text = TYPER_TEXTS[Math.floor(Math.random()*TYPER_TEXTS.length)];
  _typer = { text, started: 0, finished: false };
  document.getElementById('typer-input').value = '';
  document.getElementById('typer-input').disabled = false;
  document.getElementById('typer-input').focus();
  document.getElementById('typer-wpm').textContent = '—';
  document.getElementById('typer-acc').textContent = '—%';
  document.getElementById('typer-time').textContent = '0s';
  renderTyperText('');
  if (_typer._interval) clearInterval(_typer._interval);
}
function renderTyperText(typed) {
  const el = document.getElementById('typer-text');
  let html = '';
  for (let i=0; i<_typer.text.length; i++) {
    const c = _typer.text[i];
    const t = typed[i];
    if (t === undefined) html += `<span style="color:var(--textSec);">${escapeHtml(c)}</span>`;
    else if (t === c) html += `<span style="color:var(--success);">${escapeHtml(c)}</span>`;
    else html += `<span style="background:var(--danger); color:white;">${escapeHtml(c)}</span>`;
  }
  el.innerHTML = html;
}
function typerCheck() {
  if (!_typer || _typer.finished) return;
  const v = document.getElementById('typer-input').value;
  if (!_typer.started) {
    _typer.started = Date.now();
    _typer._interval = setInterval(() => {
      const elapsed = Math.floor((Date.now() - _typer.started)/1000);
      document.getElementById('typer-time').textContent = elapsed + 's';
    }, 200);
  }
  renderTyperText(v);
  // Stats
  const elapsed = (Date.now() - _typer.started) / 1000;
  let correct = 0;
  for (let i=0; i<v.length; i++) if (v[i] === _typer.text[i]) correct++;
  const wpm = Math.round((correct / 5) / (elapsed / 60));
  const acc = v.length ? Math.round(correct/v.length*100) : 0;
  document.getElementById('typer-wpm').textContent = isFinite(wpm) ? wpm : '—';
  document.getElementById('typer-acc').textContent = acc + '%';
  if (v === _typer.text) {
    _typer.finished = true;
    if (_typer._interval) clearInterval(_typer._interval);
    document.getElementById('typer-input').disabled = true;
    toast(`🎉 Fini ! ${wpm} WPM`);
  }
}



