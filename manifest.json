const COMMON_PWDS = ['123456','password','azerty','qwerty','000000','111111','iloveyou','admin','welcome','monkey','dragon','master','letmein','password123','abc123','soleil','marseille','azerty123','football','superman','batman','jesus','michael','starwars','princess','pokemon','mustang','tigger','000','12345','12345678','123456789','1234567890','motdepasse','soleil2024','password1','azerty1','sunshine','liverpool','chelsea','arsenal','manchester','barcelona','realmadrid'];

