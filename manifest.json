          ${d.notes ? `<div style="font-size:11px; color:var(--textSec); margin-top:4px; font-style:italic;">${escapeHtml(d.notes)}</div>` : ''}
        </div>
        <div style="display:flex; flex-direction:column; gap:4px;">
          ${d.thumb ? `<button onclick="docCoffreView('${d.id}')" style="background:none; border:none; color:var(--primary); font-size:18px; cursor:pointer;">👁</button>` : ''}
          <button onclick="docCoffreDel('${d.id}')" style="background:none; border:none; color:var(--danger); font-size:18px; cursor:pointer;">✗</button>
