let _journalKey = null;
let _journalCurId = null;
const JOURNAL_MOODS = [
  { e:'😊', n:'Heureux' }, { e:'🥰', n:'Amoureux' }, { e:'😎', n:'Cool' },
  { e:'🤔', n:'Pensif' }, { e:'😐', n:'Neutre' }, { e:'😴', n:'Fatigué' },
  { e:'😢', n:'Triste' }, { e:'😡', n:'Énervé' }, { e:'🥺', n:'Vulnérable' },
  { e:'😰', n:'Anxieux' }, { e:'🤩', n:'Excité' }, { e:'😶', n:'Vide' },
];
function journalCheckSetup() {
  const setup = localStorage.getItem('nw_journal_setup');
  document.getElementById('journal-pwd-info').textContent = setup ? '' : '⚠️ Premier accès : crée un code (4+ caractères). Ne l\'oublie pas, il n\'y a aucune récupération possible.';
}
function journalUnlock() {
  const pwd = document.getElementById('journal-pwd').value;
  if (!pwd || pwd.length < 4) return toast('Code trop court (4+ caractères)');
  const setup = localStorage.getItem('nw_journal_setup');
  if (!setup) {
    // First setup: store hash
    const hash = cryptString('VERIFY_' + pwd, pwd);
    localStorage.setItem('nw_journal_setup', hash);
    _journalKey = pwd;
    journalShow();
    toast('🔐 Journal créé et verrouillé');
  } else {
    const test = decryptString(setup, pwd);
    if (test !== 'VERIFY_' + pwd) return toast('❌ Code incorrect');
    _journalKey = pwd;
    journalShow();
  }
}
function journalShow() {
  document.getElementById('journal-locked').style.display = 'none';
  document.getElementById('journal-list').style.display = '';
  document.getElementById('journal-new-btn').style.display = '';
  renderJournal();
}
function getJournalEntries() {
  try {
    const raw = localStorage.getItem('nw_journal_entries');
    if (!raw) return [];
    const dec = decryptString(raw, _journalKey);
    return dec ? JSON.parse(dec) : [];
  } catch { return []; }
}
function saveJournalEntries(entries) {
  const enc = cryptString(JSON.stringify(entries), _journalKey);
  localStorage.setItem('nw_journal_entries', enc);
}
function renderJournal() {
  const entries = getJournalEntries();
  const list = document.getElementById('journal-list');
  if (!entries.length) {
    list.innerHTML = '<p style="text-align:center; color:var(--textSec); padding:30px;">Aucune entrée. Tap + pour commencer ✏️</p>';
    return;
  }
  entries.sort((a,b) => b.t - a.t);
  list.innerHTML = entries.map(e => `
    <div onclick="journalOpen('${e.id}')" style="background:var(--surface); padding:14px; border-radius:12px; margin-bottom:6px; cursor:pointer;">
      <div style="display:flex; justify-content:space-between; align-items:center;">
        <div style="font-weight:700; font-size:15px;">${e.mood||''} ${escapeHtml(e.title || 'Sans titre')}</div>
        <div style="font-size:11px; color:var(--textSec);">${new Date(e.t).toLocaleDateString('fr-FR')}</div>
      </div>
      <div style="font-size:12px; color:var(--textSec); margin-top:6px; line-height:1.4;">${escapeHtml((e.content||'').slice(0,100))}${e.content?.length > 100 ? '…' : ''}</div>
    </div>
  `).join('');
}
function journalNew() {
  _journalCurId = null;
  document.getElementById('journal-title').value = '';
  document.getElementById('journal-content').value = '';
  document.getElementById('journal-date').textContent = new Date().toLocaleDateString('fr-FR', { weekday:'long', day:'numeric', month:'long', year:'numeric' });
  state._journalMood = '';
  renderJournalMoods();
  goTo('journal-edit');
}
function journalOpen(id) {
  _journalCurId = id;
  const e = getJournalEntries().find(x => x.id === id);
  if (!e) return;
  document.getElementById('journal-title').value = e.title || '';
  document.getElementById('journal-content').value = e.content || '';
  document.getElementById('journal-date').textContent = new Date(e.t).toLocaleDateString('fr-FR', { weekday:'long', day:'numeric', month:'long', year:'numeric' });
  state._journalMood = e.mood || '';
  renderJournalMoods();
  goTo('journal-edit');
}
function renderJournalMoods() {
  document.getElementById('journal-moods').innerHTML = JOURNAL_MOODS.map(m => 
    `<button onclick="state._journalMood='${m.e}'; renderJournalMoods();" style="background:${state._journalMood === m.e ? 'var(--primary)' : 'var(--surfaceAlt)'}; color:${state._journalMood === m.e ? 'white' : 'var(--text)'}; border:none; padding:8px 10px; border-radius:8px; font-size:12px; cursor:pointer;">${m.e} ${m.n}</button>`
  ).join('');
}
function journalSave() {
  const title = document.getElementById('journal-title').value.trim();
  const content = document.getElementById('journal-content').value;
  if (!title && !content) return goTo('journal');
  const entries = getJournalEntries();
  if (_journalCurId) {
    const idx = entries.findIndex(e => e.id === _journalCurId);
    if (idx >= 0) entries[idx] = { ...entries[idx], title, content, mood: state._journalMood };
  } else {
    entries.push({ id: 'j_' + Date.now(), title, content, mood: state._journalMood, t: Date.now() });
  }
  saveJournalEntries(entries);
  toast('🔐 Sauvegardé chiffré');
  goTo('journal');
}
function journalDel() {
  if (!_journalCurId) return goTo('journal');
  if (!confirm('Supprimer cette entrée ?')) return;
  const entries = getJournalEntries().filter(e => e.id !== _journalCurId);
  saveJournalEntries(entries);
  goTo('journal');
}
function journalBack() { goTo('journal'); }

