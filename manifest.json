let _dp = { recording: false, recStart: 0, events: [] };
function renderDrumpad() {
  document.getElementById('dp-grid').innerHTML = DP_PADS.map((p, i) =>
    `<button onmousedown="dpHit(${i})" ontouchstart="event.preventDefault(); dpHit(${i})" style="aspect-ratio:1; background:${p.col}; color:white; border:none; border-radius:14px; font-size:11px; font-weight:800; cursor:pointer; box-shadow:0 4px 0 rgba(0,0,0,0.3); transition:transform 0.05s;">${p.name}</button>`
  ).join('');
