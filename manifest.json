// === 1. FLASHCARDS ANKI-LIKE ===
function getFcDecks() { try { return JSON.parse(localStorage.getItem('nw_fc_decks') || '[]'); } catch { return []; } }
function saveFcDecks(d) { localStorage.setItem('nw_fc_decks', JSON.stringify(d)); }
let _fcCurrent = null, _fcCardIdx = 0, _fcShowAnswer = false;

function renderFlashcards() {
  const decks = getFcDecks();
  let html = `<div style="background:linear-gradient(135deg,#FF6FA3,#9B59B6); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🧠</div><div style="font-size:16px; font-weight:800;">Flashcards (Anki-like)</div>
    <div style="font-size:11px; opacity:0.9;">Espacement répété SM-2 simplifié · ${decks.length} deck${decks.length>1?'s':''}</div>
  </div>
  <button class="btn primary full" onclick="fcCreateDeck()" style="margin-top:14px;">➕ Nouveau deck</button>`;
  if (!decks.length) html += `<p style="text-align:center; color:var(--textSec); font-size:11px; margin-top:14px;">Aucun deck. Crée-en un pour commencer !</p>`;
  decks.forEach((d, i) => {
    const due = d.cards.filter(c => !c.next || new Date(c.next) <= new Date()).length;
    html += `<div style="background:var(--surface); padding:14px; border-radius:14px; margin-top:8px;">
      <div style="display:flex; justify-content:space-between; align-items:flex-start;">
        <div style="flex:1;">
          <div style="font-size:14px; font-weight:700;">${escapeHtml(d.name)}</div>
          <div style="font-size:10px; color:var(--textSec); margin-top:2px;">${d.cards.length} cartes · ${due} à réviser</div>
        </div>
        <button onclick="fcDelDeck(${i})" style="background:none; border:none; color:var(--danger); font-size:14px;">✗</button>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:10px;">
        <button class="btn alt" onclick="fcEditDeck(${i})" style="font-size:11px;">✏️ Éditer</button>
        <button class="btn primary" onclick="fcStudyDeck(${i})" style="font-size:11px;" ${due===0?'disabled':''}>${due>0?`📖 Réviser (${due})`:'✓ À jour'}</button>
      </div>
    </div>`;
  });
  document.getElementById('flashcards-content').innerHTML = html;
}
function fcCreateDeck() {
  const name = prompt('Nom du deck :');
  if (!name) return;
  const decks = getFcDecks();
  decks.push({ name: name.slice(0, 40), cards: [], created: Date.now() });
  saveFcDecks(decks);
  renderFlashcards();
}
function fcDelDeck(i) {
  if (!confirm('Supprimer ce deck ?')) return;
  const decks = getFcDecks();
  decks.splice(i, 1);
  saveFcDecks(decks);
  renderFlashcards();
}
function fcEditDeck(i) {
  const decks = getFcDecks();
  _fcCurrent = i;
  let html = `<div style="background:linear-gradient(135deg,#FF6FA3,#9B59B6); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:14px; font-weight:800;">📚 ${escapeHtml(decks[i].name)}</div>
    <div style="font-size:11px; opacity:0.9;">${decks[i].cards.length} cartes</div>
  </div>
  <button class="btn alt full" onclick="renderFlashcards()" style="margin-top:14px;">← Retour aux decks</button>
  <div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:14px;">
    <h3 style="font-size:13px; font-weight:700; color:var(--primary);">➕ Nouvelle carte</h3>
    <textarea id="fc-q" class="input" placeholder="Question / Recto" rows="2" style="margin-top:6px;"></textarea>
    <textarea id="fc-a" class="input" placeholder="Réponse / Verso" rows="2" style="margin-top:6px;"></textarea>
    <button class="btn primary full" onclick="fcAddCard()" style="margin-top:6px;">➕ Ajouter</button>
  </div>`;
  if (decks[i].cards.length) {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📋 Cartes</h3>`;
    decks[i].cards.forEach((c, ci) => {
      html += `<div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-top:5px;">
        <div style="display:flex; justify-content:space-between;">
          <div style="flex:1; font-size:12px;"><strong>Q :</strong> ${escapeHtml(c.q)}</div>
          <button onclick="fcDelCard(${ci})" style="background:none; border:none; color:var(--danger);">✗</button>
        </div>
        <div style="font-size:12px; margin-top:4px; color:var(--textSec);"><strong>R :</strong> ${escapeHtml(c.a)}</div>
        ${c.next ? `<div style="font-size:9px; color:var(--textSec); margin-top:2px;">Prochaine révision : ${new Date(c.next).toLocaleDateString('fr-FR')}</div>` : '<div style="font-size:9px; color:var(--primary); margin-top:2px;">🆕 Nouvelle carte</div>'}
      </div>`;
    });
  }
  document.getElementById('flashcards-content').innerHTML = html;
}
function fcAddCard() {
  const q = document.getElementById('fc-q').value.trim();
  const a = document.getElementById('fc-a').value.trim();
  if (!q || !a) { toast('Q + R requis'); return; }
  const decks = getFcDecks();
  decks[_fcCurrent].cards.push({ q, a, ease: 2.5, interval: 0, next: null });
  saveFcDecks(decks);
  fcEditDeck(_fcCurrent);
}
function fcDelCard(ci) {
  const decks = getFcDecks();
  decks[_fcCurrent].cards.splice(ci, 1);
  saveFcDecks(decks);
  fcEditDeck(_fcCurrent);
}
function fcStudyDeck(i) {
  _fcCurrent = i;
  _fcShowAnswer = false;
  const decks = getFcDecks();
  const due = decks[i].cards.map((c, idx) => ({ c, idx })).filter(x => !x.c.next || new Date(x.c.next) <= new Date());
  if (!due.length) { toast('À jour !'); renderFlashcards(); return; }
  fcShowCard(due[0].idx);
}
function fcShowCard(idx) {
  const decks = getFcDecks();
  const deck = decks[_fcCurrent];
  const c = deck.cards[idx];
  _fcCardIdx = idx;
  let html = `<div style="background:linear-gradient(135deg,#FF6FA3,#9B59B6); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:14px; font-weight:800;">📖 ${escapeHtml(deck.name)}</div>
  </div>
  <button class="btn alt full" onclick="renderFlashcards()" style="margin-top:14px;">← Retour</button>
  <div style="background:var(--surface); padding:30px; border-radius:18px; margin-top:14px; min-height:160px; display:flex; align-items:center; justify-content:center; text-align:center;">
    <div>
      <div style="font-size:11px; color:var(--textSec); letter-spacing:2px; text-transform:uppercase;">${_fcShowAnswer ? 'Réponse' : 'Question'}</div>
      <div style="font-size:18px; line-height:1.5; margin-top:10px; white-space:pre-wrap;">${escapeHtml(_fcShowAnswer ? c.a : c.q)}</div>
    </div>
  </div>`;
  if (!_fcShowAnswer) {
    html += `<button class="btn primary full" onclick="_fcShowAnswer=true; fcShowCard(${idx});" style="margin-top:14px; padding:18px;">👁 Voir la réponse</button>`;
  } else {
    html += `<div style="display:grid; grid-template-columns:repeat(4,1fr); gap:6px; margin-top:14px;">
      <button onclick="fcRate(0)" style="background:#E14D6B; color:white; padding:14px 4px; border:none; border-radius:10px; font-size:11px; font-weight:700;">😩 Encore</button>
      <button onclick="fcRate(1)" style="background:#FF8C42; color:white; padding:14px 4px; border:none; border-radius:10px; font-size:11px; font-weight:700;">🤔 Dur</button>
      <button onclick="fcRate(2)" style="background:#5DD68F; color:white; padding:14px 4px; border:none; border-radius:10px; font-size:11px; font-weight:700;">👍 Bien</button>
      <button onclick="fcRate(3)" style="background:#06FFA5; color:black; padding:14px 4px; border:none; border-radius:10px; font-size:11px; font-weight:700;">🤩 Facile</button>
    </div>`;
  }
  document.getElementById('flashcards-content').innerHTML = html;
}
function fcRate(rating) {
  // SM-2 simplifié
  const decks = getFcDecks();
  const c = decks[_fcCurrent].cards[_fcCardIdx];
  if (rating === 0) { c.interval = 1; c.ease = Math.max(1.3, c.ease - 0.2); }
  else if (rating === 1) { c.interval = Math.max(1, c.interval || 1); c.ease = Math.max(1.3, c.ease - 0.15); }
  else if (rating === 2) { c.interval = c.interval ? c.interval * c.ease : 1; }
  else { c.interval = c.interval ? c.interval * c.ease * 1.3 : 4; c.ease = c.ease + 0.15; }
  c.interval = Math.max(1, Math.round(c.interval));
  c.next = new Date(Date.now() + c.interval * 86400000).toISOString();
  saveFcDecks(decks);
  if (navigator.vibrate) navigator.vibrate(8);
  
  // Next due card
  const due = decks[_fcCurrent].cards.map((cc, idx) => ({ cc, idx })).filter(x => !x.cc.next || new Date(x.cc.next) <= new Date());
  if (!due.length) { toast('🎉 Session terminée !'); renderFlashcards(); return; }
  _fcShowAnswer = false;
  fcShowCard(due[0].idx);
}

