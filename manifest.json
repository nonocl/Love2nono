  { sig: [0x50, 0x4B, 0x05, 0x06], name: 'ZIP empty archive', mime: 'application/zip', ext: 'zip' },
  { sig: [0xD0, 0xCF, 0x11, 0xE0], name: 'MS Office ancien (DOC/XLS/PPT)', mime: 'application/x-ole-storage', ext: 'doc/xls/ppt' },
  { sig: [0x7B, 0x5C, 0x72, 0x74, 0x66], name: 'RTF document', mime: 'application/rtf', ext: 'rtf' },
  // Archives
  { sig: [0x52, 0x61, 0x72, 0x21], name: 'RAR archive', mime: 'application/x-rar-compressed', ext: 'rar' },
  { sig: [0x37, 0x7A, 0xBC, 0xAF], name: '7-Zip archive', mime: 'application/x-7z-compressed', ext: '7z' },
  { sig: [0x1F, 0x8B, 0x08], name: 'GZIP archive', mime: 'application/gzip', ext: 'gz' },
  // Exécutables (HIGH RISK)
  { sig: [0x4D, 0x5A], name: '⚠️ Exécutable Windows', mime: 'application/x-msdownload', ext: 'exe/dll', risky: true },
  { sig: [0x7F, 0x45, 0x4C, 0x46], name: '⚠️ Exécutable Linux ELF', mime: 'application/x-executable', ext: 'elf', risky: true },
  { sig: [0xCF, 0xFA, 0xED, 0xFE], name: '⚠️ Mach-O 64 (Mac executable)', mime: 'application/x-mach-binary', ext: 'mac', risky: true },
  { sig: [0xCE, 0xFA, 0xED, 0xFE], name: '⚠️ Mach-O 32 (Mac executable)', mime: 'application/x-mach-binary', ext: 'mac', risky: true },
  { sig: [0xFE, 0xED, 0xFA, 0xCE], name: '⚠️ Mach-O 32 BE', mime: 'application/x-mach-binary', ext: 'mac', risky: true },
  { sig: [0xCA, 0xFE, 0xBA, 0xBE], name: '⚠️ Java Class / Mach-O Universal', mime: 'application/java-vm', ext: 'class/mac', risky: true },
  // Audio/Vidéo
  { sig: [0x49, 0x44, 0x33], name: 'MP3 audio', mime: 'audio/mpeg', ext: 'mp3' },
  { sig: [0x66, 0x4C, 0x61, 0x43], name: 'FLAC audio', mime: 'audio/flac', ext: 'flac' },
  { sig: [0x4F, 0x67, 0x67, 0x53], name: 'OGG audio/video', mime: 'audio/ogg', ext: 'ogg' },
  { sig: [0x00, 0x00, 0x00, 0x18, 0x66, 0x74, 0x79, 0x70], name: 'MP4 video', mime: 'video/mp4', ext: 'mp4', offset: 0 },
  { sig: [0x66, 0x74, 0x79, 0x70], name: 'MP4/MOV video', mime: 'video/mp4', ext: 'mp4/mov', offset: 4 },
  { sig: [0x1A, 0x45, 0xDF, 0xA3], name: 'Matroska/WebM video', mime: 'video/webm', ext: 'mkv/webm' },
  // Fonts
  { sig: [0x00, 0x01, 0x00, 0x00, 0x00], name: 'TrueType font', mime: 'font/ttf', ext: 'ttf' },
  { sig: [0x4F, 0x54, 0x54, 0x4F], name: 'OpenType font', mime: 'font/otf', ext: 'otf' },
  { sig: [0x77, 0x4F, 0x46, 0x46], name: 'WOFF font', mime: 'font/woff', ext: 'woff' },
  { sig: [0x77, 0x4F, 0x46, 0x32], name: 'WOFF2 font', mime: 'font/woff2', ext: 'woff2' },
  // Scripts (text-based, vérif via lecture)
];

const RISKY_EXTS = ['exe','dll','msi','bat','cmd','com','vbs','vbe','js','jse','wsh','wsf','ps1','psm1','sh','app','dmg','pkg','deb','rpm','apk','ipa','jar','scr','pif','cpl','hta','reg','bin','iso','dat','docm','xlsm','pptm'];

function renderFileChecker() {
  let html = `<div style="background:linear-gradient(135deg,#5DADE2,#9B59B6); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🔍</div>
    <div style="font-size:16px; font-weight:800;">Checker de fichier</div>
    <div style="font-size:11px; opacity:0.9;">Hash · Type réel · Métadonnées · Détection danger · Lien VirusTotal</div>
  </div>
  <p style="font-size:11px; color:var(--textSec); margin-top:10px; padding:10px; background:var(--surface); border-radius:10px; line-height:1.5;">
    ⚠️ <strong>Pas un antivirus</strong> (impossible en navigateur) mais analyse statique poussée. Le fichier reste sur ton appareil, rien n'est envoyé. Pour vrai scan multi-AV, on génère le lien VirusTotal à la fin.
  </p>
  
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📁 Sélectionne un fichier</h3>
  <input type="file" id="fc-input" onchange="fileCheckerAnalyze(this.files[0])" style="margin-top:6px; width:100%; padding:14px; background:var(--surface); border-radius:10px; border:1.5px dashed var(--border); cursor:pointer;">
  <p style="font-size:10px; color:var(--textSec); margin-top:4px;">Le fichier est analysé localement, jamais uploadé.</p>
  
  <div id="fc-result" style="margin-top:14px;"></div>`;
  document.getElementById('filechecker-content').innerHTML = html;
}

async function fileCheckerAnalyze(file) {
  if (!file) return;
  const out = document.getElementById('fc-result');
  out.innerHTML = `<div style="background:var(--surface); padding:14px; border-radius:12px; text-align:center; font-size:12px;">
    <div style="display:inline-block; width:14px; height:14px; border-radius:50%; background:var(--primary); animation:pulse-soft 1s infinite; margin-right:8px;"></div>
    Analyse en cours...
  </div>`;
  
  try {
    const buf = await file.arrayBuffer();
    const bytes = new Uint8Array(buf);
    
    // === Hashes ===
    const sha256 = await sha(buf, 'SHA-256');
    const sha1 = await sha(buf, 'SHA-1');
    const md5Like = await sha(buf, 'SHA-256'); // crypto.subtle no MD5, use shortened SHA-256 hint
    
    // === Magic bytes detection ===
    const magicMatch = detectMagic(bytes);
    
    // === Extension analysis ===
    const fileName = file.name;
    const ext = fileName.split('.').pop().toLowerCase();
    const extDouble = /\.(pdf|doc|jpg|png|zip|txt)\.(exe|scr|bat|cmd|js|vbs)$/i.test(fileName);
    const isExtRisky = RISKY_EXTS.includes(ext);
    
    // === Size analysis ===
    const sizeKb = file.size / 1024;
    const sizeMb = sizeKb / 1024;
    const sizeStr = sizeMb >= 1 ? sizeMb.toFixed(2) + ' Mo' : sizeKb.toFixed(2) + ' Ko';
    
    // === Flags ===
    const flags = [];
    const oks = [];
    
    // Extension vs reality mismatch
    if (magicMatch && magicMatch.ext) {
      const realExts = magicMatch.ext.split('/');
      if (!realExts.some(e => ext.includes(e) || e.includes(ext)) && magicMatch.name !== 'Unknown') {
        flags.push({ sev: 'high', msg: '🚨 Extension ne correspond pas au contenu', det: `Le fichier prétend être .${ext} mais c'est en réalité un ${magicMatch.name}. Possible déguisement de malware.` });
      }
    }
    
    // Risky extension
    if (isExtRisky) {
      flags.push({ sev: 'high', msg: `⚠️ Extension à risque (.${ext})`, det: `Les fichiers .${ext} peuvent exécuter du code. Ne lance jamais ce type de fichier reçu d'une source non sûre.` });
    }
    
    // Double extension
    if (extDouble) {
      flags.push({ sev: 'high', msg: '🚨 Double extension détectée', det: `Le nom "${fileName}" cache son vrai type. Technique classique de malware ("photo.jpg.exe").` });
    }
    
    // Magic = executable
    if (magicMatch && magicMatch.risky) {
      flags.push({ sev: 'high', msg: `🚨 Fichier exécutable (${magicMatch.name.replace('⚠️ ', '')})`, det: 'Ce fichier peut exécuter du code arbitraire sur ton appareil. Ne le lance que s\'il vient d\'une source 100% sûre.' });
    }
    
    // Size warnings
    if (file.size === 0) flags.push({ sev: 'med', msg: '⚠️ Fichier vide (0 octet)', det: 'Aucun contenu' });
    else if (file.size > 100 * 1024 * 1024) flags.push({ sev: 'low', msg: `📏 Fichier très gros (${sizeStr})`, det: 'À vérifier si attendu' });
    
    if (ext === 'txt' && file.size > 10 * 1024 * 1024) flags.push({ sev: 'med', msg: '⚠️ .txt anormalement gros', det: 'Un fichier texte de 10+ Mo est inhabituel. Peut cacher des données binaires.' });
    
    // === String search dans les premiers 256 Ko ===
    const sampleSize = Math.min(256 * 1024, bytes.length);
    const sample = bytes.slice(0, sampleSize);
    let textSample = '';
    try {
      const decoder = new TextDecoder('utf-8', { fatal: false });
      textSample = decoder.decode(sample);
    } catch {}
    
    // URLs détectées
    const urlMatches = textSample.match(/https?:\/\/[^\s<>"'`]+/g) || [];
    const uniqueUrls = [...new Set(urlMatches)].slice(0, 10);
    
    // IPs détectées
    const ipMatches = textSample.match(/\b(?:\d{1,3}\.){3}\d{1,3}\b/g) || [];
    const uniqueIps = [...new Set(ipMatches.filter(ip => {
      const parts = ip.split('.').map(Number);
      return parts.every(p => p >= 0 && p <= 255) && !ip.startsWith('0.0.0') && !ip.startsWith('255.255');
    }))].slice(0, 5);
    
    // Macros/scripts dans documents
    if (ext === 'docx' || ext === 'xlsx' || ext === 'pptx' || ext === 'docm' || ext === 'xlsm' || ext === 'pptm') {
      // PK = ZIP, look for vbaProject
      const vba = String.fromCharCode(...bytes.slice(0, Math.min(50000, bytes.length))).indexOf('vbaProject');
      if (vba > -1 || ext.endsWith('m')) {
        flags.push({ sev: 'high', msg: '🚨 Macros VBA détectées', det: 'Les macros Office sont une source majeure de malware. Ne les active PAS sauf si nécessaire et source sûre.' });
      }
    }
    
    // SVG/HTML : scripts ?
    if (ext === 'svg' || ext === 'html' || ext === 'htm' || ext === 'xhtml') {
      if (/<script[\s>]/i.test(textSample)) flags.push({ sev: 'high', msg: '🚨 JavaScript détecté', det: 'Ce fichier contient du JS qui peut être exécuté à l\'ouverture' });
      if (/javascript:/i.test(textSample)) flags.push({ sev: 'high', msg: '🚨 URL javascript: détectée', det: 'Tentative d\'exécution JS via URL' });
      if (/on(?:click|load|error|mouseover|focus)\s*=/i.test(textSample)) flags.push({ sev: 'med', msg: '⚠️ Handlers d\'événements détectés', det: 'onclick/onload/onerror peuvent exécuter du code' });
      if (/<iframe[\s>]/i.test(textSample)) flags.push({ sev: 'med', msg: '⚠️ Iframe détectée', det: 'Charge potentiellement du contenu externe' });
      if (/eval\s*\(|atob\s*\(|String\.fromCharCode/i.test(textSample)) flags.push({ sev: 'med', msg: '⚠️ Code potentiellement obfusqué', det: 'eval(), atob(), String.fromCharCode = patterns courants d\'obfuscation' });
    }
    
    // PDF : JavaScript ?
    if (ext === 'pdf' && /\/JavaScript|\/JS/.test(textSample)) {
      flags.push({ sev: 'high', msg: '🚨 JavaScript dans le PDF', det: 'Les PDF avec JS peuvent contenir des exploits. Ouvre seulement dans un viewer fiable.' });
    }
    
    // ZIP : archives suspectes
    if (ext === 'zip' || ext === 'rar' || ext === '7z') {
      // Check for risky filenames inside (look for .exe in raw bytes)
      const riskyInZip = ['exe', 'scr', 'bat', 'cmd', 'vbs', 'js'].filter(e => textSample.includes('.' + e));
      if (riskyInZip.length > 0) flags.push({ sev: 'high', msg: '🚨 Exécutables dans l\'archive', det: `Possible présence de .${riskyInZip.join(', .')} dans l'archive` });
    }
    
    // EXIF GPS dans images (privacy)
    if ((ext === 'jpg' || ext === 'jpeg') && bytes.length > 100) {
      const exifMarker = String.fromCharCode(...bytes.slice(0, Math.min(10000, bytes.length)));
      if (exifMarker.includes('GPSLatitude') || exifMarker.includes('GPS')) {
        flags.push({ sev: 'med', msg: '📍 Métadonnées GPS détectées', det: 'Cette image contient peut-être ta géolocalisation. À retirer avant partage public.' });
      }
    }
    
    // OK signals
    if (magicMatch) oks.push(`Type identifié : ${magicMatch.name}`);
    if (!isExtRisky && !magicMatch?.risky) oks.push('Pas une extension exécutable');
    if (urlMatches.length === 0 && (ext === 'jpg' || ext === 'png' || ext === 'gif' || ext === 'pdf' || ext === 'mp3')) oks.push('Aucune URL cachée détectée');
    
    // SCORE
    const highCount = flags.filter(f => f.sev === 'high').length;
    const medCount = flags.filter(f => f.sev === 'med').length;
    let score = 100 - (highCount * 30 + medCount * 12);
    if (score < 0) score = 0;
    
    let verdict, color, icon;
    if (highCount >= 1 || score < 40) { verdict = 'À RISQUE'; color = '#E14D6B'; icon = '🚨'; }
    else if (medCount >= 2 || score < 70) { verdict = 'SUSPECT'; color = '#FFC542'; icon = '⚠️'; }
    else { verdict = 'PROBABLEMENT SÛR'; color = '#5DD68F'; icon = '✅'; }
    
    // === Render ===
    let html = `<div style="background:${color}; color:white; padding:18px; border-radius:14px; text-align:center;">
      <div style="font-size:36px;">${icon}</div>
      <div style="font-size:18px; font-weight:900; margin-top:4px;">${verdict}</div>
      <div style="font-size:13px; opacity:0.9; margin-top:4px;">Score : ${score}/100</div>
    </div>
    
    <div style="background:var(--surface); padding:12px; border-radius:12px; margin-top:10px;">
      <div style="font-size:11px; color:var(--textSec); margin-bottom:4px;">📁 Fichier</div>
      <div style="font-size:13px; font-weight:700; word-break:break-all;">${escapeHtml(fileName)}</div>
      <div style="font-size:11px; color:var(--textSec); margin-top:6px;">Taille : ${sizeStr} · Extension annoncée : .${ext}</div>
      ${magicMatch ? `<div style="font-size:11px; color:var(--textSec); margin-top:2px;">Type réel : ${escapeHtml(magicMatch.name)}</div>` : '<div style="font-size:11px; color:var(--textSec); margin-top:2px;">Type non reconnu (probablement texte ou format obscur)</div>'}
    </div>`;
    
    // Hashes
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">🔐 Empreintes (hashes)</h3>
    <div style="background:var(--surface); padding:10px; border-radius:10px; margin-top:6px;">
      <div style="font-size:10px; color:var(--textSec);">SHA-256</div>
      <div style="font-family:monospace; font-size:11px; word-break:break-all; margin-top:2px;">${sha256}</div>
      <button class="btn alt" onclick="navigator.clipboard.writeText('${sha256}'); toast('📋 SHA-256 copié');" style="font-size:10px; padding:4px 8px; margin-top:6px;">📋 Copier</button>
    </div>
    <div style="background:var(--surface); padding:10px; border-radius:10px; margin-top:6px;">
      <div style="font-size:10px; color:var(--textSec);">SHA-1</div>
      <div style="font-family:monospace; font-size:11px; word-break:break-all; margin-top:2px;">${sha1}</div>
    </div>`;
    
    if (flags.length > 0) {
      html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">🚩 ${flags.length} drapeau${flags.length > 1 ? 'x' : ''}</h3>`;
      flags.forEach(f => {
        const c = f.sev === 'high' ? '#E14D6B' : f.sev === 'med' ? '#FFC542' : '#5DADE2';
        html += `<div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-top:6px; border-left:4px solid ${c};">
          <div style="font-size:12px; font-weight:700;">${escapeHtml(f.msg)}</div>
          <div style="font-size:10px; color:var(--textSec); margin-top:3px; line-height:1.4;">${escapeHtml(f.det)}</div>
        </div>`;
      });
    }
    
    if (oks.length > 0) {
      html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">✅ Points OK</h3>`;
      oks.forEach(o => {
        html += `<div style="background:var(--surface); padding:8px 12px; border-radius:8px; margin-top:4px; font-size:11px;">${escapeHtml(o)}</div>`;
      });
    }
    
    if (uniqueUrls.length > 0) {
      html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">🔗 ${uniqueUrls.length} URL trouvée${uniqueUrls.length > 1 ? 's' : ''} dans le fichier</h3>`;
      uniqueUrls.forEach(u => {
        const truncated = u.length > 80 ? u.slice(0, 80) + '...' : u;
        html += `<div style="background:var(--surface); padding:8px 12px; border-radius:8px; margin-top:4px; font-size:11px; font-family:monospace; word-break:break-all;">${escapeHtml(truncated)}</div>`;
      });
    }
    
    if (uniqueIps.length > 0) {
      html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">🌐 IPs détectées</h3>`;
      uniqueIps.forEach(ip => {
        html += `<div style="background:var(--surface); padding:8px 12px; border-radius:8px; margin-top:4px; font-size:11px; font-family:monospace;">${escapeHtml(ip)}</div>`;
      });
    }
    
    // VirusTotal link (vrai scan multi-AV)
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">🌐 Scan multi-antivirus (en ligne)</h3>
    <p style="font-size:11px; color:var(--textSec); margin-top:4px; line-height:1.5;">VirusTotal scanne avec 70+ antivirus. Si quelqu'un a déjà soumis ce fichier, tu verras les résultats sans rien uploader (recherche par hash).</p>
    <a href="https://www.virustotal.com/gui/file/${sha256}" target="_blank" rel="noopener" class="btn primary full" style="margin-top:6px; padding:14px; text-align:center; text-decoration:none; display:block;">🌐 Voir sur VirusTotal (par hash)</a>
    <p style="font-size:10px; color:var(--textSec); margin-top:6px; text-align:center;">Si "Item not found" → personne n'a encore soumis ce fichier. Tu peux l'uploader sur virustotal.com pour scan complet.</p>`;
    
    out.innerHTML = html;
    if (navigator.vibrate) navigator.vibrate(highCount > 0 ? [20, 50, 20] : 10);
  } catch (e) {
    out.innerHTML = `<div style="background:#E14D6B; color:white; padding:14px; border-radius:12px;">❌ Erreur d'analyse : ${escapeHtml(e.message)}</div>`;
  }
}

async function sha(buf, algo) {
  const h = await crypto.subtle.digest(algo, buf);
  return Array.from(new Uint8Array(h)).map(b => b.toString(16).padStart(2, '0')).join('');
}

function detectMagic(bytes) {
  for (const m of FILE_MAGIC) {
    const offset = m.offset || 0;
    if (bytes.length < offset + m.sig.length) continue;
    let match = true;
    for (let i = 0; i < m.sig.length; i++) {
      if (bytes[offset + i] !== m.sig[i]) { match = false; break; }
    }
    if (match) return m;
  }
  // Default: try to detect text
  let textCount = 0, total = Math.min(1000, bytes.length);
  for (let i = 0; i < total; i++) {
    const b = bytes[i];
    if ((b >= 32 && b <= 126) || b === 9 || b === 10 || b === 13) textCount++;
  }
  if (total > 0 && textCount / total > 0.95) {
    return { name: 'Texte (UTF-8/ASCII)', mime: 'text/plain', ext: 'txt' };
  }
  return null;
}

