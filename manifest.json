  'partir': { présent:['pars','pars','part','partons','partez','partent'], imparfait:['partais','partais','partait','partions','partiez','partaient'], passé_simple:['partis','partis','partit','partîmes','partîtes','partirent'], futur:['partirai','partiras','partira','partirons','partirez','partiront'], cond:['partirais','partirais','partirait','partirions','partiriez','partiraient'], subj:['parte','partes','parte','partions','partiez','partent'] }
