  _typerInput = '';
  renderTyper();
}
function v43typerCheck(val) {
  _typerInput = val.toLowerCase().trim();
  if (_typerInput === _typerWord.toLowerCase()) {
    _typerScore++;
    if (navigator.vibrate) navigator.vibrate(8);
