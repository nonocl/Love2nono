function getCyberState() {
  try { return JSON.parse(localStorage.getItem('nw_cyber_check') || '{}'); } catch { return {}; }
}
function saveCyberState(s) { localStorage.setItem('nw_cyber_check', JSON.stringify(s)); }

function renderCyberChecklist() {
  const state = getCyberState();
  let totalAll = 0, doneAll = 0, totalCrit = 0, doneCrit = 0;
  CYBER_CHECKLIST.forEach(cat => cat.items.forEach((item, i) => {
    totalAll++;
    if (item.critical) totalCrit++;
    const key = cat.c + '|' + i;
    if (state[key]) {
      doneAll++;
      if (item.critical) doneCrit++;
    }
  }));
  
  const pctAll = Math.round((doneAll / totalAll) * 100);
  const pctCrit = Math.round((doneCrit / totalCrit) * 100);
  
  let scoreLabel, scoreColor;
  if (pctCrit < 50) { scoreLabel = 'À RISQUE'; scoreColor = '#E14D6B'; }
  else if (pctCrit < 80) { scoreLabel = 'CORRECT'; scoreColor = '#FFC542'; }
  else if (pctCrit === 100 && pctAll < 80) { scoreLabel = 'BON'; scoreColor = '#5DD68F'; }
  else if (pctCrit === 100 && pctAll >= 80) { scoreLabel = 'EXCELLENT'; scoreColor = '#06FFA5'; }
  else { scoreLabel = 'PASSABLE'; scoreColor = '#5DADE2'; }
  
  let html = `<div style="background:linear-gradient(135deg,${scoreColor},${scoreColor}cc); color:white; padding:16px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">📋</div>
    <div style="font-size:16px; font-weight:800;">Audit cyber-hygiène</div>
    <div style="font-size:11px; opacity:0.9; margin-top:4px;">${doneAll}/${totalAll} cochés · ${doneCrit}/${totalCrit} critiques</div>
    <div style="font-size:24px; font-weight:900; margin-top:8px;">${scoreLabel}</div>
  </div>
  <div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-top:10px;">
    <div style="font-size:11px; color:var(--textSec); margin-bottom:4px;">Progression globale</div>
    <div style="background:var(--bg); height:10px; border-radius:5px; overflow:hidden;">
      <div style="background:${scoreColor}; height:100%; width:${pctAll}%; transition:width 0.3s;"></div>
    </div>
    <div style="font-size:11px; color:var(--textSec); margin-top:6px;">${pctAll}% · Critiques : ${pctCrit}%</div>
  </div>`;
  
  CYBER_CHECKLIST.forEach(cat => {
    const catTotal = cat.items.length;
    const catDone = cat.items.filter((it, i) => state[cat.c + '|' + i]).length;
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">${escapeHtml(cat.c)} <span style="color:var(--textSec); font-weight:400;">(${catDone}/${catTotal})</span></h3>`;
    cat.items.forEach((item, i) => {
      const key = cat.c + '|' + i;
      const checked = state[key] === true;
      html += `<label style="display:flex; gap:10px; align-items:flex-start; padding:10px 12px; background:var(--surface); border-radius:10px; margin-top:5px; cursor:pointer; ${item.critical ? 'border-left:3px solid #E14D6B;' : ''}">
        <input type="checkbox" ${checked ? 'checked' : ''} onchange="cyberToggle('${escapeJs(cat.c)}', ${i})" style="margin-top:3px; flex-shrink:0;">
        <div style="flex:1; font-size:12px; line-height:1.5; ${checked ? 'opacity:0.6; text-decoration:line-through;' : ''}">${escapeHtml(item.t)}${item.critical ? ' <span style="background:#E14D6B; color:white; font-size:9px; padding:2px 6px; border-radius:4px; font-weight:700; vertical-align:middle;">CRITIQUE</span>' : ''}</div>
      </label>`;
    });
  });
  
  html += `<button class="btn alt full" onclick="cyberReset()" style="margin-top:14px; opacity:0.7; font-size:11px;">🔄 Reset audit</button>`;
  document.getElementById('cyberchecklist-content').innerHTML = html;
}
function cyberToggle(cat, i) {
  const state = getCyberState();
  const key = cat + '|' + i;
  state[key] = !state[key];
  saveCyberState(state);
  renderCyberChecklist();
  if (navigator.vibrate) navigator.vibrate(8);
}
function cyberReset() {
  if (!confirm('Reset toute la checklist ?')) return;
  localStorage.removeItem('nw_cyber_check');
  renderCyberChecklist();
}

