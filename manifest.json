function dlSave() {
  const d = {};
  ['career','love','place','health','friends','creative'].forEach(k => {
    d[k] = document.getElementById('dl-'+k)?.value || '';
  });
  saveDreamLife(d);
}



// === 24. CRUSH JOURNAL ===
function getCrush() { try { return JSON.parse(localStorage.getItem('nw_crushjournal') || '[]'); } catch { return []; } }
function saveCrush(d) { localStorage.setItem('nw_crushjournal', JSON.stringify(d)); }
function renderCrushJournal() {
  const entries = getCrush();
  let html = `<div style="background:linear-gradient(135deg,#FF6FA3,#FF1493,#9B59B6); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">💘</div>
    <div style="font-size:16px; font-weight:800;">Crush journal</div>
    <div style="font-size:11px; opacity:0.9;">${entries.length} entrées · 100% privé</div>
  </div>
  <p style="font-size:11px; color:var(--textSec); margin-top:10px;">💕 Écris sur ton crush sans utiliser son nom. Sentiments, anecdotes, hopes.</p>
  <p style="font-size:11px; color:#FF8C42; margin-top:6px;">🔒 Pour vraie confidentialité, active aussi <strong>Verrouillage PIN</strong> + <strong>Mode invité</strong>.</p>`;
  if (!entries.length) html += '<p style="text-align:center; color:var(--textSec); padding:20px;">Aucune entrée. Tap + pour écrire.</p>';
  entries.forEach(e => {
    const date = new Date(e.created).toLocaleDateString('fr-FR');
    const moodEmoji = { butterflies: '🦋', sad: '😢', happy: '🥰', confused: '😵‍💫', hopeful: '🌟', jealous: '😤', missing: '🥺', acceptance: '🍃' }[e.mood] || '💕';
    html += `<div style="background:linear-gradient(135deg,rgba(255,111,163,0.1),rgba(255,20,147,0.05)); padding:14px; border-radius:12px; margin-top:8px; border-left:3px solid #FF1493;">
      <div style="display:flex; justify-content:space-between; align-items:flex-start;">
        <div style="flex:1;">
          <div style="font-size:14px; font-weight:700;">${moodEmoji} ${escapeHtml(e.mood||'crush')}</div>
          <div style="font-size:10px; color:var(--textSec);">${date}</div>
          <div style="font-size:13px; line-height:1.6; margin-top:8px; white-space:pre-wrap;">${escapeHtml(e.body)}</div>
        </div>
        <button onclick="cjDel('${e.id}')" style="background:none; border:none; color:var(--danger); font-size:18px;">✗</button>
      </div>
    </div>`;
  });
  document.getElementById('crushjournal-content').innerHTML = html;
}
function cjAdd() {
  const moods = ['butterflies','happy','sad','hopeful','confused','jealous','missing','acceptance'];
  const moodChoice = prompt(`Mood ?\n1. 🦋 Butterflies\n2. 🥰 Happy\n3. 😢 Sad\n4. 🌟 Hopeful\n5. 😵‍💫 Confused\n6. 😤 Jealous\n7. 🥺 Missing\n8. 🍃 Acceptance`);
  const idx = parseInt(moodChoice) - 1;
  const mood = moods[idx] || 'butterflies';
  const body = prompt('Écris ce qui te passe par la tête (sans nommer la personne) :');
  if (!body) return;
  const entries = getCrush();
  entries.unshift({ id:'cj_'+Date.now(), mood, body, created: Date.now() });
  saveCrush(entries); renderCrushJournal();
}
function cjDel(id) {
  if (!confirm('Supprimer ?')) return;
  saveCrush(getCrush().filter(e => e.id !== id));
  renderCrushJournal();
}

