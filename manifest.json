  <div id="coin-stats" style="margin-top:14px;"></div>`;
  document.getElementById('coinflip-content').innerHTML = html;
}
let _coinStats = { pile: 0, face: 0 };
function coinFlip() {
  const result = Math.random() < 0.5 ? 'pile' : 'face';
  const display = document.getElementById('coin-display');
  display.style.transition = 'transform 0.5s';
  display.style.transform = 'rotateY(720deg) scale(1.3)';
  setTimeout(() => {
    display.style.transition = '';
    display.style.transform = '';
    display.innerHTML = result === 'pile' 
      ? '<div style="font-size:72px;">🪙</div><div style="font-size:24px; font-weight:900; color:var(--primary);">PILE</div>'
      : '<div style="font-size:72px;">👑</div><div style="font-size:24px; font-weight:900; color:var(--primary);">FACE</div>';
    _coinStats[result]++;
    const total = _coinStats.pile + _coinStats.face;
    document.getElementById('coin-stats').innerHTML = `<div style="background:var(--surface); padding:12px; border-radius:10px; text-align:center;">
      <div style="font-size:11px; color:var(--textSec);">Total : ${total}</div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:6px;">
        <div><div style="font-size:18px; font-weight:900;">${_coinStats.pile}</div><div style="font-size:10px;">Pile (${total ? (_coinStats.pile/total*100).toFixed(0) : 0}%)</div></div>
        <div><div style="font-size:18px; font-weight:900;">${_coinStats.face}</div><div style="font-size:10px;">Face (${total ? (_coinStats.face/total*100).toFixed(0) : 0}%)</div></div>
      </div>
    </div>`;
    if (navigator.vibrate) navigator.vibrate(20);
  }, 500);
}

