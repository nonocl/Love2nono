let _stkBg = '#FFE0EC', _stkText = 'cute', _stkEmoji = '🌸', _stkColor = '#FF1493', _stkShape = 'circle';
function renderStickerMk() {
  let html = `<div style="background:linear-gradient(135deg,#FFD166,#FF6FA3); color:white; padding:14px; border-radius:14px; text-align:center;">
