  <p style="font-size:10px; color:var(--textSec); margin-top:14px;">⚠️ Taux indicatifs fixés. Pour transactions, vérifie sur xe.com ou ta banque.</p>`;
  document.getElementById('currency-content').innerHTML = html;
  curCalc();
}
function curCalc() {
  const val = parseFloat(document.getElementById('cur-val').value);
  const from = document.getElementById('cur-from').value;
  const to = document.getElementById('cur-to').value;
  if (isNaN(val)) { document.getElementById('cur-result').innerHTML = ''; return; }
  // Convert via EUR
  const eurValue = val / RATES_EUR[from];
  const result = eurValue * RATES_EUR[to];
  document.getElementById('cur-result').innerHTML = `<div style="background:var(--surface); padding:18px; border-radius:14px; text-align:center;">
    <div style="font-size:13px; color:var(--textSec);">${val} ${CURRENCIES[from].flag} ${from} =</div>
    <div style="font-size:36px; font-weight:900; color:var(--primary); margin-top:6px;">${result.toFixed(2)} ${CURRENCIES[to].flag}</div>
    <div style="font-size:13px; color:var(--textSec); margin-top:4px;">${to}</div>
    <div style="font-size:10px; color:var(--textSec); margin-top:8px;">1 ${from} = ${(RATES_EUR[to]/RATES_EUR[from]).toFixed(4)} ${to}</div>
  </div>`;
}

