    });
  });
  
  document.getElementById('grooming-content').innerHTML = html;
}
function groomingToggle(id) {
  const today = todayKey();
  const data = getGrooming();
  if (!data[today]) data[today] = [];
  if (data[today].includes(id)) data[today] = data[today].filter(x => x !== id);
  else data[today].push(id);
  saveGrooming(data);
  renderGrooming();
}

