document.getElementById('splitter-input').addEventListener('change', async (e) => {
  const f = e.target.files?.[0]; if (!f) return;
  const reader = new FileReader();
  reader.onload = () => {
    const img = new Image();
    img.onload = () => {
      state.splitterImg = img;
      document.getElementById('splitter-preview').src = reader.result;
      document.getElementById('splitter-options').style.display = 'block';
      setSplitMode('h2');
    };
    img.src = reader.result;
  };
  reader.readAsDataURL(f);
  e.target.value = '';
});

function setSplitMode(mode) {
  state.splitMode = mode;
  const ov = document.getElementById('splitter-overlay');
  ov.innerHTML = '';
  const lines = [];
  if (mode==='h2') lines.push({orient:'v',pct:50});
  if (mode==='h3') lines.push({orient:'v',pct:33.33},{orient:'v',pct:66.66});
  if (mode==='h4') lines.push({orient:'v',pct:25},{orient:'v',pct:50},{orient:'v',pct:75});
  if (mode==='grid2') lines.push({orient:'v',pct:50},{orient:'h',pct:50});
  if (mode==='grid3') lines.push({orient:'v',pct:33.33},{orient:'v',pct:66.66},{orient:'h',pct:33.33},{orient:'h',pct:66.66});
  for (const l of lines) {
    const d = document.createElement('div');
    d.className = 'split-line';
    if (l.orient==='v') d.style.cssText = `left:${l.pct}%; top:0; bottom:0; width:2px;`;
    else d.style.cssText = `top:${l.pct}%; left:0; right:0; height:2px;`;
    ov.appendChild(d);
  }
}

async function downloadSplits() {
  if (!state.splitterImg || !state.splitMode) return;
  const img = state.splitterImg;
  const W = img.naturalWidth, H = img.naturalHeight;
  let cuts = [];
  const m = state.splitMode;
  if (m==='h2') cuts = [{x:0,y:0,w:W/2,h:H},{x:W/2,y:0,w:W/2,h:H}];
  else if (m==='h3') cuts = [0,1,2].map(i=>({x:W*i/3,y:0,w:W/3,h:H}));
  else if (m==='h4') cuts = [0,1,2,3].map(i=>({x:W*i/4,y:0,w:W/4,h:H}));
  else if (m==='grid2') {
    for (let r=0; r<2; r++) for (let c=0; c<2; c++)
      cuts.push({x:c*W/2,y:r*H/2,w:W/2,h:H/2});
  } else if (m==='grid3') {
    for (let r=0; r<3; r++) for (let c=0; c<3; c++)
      cuts.push({x:c*W/3,y:r*H/3,w:W/3,h:H/3});
  }
  for (let i=0; i<cuts.length; i++) {
    const cut = cuts[i];
    const c = document.createElement('canvas');
    c.width = cut.w; c.height = cut.h;
    c.getContext('2d').drawImage(img, cut.x, cut.y, cut.w, cut.h, 0, 0, cut.w, cut.h);
    const blob = await new Promise(r => c.toBlob(r, 'image/png'));
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob); a.download = `split_${i+1}.png`;
    document.body.appendChild(a); a.click(); a.remove();
    await new Promise(r => setTimeout(r, 200));
  }
  toast(`${cuts.length} morceaux téléchargés ✨`);
}

