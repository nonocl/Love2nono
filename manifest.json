function correctorClear() {
  document.getElementById('corr-input').value = '';
  document.getElementById('corr-output').innerHTML = '';
}

function correctorRun() {
  const input = document.getElementById('corr-input').value;
  if (!input.trim()) { toast('Tape ou colle du texte'); return; }
  
  const opts = {
    typos: document.getElementById('corr-typos').checked,
    punct: document.getElementById('corr-punct').checked,
    homo: document.getElementById('corr-homo').checked,
    caps: document.getElementById('corr-caps').checked,
  };
  
  let text = input;
  const corrections = [];
  
  // STEP 1: Typos courantes
  if (opts.typos) {
    for (const [bad, good] of Object.entries(CORRECTOR_TYPOS)) {
      // Skip identical
      if (bad === good) continue;
      const regex = new RegExp('\\b' + bad.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + '\\b', 'gi');
      const matches = text.match(regex);
      if (matches) {
        text = text.replace(regex, good);
        corrections.push({ from: bad, to: good, count: matches.length, type: 'typo', desc: 'Faute fréquente' });
      }
    }
  }
  
  // STEP 2: Règles regex (ponctuation, etc.)
  if (opts.punct) {
    for (const rule of CORRECTOR_RULES) {
      if (rule.type === 'punctuation' || rule.type === 'spacing' || rule.type === 'duplicate' || rule.type === 'typo') {
        const before = text;
        text = text.replace(rule.pat, rule.rep);
        if (before !== text) {
          // Count diff (approximate)
          let count = 0;
          const test = before.match(rule.pat);
          if (test) count = test.length;
          if (count > 0) corrections.push({ from: '(règle)', to: rule.rep, count, type: rule.type, desc: rule.desc });
        }
      }
    }
  }
  
  // STEP 3: Homophones
  if (opts.homo) {
    for (const rule of CORRECTOR_HOMOPHONES) {
      if (rule.ok) continue;
      const before = text;
      if (rule.sub) {
        text = text.replace(rule.pat, rule.sub);
      } else if (rule.rep) {
        text = text.replace(rule.pat, rule.rep);
      }
      if (before !== text) {
        const m = before.match(rule.pat);
        const count = m ? m.length : 1;
        corrections.push({ from: '(homophone)', to: '(corrigé)', count, type: 'homophone', desc: rule.desc });
      }
    }
  }
  
  // STEP 4: Majuscules
  if (opts.caps) {
    const result = correctorCapitalize(text);
    text = result.text;
    if (result.fixes.length) {
      result.fixes.forEach(f => corrections.push({ from: '(minuscule)', to: '(majuscule)', count: 1, type: f.type, desc: f.desc }));
    }
  }
  
  _correctorLastResult = { input, output: text, corrections };
  
  // Render result
  const out = document.getElementById('corr-output');
  const numFixes = corrections.reduce((s, c) => s + c.count, 0);
  
  let html = `<div style="background:var(--surface); padding:14px; border-radius:14px; border-left:4px solid ${numFixes > 0 ? '#5DD68F' : '#FFC542'};">
    <div style="font-size:11px; color:var(--textSec); margin-bottom:8px; letter-spacing:1px; text-transform:uppercase;">${numFixes > 0 ? '✨ Corrigé' : '✓ Aucune faute détectée'}</div>
    <div style="font-size:14px; line-height:1.7; white-space:pre-wrap;">${escapeHtml(text)}</div>
    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:6px; margin-top:14px;">
      <button class="btn alt" onclick="correctorCopy()" style="font-size:12px; padding:8px 4px;">📋 Copier</button>
      <button class="btn alt" onclick="correctorReplace()" style="font-size:12px; padding:8px 4px;">⬆️ Remplacer</button>
      <button class="btn primary" onclick="correctorDiff()" style="font-size:12px; padding:8px 4px;">👀 Diff</button>
    </div>
  </div>`;
  
  if (corrections.length > 0) {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📋 ${numFixes} correction${numFixes > 1 ? 's' : ''}</h3>`;
    
    // Group by type
    const groups = {};
    for (const c of corrections) {
      if (!groups[c.type]) groups[c.type] = [];
      groups[c.type].push(c);
    }
    
    const typeIcons = { typo: '🔤', punctuation: '⚡', spacing: '␣', duplicate: '🔁', homophone: '🤔', capitalization: '🔠' };
    const typeLabels = { typo: 'Fautes', punctuation: 'Ponctuation', spacing: 'Espaces', duplicate: 'Doublons', homophone: 'Homophones', capitalization: 'Majuscules' };
    
    for (const [type, list] of Object.entries(groups)) {
      const total = list.reduce((s, c) => s + c.count, 0);
      html += `<div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-top:6px;">
        <div style="font-size:12px; font-weight:700; color:var(--primary); margin-bottom:4px;">${typeIcons[type] || '•'} ${typeLabels[type] || type} <span style="color:var(--textSec); font-weight:400;">(${total})</span></div>`;
      const seen = new Set();
      for (const c of list) {
        const key = c.desc + (c.from !== '(règle)' ? c.from : '');
        if (seen.has(key)) continue;
        seen.add(key);
        if (c.from !== '(règle)' && c.from !== '(homophone)' && c.from !== '(minuscule)') {
          html += `<div style="font-size:11px; margin-top:2px;">"<span style="color:#E14D6B;">${escapeHtml(c.from)}</span>" → "<span style="color:#5DD68F; font-weight:600;">${escapeHtml(c.to)}</span>" ${c.count > 1 ? '×' + c.count : ''}</div>`;
        } else {
          html += `<div style="font-size:11px; margin-top:2px; color:var(--textSec);">→ ${escapeHtml(c.desc)} ${c.count > 1 ? '×' + c.count : ''}</div>`;
        }
      }
      html += `</div>`;
    }
  }
  
  out.innerHTML = html;
  
  if (navigator.vibrate) navigator.vibrate(numFixes > 0 ? [10, 30, 10] : 5);
}

function correctorCopy() {
  if (!_correctorLastResult) return;
  navigator.clipboard.writeText(_correctorLastResult.output).then(() => toast('📋 Copié'));
}

function correctorReplace() {
  if (!_correctorLastResult) return;
  document.getElementById('corr-input').value = _correctorLastResult.output;
  toast('⬆️ Remplacé');
}

function correctorDiff() {
  if (!_correctorLastResult) return;
  const inp = _correctorLastResult.input;
  const out = _correctorLastResult.output;
  
  // Simple word diff
  const inpWords = inp.split(/(\s+)/);
  const outWords = out.split(/(\s+)/);
  
  let html = `<div style="background:var(--surface); padding:14px; border-radius:14px; margin-top:10px;">
    <div style="font-size:11px; color:var(--textSec); margin-bottom:8px; letter-spacing:1px; text-transform:uppercase;">👀 Comparaison</div>
    <div style="background:rgba(225,77,107,0.1); padding:10px; border-radius:8px; border-left:3px solid #E14D6B;">
      <div style="font-size:10px; color:#E14D6B; font-weight:700; margin-bottom:4px;">AVANT</div>
      <div style="font-size:13px; line-height:1.6; white-space:pre-wrap;">${escapeHtml(inp)}</div>
    </div>
    <div style="background:rgba(93,214,143,0.1); padding:10px; border-radius:8px; border-left:3px solid #5DD68F; margin-top:8px;">
      <div style="font-size:10px; color:#5DD68F; font-weight:700; margin-bottom:4px;">APRÈS</div>
      <div style="font-size:13px; line-height:1.6; white-space:pre-wrap;">${escapeHtml(out)}</div>
    </div>
    <button class="btn alt full" onclick="correctorRun()" style="margin-top:10px; font-size:11px;">← Retour aux corrections</button>
  </div>`;
  
  document.getElementById('corr-output').innerHTML = html;
}

