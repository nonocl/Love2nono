    <div style="width:40px;"></div>
  </div>
  <div class="section">
    <p style="font-size:11px; color:var(--textSec);">C₁V₁ = C₂V₂ — Remplis 3 valeurs, je calcule la 4ème.</p>
    <div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:10px;">
      <div style="font-size:11px; font-weight:700; color:var(--primary);">🥃 Solution mère (concentrée)</div>
      <div style="display:flex; gap:6px; margin-top:6px;">
        <input type="number" class="input" id="dil-c1" placeholder="C₁ (mol/L)" oninput="dilCalc('c1')" step="0.001" style="flex:1;">
        <input type="number" class="input" id="dil-v1" placeholder="V₁ (mL)" oninput="dilCalc('v1')" step="0.1" style="flex:1;">
      </div>
    </div>
    <div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:8px;">
      <div style="font-size:11px; font-weight:700; color:var(--accent);">💧 Solution fille (diluée)</div>
      <div style="display:flex; gap:6px; margin-top:6px;">
        <input type="number" class="input" id="dil-c2" placeholder="C₂ (mol/L)" oninput="dilCalc('c2')" step="0.001" style="flex:1;">
        <input type="number" class="input" id="dil-v2" placeholder="V₂ (mL)" oninput="dilCalc('v2')" step="0.1" style="flex:1;">
      </div>
    </div>
    <div id="dil-result" style="margin-top:14px;"></div>
    <button class="btn alt full" onclick="dilReset()" style="margin-top:10px;">↻ Reset</button>
    <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:18px;">🧮 Concentration C = n / V</h3>
    <div style="display:flex; gap:6px;">
      <input type="number" class="input" id="conc-n" placeholder="n (mol)" oninput="concCalc()" step="0.001">
      <input type="number" class="input" id="conc-v" placeholder="V (L)" oninput="concCalc()" step="0.001">
    </div>
    <div id="conc-result" style="margin-top:8px; font-size:13px;"></div>
  </div>
</div>

