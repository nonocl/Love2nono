// === 81-82. COMPTEUR MOTS + RÉPÉTITIONS ===
function wcAnalyze() {
  const txt = document.getElementById('wc-input').value;
  if (!txt) {
    document.getElementById('wc-stats').innerHTML = '';
    document.getElementById('wc-repeats').innerHTML = '';
    return;
  }
  
  const chars = txt.length;
  const charsNoSpace = txt.replace(/\s/g, '').length;
  const words = (txt.match(/\b[\wÀ-ÿ]+\b/g) || []).length;
  const sentences = (txt.match(/[.!?]+/g) || []).length;
  const paragraphs = txt.split(/\n\s*\n/).filter(p => p.trim()).length;
  const lines = txt.split('\n').length;
  const readMin = Math.max(1, Math.ceil(words / 200));
  const speakMin = Math.max(1, Math.ceil(words / 130));
  
  let html = `<div style="background:var(--surface); padding:12px; border-radius:10px;">
    <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:8px;">
      <div><div style="font-size:10px; color:var(--textSec);">Caractères</div><div style="font-size:18px; font-weight:800;">${chars}</div></div>
      <div><div style="font-size:10px; color:var(--textSec);">Sans espaces</div><div style="font-size:18px; font-weight:800;">${charsNoSpace}</div></div>
      <div><div style="font-size:10px; color:var(--textSec);">Mots</div><div style="font-size:22px; font-weight:900; color:var(--primary);">${words}</div></div>
      <div><div style="font-size:10px; color:var(--textSec);">Phrases</div><div style="font-size:18px; font-weight:800;">${sentences}</div></div>
      <div><div style="font-size:10px; color:var(--textSec);">Paragraphes</div><div style="font-size:18px; font-weight:800;">${paragraphs}</div></div>
      <div><div style="font-size:10px; color:var(--textSec);">Lignes</div><div style="font-size:18px; font-weight:800;">${lines}</div></div>
    </div>
    <div style="border-top:1px solid var(--border); margin-top:10px; padding-top:10px; display:flex; gap:14px; font-size:11px;">
      <div>📖 Lecture : <strong>${readMin} min</strong></div>
      <div>🎤 Oral : <strong>${speakMin} min</strong></div>
    </div>
  </div>`;
  document.getElementById('wc-stats').innerHTML = html;
  
  // Répétitions
  const wordsArr = (txt.toLowerCase().match(/\b[\wÀ-ÿ]+\b/g) || []);
  const stopwords = new Set(['le','la','les','un','une','des','de','du','et','ou','où','est','sont','a','ai','as','ont','je','tu','il','elle','on','nous','vous','ils','elles','que','qui','quoi','dont','où','ce','cette','ces','mon','ma','mes','ton','ta','tes','son','sa','ses','notre','votre','leur','leurs','dans','sur','sous','avec','sans','par','pour','en','au','aux','à','y','en','plus','moins','très','si','non','oui','d\'','l\'','j\'','t\'','s\'','m\'','c\'','n\'','qu\'','d','l','j','t','s','m','c','n','qu','aussi','ainsi','donc','car','mais','or','ni','quand','alors','puis','autre','autres','même','tout','tous','toute','toutes','sa','et','était','être','avoir','fait','faire','faut','peu','peut','peuvent','pas','y','avait','aurait','seraient']);
  const counts = {};
  wordsArr.forEach(w => {
    if (w.length < 4) return;
    if (stopwords.has(w)) return;
    counts[w] = (counts[w] || 0) + 1;
  });
  const repeats = Object.entries(counts).filter(([w, n]) => n >= 3).sort((a,b) => b[1] - a[1]).slice(0, 15);
  
  let rh = '';
  if (repeats.length) {
    rh = `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">🔁 Répétitions détectées</h3>
      <p style="font-size:11px; color:var(--textSec); margin-bottom:6px;">Mots utilisés 3× ou plus (>3 lettres, hors mots usuels)</p>
      <div style="background:var(--surface); padding:10px; border-radius:10px; display:flex; flex-wrap:wrap; gap:4px;">`;
    repeats.forEach(([w, n]) => {
      const intensity = Math.min(255, 60 + n * 30);
      rh += `<span style="background:rgba(${n>5?'231,76,60':n>3?'255,140,66':'255,209,102'},0.3); border:1px solid rgba(231,76,60,${n/10}); padding:4px 10px; border-radius:6px; font-size:12px;"><strong>${escapeHtml(w)}</strong> <span style="opacity:0.7;">×${n}</span></span>`;
    });
    rh += `</div>`;
  } else if (wordsArr.length > 50) {
    rh = `<div style="background:var(--surface); padding:14px; border-radius:10px; margin-top:14px; text-align:center; color:var(--success); font-weight:700;">✅ Pas de répétition détectée, vocabulaire varié 👍</div>`;
  }
  document.getElementById('wc-repeats').innerHTML = rh;
}



