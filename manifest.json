<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#FFF0F5" id="theme-meta">
<title>Love2nono</title>
<link rel="apple-touch-icon" href="icon-180.png">
<link rel="icon" type="image/png" sizes="192x192" href="icon-192.png">
<link rel="icon" type="image/png" sizes="512x512" href="icon-512.png">
<link rel="manifest" href="manifest.json">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=VT323&family=Bangers&family=Press+Start+2P&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,900&family=IBM+Plex+Mono:wght@400;700&family=Caveat:wght@400;700&family=Comfortaa:wght@400;700&display=swap">
<style>
:root {
  --bg: #FFF0F5;
  --surface: #FFE4EC;
  --surfaceAlt: #FFD6E5;
  --primary: #FF6FA3;
  --accent: #FFB6D9;
  --text: #3D2230;
  --textSec: #8B5A6B;
  --border: #FFC1D9;
  --shadow: rgba(255,111,163,0.25);
  --danger: #E14D6B;
  --success: #7BC47F;
  --radius: 20px;
  --radiusBtn: 16px;
  --radiusChip: 999px;
  --bgImage: none;
  --bgOpacity: 1;
  --bgBlur: 0px;
}
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
html, body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
  height: 100%;
  overscroll-behavior-y: none;
  color: var(--text);
}
body {
  background: var(--bg);
  position: relative;
  padding: env(safe-area-inset-top) env(safe-area-inset-right) 0 env(safe-area-inset-left);
  padding-bottom: calc(20px + env(safe-area-inset-bottom));
  min-height: 100vh;
  transition: background 0.2s, color 0.2s;
}
body::before {
  content: '';
  position: fixed; inset: 0;
  background-image: var(--bgImage);
  background-size: cover;
  background-position: center;
  opacity: var(--bgOpacity);
  filter: blur(var(--bgBlur));
  z-index: -1;
  pointer-events: none;
  transition: opacity 0.3s, filter 0.3s;
}
button { font-family: inherit; cursor: pointer; border: none; background: none; color: inherit; }
input, textarea, select { font-family: inherit; }
img { display: block; -webkit-user-select: none; user-select: none; -webkit-user-drag: none; }

/* ===== Header ===== */
.topbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 16px;
}
.title { font-size: 26px; font-weight: 800; }
.icon-btn {
  width: 40px; height: 40px; border-radius: 20px;
  background: var(--surface);
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; margin-left: 8px;
  transition: transform 0.1s;
}
.icon-btn:active { transform: scale(0.92); }

/* ===== Pages ===== */
.page { display: none; min-height: 100vh; padding-bottom: 80px; }
.page.active { display: block; animation: fadeIn 0.2s ease; }
@keyframes fadeIn { from {opacity: 0; transform: translateY(8px);} to {opacity:1; transform:none;} }

.page-header {
  display: flex; align-items: center;
  padding: 8px 16px;
}
.back-btn {
  width: 40px; height: 40px; border-radius: 20px;
  background: var(--surface);
  display: flex; align-items: center; justify-content: center;
  font-size: 26px; line-height: 0;
}
.page-title { font-size: 20px; font-weight: 700; flex: 1; text-align: center; padding: 0 8px; }

/* ===== Home grid ===== */
.home-grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 8px; padding: 0 14px 12px;
}
.home-tile {
  aspect-ratio: 1/1;
  background: var(--surface);
  border-radius: 16px;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 6px 4px;
  box-shadow: 0 1px 3px var(--shadow);
  transition: transform 0.12s ease, background 0.2s;
  border: 1px solid transparent;
}
.home-tile:active { transform: scale(0.92); }
.home-tile .ico { font-size: 26px; margin-bottom: 4px; line-height: 1; }
.home-tile .lbl { font-size: 10.5px; font-weight: 600; text-align: center; line-height: 1.15; word-wrap: break-word; max-width: 100%; }

/* === Fix v39: new tile classes used in regenerated home === */
.home-tiles {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  padding: 0 14px 12px;
}
.home-tile-ico { font-size: 26px; margin-bottom: 4px; line-height: 1; }
.home-tile-name { font-size: 10.5px; font-weight: 600; text-align: center; line-height: 1.15; word-wrap: break-word; max-width: 100%; }
.home-section-title {
  font-size: 16px; font-weight: 800;
  padding: 18px 20px 8px;
  background: linear-gradient(90deg, var(--primary), var(--accent));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
body.layout-airy .home-tiles { gap: 12px; padding: 0 16px 16px; }
body.layout-airy .home-tile-ico { font-size: 36px; margin-bottom: 8px; }
body.layout-airy .home-tile-name { font-size: 11px; }
body.layout-compact .home-tiles { grid-template-columns: repeat(5, 1fr); gap: 6px; padding: 0 10px 10px; }
body.layout-compact .home-tile-ico { font-size: 22px; margin-bottom: 2px; }
body.layout-compact .home-tile-name { font-size: 9.5px; }

/* Section header avec accent gradient & repli */
.home-section {
  margin: 4px 0 0;
}
.home-section-header {
  display: flex; align-items: center; gap: 8px;
  padding: 18px 20px 8px;
  cursor: pointer;
  user-select: none;
  -webkit-user-select: none;
}
.home-section-header .icon-bg {
  width: 32px; height: 32px;
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
  background: linear-gradient(135deg, var(--primary), var(--accent));
  color: white;
  box-shadow: 0 2px 6px var(--shadow);
  flex-shrink: 0;
}
.home-section-header .title-txt {
  font-size: 14px; font-weight: 700;
  color: var(--text);
  letter-spacing: 0.2px;
  flex: 1;
}
.home-section-header .count-badge {
  font-size: 11px; font-weight: 600;
  color: var(--textSec);
  background: var(--surfaceAlt);
  padding: 3px 9px;
  border-radius: 10px;
}
.home-section-header .chev {
  font-size: 12px; color: var(--textSec);
  transition: transform 0.2s;
  margin-left: 6px;
}
.home-section.collapsed .chev { transform: rotate(-90deg); }
.home-section.collapsed .home-grid { display: none; }

/* === SEARCHBAR (rebuilt clean v2) === */
.searchbar-wrap {
  padding: 4px 16px 10px;
}
.searchbar {
  width: 100%;
  display: block;
  box-sizing: border-box;
  padding: 11px 16px;
  background: transparent !important;
  border: 1px solid rgba(255, 255, 255, 0.18) !important;
  border-radius: 14px;
  color: var(--text);
  font-size: 14px;
  font-family: inherit;
  outline: none !important;
  -webkit-appearance: none !important;
  appearance: none !important;
  -webkit-tap-highlight-color: transparent;
  box-shadow: none !important;
  transition: border-color 0.2s;
}
.searchbar::placeholder {
  color: var(--textSec);
  opacity: 0.6;
}
.searchbar:focus,
.searchbar:focus-visible,
.searchbar:active {
  outline: none !important;
  border-color: var(--primary) !important;
  box-shadow: none !important;
}
/* Adapter le contour selon le fond clair (pour designs sur fond pâle) */
body.design-vogue .searchbar,
body.design-paper .searchbar,
body.design-manga .searchbar,
body.design-pokemon .searchbar,
body.design-brutalist .searchbar {
  border-color: rgba(0, 0, 0, 0.2) !important;
  color: var(--text);
}
body.design-hellokitty .searchbar {
  background: rgba(255,255,255,0.85) !important;
  border: 2px solid #FFB3D1 !important;
  color: #4A1A2C !important;
}
body.design-hellokitty .searchbar::placeholder {
  color: #C71585 !important;
  opacity: 0.5 !important;
}
body.design-cat .searchbar {
  background: rgba(255,248,236,0.9) !important;
  border: 2px solid #C8956D !important;
  color: #3D2817 !important;
}
body.design-cat .searchbar::placeholder {
  color: #6B3410 !important;
  opacity: 0.5 !important;
}

/* Recherche en direct - résultats overlay */
.home-search-results {
  background: var(--surface);
  border-radius: 14px;
  margin: 8px 16px;
  overflow: hidden;
  display: none;
}
.home-search-results.active { display: block; }
.home-search-result {
  display: flex; align-items: center; gap: 12px;
  padding: 10px 14px;
  border-bottom: 1px solid var(--border);
  cursor: pointer;
}
.home-search-result:last-child { border: none; }
.home-search-result:active { background: var(--surfaceAlt); }
.home-search-result .res-ico { font-size: 22px; }
.home-search-result .res-info { flex: 1; min-width: 0; }
.home-search-result .res-name { font-weight: 600; font-size: 14px; }
.home-search-result .res-cat { font-size: 11px; color: var(--textSec); }

/* Tuile favorite (épinglée) */
.home-tile.fav { 
  background: linear-gradient(135deg, var(--primary), var(--accent));
  color: white;
}
.home-tile.fav .lbl { color: white; }

/* ========================================================== */
/* === MODES DE DISPOSITION D'ACCUEIL === */
/* ========================================================== */

/* DEFAULT (4 cols compact, déjà en place) */

/* === Mode AÉRÉ (3 cols, gros boutons) === */
body.layout-airy .home-grid {
  grid-template-columns: repeat(3, 1fr) !important;
  gap: 12px !important;
  padding: 0 16px 14px !important;
}
body.layout-airy .home-tile { aspect-ratio: 1/1; padding: 12px 6px; border-radius: 20px; }
body.layout-airy .home-tile .ico { font-size: 36px; margin-bottom: 8px; }
body.layout-airy .home-tile .lbl { font-size: 12px; }

/* === Mode LISTE (1 col Spotify-like) === */
body.layout-list .home-grid {
  grid-template-columns: 1fr !important;
  gap: 4px !important;
  padding: 0 12px 10px !important;
}
body.layout-list .home-tile {
  aspect-ratio: auto !important;
  flex-direction: row !important;
  justify-content: flex-start !important;
  padding: 12px 14px !important;
  text-align: left;
  gap: 14px;
  border-radius: 12px;
}
body.layout-list .home-tile .ico { font-size: 24px; margin: 0 !important; }
body.layout-list .home-tile .lbl { font-size: 14px; text-align: left !important; }
body.layout-list .home-tile.is-fav::after { top: 50%; right: 14px; transform: translateY(-50%); font-size: 14px; }

/* === Mode MAGAZINE (mosaïque tailles variées) === */
body.layout-mag .home-grid {
  grid-template-columns: repeat(4, 1fr) !important;
  grid-auto-rows: 80px;
  gap: 6px !important;
  padding: 0 14px 14px !important;
}
body.layout-mag .home-tile { aspect-ratio: auto !important; }
body.layout-mag .home-tile:nth-child(7n+1) { grid-column: span 2; grid-row: span 2; }
body.layout-mag .home-tile:nth-child(7n+1) .ico { font-size: 40px; }
body.layout-mag .home-tile:nth-child(7n+5) { grid-row: span 2; }
body.layout-mag .home-tile:nth-child(11n+3) { grid-column: span 2; }

/* === Mode CARDS (tuiles hautes avec description) === */
body.layout-cards .home-grid {
  grid-template-columns: repeat(2, 1fr) !important;
  gap: 10px !important;
  padding: 0 14px 14px !important;
}
body.layout-cards .home-tile {
  aspect-ratio: 4/3 !important;
  padding: 14px !important;
  flex-direction: column !important;
  justify-content: flex-start !important;
  align-items: flex-start !important;
  text-align: left;
  border-radius: 18px;
  background: linear-gradient(135deg, var(--surface), var(--surfaceAlt));
}
body.layout-cards .home-tile .ico { font-size: 32px; margin-bottom: 8px; }
body.layout-cards .home-tile .lbl { font-size: 13px; text-align: left !important; }

/* ========================================================== */
/* === STYLES DE SECTIONS === */
/* ========================================================== */

/* MINIMAL (sans icône) */
body.section-minimal .home-section-header .icon-bg { display: none; }
body.section-minimal .home-section-header { padding: 14px 20px 6px; }
body.section-minimal .home-section-header .title-txt { font-size: 13px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--textSec); font-weight: 600; }
body.section-minimal .home-section-header .count-badge { background: transparent; border: 1px solid var(--border); padding: 2px 8px; }

/* CARDS (fond gradient) */
body.section-cards .home-section { 
  margin: 8px 12px; 
  background: linear-gradient(135deg, var(--surface) 0%, var(--surfaceAlt) 100%); 
  border-radius: 18px; 
  overflow: hidden;
  border: 1px solid var(--border);
}
body.section-cards .home-section-header {
  background: rgba(255,255,255,0.03);
  border-bottom: 1px solid var(--border);
  padding: 14px 16px;
}
body.section-cards .home-grid { padding: 12px 12px 14px !important; }

/* SEPARATORS (lignes simples, pas d'en-tête boxé) */
body.section-line .home-section-header .icon-bg { display: none; }
body.section-line .home-section-header { padding: 18px 20px 6px; border-top: 1px solid var(--border); margin-top: 8px; }
body.section-line .home-section-header .title-txt { font-size: 16px; font-weight: 800; }

/* DOTS */
body.section-dots .home-section-header { padding: 18px 20px 8px; }
body.section-dots .home-section-header::before { content: '••• '; color: var(--primary); font-weight: 900; margin-right: 6px; }
body.section-dots .home-section-header .icon-bg { display: none; }
body.section-dots .home-section-header .title-txt { font-size: 15px; }

/* ========================================================== */
/* === PRÉSETS DE THÈME GLOBAL === */
/* ========================================================== */

/* PRESET MAGAZINE ÉCLATÉ - pastel coloré chaos */
body.preset-mag .home-tile:nth-child(odd) { background: linear-gradient(135deg, #FFD6E8, #FFC4DD); color: #1c1c1e; }
body.preset-mag .home-tile:nth-child(even) { background: linear-gradient(135deg, #B3D9FF, #C7CFFF); color: #1c1c1e; }
body.preset-mag .home-tile:nth-child(3n) { background: linear-gradient(135deg, #C6F0C6, #D0F4D8); color: #1c1c1e; }
body.preset-mag .home-tile:nth-child(5n) { background: linear-gradient(135deg, #FFF3B3, #FFE699); color: #1c1c1e; }
body.preset-mag .home-tile:nth-child(7n) { background: linear-gradient(135deg, #D9B3FF, #E0CCFF); color: #1c1c1e; }
body.preset-mag .home-tile .lbl { color: #1c1c1e; }
body.preset-mag .home-tile { transform: rotate(-1deg); transition: transform 0.2s; }
body.preset-mag .home-tile:nth-child(even) { transform: rotate(1deg); }
body.preset-mag .home-tile:active { transform: rotate(0) scale(0.95); }

/* PRESET MINIMAL PUR (tout texte) */
body.preset-minimal .home-tile {
  background: transparent !important;
  border: 1px solid var(--border) !important;
  box-shadow: none !important;
  border-radius: 4px !important;
  background: transparent;
}
body.preset-minimal .home-tile .ico { display: none; }
body.preset-minimal .home-tile .lbl { font-size: 11px !important; }
body.preset-minimal .home-section-header .icon-bg { display: none; }
body.preset-minimal .home-section-header .title-txt { text-transform: uppercase; letter-spacing: 2px; font-size: 11px; }

/* PRESET NEON GLOW (bordures lumineuses) */
body.preset-neon .home-tile {
  border: 1.5px solid var(--primary);
  box-shadow: 0 0 14px rgba(255,111,163,0.4), inset 0 0 8px rgba(255,111,163,0.1);
  background: rgba(0,0,0,0.4) !important;
  color: var(--primary);
}
body.preset-neon .home-tile .lbl { color: var(--text); text-shadow: 0 0 4px var(--primary); }
body.preset-neon .home-tile:nth-child(2n) { border-color: var(--accent); box-shadow: 0 0 14px rgba(199,125,255,0.4); }
body.preset-neon .home-tile:nth-child(3n) { border-color: #5DD6E5; box-shadow: 0 0 14px rgba(93,214,229,0.4); }
body.preset-neon .home-section-header .icon-bg { box-shadow: 0 0 12px var(--primary); }

/* PRESET PASTEL KAWAII */
body.preset-kawaii .home-tile {
  background: #FFE4F0 !important;
  color: #6B3A5A !important;
  border-radius: 24px !important;
  border: 2px solid #FFB3D9;
}
body.preset-kawaii .home-tile .lbl { color: #6B3A5A; font-weight: 700; }
body.preset-kawaii .home-tile:nth-child(2n) { background: #E0F0FF !important; border-color: #B3D9FF; }
body.preset-kawaii .home-tile:nth-child(3n) { background: #E8F8E0 !important; border-color: #B3E5B3; }
body.preset-kawaii .home-tile:nth-child(4n) { background: #FFF0D6 !important; border-color: #FFD9B3; }
body.preset-kawaii .home-tile:nth-child(5n) { background: #F0E0FF !important; border-color: #D9B3FF; }
body.preset-kawaii .home-section-header .icon-bg { background: #FFB3D9 !important; }

/* PRESET iOS CLASSIQUE */
body.preset-ios .home-tile {
  background: var(--surface);
  border-radius: 14px !important;
  box-shadow: 0 1px 2px rgba(0,0,0,0.08), 0 1px 1px rgba(0,0,0,0.06) !important;
  border: 1px solid rgba(255,255,255,0.05);
}
body.preset-ios .home-section-header .icon-bg {
  border-radius: 12px;
  width: 30px; height: 30px;
}
body.preset-ios .home-section-header .title-txt { font-size: 13px; text-transform: none; letter-spacing: 0; }

/* PRESET COMPACT PRO (très dense, technique) */
body.preset-compact .home-grid { grid-template-columns: repeat(5, 1fr) !important; gap: 4px !important; padding: 0 12px 8px !important; }
body.preset-compact .home-tile { aspect-ratio: 1/1; padding: 4px !important; border-radius: 8px !important; }
body.preset-compact .home-tile .ico { font-size: 20px; margin-bottom: 2px; }
body.preset-compact .home-tile .lbl { font-size: 9px !important; line-height: 1.1; }
body.preset-compact .home-section-header { padding: 10px 16px 4px !important; }
body.preset-compact .home-section-header .icon-bg { width: 24px; height: 24px; font-size: 14px; }
body.preset-compact .home-section-header .title-txt { font-size: 12px; }


/* ============================================================
   DESIGNS COMPLETS (DA totale qui change TOUTE l'app)
   ============================================================ */

/* ====== DESIGN: TERMINAL HACKER ====== */
body.design-terminal {
  --primary: #00FF41;
  --accent: #00FF41;
  --bg: #000000;
  --surface: #0A0E0A;
  --surfaceAlt: #050805;
  --text: #00FF41;
  --textSec: #008F1D;
  --border: #00FF4133;
  --danger: #FF003C;
  --success: #00FF41;
  background: #000 !important;
  font-family: 'IBM Plex Mono', 'Courier New', 'Consolas', monospace !important;
}
body.design-terminal * { font-family: 'IBM Plex Mono', 'Courier New', 'Consolas', monospace !important; }
body.design-terminal .home-tile {
  background: transparent !important;
  border: 1px solid #00FF4144 !important;
  color: #00FF41 !important;
  border-radius: 0 !important;
  box-shadow: inset 0 0 12px rgba(0,255,65,0.05) !important;
}
body.design-terminal .home-tile::before {
  content: '> '; color: #00FF41; opacity: 0.6;
  position: absolute; top: 4px; left: 4px; font-size: 10px;
}
body.design-terminal .home-tile .lbl { color: #00FF41 !important; text-transform: lowercase; }
body.design-terminal .home-tile .ico { filter: hue-rotate(90deg) saturate(2); }
body.design-terminal .home-section-header { border-left: 3px solid #00FF41; background: rgba(0,255,65,0.03); }
body.design-terminal .home-section-header .icon-bg { background: transparent !important; border: 1px solid #00FF41; color: #00FF41 !important; border-radius: 0 !important; }
body.design-terminal .home-section-header .title-txt { color: #00FF41 !important; text-transform: uppercase; letter-spacing: 3px; }
body.design-terminal .home-section-header .title-txt::before { content: '['; }
body.design-terminal .home-section-header .title-txt::after { content: ']'; }
body.design-terminal .count-badge { background: #00FF41 !important; color: #000 !important; border-radius: 0 !important; }
body.design-terminal .page-header { background: #000 !important; border-bottom: 1px solid #00FF4144; }
body.design-terminal .page-title { color: #00FF41 !important; font-family: monospace !important; }
body.design-terminal .section { border: 1px solid #00FF4122; border-radius: 0; background: rgba(0,255,65,0.02); }
body.design-terminal .btn { border-radius: 0 !important; border: 1px solid #00FF41 !important; background: transparent !important; color: #00FF41 !important; text-transform: uppercase; letter-spacing: 2px; font-family: monospace !important; }
body.design-terminal .btn.primary { background: #00FF41 !important; color: #000 !important; }
body.design-terminal .btn.alt { border-color: #008F1D !important; color: #008F1D !important; }
body.design-terminal .input, body.design-terminal select, body.design-terminal textarea { background: #000 !important; border: 1px solid #00FF4166 !important; color: #00FF41 !important; border-radius: 0 !important; font-family: monospace !important; caret-color: #00FF41; }
body.design-terminal .label { color: #00FF41 !important; text-transform: uppercase; font-size: 10px; letter-spacing: 2px; }
body.design-terminal .label::before { content: '$ '; }
body.design-terminal .bottom-nav { background: #000 !important; border-top: 1px solid #00FF4144 !important; }
body.design-terminal .bottom-nav-btn { color: #008F1D !important; }
body.design-terminal .bottom-nav-btn.active { color: #00FF41 !important; text-shadow: 0 0 8px #00FF41; }
body.design-terminal .top-bar { background: #000 !important; border-bottom: 1px solid #00FF4144 !important; }
body.design-terminal .top-title { color: #00FF41 !important; font-family: monospace !important; }
