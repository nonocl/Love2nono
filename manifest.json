<!-- ======= CALC SCIENTIFIQUE ======= -->
<div class="page" id="page-scicalc">
  <div class="page-header">
    <button class="back-btn" onclick="goBack()">‹</button>
    <div class="page-title">🔬 Calc scientifique</div>
    <div style="width:40px;"></div>
  </div>
  <div class="section">
    <input type="text" class="input" id="sci-display" readonly style="text-align:right; font-size:22px; padding:14px; font-family:monospace; word-break:break-all;">
    <div id="sci-history" style="font-size:11px; color:var(--textSec); text-align:right; min-height:14px; margin:4px 0; max-height:60px; overflow-y:auto;"></div>
    <div style="display:grid; grid-template-columns:repeat(5,1fr); gap:6px; margin-top:8px;">
      <button class="btn alt" onclick="sciIns('sin(')">sin</button>
      <button class="btn alt" onclick="sciIns('cos(')">cos</button>
      <button class="btn alt" onclick="sciIns('tan(')">tan</button>
      <button class="btn alt" onclick="sciIns('Math.PI')">π</button>
      <button class="btn alt" onclick="sciIns('Math.E')">e</button>
      <button class="btn alt" onclick="sciIns('Math.log10(')">log</button>
      <button class="btn alt" onclick="sciIns('Math.log(')">ln</button>
      <button class="btn alt" onclick="sciIns('Math.sqrt(')">√</button>
      <button class="btn alt" onclick="sciIns('**2')">x²</button>
      <button class="btn alt" onclick="sciIns('**')">^</button>
      <button class="btn alt" onclick="sciIns('(')">(</button>
      <button class="btn alt" onclick="sciIns(')')">)</button>
      <button class="btn alt" onclick="sciIns('!')">!</button>
      <button class="btn alt" onclick="sciIns('Math.abs(')">|x|</button>
      <button class="btn ghost" onclick="sciClear()" style="color:var(--danger);">C</button>
    </div>
    <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:6px; margin-top:6px;">
      <button class="btn alt" onclick="sciIns('7')">7</button>
      <button class="btn alt" onclick="sciIns('8')">8</button>
      <button class="btn alt" onclick="sciIns('9')">9</button>
      <button class="btn alt" onclick="sciIns('/')" style="color:var(--primary);">÷</button>
      <button class="btn alt" onclick="sciIns('4')">4</button>
      <button class="btn alt" onclick="sciIns('5')">5</button>
      <button class="btn alt" onclick="sciIns('6')">6</button>
      <button class="btn alt" onclick="sciIns('*')" style="color:var(--primary);">×</button>
      <button class="btn alt" onclick="sciIns('1')">1</button>
      <button class="btn alt" onclick="sciIns('2')">2</button>
      <button class="btn alt" onclick="sciIns('3')">3</button>
      <button class="btn alt" onclick="sciIns('-')" style="color:var(--primary);">−</button>
      <button class="btn alt" onclick="sciIns('0')">0</button>
      <button class="btn alt" onclick="sciIns('.')">.</button>
      <button class="btn alt" onclick="sciBack()">⌫</button>
      <button class="btn alt" onclick="sciIns('+')" style="color:var(--primary);">+</button>
    </div>
    <button class="btn primary full" style="margin-top:8px;" onclick="sciEval()">=</button>
  </div>
</div>

