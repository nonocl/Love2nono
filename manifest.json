    <div style="font-size:36px;">🌍</div><div style="font-size:16px; font-weight:800;">Fuseaux horaires</div>
    <div style="font-size:11px; opacity:0.9;">${TIMEZONES_LIST.length} villes dans le monde</div>
  </div>
  <div id="tz-list" style="margin-top:14px;"></div>`;
  document.getElementById('timezones-content').innerHTML = html;
  tzUpdate();
  if (window._tzInterval) clearInterval(window._tzInterval);
  window._tzInterval = setInterval(tzUpdate, 1000);
}
function tzUpdate() {
  const list = document.getElementById('tz-list');
  if (!list) { if (window._tzInterval) clearInterval(window._tzInterval); return; }
  const now = new Date();
  let html = '';
  TIMEZONES_LIST.forEach(z => {
    try {
      const t = now.toLocaleTimeString('fr-FR', { timeZone: z.tz, hour: '2-digit', minute: '2-digit' });
      const d = now.toLocaleDateString('fr-FR', { timeZone: z.tz, weekday: 'short', day: 'numeric', month: 'short' });
      html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px; display:flex; justify-content:space-between; align-items:center;">
        <div style="font-size:14px; font-weight:700;">${z.c}</div>
        <div style="text-align:right;">
          <div style="font-size:18px; font-weight:900; color:var(--primary);">${t}</div>
          <div style="font-size:10px; color:var(--textSec);">${d}</div>
        </div>
      </div>`;
    } catch (e) {}
  });
  list.innerHTML = html;
}


