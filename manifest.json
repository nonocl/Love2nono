function renderConjugIt() {
  let html = `<div style="background:linear-gradient(135deg,#06FFA5,#FF6FA3); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🇮🇹</div><div style="font-size:16px; font-weight:800;">Coniugatore italiano</div>
    <div style="font-size:11px; opacity:0.9;">12 verbi irregolari + gruppi -are -ere -ire</div>
  </div>
  <input type="text" id="cit-verb" class="input" placeholder="Verbo (parlare, vedere, dormire, essere...)" oninput="citConjugate()" style="margin-top:14px;" autocomplete="off" autocapitalize="off">
  <div id="cit-result" style="margin-top:14px;"></div>
  <p style="font-size:10px; color:var(--textSec); margin-top:14px;">💡 Verbi irregolari : essere, avere, andare, fare, venire, dire, sapere, volere, potere, dovere, stare, dare.</p>`;
  document.getElementById('conjugit-content').innerHTML = html;
}
function citConjugate() {
  const verb = document.getElementById('cit-verb').value.trim().toLowerCase();
  if (!verb) { document.getElementById('cit-result').innerHTML = ''; return; }
  let conj;
  if (IT_IRREG[verb]) {
    conj = IT_IRREG[verb];
  } else if (verb.endsWith('are') || verb.endsWith('ere') || verb.endsWith('ire')) {
    const ending = verb.slice(-3);
    const stem = verb.slice(0, -3);
    const tmpl = v52_IT_VERBS[ending];
    conj = {};
    for (const t in tmpl) conj[t] = tmpl[t].map(s => stem + s);
  } else {
    document.getElementById('cit-result').innerHTML = '<div style="background:var(--surface); padding:14px; border-radius:12px; color:var(--textSec); font-size:12px;">Verbo non riconosciuto. Prova un verbo in -are, -ere, -ire o un irregolare.</div>';
    return;
  }
  let html = '';
  const tenseLabels = { presente: 'Presente', imperfetto: 'Imperfetto', passato_remoto: 'Passato remoto', futuro: 'Futuro', condizionale: 'Condizionale', congiuntivo: 'Congiuntivo presente' };
  for (const t in tenseLabels) {
    if (!conj[t]) continue;
    html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px;">
      <div style="font-size:11px; font-weight:700; color:var(--primary); margin-bottom:4px;">${tenseLabels[t]}</div>`;
    for (let i = 0; i < 6; i++) {
      html += `<div style="font-size:13px; display:flex; gap:8px; margin-top:2px;"><span style="color:var(--textSec); min-width:60px;">${PRONOMS_IT[i]}</span><strong>${escapeHtml(conj[t][i])}</strong></div>`;
    }
    html += '</div>';
  }
  document.getElementById('cit-result').innerHTML = html;
}

