let _pong = null;
let _pongAnim = null;

function initPong() {
  if (_pongAnim) cancelAnimationFrame(_pongAnim);
  const c = document.getElementById('pong-canvas');
  _pong = {
    pw: 60, ph: 8, // paddle
    ball: { x: c.width/2, y: c.height/2, vx: 3, vy: 3, r: 6 },
    you: { x: c.width/2 - 30 }, ai: { x: c.width/2 - 30 },
    youScore: 0, aiScore: 0, running: true
  };
  document.getElementById('pong-score').textContent = 'Toi 0 — 0 IA';
  // Touch handler for paddle
  c.ontouchmove = (e) => {
    e.preventDefault();
    const rect = c.getBoundingClientRect();
    const tx = e.touches[0].clientX - rect.left;
    _pong.you.x = Math.max(0, Math.min(c.width - _pong.pw, tx * (c.width / rect.width) - _pong.pw/2));
  };
  pongLoop();
}

function pongLoop() {
  const c = document.getElementById('pong-canvas');
  if (!c || !_pong || state.page !== 'game-pong') return;
  const ctx = c.getContext('2d');
  const W = c.width, H = c.height;
  // Update
  _pong.ball.x += _pong.ball.vx;
  _pong.ball.y += _pong.ball.vy;
  if (_pong.ball.x < _pong.ball.r || _pong.ball.x > W - _pong.ball.r) _pong.ball.vx *= -1;
  // Top paddle (AI) bounce
  if (_pong.ball.y < _pong.ph + _pong.ball.r && _pong.ball.x > _pong.ai.x && _pong.ball.x < _pong.ai.x + _pong.pw) {
    _pong.ball.vy = Math.abs(_pong.ball.vy);
  }
  // Bottom paddle bounce
  if (_pong.ball.y > H - _pong.ph - _pong.ball.r && _pong.ball.x > _pong.you.x && _pong.ball.x < _pong.you.x + _pong.pw) {
    _pong.ball.vy = -Math.abs(_pong.ball.vy);
    _pong.ball.vy *= 1.05; if (Math.abs(_pong.ball.vy) > 8) _pong.ball.vy = 8 * Math.sign(_pong.ball.vy);
  }
  // Score
  if (_pong.ball.y < 0) { _pong.youScore++; pongReset(); }
  if (_pong.ball.y > H) { _pong.aiScore++; pongReset(); }
  // AI
  const aiCenter = _pong.ai.x + _pong.pw/2;
  if (_pong.ball.x > aiCenter + 5) _pong.ai.x = Math.min(W - _pong.pw, _pong.ai.x + 3);
  if (_pong.ball.x < aiCenter - 5) _pong.ai.x = Math.max(0, _pong.ai.x - 3);
  // Draw
  ctx.fillStyle = '#000'; ctx.fillRect(0,0,W,H);
  ctx.fillStyle = 'white';
  ctx.fillRect(_pong.you.x, H - _pong.ph, _pong.pw, _pong.ph);
  ctx.fillRect(_pong.ai.x, 0, _pong.pw, _pong.ph);
  ctx.beginPath(); ctx.arc(_pong.ball.x, _pong.ball.y, _pong.ball.r, 0, Math.PI*2); ctx.fill();
  // Mid line
  ctx.strokeStyle = 'rgba(255,255,255,0.3)';
  ctx.setLineDash([5,5]); ctx.beginPath(); ctx.moveTo(0, H/2); ctx.lineTo(W, H/2); ctx.stroke();
  ctx.setLineDash([]);
  document.getElementById('pong-score').textContent = `Toi ${_pong.youScore} — ${_pong.aiScore} IA`;
  // Win check
  if (_pong.youScore >= 5 || _pong.aiScore >= 5) {
    _pong.running = false;
    setTimeout(() => alert(_pong.youScore > _pong.aiScore ? '🎉 Tu gagnes !' : '😬 IA gagne'), 100);
    return;
  }
  _pongAnim = requestAnimationFrame(pongLoop);
}

function pongReset() {
  const c = document.getElementById('pong-canvas');
  _pong.ball = { x: c.width/2, y: c.height/2, vx: (Math.random()>0.5?3:-3), vy: 3 * (Math.random()>0.5?1:-1), r: 6 };
}

