.x-stat-lbl { color:#71767b; }

/* Snapchat */
.sc-card { background:#FFFC00; color:black; border-radius:18px; overflow:hidden; max-width:340px; margin:0 auto; box-shadow:0 8px 24px rgba(0,0,0,0.3); font-family:system-ui, sans-serif; }
.sc-header { padding:30px 16px 14px; text-align:center; }
.sc-avatar { width:96px; height:96px; border-radius:50%; margin:0 auto 8px; background:white; display:flex; align-items:center; justify-content:center; font-size:42px; overflow:hidden; box-shadow:0 4px 14px rgba(0,0,0,0.15); }
.sc-avatar img { width:100%; height:100%; object-fit:cover; border-radius:50%; }
.sc-name { font-size:22px; font-weight:800; }
.sc-handle { font-size:14px; color:rgba(0,0,0,0.65); }
.sc-stats { background:white; padding:12px; border-radius:12px; margin:14px; display:flex; justify-content:space-around; }
.sc-stat { text-align:center; }
.sc-stat-num { font-weight:800; font-size:18px; }
.sc-stat-lbl { font-size:11px; color:#666; text-transform:uppercase; letter-spacing:0.4px; }
.sc-score { background:white; margin:14px; padding:10px 14px; border-radius:10px; display:flex; justify-content:space-between; align-items:center; font-weight:700; }

/* Guest mode hide sensitive */
body.guest-mode [data-guest-hide],
body.guest-mode .home-tile[onclick*="'privfolder'"],
body.guest-mode .home-tile[onclick*="'locknotes'"],
body.guest-mode .home-tile[onclick*="'doccoffre'"],
body.guest-mode .home-tile[onclick*="'pity'"],
body.guest-mode .home-tile[onclick*="'finances'"],
body.guest-mode .home-tile[onclick*="'mood'"],
body.guest-mode .home-tile[onclick*="'cycle'"],
body.guest-mode .home-tile[onclick*="'pwdvault'"] {
  display: none !important;
}


