function renderMotRare() {
  const seed = getTodaySeed();
  const idx = Math.floor(seededRandom(seed) * RARE_WORDS.length);
  const w = RARE_WORDS[idx];
  let html = `<div style="background:linear-gradient(135deg,#5D2E8C,#FF6FA3); color:white; padding:20px; border-radius:18px; text-align:center;">
