let _simon = null;
const SIMON_COLORS = ['green','red','yellow','blue'];
const SIMON_TONES = { green:392, red:329, yellow:261, blue:523 };

async function initSimon() {
  const best = await getScore('simon');
  _simon = { sequence:[], userPos:0, level:0, best:best?best.value:0, playing:false, showing:false };
  document.getElementById('simon-best').textContent = _simon.best;
  document.getElementById('simon-level').textContent = '0';
  document.getElementById('simon-status').textContent = 'Tap démarrer';
  // Setup buttons
  document.querySelectorAll('.simon-btn').forEach(btn => {
    btn.onclick = () => simonClick(btn.dataset.c);
  });
}

async function simonStart() {
  initSimon();
  setTimeout(simonNext, 500);
}

function simonNext() {
  _simon.sequence.push(SIMON_COLORS[Math.floor(Math.random()*4)]);
  _simon.level = _simon.sequence.length;
  _simon.userPos = 0;
  document.getElementById('simon-level').textContent = _simon.level;
  document.getElementById('simon-status').textContent = '👀 Regarde...';
  simonShow(0);
}

function simonShow(i) {
  _simon.showing = true;
  if (i >= _simon.sequence.length) {
    _simon.showing = false;
    document.getElementById('simon-status').textContent = '✋ À ton tour';
    return;
  }
  const c = _simon.sequence[i];
  simonFlash(c);
  setTimeout(() => simonShow(i+1), 600);
}

function simonFlash(c) {
  const btn = document.querySelector(`.simon-btn[data-c="${c}"]`);
  if (!btn) return;
  btn.style.opacity = '0.4';
  setTimeout(() => { btn.style.opacity = '1'; }, 300);
  // Beep
  try {
    const ctx = new (window.AudioContext||window.webkitAudioContext)();
    const o = ctx.createOscillator(); const g = ctx.createGain();
    o.frequency.value = SIMON_TONES[c]; o.type = 'sine';
    g.gain.value = 0.2;
    o.connect(g); g.connect(ctx.destination);
    o.start(); o.stop(ctx.currentTime + 0.3);
  } catch (e) {}
}

function simonClick(c) {
  if (_simon.showing || _simon.sequence.length === 0) return;
  simonFlash(c);
  if (c !== _simon.sequence[_simon.userPos]) {
    document.getElementById('simon-status').textContent = '😬 Game Over';
    if (_simon.level - 1 > _simon.best) { setScore('simon', _simon.level-1); _simon.best = _simon.level-1; document.getElementById('simon-best').textContent = _simon.best; }
    setTimeout(() => alert(`Game Over au niveau ${_simon.level}`), 200);
    _simon.sequence = [];
    return;
  }
  _simon.userPos++;
  if (_simon.userPos === _simon.sequence.length) {
    document.getElementById('simon-status').textContent = '✓ Bien !';
    setTimeout(simonNext, 800);
  }
}

