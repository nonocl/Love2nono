async function renderHabits() {
  const habits = await dbAll('habits');
  const logs = await dbAll('habit_logs');
  const today = new Date().toISOString().split('T')[0];
  const el = document.getElementById('habits-list');
  el.innerHTML = '';
  if (habits.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">🎯</div><h3>Aucune habitude</h3><p>Ajoute des habitudes à cocher chaque jour.</p></div>`;
    return;
  }
  for (const h of habits) {
    const todayDone = logs.some(l => l.habit_id === h.id && l.date === today);
    // Calc streak
    let streak = 0;
    const sorted = logs.filter(l => l.habit_id === h.id).map(l => l.date).sort().reverse();
    let d = new Date(today);
    for (const ds of sorted) {
      if (ds === d.toISOString().split('T')[0]) {
        streak++;
        d.setDate(d.getDate()-1);
      } else break;
    }
    const row = document.createElement('div');
    row.className = 'habit-row';
    row.innerHTML = `
      <span style="font-size:22px;">${h.icon||'🎯'}</span>
      <div style="flex:1;">
        <div class="habit-name">${escapeHtml(h.name)}</div>
        <div class="habit-streak">🔥 ${streak} jour${streak>1?'s':''} d'affilée</div>
      </div>
      <button class="habit-check ${todayDone?'done':''}">${todayDone?'✓':''}</button>
    `;
    row.querySelector('.habit-check').onclick = async () => {
      const k = `${h.id}_${today}`;
      if (todayDone) await dbDel('habit_logs', k);
      else await dbAdd('habit_logs', { key: k, habit_id: h.id, date: today });
      renderHabits();
    };
    row.onclick = (e) => { if (!e.target.classList.contains('habit-check')) openHabitModal(h); };
    el.appendChild(row);
  }
}

function openHabitModal(habit) {
  state.editingHabit = habit || null;
  document.getElementById('habit-modal-title').textContent = habit ? 'Modifier' : 'Nouvelle habitude';
  document.getElementById('habit-name-input').value = habit ? habit.name : '';
  state.habitIcon = habit ? (habit.icon || '🎯') : '🎯';
  document.getElementById('habit-del-btn').style.display = habit ? 'inline-flex' : 'none';
  const ic = document.getElementById('habit-icons');
  ic.innerHTML = '';
  for (const i of ICONS) {
    const b = document.createElement('button');
    b.className = 'swatch' + (i === state.habitIcon ? ' selected' : '');
    b.style.background = 'var(--surface)';
    b.textContent = i;
    b.onclick = () => { state.habitIcon = i; openHabitModal(habit); };
    ic.appendChild(b);
  }
  openModal('modal-habit');
}

async function saveHabit() {
  const name = document.getElementById('habit-name-input').value.trim();
  if (!name) { alert('Donne un nom.'); return; }
  if (state.editingHabit) await dbPut('habits', { ...state.editingHabit, name, icon: state.habitIcon });
  else await dbAdd('habits', { name, icon: state.habitIcon, created_at: new Date().toISOString() });
  closeModal('modal-habit');
  renderHabits();
}

async function deleteHabitNow() {
  if (!confirm('Supprimer cette habitude et son historique ?')) return;
  const logs = await dbAll('habit_logs');
  for (const l of logs.filter(x => x.habit_id === state.editingHabit.id)) await dbDel('habit_logs', l.key);
