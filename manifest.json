    </div>
  `).join('') || `<p style="text-align:center; color:var(--textSec);">Aucun résultat.</p>`;
}
function newCapQuiz() {
  if (_capMode !== 'quiz') { capMode('quiz'); return; }
  const idx = Math.floor(Math.random()*CAPITALES.length);
  const correct = CAPITALES[idx];
  // 3 wrong options
  const wrong = [];
  while (wrong.length < 3) {
    const w = CAPITALES[Math.floor(Math.random()*CAPITALES.length)];
    if (w[1] !== correct[1] && !wrong.find(x => x[1]===w[1])) wrong.push(w);
  }
  const options = [correct, ...wrong].sort(() => Math.random()-0.5);
  _capQuiz = { country: correct[0], answer: correct[1], options };
  document.getElementById('cap-content').innerHTML = `
    <div style="background:var(--surface); padding:18px; border-radius:14px; text-align:center;">
      <div style="font-size:11px; color:var(--textSec); text-transform:uppercase; letter-spacing:0.5px;">Capitale de</div>
      <div style="font-size:24px; font-weight:800; color:var(--primary); margin:10px 0;">${escapeHtml(correct[0])}</div>
      ${options.map(o => `<button class="btn alt full" style="margin-top:6px;" onclick="capAnswer('${escapeHtml(o[1])}')">${escapeHtml(o[1])}</button>`).join('')}
      <div id="cap-fb" style="margin-top:10px; font-weight:700; min-height:24px;"></div>
    </div>
  `;
}
function capAnswer(a) {
  if (!_capQuiz) return;
  const fb = document.getElementById('cap-fb');
  if (a === _capQuiz.answer) {
    fb.innerHTML = `<span style="color:var(--success);">✅ Bravo !</span>`;
    setTimeout(newCapQuiz, 1000);
  } else {
    fb.innerHTML = `<span style="color:var(--danger);">❌ C'était : ${_capQuiz.answer}</span>`;
    setTimeout(newCapQuiz, 1500);
  }
}

