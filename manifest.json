// ============================================================
let _icFile = null, _icSrcSize = 0;
function icLoad(input) {
  _icFile = (input.files || [])[0];
  document.getElementById('ic-btn').disabled = !_icFile;
  if (_icFile) {
    _icSrcSize = _icFile.size;
    setStatus('ic-status', `📷 ${(_icFile.size/1024).toFixed(1)} Ko`, 'info');
  }
}
function icPreview() {
  const q = document.getElementById('ic-quality').value;
  document.getElementById('ic-quality-label').textContent = q + '%';
}
async function icCompress() {
  if (!_icFile) return;
  const q = parseInt(document.getElementById('ic-quality').value) / 100;
  const maxW = parseInt(document.getElementById('ic-maxw').value) || 0;
  setStatus('ic-status', 'Compression...', 'loading');
  try {
    const img = new Image();
    await new Promise((res, rej) => { img.onload = res; img.onerror = rej; img.src = URL.createObjectURL(_icFile); });
    let w = img.width, h = img.height;
    if (maxW && w > maxW) { h = h * maxW / w; w = maxW; }
    const c = document.createElement('canvas');
    c.width = w; c.height = h;
    const ctx = c.getContext('2d');
    ctx.fillStyle = '#fff'; ctx.fillRect(0,0,w,h);
    ctx.drawImage(img, 0, 0, w, h);
    const blob = await new Promise(r => c.toBlob(r, 'image/jpeg', q));
    dlBlob(blob, `compressed-${Date.now()}.jpg`);
    const ratio = ((1 - blob.size/_icSrcSize) * 100).toFixed(1);
    document.getElementById('ic-result').innerHTML = `
      <div style="background:var(--surface); padding:14px; border-radius:10px;">
        <div>Avant : <strong>${(_icSrcSize/1024).toFixed(1)} Ko</strong></div>
        <div>Après : <strong style="color:var(--success);">${(blob.size/1024).toFixed(1)} Ko</strong></div>
        <div style="font-size:12px; color:var(--textSec); margin-top:6px;">Réduction : <strong>${ratio}%</strong></div>
      </div>
    `;
    setStatus('ic-status', '✅ Téléchargé', 'success');
  } catch (e) {
    console.error(e); setStatus('ic-status', '❌ ' + e.message, 'error');
  }
}

// ============================================================
// CONVERTIR IMAGE
// ============================================================
let _ivFile = null;
function ivLoad(input) {
  _ivFile = (input.files || [])[0];
  document.getElementById('iv-btn').disabled = !_ivFile;
  if (_ivFile) setStatus('iv-status', `📷 ${_ivFile.name}`, 'info');
}
async function ivConvert() {
  if (!_ivFile) return;
  setStatus('iv-status', 'Conversion...', 'loading');
  try {
    const fmt = document.getElementById('iv-format').value;
    const q = parseInt(document.getElementById('iv-quality').value) / 100;
    const img = new Image();
    await new Promise((res, rej) => { img.onload = res; img.onerror = rej; img.src = URL.createObjectURL(_ivFile); });
    const c = document.createElement('canvas');
    c.width = img.width; c.height = img.height;
    const ctx = c.getContext('2d');
    if (fmt === 'image/jpeg') { ctx.fillStyle = '#fff'; ctx.fillRect(0,0,c.width,c.height); }
    ctx.drawImage(img, 0, 0);
    const blob = await new Promise(r => c.toBlob(r, fmt, q));
    const ext = fmt.split('/')[1].replace('jpeg','jpg');
    dlBlob(blob, `convert-${Date.now()}.${ext}`);
    setStatus('iv-status', `✅ Converti en ${ext.toUpperCase()} (${(blob.size/1024).toFixed(1)} Ko)`, 'success');
  } catch (e) {
    console.error(e); setStatus('iv-status', '❌ ' + e.message, 'error');
  }
}

// ============================================================
// REDIMENSIONNER IMAGE
// ============================================================
let _irFile = null, _irRatio = 1;
function irLoad(input) {
  _irFile = (input.files || [])[0];
  document.getElementById('ir-btn').disabled = !_irFile;
  if (!_irFile) return;
  const img = new Image();
  img.onload = () => {
    _irRatio = img.width / img.height;
    document.getElementById('ir-info').textContent = `📐 ${img.width}×${img.height} px (${(_irFile.size/1024).toFixed(1)} Ko)`;
    document.getElementById('ir-w').value = img.width;
    document.getElementById('ir-h').value = img.height;
  };
  img.src = URL.createObjectURL(_irFile);
}
function irLink(changed) {
  if (!document.getElementById('ir-ratio').checked) return;
  if (changed === 'w') {
    const w = parseInt(document.getElementById('ir-w').value);
    if (w) document.getElementById('ir-h').value = Math.round(w / _irRatio);
  } else {
    const h = parseInt(document.getElementById('ir-h').value);
    if (h) document.getElementById('ir-w').value = Math.round(h * _irRatio);
  }
}
async function irResize() {
  if (!_irFile) return;
  const w = parseInt(document.getElementById('ir-w').value);
  const h = parseInt(document.getElementById('ir-h').value);
  if (!w || !h) return setStatus('ir-status', 'Indique largeur et hauteur', 'error');
  const fmt = document.getElementById('ir-format').value;
  setStatus('ir-status', 'Redimensionnement...', 'loading');
  try {
    const img = new Image();
    await new Promise((res, rej) => { img.onload = res; img.onerror = rej; img.src = URL.createObjectURL(_irFile); });
    const c = document.createElement('canvas');
    c.width = w; c.height = h;
    const ctx = c.getContext('2d');
    if (fmt === 'image/jpeg') { ctx.fillStyle = '#fff'; ctx.fillRect(0,0,w,h); }
    ctx.drawImage(img, 0, 0, w, h);
    const blob = await new Promise(r => c.toBlob(r, fmt, 0.92));
    const ext = fmt.split('/')[1].replace('jpeg','jpg');
    dlBlob(blob, `resize-${w}x${h}-${Date.now()}.${ext}`);
    setStatus('ir-status', `✅ ${w}×${h} (${(blob.size/1024).toFixed(1)} Ko)`, 'success');
  } catch (e) {
    console.error(e); setStatus('ir-status', '❌ ' + e.message, 'error');
  }
}

// ============================================================
// OCR (Tesseract)
// ============================================================
let _ocrFile = null;
function ocrLoad(input) {
  _ocrFile = (input.files || [])[0];
  document.getElementById('ocr-btn').disabled = !_ocrFile;
  if (_ocrFile) setStatus('ocr-status', `📷 ${_ocrFile.name}`, 'info');
}
async function ocrRun() {
  if (!_ocrFile) return;
  const lang = document.getElementById('ocr-lang').value;
  setStatus('ocr-status', '⏳ Chargement Tesseract (1ère fois ~3 Mo)...', 'loading');
  document.getElementById('ocr-output').value = '';
  try {
    const Tesseract = await ensureTesseract();
    setStatus('ocr-status', '🔍 Analyse en cours...', 'loading');
    const result = await Tesseract.recognize(_ocrFile, lang, {
      logger: (m) => {
        if (m.status === 'recognizing text') {
          const pct = Math.round(m.progress * 100);
          document.getElementById('ocr-progress').innerHTML = `<div style="background:var(--surfaceAlt); height:6px; border-radius:3px; overflow:hidden;"><div style="background:var(--primary); height:100%; width:${pct}%; transition:width 0.2s;"></div></div><div style="text-align:center; font-size:11px; color:var(--textSec); margin-top:2px;">${pct}%</div>`;
        }
      },
    });
    document.getElementById('ocr-output').value = result.data.text;
    document.getElementById('ocr-progress').innerHTML = '';
    setStatus('ocr-status', `✅ ${result.data.text.length} caractères extraits`, 'success');
  } catch (e) {
    console.error(e); setStatus('ocr-status', '❌ ' + e.message, 'error');
    document.getElementById('ocr-progress').innerHTML = '';
  }
}
function ocrCopy() {
  const v = document.getElementById('ocr-output').value;
  if (!v) return toast('Rien à copier');
  navigator.clipboard.writeText(v).then(() => toast('📋 Copié !'));
}



