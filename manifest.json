// ============================================================
// DATE CALC
// ============================================================
function calcDateDiff() {
  const from = document.getElementById('dc-from').value;
  const to = document.getElementById('dc-to').value;
  if (!from || !to) { alert('Renseigne les 2 dates.'); return; }
  const days = daysBetween(from, to);
  const weeks = Math.floor(Math.abs(days)/7);
  const months = Math.round(Math.abs(days)/30.44);
  const years = (Math.abs(days)/365.25).toFixed(2);
  document.getElementById('dc-diff-result').innerHTML = `
    <div style="background:var(--surfaceAlt); padding:12px; border-radius:12px;">
      <div><strong>${Math.abs(days)} jours</strong> ${days<0?'(dans le passé)':''}</div>
      <div style="color:var(--textSec); font-size:13px; margin-top:4px;">≈ ${weeks} semaines · ${months} mois · ${years} ans</div>
    </div>`;
}

function calcDateAdd() {
  const base = document.getElementById('dc-base').value;
  const add = parseInt(document.getElementById('dc-add').value);
  if (!base || isNaN(add)) { alert('Renseigne la date et le nombre.'); return; }
  const d = new Date(base);
  d.setDate(d.getDate() + add);
  const day = d.toLocaleDateString('fr-FR', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
  document.getElementById('dc-add-result').innerHTML = `
    <div style="background:var(--surfaceAlt); padding:12px; border-radius:12px;">
      <strong>${day}</strong>
    </div>`;
}

// ============================================================
// BIRTHDAYS
// ============================================================
async function renderBdays() {
  const list = await dbAll('bdays');
  const el = document.getElementById('bdays-list');
  el.innerHTML = '';
  if (list.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">🎂</div><h3>Aucun anniversaire</h3><p>Garde une trace des anniversaires importants.</p></div>`;
    return;
  }
  const today = new Date();
  const enriched = list.map(b => {
    const bd = new Date(b.date);
    const next = new Date(today.getFullYear(), bd.getMonth(), bd.getDate());
    if (next < today) next.setFullYear(next.getFullYear()+1);
    const days = daysBetween(today, next);
    const age = today.getFullYear() - bd.getFullYear() + (next > today ? 0 : 0);
    return { ...b, days, age };
  }).sort((a,b)=>a.days-b.days);
  for (const b of enriched) {
    const row = document.createElement('button');
    row.className = 'list-row';
    row.innerHTML = `
      <div style="width:40px; height:40px; border-radius:20px; background:var(--primary); display:flex; align-items:center; justify-content:center; color:white; font-size:18px;">🎂</div>
      <div class="info">
        <div class="name">${escapeHtml(b.name)}</div>
        <div class="sub">${b.days===0?'Aujourd\'hui ! 🎉':b.days+' jour'+(b.days>1?'s':'')} · ${b.age} ans</div>
      </div>
    `;
    row.onclick = () => openBdayModal(b);
    el.appendChild(row);
  }
}

