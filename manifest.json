  {auteur:'Teddy Roosevelt', cat:'Action', txt:'Fais ce que tu peux, avec ce que tu as, là où tu es.'},
  {auteur:'Confucius', cat:'Sagesse', txt:'Peu importe que tu avances lentement, tant que tu n\'arrêtes pas.'},
  {auteur:'Floyd Mayweather', cat:'Argent', txt:'Le travail dur est sans talent ce que les diamants sont sans poussière. Inutile.'},
  {auteur:'Cristiano Ronaldo', cat:'Sport', txt:'Le talent sans travail acharné, c\'est rien.'},
  {auteur:'Goku (en mode joke)', cat:'Anime', txt:'Plus fort. Toujours plus fort. Le power-up ne s\'arrête jamais.'}
];
function mentorNew() {
  const today = todayKey();
  const seed = parseInt(today.replace(/-/g,'')) + Math.floor(Math.random() * 1000);
  const m = MENTORS[seed % MENTORS.length];
  document.getElementById('mentor-content').innerHTML = `<div style="background:linear-gradient(135deg, #FF4757, #1A1A1A); color:white; padding:30px 18px; border-radius:24px; text-align:center; min-height:50vh; display:flex; flex-direction:column; align-items:center; justify-content:center;">
    <div style="font-size:60px;">🎯</div>
    <div style="font-size:11px; opacity:0.7; margin-top:14px; text-transform:uppercase; letter-spacing:3px;">${escapeHtml(m.cat)}</div>
    <div style="font-size:18px; font-weight:600; line-height:1.5; margin-top:18px; font-style:italic;">« ${escapeHtml(m.txt)} »</div>
    <div style="font-size:14px; font-weight:700; margin-top:18px; color:#FFD700;">— ${escapeHtml(m.auteur)}</div>
  </div>
  <button class="btn primary full" onclick="mentorNew()" style="margin-top:14px;">↻ Un autre</button>
  <button class="btn alt full" onclick="mentorShare(${seed % MENTORS.length})" style="margin-top:6px;">📤 Partager</button>`;
}
function mentorShare(idx) {
  const m = MENTORS[idx];
  const txt = `« ${m.txt} »\n— ${m.auteur}`;
  if (navigator.share) navigator.share({ text: txt }).catch(() => {});
  else { navigator.clipboard?.writeText(txt); toast('📋 Copié'); }
}

// === SIDE PROJECTS ===
function getProjects() { try { return JSON.parse(localStorage.getItem('nw_projects') || '[]'); } catch { return []; } }
function saveProjects(d) { localStorage.setItem('nw_projects', JSON.stringify(d)); }
function projAdd() {
  const name = prompt('Nom du projet ?');
  if (!name) return;
  const desc = prompt('Description courte ?') || '';
  const projs = getProjects();
  projs.unshift({ id:'p_'+Date.now(), name, desc, status:'idea', tasks:[], created:Date.now() });
  saveProjects(projs);
  renderProjects();
}
function renderProjects() {
  const projs = getProjects();
  if (!projs.length) {
    document.getElementById('proj-list').innerHTML = '<p style="text-align:center; color:var(--textSec); padding:30px;">Aucun projet. Tap + pour démarrer.</p>';
    return;
  }
  const STATUS = {
    idea: {emoji:'💡', name:'Idée', color:'#FFD166'},
    active: {emoji:'🚀', name:'En cours', color:'#5DD68F'},
    pause: {emoji:'⏸', name:'En pause', color:'#A78BFA'},
    done: {emoji:'✅', name:'Terminé', color:'#5DADE2'},
    drop: {emoji:'❌', name:'Abandonné', color:'#888'}
  };
  document.getElementById('proj-list').innerHTML = projs.map(p => {
    const s = STATUS[p.status] || STATUS.idea;
    const tasksDone = (p.tasks || []).filter(t => t.done).length;
    return `<div style="background:var(--surface); padding:14px; border-radius:14px; margin-bottom:8px; border-left:4px solid ${s.color};">
      <div style="display:flex; justify-content:space-between; align-items:flex-start;">
        <div style="flex:1;">
          <div style="font-size:14px; font-weight:700;">${s.emoji} ${escapeHtml(p.name)}</div>
          ${p.desc ? `<div style="font-size:11px; color:var(--textSec); margin-top:2px; line-height:1.4;">${escapeHtml(p.desc)}</div>` : ''}
          <div style="font-size:10px; color:var(--primary); margin-top:6px;">${s.name}${p.tasks?.length ? ` · ${tasksDone}/${p.tasks.length} tâches` : ''}</div>
        </div>
      </div>
      <div style="display:flex; gap:4px; flex-wrap:wrap; margin-top:8px;">
        <button class="btn alt" onclick="projChangeStatus('${p.id}')" style="font-size:10px; padding:3px 8px;">↻ Statut</button>
        <button class="btn alt" onclick="projAddTask('${p.id}')" style="font-size:10px; padding:3px 8px;">+ Tâche</button>
        <button class="btn alt" onclick="projViewTasks('${p.id}')" style="font-size:10px; padding:3px 8px;">📋 Voir</button>
        <button class="btn alt" onclick="projDel('${p.id}')" style="font-size:10px; padding:3px 8px; color:var(--danger);">🗑</button>
      </div>
    </div>`;
  }).join('');
}
function projChangeStatus(id) {
  const projs = getProjects();
  const p = projs.find(x => x.id === id); if (!p) return;
  const order = ['idea','active','pause','done','drop'];
  const cur = order.indexOf(p.status);
  p.status = order[(cur + 1) % order.length];
  saveProjects(projs);
  renderProjects();
}
function projAddTask(id) {
  const text = prompt('Tâche à ajouter ?');
  if (!text) return;
  const projs = getProjects();
  const p = projs.find(x => x.id === id); if (!p) return;
  if (!p.tasks) p.tasks = [];
  p.tasks.push({ id:'t_'+Date.now(), text, done:false });
  saveProjects(projs);
  renderProjects();
}
function projViewTasks(id) {
  const projs = getProjects();
  const p = projs.find(x => x.id === id); if (!p) return;
  if (!p.tasks?.length) return toast('Pas de tâches');
  let txt = `📋 ${p.name}\n\n`;
  p.tasks.forEach((t, i) => txt += `${t.done ? '✅' : '⬜'} ${t.text}\n`);
  txt += '\nTap OK pour continuer';
  alert(txt);
  // Toggle via prompt
  const toggle = prompt('Numéro de tâche à toggle (1-' + p.tasks.length + ') ou Annuler :');
  const idx = parseInt(toggle) - 1;
  if (idx >= 0 && idx < p.tasks.length) {
    p.tasks[idx].done = !p.tasks[idx].done;
    saveProjects(projs);
    renderProjects();
  }
}
function projDel(id) {
  if (!confirm('Supprimer ce projet ?')) return;
  saveProjects(getProjects().filter(p => p.id !== id));
  renderProjects();
}

