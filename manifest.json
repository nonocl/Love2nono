}

function peDelOverlay() {
  if (!_pe.selectedOverlay) return;
  peSnapshot();
  _pe.overlays = _pe.overlays.filter(o => o !== _pe.selectedOverlay);
  _pe.selectedOverlay = null;
  peRedraw();
  if (_pe.tool === 'text') peRenderText();
  else if (_pe.tool === 'sticker') peRenderStickers();
}

// Drag overlays
function peSetupOverlayInteract() {
  const ovl = _pe.overlayCanvas;
  // Cleanup previous
  if (ovl._oiStart) {
    ovl.removeEventListener('mousedown', ovl._oiStart);
    ovl.removeEventListener('mousemove', ovl._oiMove);
    ovl.removeEventListener('mouseup', ovl._oiEnd);
    ovl.removeEventListener('touchstart', ovl._oiStart);
    ovl.removeEventListener('touchmove', ovl._oiMove);
    ovl.removeEventListener('touchend', ovl._oiEnd);
  }
  let dragging = false;
  let dragOff = { x:0, y:0 };
  const start = (e) => {
    if (_pe.tool !== 'text' && _pe.tool !== 'sticker') return;
    e.preventDefault();
    const { x, y } = peXY(e);
    // Hit test (last drawn = top)
    let hit = null;
    for (let i=_pe.overlays.length-1; i>=0; i--) {
      const o = _pe.overlays[i];
      if (o.type === 'text') {
        const ctx = _pe.overlayCanvas.getContext('2d');
        ctx.font = `${o.bold ? 'bold ' : ''}${o.italic ? 'italic ' : ''}${o.size}px ${o.font}`;
        const m = ctx.measureText(o.text);
        if (x >= o.x - 4 && x <= o.x + m.width + 4 && y >= o.y - o.size && y <= o.y + 8) {
          hit = o; break;
        }
      } else if (o.type === 'sticker') {
        const half = o.size / 2;
        if (x >= o.x - half && x <= o.x + half && y >= o.y - half && y <= o.y + half) {
          hit = o; break;
        }
      }
    }
    if (hit) {
      _pe.selectedOverlay = hit;
      dragging = true;
      dragOff = { x: x - hit.x, y: y - hit.y };
      peRedraw();
      if (_pe.tool === 'text') peRenderText();
      else peRenderStickers();
    } else {
      _pe.selectedOverlay = null;
      peRedraw();
    }
  };
  const move = (e) => {
    if (!dragging || !_pe.selectedOverlay) return;
    e.preventDefault();
    const { x, y } = peXY(e);
    _pe.selectedOverlay.x = x - dragOff.x;
    _pe.selectedOverlay.y = y - dragOff.y;
    peRedraw();
  };
  const end = () => { dragging = false; };
  ovl._oiStart = start; ovl._oiMove = move; ovl._oiEnd = end;
  ovl.addEventListener('mousedown', start);
  ovl.addEventListener('mousemove', move);
  ovl.addEventListener('mouseup', end);
  ovl.addEventListener('touchstart', start, { passive:false });
  ovl.addEventListener('touchmove', move, { passive:false });
  ovl.addEventListener('touchend', end);
}

// === ANNOTATION (dessin libre) ===
function peRenderAnno() {
  const panel = document.getElementById('pe-panel');
  panel.innerHTML = `
    <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-bottom:8px;">Dessiner / annoter</h3>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px;">
      <div>
        <span style="font-size:11px; color:var(--textSec);">Couleur</span>
        <input type="color" id="pe-anno-color" value="#FF6FA3" style="width:100%; height:36px; border:none; border-radius:8px;">
      </div>
      <div>
        <span style="font-size:11px; color:var(--textSec);">Outil</span>
        <select class="input" id="pe-anno-tool" style="padding:8px;">
          <option value="pen">✏️ Stylo</option>
          <option value="marker">🖊️ Surligneur</option>
          <option value="arrow">➤ Flèche</option>
          <option value="rect">▢ Rectangle</option>
          <option value="circle">○ Cercle</option>
        </select>
      </div>
    </div>
    <div style="font-size:11px; color:var(--textSec); margin-top:6px;">Épaisseur <span id="pe-anno-size-v">5</span>px</div>
    <input type="range" id="pe-anno-size" min="1" max="30" value="5" oninput="document.getElementById('pe-anno-size-v').textContent=this.value;" style="width:100%;">
    <p style="font-size:11px; color:var(--textSec); margin-top:8px;">Dessine directement sur la photo.</p>
  `;
  peSetupAnnoDraw();
}

function peSetupAnnoDraw() {
  const ovl = _pe.overlayCanvas;
  let drawing = false, sx = 0, sy = 0, snap = null;
  const start = (e) => {
    if (_pe.tool !== 'anno') return;
    e.preventDefault();
    peSnapshot();
    drawing = true;
    const p = peXY(e);
    sx = p.x; sy = p.y;
    _pe.lastX = p.x; _pe.lastY = p.y;
    const t = document.getElementById('pe-anno-tool').value;
    if (t !== 'pen' && t !== 'marker') {
      snap = _pe.baseCanvas.toDataURL();
    } else {
      // Pen draws directly
      peDrawAnnoPoint(p.x, p.y);
    }
  };
  const move = (e) => {
    if (!drawing || _pe.tool !== 'anno') return;
    e.preventDefault();
    const p = peXY(e);
    const t = document.getElementById('pe-anno-tool').value;
    if (t === 'pen' || t === 'marker') {
      peDrawAnnoSegment(_pe.lastX, _pe.lastY, p.x, p.y);
      _pe.lastX = p.x; _pe.lastY = p.y;
    } else {
      // Restore snap then draw shape
      const img = new Image();
      img.onload = () => {
        const ctx = _pe.baseCanvas.getContext('2d');
        ctx.clearRect(0,0,_pe.W,_pe.H);
        ctx.drawImage(img, 0, 0);
        peDrawAnnoShape(t, sx, sy, p.x, p.y);
        peRedraw();
      };
      img.src = snap;
    }
  };
  const end = () => { drawing = false; };
  ovl._anStart = start; ovl._anMove = move; ovl._anEnd = end;
  ovl.addEventListener('mousedown', start);
  ovl.addEventListener('mousemove', move);
  ovl.addEventListener('mouseup', end);
  ovl.addEventListener('touchstart', start, { passive:false });
  ovl.addEventListener('touchmove', move, { passive:false });
  ovl.addEventListener('touchend', end);
}

function peDrawAnnoPoint(x, y) {
  const ctx = _pe.baseCanvas.getContext('2d');
  const t = document.getElementById('pe-anno-tool').value;
  const color = document.getElementById('pe-anno-color').value;
  const size = parseInt(document.getElementById('pe-anno-size').value);
  ctx.globalAlpha = t === 'marker' ? 0.4 : 1;
  ctx.fillStyle = color;
  ctx.beginPath();
  ctx.arc(x, y, size, 0, Math.PI*2);
  ctx.fill();
  ctx.globalAlpha = 1;
  peRedraw();
}
function peDrawAnnoSegment(x1, y1, x2, y2) {
  const ctx = _pe.baseCanvas.getContext('2d');
  const t = document.getElementById('pe-anno-tool').value;
  const color = document.getElementById('pe-anno-color').value;
  const size = parseInt(document.getElementById('pe-anno-size').value);
  ctx.globalAlpha = t === 'marker' ? 0.4 : 1;
  ctx.strokeStyle = color;
  ctx.lineWidth = size * 2;
  ctx.lineCap = 'round';
  ctx.lineJoin = 'round';
  ctx.beginPath();
  ctx.moveTo(x1, y1);
  ctx.lineTo(x2, y2);
  ctx.stroke();
  ctx.globalAlpha = 1;
  peRedraw();
}
function peDrawAnnoShape(tool, x1, y1, x2, y2) {
  const ctx = _pe.baseCanvas.getContext('2d');
  const color = document.getElementById('pe-anno-color').value;
  const size = parseInt(document.getElementById('pe-anno-size').value);
  ctx.strokeStyle = color;
  ctx.fillStyle = color;
  ctx.lineWidth = size * 2;
  ctx.lineCap = 'round';
  if (tool === 'rect') {
    ctx.strokeRect(x1, y1, x2-x1, y2-y1);
  } else if (tool === 'circle') {
    const cx = (x1+x2)/2, cy = (y1+y2)/2;
    const rx = Math.abs(x2-x1)/2, ry = Math.abs(y2-y1)/2;
    ctx.beginPath();
    ctx.ellipse(cx, cy, rx, ry, 0, 0, Math.PI*2);
    ctx.stroke();
  } else if (tool === 'arrow') {
    ctx.beginPath();
    ctx.moveTo(x1, y1);
    ctx.lineTo(x2, y2);
    ctx.stroke();
    // Arrow head
    const angle = Math.atan2(y2-y1, x2-x1);
    const ah = size * 4;
    ctx.beginPath();
    ctx.moveTo(x2, y2);
    ctx.lineTo(x2 - ah*Math.cos(angle - Math.PI/6), y2 - ah*Math.sin(angle - Math.PI/6));
    ctx.lineTo(x2 - ah*Math.cos(angle + Math.PI/6), y2 - ah*Math.sin(angle + Math.PI/6));
    ctx.closePath();
    ctx.fill();
  }
}

// === CROP ===
let _peCrop = null;
function peRenderCrop() {
  const panel = document.getElementById('pe-panel');
  panel.innerHTML = `
    <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-bottom:8px;">Recadrer</h3>
    <p style="font-size:11px; color:var(--textSec); margin-bottom:6px;">Glisse sur l'image pour définir la zone à garder.</p>
    <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:4px;">
      <button class="btn alt" onclick="peCropPreset(1,1)" style="padding:6px; font-size:10px;">1:1</button>
      <button class="btn alt" onclick="peCropPreset(4,5)" style="padding:6px; font-size:10px;">4:5</button>
      <button class="btn alt" onclick="peCropPreset(9,16)" style="padding:6px; font-size:10px;">9:16</button>
      <button class="btn alt" onclick="peCropPreset(16,9)" style="padding:6px; font-size:10px;">16:9</button>
    </div>
    <button class="btn primary full" onclick="peCropApply()" style="margin-top:8px;">✓ Appliquer le crop</button>
  `;
  _peCrop = { x: _pe.W*0.1, y: _pe.H*0.1, w: _pe.W*0.8, h: _pe.H*0.8 };
  peDrawCropOverlay();
  peSetupCropDrag();
}

function peCropPreset(rw, rh) {
  const ratio = rw / rh;
  let w = _pe.W * 0.8, h = w / ratio;
  if (h > _pe.H * 0.8) { h = _pe.H * 0.8; w = h * ratio; }
  _peCrop = { x: (_pe.W - w)/2, y: (_pe.H - h)/2, w, h };
  peDrawCropOverlay();
}

function peDrawCropOverlay() {
  if (!_peCrop) return;
  const ctx = _pe.overlayCanvas.getContext('2d');
  ctx.clearRect(0, 0, _pe.W, _pe.H);
  ctx.fillStyle = 'rgba(0,0,0,0.6)';
  ctx.fillRect(0, 0, _pe.W, _pe.H);
  ctx.clearRect(_peCrop.x, _peCrop.y, _peCrop.w, _peCrop.h);
  ctx.strokeStyle = '#FF6FA3';
  ctx.lineWidth = 2;
  ctx.strokeRect(_peCrop.x, _peCrop.y, _peCrop.w, _peCrop.h);
}

function peSetupCropDrag() {
  const ovl = _pe.overlayCanvas;
  let dragging = false, off = {x:0, y:0};
  const start = (e) => {
    if (_pe.tool !== 'crop') return;
    e.preventDefault();
    const { x, y } = peXY(e);
    if (x >= _peCrop.x && x <= _peCrop.x + _peCrop.w && y >= _peCrop.y && y <= _peCrop.y + _peCrop.h) {
      dragging = true;
      off = { x: x - _peCrop.x, y: y - _peCrop.y };
    } else {
      // Resize from corner
      _peCrop = { x, y, w: 100, h: 100 };
      peDrawCropOverlay();
    }
  };
  const move = (e) => {
    if (!dragging || _pe.tool !== 'crop') return;
    e.preventDefault();
    const { x, y } = peXY(e);
    _peCrop.x = Math.max(0, Math.min(_pe.W - _peCrop.w, x - off.x));
    _peCrop.y = Math.max(0, Math.min(_pe.H - _peCrop.h, y - off.y));
    peDrawCropOverlay();
  };
  const end = () => { dragging = false; };
  ovl._cStart = start; ovl._cMove = move; ovl._cEnd = end;
  ovl.addEventListener('mousedown', start);
  ovl.addEventListener('mousemove', move);
  ovl.addEventListener('mouseup', end);
  ovl.addEventListener('touchstart', start, { passive:false });
  ovl.addEventListener('touchmove', move, { passive:false });
  ovl.addEventListener('touchend', end);
}

function peCropApply() {
  if (!_peCrop) return;
  peSnapshot();
  // Compose all (base + filter + overlays) into a final canvas, then crop
  const final = peComposeFinal();
  const cropped = document.createElement('canvas');
  cropped.width = _peCrop.w; cropped.height = _peCrop.h;
  cropped.getContext('2d').drawImage(final, _peCrop.x, _peCrop.y, _peCrop.w, _peCrop.h, 0, 0, _peCrop.w, _peCrop.h);
  // Replace base with cropped
  _pe.W = _peCrop.w; _pe.H = _peCrop.h;
  _pe.workCanvas.width = _pe.W; _pe.workCanvas.height = _pe.H;
  _pe.overlayCanvas.width = _pe.W; _pe.overlayCanvas.height = _pe.H;
  const newBase = document.createElement('canvas');
  newBase.width = _pe.W; newBase.height = _pe.H;
  newBase.getContext('2d').drawImage(cropped, 0, 0);
  _pe.baseCanvas = newBase;
  // Reset filters and overlays (déjà bake)
  _pe.filter = { brightness:100, contrast:100, saturate:100, blur:0, hue:0, sepia:0, grayscale:0 };
  _pe.cssFilter = '';
  _pe.overlays = [];
  _peCrop = null;
  peRedraw();
  peTool('filter');
  toast('✂️ Recadré');
}

// === XY helper ===
function peXY(e) {
  const c = _pe.overlayCanvas;
  const rect = c.getBoundingClientRect();
  const t = e.touches ? e.touches[0] : e;
  return {
    x: (t.clientX - rect.left) * _pe.W / rect.width,
    y: (t.clientY - rect.top) * _pe.H / rect.height,
  };
}

// === COMPOSE FINAL ===
function peComposeFinal() {
  const out = document.createElement('canvas');
  out.width = _pe.W; out.height = _pe.H;
  const ctx = out.getContext('2d');
  ctx.filter = _pe.cssFilter || 'none';
  ctx.drawImage(_pe.baseCanvas, 0, 0);
  ctx.filter = 'none';
  // Re-render overlays without selection box
  const tmpSel = _pe.selectedOverlay;
  _pe.selectedOverlay = null;
  for (const o of _pe.overlays) {
    if (o.type === 'text') {
      ctx.font = `${o.bold ? 'bold ' : ''}${o.italic ? 'italic ' : ''}${o.size}px ${o.font}`;
      if (o.outline) {
        ctx.strokeStyle = o.outline;
        ctx.lineWidth = Math.max(2, o.size / 16);
        ctx.strokeText(o.text, o.x, o.y);
      }
      ctx.fillStyle = o.color;
      ctx.fillText(o.text, o.x, o.y);
    } else if (o.type === 'sticker') {
      ctx.font = `${o.size}px sans-serif`;
      ctx.textBaseline = 'middle';
      ctx.textAlign = 'center';
      ctx.fillText(o.emoji, o.x, o.y);
      ctx.textBaseline = 'alphabetic';
      ctx.textAlign = 'start';
    }
  }
  _pe.selectedOverlay = tmpSel;
  return out;
}

// === EXPORT ===
function peExport() {
  if (!_pe.baseCanvas) return toast('Charge une photo d\'abord');
  const final = peComposeFinal();
  final.toBlob(b => {
    const a = document.createElement('a');
    a.href = URL.createObjectURL(b);
    a.download = `photo-edit-${Date.now()}.png`;
    a.click();
    toast('📥 Exporté !');
  }, 'image/png');
}

// ============================================================
// PODOMÈTRE
// ============================================================
const PEDO_DEFAULT_GOAL = 10000;

function getPedoData() {
  try { return JSON.parse(localStorage.getItem('nw_pedo') || '{}'); } catch { return {}; }
}
function savePedoData(d) { localStorage.setItem('nw_pedo', JSON.stringify(d)); }
function getPedoGoal() {
  return parseInt(localStorage.getItem('nw_pedo_goal') || PEDO_DEFAULT_GOAL);
}
function todayKey() { return new Date().toISOString().slice(0,10); }

function pedoToday() {
  const d = getPedoData();
  return d[todayKey()] || 0;
}
function pedoSetToday(v) {
  const d = getPedoData();
  d[todayKey()] = Math.max(0, v);
  savePedoData(d);
  renderPedo();
}

function pedoAddManual() {
  const v = parseInt(document.getElementById('pedo-add-input').value);
  if (!v || v <= 0) return toast('Tape un nombre positif');
  pedoSetToday(pedoToday() + v);
  document.getElementById('pedo-add-input').value = '';
  toast(`+${v} pas ajoutés`);
}
function pedoQuickAdd(n) {
  pedoSetToday(pedoToday() + n);
  toast(`+${n} pas`);
}
function pedoSetTotal() {
  const v = prompt('Nouveau total exact pour aujourd\'hui ?', pedoToday());
  if (v === null) return;
  const n = parseInt(v);
  if (isNaN(n) || n < 0) return toast('Nombre invalide');
  pedoSetToday(n);
  toast('Total mis à jour');
}

function pedoMenu() {
  const choice = prompt('1: Changer objectif quotidien\n2: Effacer aujourd\'hui\n3: Effacer tout l\'historique\n\nTape le numéro :');
  if (choice === '1') {
    const g = prompt('Nouvel objectif (pas/jour) ?', getPedoGoal());
    const n = parseInt(g);
    if (n > 0) { localStorage.setItem('nw_pedo_goal', n); renderPedo(); toast('🎯 Objectif : ' + n); }
  } else if (choice === '2') {
    if (confirm('Effacer les pas d\'aujourd\'hui ?')) pedoSetToday(0);
  } else if (choice === '3') {
    if (confirm('⚠️ Effacer TOUT l\'historique ?')) {
      localStorage.removeItem('nw_pedo');
      renderPedo();
    }
  }
}

// === Auto tracker via accéléromètre ===
let _pedoMotion = null;
let _pedoLastStep = 0;
let _pedoLastMag = 0;
let _pedoSession = 0;
let _pedoSessionStart = 0;
let _pedoListener = null;

function pedoStart() {
  // iOS permission
  const start = () => {
    _pedoSession = 0;
    _pedoSessionStart = Date.now();
    _pedoLastStep = 0;
    _pedoLastMag = 0;
    document.getElementById('pedo-start').style.display = 'none';
    document.getElementById('pedo-stop').style.display = '';
    document.getElementById('pedo-status').innerHTML = '🟢 <strong>Tracker actif</strong> - garde l\'app ouverte et le téléphone dans ta poche';
    _pedoListener = (e) => {
      const acc = e.accelerationIncludingGravity;
      if (!acc) return;
      const mag = Math.sqrt(acc.x*acc.x + acc.y*acc.y + acc.z*acc.z);
      const now = Date.now();
      // Détection pic + minimum interval 300ms
      if (mag > 13 && _pedoLastMag <= 13 && now - _pedoLastStep > 300) {
        _pedoSession++;
        _pedoLastStep = now;
        pedoSetToday(pedoToday() + 1);
        const live = document.getElementById('pedo-live');
        const dur = Math.floor((now - _pedoSessionStart) / 1000);
        const min = Math.floor(dur / 60), sec = dur % 60;
        const cadence = dur > 0 ? Math.round(_pedoSession * 60 / dur) : 0;
        live.innerHTML = `<div style="background:var(--surface); padding:12px; border-radius:10px; text-align:center;">
          <div style="font-size:11px; color:var(--textSec);">Session</div>
          <div style="font-size:32px; font-weight:900; color:var(--primary);">${_pedoSession} <span style="font-size:14px; font-weight:600;">pas</span></div>
          <div style="font-size:12px; color:var(--textSec); margin-top:4px;">${min}:${String(sec).padStart(2,'0')} · ${cadence} pas/min</div>
        </div>`;
      }
      _pedoLastMag = mag;
    };
    window.addEventListener('devicemotion', _pedoListener);
    _pedoMotion = true;
  };
  if (typeof DeviceMotionEvent !== 'undefined' && typeof DeviceMotionEvent.requestPermission === 'function') {
    DeviceMotionEvent.requestPermission().then(s => {
      if (s === 'granted') start();
      else toast('❌ Permission refusée');
    }).catch(() => toast('❌ Erreur permission'));
  } else if (window.DeviceMotionEvent) {
    start();
  } else {
    toast('❌ Accéléromètre non supporté sur ce navigateur');
  }
}

function pedoStop() {
  if (_pedoListener) {
    window.removeEventListener('devicemotion', _pedoListener);
    _pedoListener = null;
  }
  _pedoMotion = false;
  document.getElementById('pedo-start').style.display = '';
  document.getElementById('pedo-stop').style.display = 'none';
  const dur = _pedoSessionStart ? Math.floor((Date.now() - _pedoSessionStart) / 1000) : 0;
  document.getElementById('pedo-status').innerHTML = `⏸ Arrêté · Session : ${_pedoSession} pas en ${Math.floor(dur/60)}min`;
}

function renderPedo() {
  const today = pedoToday();
  const goal = getPedoGoal();
  document.getElementById('pedo-today-count').textContent = today.toLocaleString('fr-FR');
  document.getElementById('pedo-goal-val').textContent = goal.toLocaleString('fr-FR') + ' pas';
  const pct = Math.min(100, today / goal * 100);
  document.getElementById('pedo-progress').style.width = pct + '%';
  document.getElementById('pedo-progress-pct').textContent = pct.toFixed(0) + '%';
  // Estimations
  const km = (today * 0.0008).toFixed(2);
  const kcal = Math.round(today * 0.04);
  const min = Math.round(today / 100);
  document.getElementById('pedo-today-info').textContent = `≈ ${km} km · ${kcal} kcal · ${min} min de marche`;
  // Week stats
  renderPedoWeek();
  renderPedoHistory();
}

function renderPedoWeek() {
  const data = getPedoData();
  const days = ['Dim','Lun','Mar','Mer','Jeu','Ven','Sam'];
  let html = '<div style="display:flex; gap:4px; align-items:flex-end; height:80px;">';
  const today = new Date();
  const goal = getPedoGoal();
  let total = 0, count = 0;
  for (let i=6; i>=0; i--) {
    const d = new Date(today);
    d.setDate(d.getDate() - i);
    const k = d.toISOString().slice(0,10);
    const val = data[k] || 0;
    total += val;
    if (val > 0) count++;
    const pct = Math.min(100, val / goal * 100);
    const isToday = i === 0;
    html += `<div style="flex:1; display:flex; flex-direction:column; align-items:center; gap:2px;">
      <div style="font-size:10px; color:var(--textSec);">${val > 999 ? (val/1000).toFixed(1)+'k' : val}</div>
      <div style="width:100%; background:var(--surfaceAlt); border-radius:4px; flex:1; display:flex; align-items:flex-end; height:40px;">
        <div style="width:100%; background:${isToday ? 'linear-gradient(180deg, var(--primary), var(--accent))' : 'var(--primary)'}; height:${pct}%; border-radius:4px;"></div>
      </div>
      <div style="font-size:10px; ${isToday ? 'color:var(--primary); font-weight:700' : 'color:var(--textSec)'};">${days[d.getDay()]}</div>
    </div>`;
  }
  html += '</div>';
  const avg = count ? Math.round(total / 7) : 0;
  html += `<div style="text-align:center; font-size:11px; color:var(--textSec); margin-top:8px;">Total : <strong>${total.toLocaleString('fr-FR')}</strong> pas · Moyenne : <strong>${avg.toLocaleString('fr-FR')}</strong>/jour</div>`;
  document.getElementById('pedo-week').innerHTML = html;
}

function renderPedoHistory() {
  const data = getPedoData();
  const entries = Object.entries(data).sort((a,b) => b[0].localeCompare(a[0])).slice(0, 30);
  if (!entries.length) {
    document.getElementById('pedo-history').innerHTML = '<p style="color:var(--textSec); text-align:center; font-size:12px; padding:20px;">Pas d\'historique</p>';
    return;
  }
  const goal = getPedoGoal();
  document.getElementById('pedo-history').innerHTML = entries.map(([d, v]) => {
    const date = new Date(d);
    const dateStr = date.toLocaleDateString('fr-FR', { weekday:'short', day:'numeric', month:'short' });
    const reached = v >= goal;
    return `<div style="display:flex; gap:12px; align-items:center; padding:8px 12px; background:var(--surface); border-radius:8px; margin-bottom:4px;">
      <div style="flex:1;">
        <div style="font-weight:600; font-size:13px;">${dateStr}</div>
        <div style="font-size:11px; color:var(--textSec);">${reached ? '🎯 Objectif atteint !' : `${Math.round(v/goal*100)}% de l'objectif`}</div>
      </div>
      <div style="font-weight:800; color:${reached ? 'var(--success)' : 'var(--text)'};">${v.toLocaleString('fr-FR')}</div>
    </div>`;
  }).join('');
}




