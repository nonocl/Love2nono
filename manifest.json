      if (allPage) {
        const sections = allPage.querySelectorAll('.home-section');
        let found = null;
        sections.forEach(s => {
          const title = s.querySelector('.home-section-title');
          if (title && title.textContent.toLowerCase().includes(cat.toLowerCase())) found = s;
        });
        if (found) found.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
  }, 200);
}

// === SEARCH OVERLAY ===
function v56_openSearch() {
  let ov = document.getElementById('v56-search-overlay');
  if (!ov) {
    ov = document.createElement('div');
    ov.id = 'v56-search-overlay';
    ov.className = 'v56-search-overlay';
    ov.innerHTML = `
      <div class="v56-search-input-wrap">
        <input type="text" id="v56-search-input" placeholder="Cherche dans 460+ outils..." autocomplete="off" autocorrect="off" spellcheck="false">
        <button class="v56-search-close" onclick="v56_closeSearch()">×</button>
      </div>
      <div class="v56-search-chips" id="v56-search-chips"></div>
      <div class="v56-search-results" id="v56-search-results"></div>
    `;
    document.body.appendChild(ov);
  }
  ov.classList.add('active');
  // Quick chips
  const chips = ['Todo','Pomodoro','Math','Anglais','Wordle','Méditation','Couleurs','Recettes','Citation','Devoirs'];
  document.getElementById('v56-search-chips').innerHTML = chips.map(c => `<button class="v56-search-chip" onclick="v56_searchInput('${escapeJs(c)}')">${escapeHtml(c)}</button>`).join('');
  // Show recents on open
  v56_searchRender('');
  setTimeout(() => document.getElementById('v56-search-input').focus(), 100);
  document.getElementById('v56-search-input').oninput = (e) => v56_searchRender(e.target.value);
}

function v56_closeSearch() {
  const ov = document.getElementById('v56-search-overlay');
  if (ov) ov.classList.remove('active');
}

function v56_searchInput(q) {
  document.getElementById('v56-search-input').value = q;
  v56_searchRender(q);
}

function v56_searchRender(q) {
  const list = document.getElementById('v56-search-results');
  if (!list) return;
  let pageIdx = [];
  try { pageIdx = (typeof PAGE_INDEX !== 'undefined' && PAGE_INDEX) ? PAGE_INDEX : []; } catch {}
  let recent = [];
  try { recent = JSON.parse(localStorage.getItem('nw_recent') || '[]'); } catch {}
  let results;
  if (!q.trim()) {
    // Show recent + popular
    const recItems = recent.map(p => pageIdx.find(x => x.page === p)).filter(Boolean).slice(0, 8);
    if (recItems.length === 0) {
      results = pageIdx.slice(0, 12);
      list.innerHTML = `<div style="padding:14px; font-size:11px; font-weight:700; color:var(--textSec); text-transform:uppercase; letter-spacing:1px;">Suggestions</div>` + results.map(v56_resultRow).join('');
    } else {
      list.innerHTML = `<div style="padding:14px; font-size:11px; font-weight:700; color:var(--textSec); text-transform:uppercase; letter-spacing:1px;">Récents</div>` + recItems.map(v56_resultRow).join('');
    }
    return;
  }
  const ql = q.toLowerCase();
  results = pageIdx.filter(p => {
    const haystack = `${p.name} ${p.cat} ${p.kw || ''}`.toLowerCase();
    return haystack.includes(ql);
  }).slice(0, 30);
  if (results.length === 0) {
    list.innerHTML = `<div style="padding:30px; text-align:center; color:var(--textSec);"><div style="font-size:36px; margin-bottom:8px;">🔍</div>Aucun résultat pour "${escapeHtml(q)}"</div>`;
    return;
  }
  list.innerHTML = `<div style="padding:14px; font-size:11px; font-weight:700; color:var(--textSec); text-transform:uppercase; letter-spacing:1px;">${results.length} résultat${results.length>1?'s':''}</div>` + results.map(v56_resultRow).join('');
}

function v56_resultRow(p) {
  return `<div class="v56-search-result" onclick="v56_goSearch('${escapeJs(p.page)}')">
    <div class="v56-search-result-ico">${p.ico}</div>
    <div class="v56-search-result-info">
      <div class="v56-search-result-name">${escapeHtml(p.name)}</div>
      <div class="v56-search-result-cat">${escapeHtml(p.cat)}</div>
    </div>
    <div class="v56-search-result-arrow">›</div>
  </div>`;
}

function v56_goSearch(page) {
  v56_closeSearch();
  // Handle watch_X redirection
  if (page.startsWith('watch_')) {
    window._curWatchType = page.slice(6);
    goTo('watch');
  } else {
    goTo(page);
  }
  // Save in recents
  try {
    let recent = JSON.parse(localStorage.getItem('nw_recent') || '[]');
    recent = [page, ...recent.filter(x => x !== page)].slice(0, 30);
    localStorage.setItem('nw_recent', JSON.stringify(recent));
  } catch {}
}

// === HOOK PAGE CHANGES ===
(function v56_hookNav() {
  // Patch goTo if exists to update bottom nav
  if (typeof window.goTo === 'function' && !window._v56HookDone) {
    window._v56HookDone = true;
    const origGoTo = window.goTo;
    const _v56args = [];
    window.goTo = function() {
      const args = arguments;
      const r = origGoTo.apply(this, args);
      setTimeout(() => {
        try {
          if (typeof v56_updateActiveNav === 'function') v56_updateActiveNav();
          const arg0 = args[0];
          if (arg0 && arg0 !== 'home' && arg0 !== 'all' && arg0 !== 'recent') {
            let recent = JSON.parse(localStorage.getItem('nw_recent') || '[]');
            recent = [arg0, ...recent.filter(x => x !== arg0)].slice(0, 30);
            localStorage.setItem('nw_recent', JSON.stringify(recent));
          }
        } catch(e) { console.warn('v56 hook err', e); }
      }, 50);
      return r;
    };
  }
})();

