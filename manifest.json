// === MOOD TRACKER ===
const EMO_LEVELS = ['😢','😞','😐','🙂','😊','😄','🤩','🥰'];
const EMO_LABELS = ['Très triste','Triste','Neutre','Bien','Heureuse','Très heureuse','Excitée','Amoureuse'];
function getMoods() { try { return JSON.parse(localStorage.getItem('nw_moods') || '{}'); } catch { return {}; } }
function saveMoods(d) { localStorage.setItem('nw_moods', JSON.stringify(d)); }
function moodSet(level) {
  const moods = getMoods();
  const today = todayKey();
  if (!moods[today]) moods[today] = {};
  moods[today].level = level;
  moods[today].time = Date.now();
  saveMoods(moods);
  toast(`Humeur sauvée : ${EMO_LEVELS[level]}`);
  renderEmotion();
}
function moodNote(text) {
  const moods = getMoods();
  const today = todayKey();
  if (!moods[today]) moods[today] = {};
  moods[today].note = text;
  saveMoods(moods);
}
function renderEmotion() {
  const moods = getMoods();
  const today = todayKey();
  const todayMood = moods[today] || {};
  
  let html = `<div style="background:linear-gradient(135deg, #FF9A8B, #FF6A88, #FF99AC); color:white; padding:18px; border-radius:18px; text-align:center;">
    <div style="font-size:14px; opacity:0.9;">Comment tu te sens aujourd'hui ?</div>
    <div style="display:flex; justify-content:space-between; margin-top:14px;">`;
  EMO_LEVELS.forEach((em, i) => {
    const sel = todayMood.level === i;
    html += `<button onclick="moodSet(${i})" style="background:${sel ? 'rgba(255,255,255,0.4)' : 'rgba(255,255,255,0.15)'}; border:${sel ? '2px solid white' : 'none'}; border-radius:50%; width:40px; height:40px; font-size:22px; cursor:pointer;">${em}</button>`;
  });
  html += `</div>${todayMood.level !== undefined ? `<div style="font-size:13px; margin-top:10px; font-weight:700;">${EMO_LABELS[todayMood.level]}</div>` : ''}</div>`;
  
  // Note du jour
  html += `<h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-top:18px;">📝 Note du jour</h3>
    <textarea id="emotion-note" class="input" rows="3" placeholder="Qu'est-ce qui s'est passé aujourd'hui..." onblur="moodNote(this.value)">${escapeHtml(todayMood.note || '')}</textarea>`;
  
  // Historique 7 jours
  html += `<h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-top:18px;">📊 7 derniers jours</h3>
    <div style="display:grid; grid-template-columns:repeat(7,1fr); gap:4px; margin-top:8px;">`;
  for (let i = 6; i >= 0; i--) {
    const d = new Date(); d.setDate(d.getDate() - i);
    const k = d.toISOString().slice(0,10);
    const m = moods[k];
    const dayName = d.toLocaleDateString('fr-FR', {weekday:'short'}).slice(0,3);
    html += `<div style="background:var(--surface); padding:8px 4px; border-radius:8px; text-align:center;">
      <div style="font-size:9px; color:var(--textSec);">${dayName}</div>
      <div style="font-size:24px;">${m?.level !== undefined ? EMO_LEVELS[m.level] : '·'}</div>
    </div>`;
  }
  html += `</div>`;
  
  // Stats mois
  const monthMoods = Object.entries(moods).filter(([k]) => k.startsWith(today.slice(0,7)));
  if (monthMoods.length) {
    const avg = monthMoods.reduce((s, [_, v]) => s + (v.level || 0), 0) / monthMoods.length;
    html += `<div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:14px; text-align:center;">
      <div style="font-size:11px; color:var(--textSec);">Humeur moyenne ce mois</div>
      <div style="font-size:36px; margin-top:4px;">${EMO_LEVELS[Math.round(avg)]}</div>
      <div style="font-size:11px; color:var(--textSec);">${monthMoods.length} jours loggés</div>
    </div>`;
  }
  
  document.getElementById('emotion-content').innerHTML = html;
}

// === OUTFIT BUILDER ===
function getOutfits() { try { return JSON.parse(localStorage.getItem('nw_outfits') || '[]'); } catch { return []; } }
function saveOutfits(d) { localStorage.setItem('nw_outfits', JSON.stringify(d)); }

let _outfitCurrent = { haut:null, bas:null, chaussure:null, acc:null };

async function renderOutfit() {
  const items = (await dbAll('wardrobe')) || [];
  const slots = ['haut','bas','chaussure','acc'];
  const slotNames = {haut:'👕 Haut', bas:'👖 Bas', chaussure:'👟 Chaussures', acc:'👜 Accessoires'};
  
  let html = '';
  slots.forEach(slot => {
    const cur = _outfitCurrent[slot] ? items.find(i => i.id === _outfitCurrent[slot]) : null;
    const choices = items.filter(i => i.cat === slot);
    html += `<div style="background:var(--surface); padding:10px; border-radius:12px; margin-bottom:8px;">
      <div style="font-size:13px; font-weight:700; margin-bottom:6px;">${slotNames[slot]}</div>
      ${cur ? `<div style="display:flex; gap:10px; align-items:center;">
        ${cur.photo ? `<img src="${cur.photo}" style="width:60px; height:60px; object-fit:cover; border-radius:8px;">` : `<div style="width:60px; height:60px; background:var(--surfaceAlt); border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:24px;">${WARD_CATS.find(c=>c.id===cur.cat)?.emoji || '👕'}</div>`}
        <div style="flex:1; font-size:12px;">${escapeHtml(cur.name)}</div>
        <button onclick="outfitClear('${slot}')" style="background:none; border:none; color:var(--danger); font-size:18px;">✗</button>
      </div>` : ''}
      <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:4px; margin-top:6px; max-height:160px; overflow-y:auto;">
        ${choices.map(c => `<div onclick="outfitPick('${slot}', ${c.id})" style="cursor:pointer; aspect-ratio:1; border-radius:8px; overflow:hidden; ${_outfitCurrent[slot] === c.id ? 'border:3px solid var(--primary);' : 'border:1px solid var(--border);'}">
          ${c.photo ? `<img src="${c.photo}" style="width:100%; height:100%; object-fit:cover;">` : `<div style="width:100%; height:100%; background:var(--surfaceAlt); display:flex; align-items:center; justify-content:center; font-size:20px;">${WARD_CATS.find(x=>x.id===c.cat)?.emoji || '👕'}</div>`}
        </div>`).join('') || '<div style="grid-column:1/-1; text-align:center; padding:10px; color:var(--textSec); font-size:11px;">Pas d\'élément. Ajoute dans Garde-robe.</div>'}
      </div>
    </div>`;
  });
  document.getElementById('outfit-builder').innerHTML = html;
  
  // History
  const hist = getOutfits();
  if (hist.length) {
    document.getElementById('outfit-history').innerHTML = hist.slice(0, 10).map(o => 
      `<div style="background:var(--surface); padding:10px; border-radius:10px; margin-bottom:6px;">
        <div style="font-size:11px; color:var(--textSec);">${new Date(o.date).toLocaleDateString('fr-FR')}${o.label ? ' · '+escapeHtml(o.label) : ''}</div>
        <div style="display:flex; gap:6px; margin-top:6px; overflow-x:auto;">
          ${(o.items || []).map(id => {
            const item = items.find(i => i.id === id);
            if (!item) return '';
            return item.photo ? `<img src="${item.photo}" style="width:50px; height:50px; object-fit:cover; border-radius:6px; flex-shrink:0;">` : '';
          }).join('')}
        </div>
        <div style="display:flex; gap:4px; margin-top:6px;">
          <button class="btn alt" onclick="outfitLoad('${o.id}')" style="font-size:10px; padding:4px 10px;">↻ Recharger</button>
          <button class="btn alt" onclick="outfitDel('${o.id}')" style="font-size:10px; padding:4px 10px; color:var(--danger);">🗑</button>
        </div>
      </div>`
    ).join('');
  } else {
    document.getElementById('outfit-history').innerHTML = '<p style="text-align:center; color:var(--textSec); font-size:11px; padding:14px;">Aucune tenue sauvée encore.</p>';
  }
}
function outfitPick(slot, id) {
  _outfitCurrent[slot] = _outfitCurrent[slot] === id ? null : id;
  renderOutfit();
}
function outfitClear(slot) { _outfitCurrent[slot] = null; renderOutfit(); }
function outfitSave() {
  const items = Object.values(_outfitCurrent).filter(Boolean);
  if (!items.length) return toast('Sélectionne au moins une pièce');
  const label = prompt('Nom de la tenue (optionnel) :', '') || '';
  const hist = getOutfits();
  hist.unshift({ id:'o_'+Date.now(), date:Date.now(), items, label });
  saveOutfits(hist);
  toast('🪞 Tenue sauvée !');
  renderOutfit();
}
function outfitLoad(id) {
  const o = getOutfits().find(x => x.id === id); if (!o) return;
  _outfitCurrent = { haut:null, bas:null, chaussure:null, acc:null };
  o.items.forEach(itemId => {
    // On doit retrouver le slot via le cat de l'item
    dbAll('wardrobe').then(all => {
      const it = all.find(x => x.id === itemId);
      if (it && _outfitCurrent.hasOwnProperty(it.cat)) _outfitCurrent[it.cat] = itemId;
      renderOutfit();
    });
  });
}
function outfitDel(id) {
  if (!confirm('Supprimer ?')) return;
  saveOutfits(getOutfits().filter(o => o.id !== id));
  renderOutfit();
}

// === SOIRÉE PLANNER ===
function getSoirees() { try { return JSON.parse(localStorage.getItem('nw_soirees') || '[]'); } catch { return []; } }
function saveSoirees(d) { localStorage.setItem('nw_soirees', JSON.stringify(d)); }
function renderSoirees() {
  const d = getSoirees();
  if (!d.length) {
    document.getElementById('soiree-list').innerHTML = '<p style="text-align:center; color:var(--textSec); padding:30px;">Pas encore de soirée. Tap + pour planifier.</p>';
    return;
  }
  document.getElementById('soiree-list').innerHTML = d.sort((a,b) => (a.date || '').localeCompare(b.date || '')).map(s => {
    const dt = s.date ? new Date(s.date) : null;
    const isPast = dt && dt < new Date();
    return `<div onclick="soireeOpen('${s.id}')" style="background:var(--surface); padding:14px; border-radius:14px; margin-bottom:8px; cursor:pointer; ${isPast ? 'opacity:0.6;' : ''}">
      <div style="font-size:15px; font-weight:700;">🎉 ${escapeHtml(s.title || 'Sans titre')}</div>
      ${dt ? `<div style="font-size:11px; color:var(--primary); margin-top:2px;">📅 ${dt.toLocaleDateString('fr-FR', {weekday:'long', day:'numeric', month:'long'})}</div>` : ''}
      ${s.location ? `<div style="font-size:11px; color:var(--textSec); margin-top:2px;">📍 ${escapeHtml(s.location)}</div>` : ''}
      <div style="font-size:10px; color:var(--textSec); margin-top:6px;">${(s.guests || []).length} invités · ${(s.checklist || []).filter(c=>c.done).length}/${(s.checklist || []).length} tâches</div>
    </div>`;
  }).join('');
}
function soireeNew() {
  const id = 's_' + Date.now();
  const s = { id, title:'', date:'', location:'', dress:'', budget:0, guests:[], checklist:[], playlist:[], notes:'' };
  const d = getSoirees(); d.push(s); saveSoirees(d);
  soireeOpen(id);
}
let _curSoiree = null;
function soireeOpen(id) {
  _curSoiree = id;
  goTo('soiree-edit');
}
function renderSoireeEdit() {
  const s = getSoirees().find(x => x.id === _curSoiree);
  if (!s) { goTo('soiree'); return; }
  const html = `<input type="text" class="input" value="${escapeHtml(s.title || '')}" placeholder="🎉 Titre soirée" onchange="soireeUpdate('title', this.value)">
    <span class="label">Date</span>
    <input type="datetime-local" class="input" value="${s.date || ''}" onchange="soireeUpdate('date', this.value)">
    <span class="label">Lieu</span>
    <input type="text" class="input" value="${escapeHtml(s.location || '')}" placeholder="📍" onchange="soireeUpdate('location', this.value)">
    <span class="label">Code vestimentaire / tenue prévue</span>
    <input type="text" class="input" value="${escapeHtml(s.dress || '')}" placeholder="👗" onchange="soireeUpdate('dress', this.value)">
    <span class="label">Budget</span>
    <input type="number" class="input" value="${s.budget || 0}" placeholder="€" onchange="soireeUpdate('budget', parseFloat(this.value) || 0)">
    
    <h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-top:18px;">👥 Invités (${(s.guests || []).length})</h3>
    <div style="display:flex; gap:6px;">
      <input type="text" id="soiree-guest" class="input" placeholder="Nom" onkeypress="if(event.key==='Enter')soireeAddGuest()">
      <button class="btn primary" onclick="soireeAddGuest()" style="padding:8px 14px;">+</button>
    </div>
    <div style="margin-top:8px;">${(s.guests || []).map((g, i) => `<div style="background:var(--surface); padding:8px 12px; border-radius:8px; margin-bottom:4px; display:flex; justify-content:space-between; align-items:center;"><span>${escapeHtml(g)}</span><button onclick="soireeDelGuest(${i})" style="background:none; border:none; color:var(--danger);">✗</button></div>`).join('')}</div>
    
    <h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-top:18px;">✅ Checklist</h3>
    <div style="display:flex; gap:6px;">
      <input type="text" id="soiree-task" class="input" placeholder="Tâche" onkeypress="if(event.key==='Enter')soireeAddTask()">
      <button class="btn primary" onclick="soireeAddTask()" style="padding:8px 14px;">+</button>
    </div>
    <div style="margin-top:8px;">${(s.checklist || []).map((c, i) => `<div onclick="soireeToggleTask(${i})" style="background:var(--surface); padding:8px 12px; border-radius:8px; margin-bottom:4px; display:flex; gap:8px; align-items:center; cursor:pointer; ${c.done ? 'opacity:0.5;' : ''}">
      <div style="width:18px; height:18px; border-radius:4px; background:${c.done ? 'var(--success)' : 'transparent'}; border:2px solid ${c.done ? 'var(--success)' : 'var(--border)'}; color:white; font-size:12px; display:flex; align-items:center; justify-content:center;">${c.done ? '✓' : ''}</div>
      <span style="${c.done ? 'text-decoration:line-through;' : ''}">${escapeHtml(c.text)}</span>
    </div>`).join('')}</div>
    
    <span class="label">Notes</span>
    <textarea class="input" rows="3" onchange="soireeUpdate('notes', this.value)">${escapeHtml(s.notes || '')}</textarea>
    
    <button class="btn alt full" onclick="soireeDel()" style="margin-top:14px; color:var(--danger);">🗑 Supprimer cette soirée</button>`;
  document.getElementById('soiree-edit-content').innerHTML = html;
}
function soireeUpdate(field, val) {
  const d = getSoirees();
  const s = d.find(x => x.id === _curSoiree);
  if (!s) return;
  s[field] = val;
  saveSoirees(d);
}
function soireeAddGuest() {
  const inp = document.getElementById('soiree-guest');
  const v = inp.value.trim(); if (!v) return;
  const d = getSoirees();
  const s = d.find(x => x.id === _curSoiree); if (!s) return;
  s.guests = s.guests || []; s.guests.push(v);
  saveSoirees(d); inp.value = ''; renderSoireeEdit();
}
function soireeDelGuest(i) {
  const d = getSoirees(); const s = d.find(x => x.id === _curSoiree);
  s.guests.splice(i, 1); saveSoirees(d); renderSoireeEdit();
}
function soireeAddTask() {
  const inp = document.getElementById('soiree-task');
  const v = inp.value.trim(); if (!v) return;
  const d = getSoirees(); const s = d.find(x => x.id === _curSoiree);
  s.checklist = s.checklist || []; s.checklist.push({ text:v, done:false });
  saveSoirees(d); inp.value = ''; renderSoireeEdit();
}
function soireeToggleTask(i) {
  const d = getSoirees(); const s = d.find(x => x.id === _curSoiree);
  s.checklist[i].done = !s.checklist[i].done;
  saveSoirees(d); renderSoireeEdit();
}
function soireeDel() {
  if (!confirm('Supprimer cette soirée ?')) return;
  saveSoirees(getSoirees().filter(s => s.id !== _curSoiree));
  goTo('soiree');
}



