// === 23. BILAN HEBDOMADAIRE ===
function getWeeklyReviews() { try { return JSON.parse(localStorage.getItem('nw_weekly_reviews') || '[]'); } catch { return []; } }
function saveWeeklyReviews(r) { localStorage.setItem('nw_weekly_reviews', JSON.stringify(r)); }
function renderWeeklyReview() {
  const reviews = getWeeklyReviews();
  // ID semaine
  function getWeekId(d = new Date()) {
    const onejan = new Date(d.getFullYear(), 0, 1);
    const week = Math.ceil((((d - onejan) / 86400000) + onejan.getDay() + 1) / 7);
    return d.getFullYear() + '-W' + String(week).padStart(2, '0');
  }
  const thisWeek = getWeekId();
  const cur = reviews.find(r => r.week === thisWeek);
  let html = `<div style="background:linear-gradient(135deg,#FFD166,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">📊</div><div style="font-size:16px; font-weight:800;">Bilan hebdomadaire</div>
    <div style="font-size:11px; opacity:0.9;">Semaine ${thisWeek} · ${reviews.length} bilans archivés</div>
  </div>
  <div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:14px;">
    <h3 style="font-size:13px; font-weight:700; color:#5DD68F;">✅ Ce qui a bien marché</h3>
    <textarea id="wr-good" class="input" rows="3" placeholder="Mes wins de la semaine..." style="margin-top:6px;">${cur ? escapeHtml(cur.good) : ''}</textarea>
    <h3 style="font-size:13px; font-weight:700; color:#FF8C42; margin-top:10px;">🤔 Ce qui était difficile</h3>
    <textarea id="wr-hard" class="input" rows="3" placeholder="Les galères..." style="margin-top:6px;">${cur ? escapeHtml(cur.hard) : ''}</textarea>
    <h3 style="font-size:13px; font-weight:700; color:#FF6FA3; margin-top:10px;">💡 Ce que j'ai appris</h3>
    <textarea id="wr-learn" class="input" rows="3" placeholder="Mes apprentissages..." style="margin-top:6px;">${cur ? escapeHtml(cur.learn) : ''}</textarea>
    <h3 style="font-size:13px; font-weight:700; color:#5DADE2; margin-top:10px;">🎯 Objectifs semaine prochaine</h3>
    <textarea id="wr-goals" class="input" rows="3" placeholder="Ce que je veux faire..." style="margin-top:6px;">${cur ? escapeHtml(cur.goals) : ''}</textarea>
    <button class="btn primary full" onclick="wrSave()" style="margin-top:10px;">💾 Sauver</button>
  </div>`;
  if (reviews.length > 0) {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📚 Historique</h3>`;
    reviews.slice().reverse().forEach(r => {
      html += `<details style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px;">
        <summary style="cursor:pointer; font-size:13px; font-weight:700;">${r.week}</summary>
        <div style="margin-top:10px; padding-top:10px; border-top:1px solid var(--border); font-size:12px; line-height:1.6;">
          <div style="color:#5DD68F;"><strong>✅ Wins :</strong> ${escapeHtml(r.good)}</div>
          <div style="color:#FF8C42; margin-top:6px;"><strong>🤔 Difficile :</strong> ${escapeHtml(r.hard)}</div>
          <div style="color:#FF6FA3; margin-top:6px;"><strong>💡 Appris :</strong> ${escapeHtml(r.learn)}</div>
          <div style="color:#5DADE2; margin-top:6px;"><strong>🎯 Objectifs :</strong> ${escapeHtml(r.goals)}</div>
        </div>
      </details>`;
    });
  }
  document.getElementById('weeklyreview-content').innerHTML = html;
}
function wrSave() {
  function getWeekId(d = new Date()) {
    const onejan = new Date(d.getFullYear(), 0, 1);
    const week = Math.ceil((((d - onejan) / 86400000) + onejan.getDay() + 1) / 7);
    return d.getFullYear() + '-W' + String(week).padStart(2, '0');
  }
  const thisWeek = getWeekId();
  const reviews = getWeeklyReviews().filter(r => r.week !== thisWeek);
  reviews.push({
    week: thisWeek,
    good: document.getElementById('wr-good').value.trim(),
    hard: document.getElementById('wr-hard').value.trim(),
    learn: document.getElementById('wr-learn').value.trim(),
    goals: document.getElementById('wr-goals').value.trim()
  });
  saveWeeklyReviews(reviews);
  toast('💾 Sauvé');
  renderWeeklyReview();
}

// === 24. BUCKET LIST VOYAGE ===
function getBucketList() { try { return JSON.parse(localStorage.getItem('nw_bucket') || '[]'); } catch { return []; } }
function saveBucketList(b) { localStorage.setItem('nw_bucket', JSON.stringify(b)); }
function renderBucket() {
  const b = getBucketList();
  const visited = b.filter(x => x.visited).length;
  let html = `<div style="background:linear-gradient(135deg,#5DADE2,#FF6FA3); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">✈️</div><div style="font-size:16px; font-weight:800;">Bucket list voyage</div>
    <div style="font-size:11px; opacity:0.9;">${visited} / ${b.length} destinations visitées</div>
  </div>
  <div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:14px;">
    <input type="text" id="bk-place" class="input" placeholder="Destination (ex: Tokyo, Japon)" autocomplete="off">
    <textarea id="bk-note" class="input" rows="2" placeholder="Pourquoi tu veux y aller..." style="margin-top:6px;"></textarea>
    <button class="btn primary full" onclick="bkAdd()" style="margin-top:6px;">➕ Ajouter</button>
  </div>`;
  if (b.length === 0) html += `<p style="text-align:center; color:var(--textSec); font-size:11px; margin-top:14px;">Ajoute ta première destination !</p>`;
  b.forEach((x, i) => {
    html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:6px; ${x.visited?'opacity:0.6;':''}">
      <div style="display:flex; justify-content:space-between; align-items:flex-start;">
        <div style="flex:1;">
          <div style="font-size:14px; font-weight:700;">${x.visited?'✅':'📍'} ${escapeHtml(x.place)}</div>
          ${x.note ? `<div style="font-size:11px; color:var(--textSec); margin-top:4px;">${escapeHtml(x.note)}</div>` : ''}
        </div>
        <div style="display:flex; gap:4px;">
          <button onclick="bkVisit(${i})" style="background:none; border:none; color:${x.visited?'#FFD166':'#5DD68F'}; font-size:14px;">${x.visited?'↩️':'✓'}</button>
          <button onclick="bkDel(${i})" style="background:none; border:none; color:var(--danger);">✗</button>
        </div>
      </div>
    </div>`;
  });
  document.getElementById('bucket-content').innerHTML = html;
}
function bkAdd() {
  const place = document.getElementById('bk-place').value.trim();
  const note = document.getElementById('bk-note').value.trim();
  if (!place) return;
  const b = getBucketList();
  b.push({ place: place.slice(0, 60), note: note.slice(0, 200), visited: false });
  saveBucketList(b);
  document.getElementById('bk-place').value = ''; document.getElementById('bk-note').value = '';
  renderBucket();
}
function bkVisit(i) { const b = getBucketList(); b[i].visited = !b[i].visited; saveBucketList(b); renderBucket(); }
function bkDel(i) { if (!confirm('Supprimer ?')) return; const b = getBucketList(); b.splice(i,1); saveBucketList(b); renderBucket(); }

