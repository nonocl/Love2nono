const v51_CONV_UNITS = {
  'Longueur': { mm:1, cm:10, dm:100, m:1000, km:1000000, in:25.4, ft:304.8, yd:914.4, mi:1609344 },
  'Masse': { mg:1, g:1000, kg:1000000, T:1000000000, oz:28349.5, lb:453592 },
  'Volume': { ml:1, cl:10, dl:100, L:1000, m3:1000000, 'fl oz':29.5735, gal:3785.41 },
  'Température': { '°C':1, '°F':1, K:1 }, // special case
  'Vitesse': { 'm/s':1, 'km/h':0.277778, mph:0.44704, knots:0.514444 },
  'Temps': { sec:1, min:60, h:3600, jour:86400, sem:604800, mois:2628000, an:31536000 }
};
function renderUnitConv() {
  let html = `<div style="background:linear-gradient(135deg,#06FFA5,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">📐</div><div style="font-size:16px; font-weight:800;">Convertisseur unités</div>
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">Catégorie</h3>
  <select id="uc-cat" class="input" onchange="ucCatChange()" style="margin-top:6px;">${Object.keys(v51_CONV_UNITS).map(c=>`<option>${c}</option>`).join('')}</select>
  <div id="uc-fields" style="margin-top:14px;"></div>`;
  document.getElementById('unitconv-content').innerHTML = html;
  ucCatChange();
}
function ucCatChange() {
  const cat = document.getElementById('uc-cat').value;
  const units = Object.keys(v51_CONV_UNITS[cat]);
  const html = `<div style="background:var(--surface); padding:14px; border-radius:12px;">
    <input type="number" id="uc-val" class="input" placeholder="Valeur" oninput="ucCalc()" inputmode="decimal">
    <select id="uc-from" class="input" onchange="ucCalc()" style="margin-top:6px;">${units.map(u=>`<option>${u}</option>`).join('')}</select>
    <div style="text-align:center; font-size:18px; margin:8px 0; color:var(--primary);">↓</div>
    <select id="uc-to" class="input" onchange="ucCalc()" style="margin-top:0;">${units.map((u,i)=>`<option ${i===1?'selected':''}>${u}</option>`).join('')}</select>
    <div id="uc-r" style="font-size:24px; font-weight:900; text-align:center; color:var(--primary); margin-top:10px;">—</div>
  </div>`;
  document.getElementById('uc-fields').innerHTML = html;
}
function ucCalc() {
  const cat = document.getElementById('uc-cat').value;
  const val = parseFloat(document.getElementById('uc-val').value);
  const from = document.getElementById('uc-from').value;
  const to = document.getElementById('uc-to').value;
  if (isNaN(val)) { document.getElementById('uc-r').textContent = '—'; return; }
  let result;
  if (cat === 'Température') {
    let c;
    if (from === '°C') c = val;
    else if (from === '°F') c = (val - 32) * 5/9;
    else c = val - 273.15;
    if (to === '°C') result = c;
    else if (to === '°F') result = c * 9/5 + 32;
    else result = c + 273.15;
  } else {
    const factors = v51_CONV_UNITS[cat];
    result = val * factors[from] / factors[to];
  }
  document.getElementById('uc-r').textContent = result.toFixed(4).replace(/\.?0+$/, '') + ' ' + to;
}

// === 27. CALCULATRICE SCIENTIFIQUE ===
let _calcDisplay = '0', _calcMemory = 0;
function renderSciCalc() {
  let html = `<div style="background:linear-gradient(135deg,#000,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🧮</div><div style="font-size:16px; font-weight:800;">Calculatrice scientifique</div>
  </div>
  <div id="calc-display" style="background:var(--surface); padding:18px; border-radius:12px; margin-top:14px; text-align:right; font-family:monospace; font-size:28px; font-weight:900; word-break:break-all; min-height:50px;">${_calcDisplay}</div>
  <div style="display:grid; grid-template-columns:repeat(5,1fr); gap:4px; margin-top:8px;">`;
  const buttons = [
    ['sin','cos','tan','π','C'],
    ['asin','acos','atan','e','⌫'],
    ['(',')','^','√','÷'],
    ['7','8','9','log','×'],
    ['4','5','6','ln','−'],
    ['1','2','3','%','+'],
    ['±','0','.','=','=']
  ];
  buttons.forEach(row => {
    row.forEach(b => {
      const isOp = ['÷','×','−','+','='].includes(b);
      const isSpec = ['C','⌫'].includes(b);
      const isFn = ['sin','cos','tan','asin','acos','atan','log','ln','π','e','^','√','%','±','(',')'].includes(b);
      const cls = isOp ? 'primary' : (isSpec ? 'alt' : (isFn ? 'alt' : 'alt'));
      const fontSize = isFn ? '11px' : '14px';
      html += `<button class="btn ${cls}" onclick="calcBtn('${b}')" style="padding:14px 0; font-size:${fontSize};">${b}</button>`;
    });
  });
  html += `</div>`;
  document.getElementById('scicalc-content').innerHTML = html;
}
function calcBtn(b) {
  const d = document.getElementById('calc-display');
  let cur = _calcDisplay;
  if (b === 'C') { _calcDisplay = '0'; }
  else if (b === '⌫') { _calcDisplay = cur.length > 1 ? cur.slice(0, -1) : '0'; }
  else if (b === '=') {
    try {
      let expr = cur.replace(/×/g,'*').replace(/÷/g,'/').replace(/−/g,'-').replace(/π/g,'Math.PI').replace(/√/g,'Math.sqrt')
        .replace(/sin\(/g,'Math.sin(').replace(/cos\(/g,'Math.cos(').replace(/tan\(/g,'Math.tan(')
        .replace(/asin\(/g,'Math.asin(').replace(/acos\(/g,'Math.acos(').replace(/atan\(/g,'Math.atan(')
        .replace(/log\(/g,'Math.log10(').replace(/ln\(/g,'Math.log(')
        .replace(/e/g,'Math.E').replace(/\^/g,'**');
      const r = Function('"use strict"; return (' + expr + ')')();
      _calcDisplay = String(r).slice(0, 20);
    } catch { _calcDisplay = 'Erreur'; }
  }
  else if (b === '±') { _calcDisplay = cur.startsWith('-') ? cur.slice(1) : '-' + cur; }
  else if (['sin','cos','tan','asin','acos','atan','log','ln','√'].includes(b)) {
    if (cur === '0') _calcDisplay = b + '(';
    else _calcDisplay = cur + b + '(';
  }
  else {
    if (cur === '0' && /[0-9.πe]/.test(b)) _calcDisplay = b;
    else _calcDisplay = cur + b;
  }
  d.textContent = _calcDisplay;
}

