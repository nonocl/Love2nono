  <textarea id="diff-a" class="input" rows="5" placeholder="Premier texte..." oninput="diffCalc()" style="font-family:monospace; font-size:12px;"></textarea>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">📝 Texte B</h3>
  <textarea id="diff-b" class="input" rows="5" placeholder="Deuxième texte..." oninput="diffCalc()" style="font-family:monospace; font-size:12px;"></textarea>
  <div id="diff-result" style="margin-top:14px;"></div>`;
  document.getElementById('diffcheck-content').innerHTML = html;
}
function diffCalc() {
  const a = (document.getElementById('diff-a').value || '').split('\n');
  const b = (document.getElementById('diff-b').value || '').split('\n');
  const max = Math.max(a.length, b.length);
  let html = '<div style="background:var(--surface); padding:10px; border-radius:10px; font-family:monospace; font-size:11px; overflow-x:auto;">';
  let added = 0, removed = 0, same = 0;
  for (let i = 0; i < max; i++) {
    const la = a[i] || '', lb = b[i] || '';
    if (la === lb) { same++; html += `<div style="padding:2px 6px; color:var(--textSec);">  ${escapeHtml(la)}</div>`; }
    else {
      if (la) { removed++; html += `<div style="padding:2px 6px; background:rgba(225,77,107,0.15); color:#E14D6B;">- ${escapeHtml(la)}</div>`; }
      if (lb) { added++; html += `<div style="padding:2px 6px; background:rgba(93,214,143,0.15); color:#5DD68F;">+ ${escapeHtml(lb)}</div>`; }
    }
  }
  html += '</div>';
  html += `<div style="display:grid; grid-template-columns:repeat(3,1fr); gap:6px; margin-top:8px;">
    <div style="background:#5DD68F22; padding:8px; border-radius:8px; text-align:center;"><div style="font-size:18px; font-weight:900; color:#5DD68F;">+${added}</div><div style="font-size:10px;">ajoutées</div></div>
    <div style="background:#E14D6B22; padding:8px; border-radius:8px; text-align:center;"><div style="font-size:18px; font-weight:900; color:#E14D6B;">-${removed}</div><div style="font-size:10px;">retirées</div></div>
    <div style="background:var(--surface); padding:8px; border-radius:8px; text-align:center;"><div style="font-size:18px; font-weight:900;">${same}</div><div style="font-size:10px;">identiques</div></div>
  </div>`;
  document.getElementById('diff-result').innerHTML = html;
}

