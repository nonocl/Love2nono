let _hsTimer = null;
function onHomeSearch(v) {
  clearTimeout(_hsTimer);
  _hsTimer = setTimeout(() => doHomeSearch(v), 150);
}
async function doHomeSearch(v) {
  v = (v || '').trim().toLowerCase();
  const out = document.getElementById('home-search-results');
  if (!v) { out.classList.remove('active'); out.innerHTML = ''; return; }
  // Match dans PAGE_INDEX
  const matches = PAGE_INDEX.filter(p =>
    p.name.toLowerCase().includes(v) ||
    p.cat.toLowerCase().includes(v) ||
    (p.kw && p.kw.toLowerCase().includes(v))
  ).slice(0, 12);
  // Aussi : recherche dans les données utilisateur (notes, todos, etc.)
  let dataMatches = [];
  if (v.length >= 2) {
    try {
      for (const n of (await dbAll('notes')).slice(0, 100)) {
        if ((n.title||'').toLowerCase().includes(v) || (n.content||'').toLowerCase().includes(v)) {
          dataMatches.push({ ico:'📌', name:n.title||'(sans titre)', cat:'Note', action:() => { goTo('notes'); openNote && openNote(n); } });
          if (dataMatches.length >= 5) break;
        }
      }
    } catch {}
    try {
      for (const f of (await dbAll('friends')).slice(0, 50)) {
        if ((f.name||'').toLowerCase().includes(v)) {
          dataMatches.push({ ico:'👥', name:f.name, cat:'Ami', action:() => goTo('friends') });
          if (dataMatches.length >= 10) break;
        }
      }
    } catch {}
    try {
      for (const w of (await dbAll('watchlist')).slice(0, 100)) {
        if ((w.name||'').toLowerCase().includes(v)) {
          dataMatches.push({ ico:'🎬', name:w.name, cat:'Watchlist', action:() => { _curWatchType=w.type; goTo('watch'); } });
          if (dataMatches.length >= 15) break;
        }
      }
    } catch {}
  }

  if (!matches.length && !dataMatches.length) {
    out.innerHTML = '<div style="padding:20px; text-align:center; color:var(--textSec); font-size:13px;">Aucun résultat</div>';
    out.classList.add('active');
    return;
  }
  let html = '';
  for (const m of matches) {
    html += `<div class="home-search-result" onclick="goTo('${m.page.startsWith('watch_') ? 'watch' : m.page}'); ${m.page.startsWith('watch_') ? `_curWatchType='${m.page.slice(6)}';` : ''} clearHomeSearch();"><div class="res-ico">${m.ico}</div><div class="res-info"><div class="res-name">${m.name}</div><div class="res-cat">📍 ${m.cat}</div></div></div>`;
  }
  for (let i=0; i<dataMatches.length; i++) {
    const m = dataMatches[i];
    html += `<div class="home-search-result" onclick="window._hsClick(${i})"><div class="res-ico">${m.ico}</div><div class="res-info"><div class="res-name">${escapeHtml(m.name)}</div><div class="res-cat">📍 ${m.cat}</div></div></div>`;
  }
  window._hsClick = (i) => { dataMatches[i].action(); clearHomeSearch(); };
  out.innerHTML = html;
  out.classList.add('active');
}
function clearHomeSearch() {
  document.getElementById('home-search').value = '';
  document.getElementById('home-search-results').classList.remove('active');
}

// ============================================================
// NAVIGATION SYSTEM
// ============================================================

// === Bottom nav ===
function navTo(p) { goTo(p); }
function navSearch() {
  // Go to "all" page which has the search bar
  goTo('all');
  setTimeout(() => {
    const sb = document.getElementById('home-search');
    if (sb) {
      sb.focus();
      sb.scrollIntoView({behavior:'smooth', block:'start'});
    }
  }, 150);
}
function navFavs() {
  goTo('home');
  setTimeout(() => filterHomeTab('fav'), 100);
}
function updateBottomNav(page) {
  document.querySelectorAll('.bottom-nav-btn').forEach(b => b.classList.remove('active'));
  let active = '';
  if (page === 'recent') active = 'recent';
  else if (page === 'home') active = 'home';
  else if (page === 'all') active = 'all';
  if (active) {
    const btn = document.querySelector(`.bottom-nav-btn[data-nav="${active}"]`);
    if (btn) btn.classList.add('active');
  }
}

// === Filtre onglets accueil ===
let _currentTab = 'all';
function filterHomeTab(tab) {
  _currentTab = tab;
  document.querySelectorAll('.home-tab').forEach(t => t.classList.toggle('active', t.dataset.tab === tab));
  // Map titre section → tab
  document.querySelectorAll('.home-section').forEach(sec => {
    const title = sec.querySelector('.title-txt')?.textContent;
    const isFav = sec.id === 'fav-section';
    if (tab === 'all') {
      sec.style.display = '';
    } else if (tab === 'fav') {
      sec.style.display = isFav && getFavs().length ? '' : 'none';
    } else {
      sec.style.display = title === tab ? '' : 'none';
    }
  });
  // Si onglet vide → message
  if (tab === 'fav' && !getFavs().length) {
    document.getElementById('fav-section').style.display = 'none';
    if (!document.getElementById('empty-fav-msg')) {
      const msg = document.createElement('div');
      msg.id = 'empty-fav-msg';
      msg.style.cssText = 'text-align:center; padding:40px 20px; color:var(--textSec);';
      msg.innerHTML = '<div style="font-size:48px;">⭐</div><p style="margin-top:14px; font-size:14px;">Aucun favori. Long-press sur une tuile pour l\'ajouter !</p>';
      document.querySelector('#page-home').appendChild(msg);
    }
  } else {
    const m = document.getElementById('empty-fav-msg');
    if (m) m.remove();
  }
}

// === Burger menu ===
function openBurger() {
  renderBurgerContent();
  document.getElementById('burger-overlay').classList.add('open');
  document.getElementById('burger-menu').classList.add('open');
}
function closeBurger() {
  document.getElementById('burger-overlay').classList.remove('open');
  document.getElementById('burger-menu').classList.remove('open');
}
function renderBurgerContent() {
  // Group PAGE_INDEX by category
  const byCat = {};
  for (const p of PAGE_INDEX) {
    if (!byCat[p.cat]) byCat[p.cat] = [];
    byCat[p.cat].push(p);
  }
  let html = '';
  // Section Vue d'ensemble
  html += '<div class="burger-section"><div class="burger-section-title">Navigation</div>';
  html += `<div class="burger-item" onclick="goTo('home'); closeBurger();"><span class="b-ico">🏠</span>Accueil</div>`;
  html += `<div class="burger-item" onclick="goTo('recent'); closeBurger();"><span class="b-ico">🕒</span>Récents</div>`;
  html += `<div class="burger-item" onclick="navFavs(); closeBurger();"><span class="b-ico">⭐</span>Favoris</div>`;
  html += '</div>';
  // Sections par catégorie
  for (const [cat, items] of Object.entries(byCat).sort((a,b) => b[1].length - a[1].length)) {
    html += `<div class="burger-section"><div class="burger-section-title">${cat} (${items.length})</div>`;
    for (const it of items) {
      const target = it.page.startsWith('watch_') ? `_curWatchType='${it.page.slice(6)}'; goTo('watch')` : `goTo('${it.page}')`;
      html += `<div class="burger-item" onclick="${target}; closeBurger();"><span class="b-ico">${it.ico}</span>${it.name}</div>`;
    }
    html += '</div>';
  }
  document.getElementById('burger-content').innerHTML = html;
}

// === FAB menu rapide ===
function toggleFabMenu() {
  const m = document.getElementById('fab-menu');
  const f = document.getElementById('fab-quick');
  m.classList.toggle('open');
  f.classList.toggle('spin');
  if (m.classList.contains('open')) {
    setTimeout(() => {
      document.addEventListener('click', _fabOutsideClick, { once:true });
    }, 50);
  }
}
function closeFabMenu() {
  document.getElementById('fab-menu').classList.remove('open');
  document.getElementById('fab-quick').classList.remove('spin');
}
function _fabOutsideClick(e) {
  const m = document.getElementById('fab-menu'), f = document.getElementById('fab-quick');
  if (!m.contains(e.target) && !f.contains(e.target)) closeFabMenu();
  else if (m.classList.contains('open')) document.addEventListener('click', _fabOutsideClick, { once:true });
}

// === Historique récents ===
function getRecents() {
  try { return JSON.parse(localStorage.getItem('nw_recents') || '[]'); } catch { return []; }
}
function pushRecent(page) {
  if (!page || page === 'home' || page === 'recent') return;
  const meta = PAGE_INDEX.find(p => p.page === page);
  if (!meta) return;
  let recents = getRecents();
  // Retire si déjà présent
  recents = recents.filter(r => r.page !== page);
  recents.unshift({ page, name: meta.name, ico: meta.ico, cat: meta.cat, t: Date.now() });
  // Garde les 30 plus récents
  recents = recents.slice(0, 30);
  localStorage.setItem('nw_recents', JSON.stringify(recents));
}
function renderRecents() {
  const list = getRecents();
  const out = document.getElementById('recent-list');
  if (!out) return;
  if (!list.length) {
    out.innerHTML = '<p style="text-align:center; color:var(--textSec); padding:40px 20px;">Aucun écran visité récemment. Tape sur des tuiles depuis l\'accueil pour les voir apparaître ici !</p>';
    return;
  }
  out.innerHTML = list.map(r => {
    const ago = formatTimeAgo(Date.now() - r.t);
    const onclick = r.page.startsWith('watch_') ? `_curWatchType='${r.page.slice(6)}'; goTo('watch')` : `goTo('${r.page}')`;
    return `<div class="recent-item" onclick="${onclick}"><div class="r-ico">${r.ico}</div><div class="r-info"><div class="r-name">${escapeHtml(r.name)}</div><div class="r-time">📍 ${r.cat} · ${ago}</div></div></div>`;
  }).join('');
}
function formatTimeAgo(ms) {
  const sec = Math.floor(ms/1000);
  if (sec < 60) return 'à l\'instant';
  const min = Math.floor(sec/60);
  if (min < 60) return `il y a ${min} min`;
  const h = Math.floor(min/60);
  if (h < 24) return `il y a ${h}h`;
  const d = Math.floor(h/24);
  return `il y a ${d} jour${d>1?'s':''}`;
}
function clearRecents() {
  if (!confirm('Effacer tout l\'historique des écrans récents ?')) return;
  localStorage.removeItem('nw_recents');
  renderRecents();
}

// === Swipe back (depuis bord gauche) ===
let _sbStart = null, _sbProgress = 0;
function setupSwipeBack() {
  document.addEventListener('touchstart', (e) => {
    const t = e.touches[0];
    if (t.clientX < 25 && state.page !== 'home') {
      _sbStart = { x: t.clientX, y: t.clientY, t: Date.now() };
    }
  }, { passive: true });
  document.addEventListener('touchmove', (e) => {
    if (!_sbStart) return;
    const t = e.touches[0];
    const dx = t.clientX - _sbStart.x;
    const dy = Math.abs(t.clientY - _sbStart.y);
    if (dy > 50) { _sbStart = null; document.getElementById('swipe-back-ind').style.transform = 'translateY(-50%) translateX(-100%)'; return; }
    if (dx > 0) {
      _sbProgress = Math.min(dx, 100);
      const ind = document.getElementById('swipe-back-ind');
      ind.style.transform = `translateY(-50%) translateX(${-100 + _sbProgress}%)`;
    }
  }, { passive: true });
  document.addEventListener('touchend', () => {
    if (!_sbStart) return;
    const ind = document.getElementById('swipe-back-ind');
    if (_sbProgress > 60) {
      // Trigger back
      ind.style.transform = 'translateY(-50%) translateX(0)';
      setTimeout(() => {
        ind.style.transform = 'translateY(-50%) translateX(-100%)';
        goBack();
      }, 100);
    } else {
      ind.style.transform = 'translateY(-50%) translateX(-100%)';
    }
    _sbStart = null; _sbProgress = 0;
  }, { passive: true });
}

