// === 18. BIRTHDAY TRACKER ===
function getBirthdays() { try { return JSON.parse(localStorage.getItem('nw_birthdays') || '[]'); } catch { return []; } }
function saveBirthdays(b) { localStorage.setItem('nw_birthdays', JSON.stringify(b)); }
function renderBirthdays() {
  const bdays = getBirthdays();
  // Calcul jours restants
  const today = new Date();
  bdays.forEach(b => {
    const [m, d] = b.date.split('-').map(Number);
    const next = new Date(today.getFullYear(), m-1, d);
    if (next < today) next.setFullYear(today.getFullYear() + 1);
    b.days = Math.ceil((next - today) / 86400000);
  });
  bdays.sort((a, b) => a.days - b.days);
  let html = `<div style="background:linear-gradient(135deg,#FF6FA3,#FFD166); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🎂</div><div style="font-size:16px; font-weight:800;">Anniversaires</div>
    <div style="font-size:11px; opacity:0.9;">${bdays.length} anniversaires suivis</div>
  </div>
  <div style="background:var(--surface); padding:12px; border-radius:12px; margin-top:14px;">
    <input type="text" id="bd-name" class="input" placeholder="Prénom" autocomplete="off">
    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:6px; margin-top:6px;">
      <input type="number" id="bd-d" class="input" placeholder="Jour" min="1" max="31">
      <input type="number" id="bd-m" class="input" placeholder="Mois" min="1" max="12">
      <button class="btn primary" onclick="bdAdd()">➕</button>
    </div>
  </div>`;
  bdays.forEach((b, i) => {
    const isToday = b.days === 0;
    const isSoon = b.days <= 7;
    html += `<div style="background:${isToday?'#FF6FA3':'var(--surface)'}; padding:12px; border-radius:10px; margin-top:6px; ${isToday?'color:white;':''}">
      <div style="display:flex; justify-content:space-between; align-items:center;">
        <div>
          <div style="font-size:14px; font-weight:700;">${isToday?'🎉 ':''}${escapeHtml(b.name)}</div>
          <div style="font-size:11px; ${isToday?'':'color:var(--textSec);'}">${b.date.replace('-','/')}</div>
        </div>
        <div style="font-size:18px; font-weight:900; ${isSoon&&!isToday?'color:#FF8C42;':''}">${isToday?'🎂 AUJ':b.days+'j'}</div>
        <button onclick="bdDel(${i})" style="background:none; border:none; ${isToday?'color:white;':'color:var(--danger);'} margin-left:6px;">✗</button>
      </div>
    </div>`;
  });
  document.getElementById('birthdaysV54-content').innerHTML = html;
}
function bdAdd() {
  const name = document.getElementById('bd-name').value.trim();
  const d = parseInt(document.getElementById('bd-d').value);
  const m = parseInt(document.getElementById('bd-m').value);
  if (!name || !d || !m) return;
  const date = String(m).padStart(2,'0') + '-' + String(d).padStart(2,'0');
  const b = getBirthdays();
  b.push({ name: name.slice(0, 40), date });
  saveBirthdays(b);
  document.getElementById('bd-name').value = ''; document.getElementById('bd-d').value = ''; document.getElementById('bd-m').value = '';
  renderBirthdays();
}
function bdDel(i) { if (!confirm('Supprimer ?')) return; const b = getBirthdays(); b.splice(i,1); saveBirthdays(b); renderBirthdays(); }

