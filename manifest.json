          <div style="display:flex; gap:10px; align-items:center;">
            <span style="font-size:32px;">${v.emoji}</span>
            <div>
              <div style="font-size:14px; font-weight:700;">${escapeHtml(v.word)}</div>
              <div style="font-size:10px; color:var(--textSec);">${date}</div>
            </div>
          </div>
          ${v.song ? `<div style="font-size:11px; color:var(--textSec); margin-top:6px;">🎵 ${escapeHtml(v.song)}</div>` : ''}
          ${v.note ? `<div style="font-size:12px; line-height:1.4; margin-top:6px; font-style:italic;">${escapeHtml(v.note)}</div>` : ''}
        </div>
        <button onclick="vbDel('${v.id}')" style="background:none; border:none; color:var(--danger); font-size:18px;">✗</button>
      </div>
    </div>`;
  });
  document.getElementById('vibes-content').innerHTML = html;
}
function vbAdd() {
  const word = prompt('Un mot qui résume cette vibe :');
  if (!word) return;
  const emoji = prompt('Un emoji :', '✨') || '✨';
  const color = prompt('Une couleur (#FF6FA3 ou nom CSS) :', '#FF6FA3') || '#FF6FA3';
  const song = prompt('Une chanson (optionnel) :') || '';
  const note = prompt('Note libre (optionnel) :') || '';
  const vibes = getVibes();
  vibes.unshift({ id: 'vb_'+Date.now(), word, emoji, color, song, note, created: Date.now() });
  saveVibes(vibes); renderVibes();
}
function vbDel(id) {
  if (!confirm('Supprimer ?')) return;
  saveVibes(getVibes().filter(v => v.id !== id));
  renderVibes();
}

// === 23. DREAM LIFE ===
function getDreamLife() {
  let d;
  try { d = JSON.parse(localStorage.getItem('nw_dreamlife') || 'null'); } catch { d = null; }
  if (!d) d = { career: '', love: '', place: '', health: '', friends: '', creative: '' };
  return d;
}
function saveDreamLife(d) { localStorage.setItem('nw_dreamlife', JSON.stringify(d)); }
function renderDreamLife() {
  const d = getDreamLife();
  const pillars = [
    { key: 'career', emoji: '💼', name: 'Carrière / Études', placeholder: 'Mon métier rêvé, mes études parfaites...' },
    { key: 'love', emoji: '💕', name: 'Amour / Relations', placeholder: 'La personne avec qui je veux vivre...' },
    { key: 'place', emoji: '🏡', name: 'Lieu de vie', placeholder: 'Où je veux vivre, à quoi ressemble ma maison...' },
    { key: 'health', emoji: '💪', name: 'Santé / Corps', placeholder: 'Comment je me sens dans mon corps...' },
    { key: 'friends', emoji: '👯', name: 'Amis / Famille', placeholder: 'Les gens dont je m\'entoure...' },
    { key: 'creative', emoji: '🎨', name: 'Créatif / Loisirs', placeholder: 'Mes passions, mes hobbies idéaux...' }
  ];
  let html = `<div style="background:linear-gradient(135deg,#FF6FA3,#9B59B6,#5DADE2); color:white; padding:14px; border-radius:14px; text-align:center;">
