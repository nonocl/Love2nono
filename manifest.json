// Magic bytes (signatures de fichiers connues)
const FILE_MAGIC = [
  // Images
  { sig: [0xFF, 0xD8, 0xFF], name: 'JPEG image', mime: 'image/jpeg', ext: 'jpg' },
  { sig: [0x89, 0x50, 0x4E, 0x47], name: 'PNG image', mime: 'image/png', ext: 'png' },
  { sig: [0x47, 0x49, 0x46, 0x38], name: 'GIF image', mime: 'image/gif', ext: 'gif' },
  { sig: [0x42, 0x4D], name: 'BMP image', mime: 'image/bmp', ext: 'bmp' },
  { sig: [0x52, 0x49, 0x46, 0x46], name: 'WebP/AVI/WAV', mime: 'multi/RIFF', ext: 'webp/avi/wav' },
  { sig: [0x00, 0x00, 0x01, 0x00], name: 'Icon ICO', mime: 'image/x-icon', ext: 'ico' },
  // Documents
  { sig: [0x25, 0x50, 0x44, 0x46], name: 'PDF document', mime: 'application/pdf', ext: 'pdf' },
