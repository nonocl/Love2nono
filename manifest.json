// === ENREGISTREUR + NOTES VOCALES (partagent le même DB) ===
let _recState = null; // {recorder, chunks, startTime, timer}
async function startRecording() {
  try {
    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
    const mr = new MediaRecorder(stream);
    _recState = { recorder: mr, chunks: [], startTime: Date.now(), stream, timer: null };
    mr.ondataavailable = (e) => { if (e.data.size > 0) _recState.chunks.push(e.data); };
    mr.onstop = () => {
      const blob = new Blob(_recState.chunks, { type: 'audio/webm' });
      _recState.lastBlob = blob;
      // Auto save?
      if (_recState.autoSave) saveVoiceNote(blob, _recState.title || 'Note vocale');
      stream.getTracks().forEach(t => t.stop());
    };
    mr.start();
    _recState.timer = setInterval(() => updateRecTimer(), 100);
    return true;
  } catch (e) {
    toast('❌ Pas de micro / permission refusée');
    return false;
  }
}
function stopRecording() {
  if (_recState) {
    _recState.recorder.stop();
    clearInterval(_recState.timer);
  }
}
function getRecDuration() {
  if (!_recState) return 0;
  return Math.floor((Date.now() - _recState.startTime) / 1000);
}
function fmtDuration(s) {
  const m = Math.floor(s / 60);
  const sec = s % 60;
  return `${m}:${sec.toString().padStart(2,'0')}`;
}
function updateRecTimer() {
  const el = document.getElementById('rec-timer');
  if (el) el.textContent = fmtDuration(getRecDuration());
}

// === ENREGISTREUR (simple) ===
function renderRecorder() {
  let html = `<div style="background:linear-gradient(135deg,#FF4757,#E73C3C); color:white; padding:18px; border-radius:18px; text-align:center;">
    <div id="rec-status" style="font-size:60px;">${_recState ? '🔴' : '⚪'}</div>
    <div id="rec-timer" style="font-size:32px; font-weight:900; font-family:monospace; margin-top:6px;">${_recState ? fmtDuration(getRecDuration()) : '0:00'}</div>
    <div style="font-size:12px; opacity:0.9; margin-top:4px;">${_recState ? 'Enregistrement...' : 'Prêt'}</div>
  </div>
  <button class="btn primary full" onclick="${_recState ? 'recStop()' : 'recStart()'}" style="margin-top:14px; padding:18px; font-size:15px;">${_recState ? '⏹ Arrêter' : '▶ Démarrer'}</button>
  ${_recState && _recState.lastBlob ? `<button class="btn alt full" onclick="recDownload()" style="margin-top:6px;">💾 Télécharger</button>
    <button class="btn alt full" onclick="recPlay()" style="margin-top:4px;">▶ Écouter</button>
    <button class="btn alt full" onclick="recSaveAsVN()" style="margin-top:4px;">📌 Sauver comme note vocale</button>` : ''}
  <p style="font-size:11px; color:var(--textSec); margin-top:14px; text-align:center;">⚠️ Ton audio reste en local, jamais envoyé ailleurs.</p>`;
  document.getElementById('recorder-content').innerHTML = html;
}
async function recStart() {
  const ok = await startRecording();
  if (ok) renderRecorder();
}
function recStop() {
  stopRecording();
  setTimeout(() => renderRecorder(), 200);
}
function recDownload() {
  if (!_recState?.lastBlob) return;
  const url = URL.createObjectURL(_recState.lastBlob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `record-${new Date().toISOString().slice(0,16).replace(/:/g,'-')}.webm`;
  a.click();
  URL.revokeObjectURL(url);
}
function recPlay() {
  if (!_recState?.lastBlob) return;
  const url = URL.createObjectURL(_recState.lastBlob);
  const audio = new Audio(url);
  audio.play();
}
async function recSaveAsVN() {
  if (!_recState?.lastBlob) return;
  const title = prompt('Titre de la note vocale :') || 'Note vocale';
  await saveVoiceNote(_recState.lastBlob, title);
  toast('✅ Sauvegardée');
}

// === NOTES VOCALES (avec IndexedDB pour stocker les blobs) ===
async function saveVoiceNote(blob, title) {
  // Convertir en data URL (limite ~5Mo en localStorage)
  const reader = new FileReader();
  return new Promise((resolve, reject) => {
    reader.onload = () => {
      const data = reader.result;
      const notes = JSON.parse(localStorage.getItem('nw_voicenotes') || '[]');
      const duration = _recState?.lastBlob ? Math.floor((Date.now() - (_recState.startTime || Date.now())) / 1000) : 0;
      notes.unshift({
        id: 'vn_'+Date.now(), title, data,
        duration, created: Date.now(), size: blob.size
      });
      // Limite à 20 notes pour éviter de remplir le storage
      if (notes.length > 30) notes.length = 30;
      try {
        localStorage.setItem('nw_voicenotes', JSON.stringify(notes));
        resolve(true);
      } catch (e) {
        toast('❌ Storage plein. Supprime des anciennes notes.');
        reject(e);
      }
    };
    reader.readAsDataURL(blob);
  });
}
function getVoiceNotes() { try { return JSON.parse(localStorage.getItem('nw_voicenotes') || '[]'); } catch { return []; } }
function saveVNList(d) { localStorage.setItem('nw_voicenotes', JSON.stringify(d)); }
function renderVoiceNotes() {
  const notes = getVoiceNotes();
  // Storage usage
  let usedMo = 0;
  try {
    const data = localStorage.getItem('nw_voicenotes') || '[]';
    usedMo = (data.length * 2) / (1024 * 1024);
  } catch {}
  let html = `<div style="background:var(--surface); padding:12px 14px; border-radius:12px; margin-bottom:10px;">
    <div style="display:flex; justify-content:space-between; font-size:12px; font-weight:700;">
      <span>🎤 ${notes.length} note${notes.length>1?'s':''} vocale${notes.length>1?'s':''}</span>
      <span style="color:var(--primary);">${usedMo.toFixed(2)} Mo</span>
    </div>
    <div style="font-size:10px; color:var(--textSec); margin-top:4px;">100% local · pas de limite imposée par l'app</div>
  </div>`;
  if (!notes.length) html += '<p style="text-align:center; color:var(--textSec); padding:30px;">Aucune note. Tap + pour enregistrer.</p>';
  notes.forEach(n => {
    const d = new Date(n.created).toLocaleString('fr-FR');
    const sizeKb = Math.round((n.size || 0) / 1024);
    html += `<div style="background:var(--surface); padding:12px; border-radius:12px; margin-top:6px;">
      <div style="font-size:13px; font-weight:700;">🎤 ${escapeHtml(n.title)}</div>
      <div style="font-size:10px; color:var(--textSec); margin-top:2px;">${d} · ${fmtDuration(n.duration || 0)} · ${sizeKb}KB</div>
      <audio controls src="${n.data}" style="width:100%; margin-top:8px; height:36px;"></audio>
      <div style="display:flex; gap:6px; margin-top:6px;">
        <button class="btn alt" onclick="vnRename('${n.id}')" style="font-size:11px; flex:1;">✎ Renommer</button>
        <button class="btn alt" onclick="vnDelete('${n.id}')" style="font-size:11px; color:var(--danger);">🗑</button>
      </div>
    </div>`;
  });
  document.getElementById('voicenotes-content').innerHTML = html;
}
async function vnNew() {
  if (_recState) {
    // Stop in progress
    _recState.title = prompt('Titre :') || 'Note vocale';
    _recState.autoSave = true;
    stopRecording();
    setTimeout(() => renderVoiceNotes(), 500);
  } else {
    if (await startRecording()) {
      _recState.autoSave = true;
      _recState.title = prompt('Titre (avant d\'enregistrer) :') || 'Note vocale';
      toast('🔴 Enregistrement... Tap + pour stopper');
      // Fake re-render
      const btn = document.querySelector('#page-voicenotes .icon-btn');
      if (btn) btn.textContent = '⏹';
    }
  }
}
function vnRename(id) {
  const notes = getVoiceNotes();
  const n = notes.find(x => x.id === id); if (!n) return;
  const t = prompt('Nouveau titre :', n.title); if (!t) return;
  n.title = t; saveVNList(notes); renderVoiceNotes();
}
function vnDelete(id) {
  if (!confirm('Supprimer ?')) return;
  saveVNList(getVoiceNotes().filter(n => n.id !== id));
  renderVoiceNotes();
}

// === TTS ===
function getVoices() {
  return new Promise((resolve) => {
    let voices = speechSynthesis.getVoices();
    if (voices.length) { resolve(voices); return; }
    speechSynthesis.onvoiceschanged = () => resolve(speechSynthesis.getVoices());
  });
}
async function renderTTS() {
  const voices = await getVoices();
  const frVoices = voices.filter(v => v.lang.startsWith('fr'));
  const enVoices = voices.filter(v => v.lang.startsWith('en'));
  const itVoices = voices.filter(v => v.lang.startsWith('it'));
  const allLangs = [...new Set(voices.map(v => v.lang))].sort();
  
  let html = `<div style="background:linear-gradient(135deg,#5DADE2,#9B59B6); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🔊</div>
    <div style="font-size:16px; font-weight:800;">Texte → Audio</div>
    <div style="font-size:11px; opacity:0.9;">Lecture vocale par ton tel · ${voices.length} voix dispo</div>
  </div>
  <textarea class="input" id="tts-text" rows="6" placeholder="Colle ton texte ici..." style="margin-top:14px;"></textarea>
  
  <span class="label" style="margin-top:10px;">Langue / voix</span>
  <select class="input" id="tts-voice">`;
  voices.forEach((v, i) => {
    html += `<option value="${i}">${escapeHtml(v.name)} (${escapeHtml(v.lang)})${v.default ? ' · défaut' : ''}</option>`;
  });
  html += `</select>
  
  <div style="display:flex; gap:8px; margin-top:8px;">
    <div style="flex:1;"><span class="label">Vitesse</span><input type="range" id="tts-rate" min="0.5" max="2" step="0.1" value="1" oninput="document.getElementById('tts-rate-val').textContent=this.value+'x'" style="width:100%;"><div id="tts-rate-val" style="font-size:11px; text-align:center;">1x</div></div>
    <div style="flex:1;"><span class="label">Tonalité</span><input type="range" id="tts-pitch" min="0.5" max="2" step="0.1" value="1" oninput="document.getElementById('tts-pitch-val').textContent=this.value" style="width:100%;"><div id="tts-pitch-val" style="font-size:11px; text-align:center;">1</div></div>
  </div>
  
  <div style="display:flex; gap:6px; margin-top:14px;">
    <button class="btn primary full" onclick="ttsSpeak()">▶ Lire</button>
    <button class="btn alt" onclick="ttsStop()" style="padding:10px 16px;">⏹</button>
    <button class="btn alt" onclick="ttsPause()" style="padding:10px 16px;">⏸</button>
  </div>
  <p style="font-size:11px; color:var(--textSec); margin-top:14px; text-align:center;">💡 Utile pour réviser à l'oral, écouter un texte en voiture, ou faire une dictée maison.</p>`;
  document.getElementById('tts-content').innerHTML = html;
}
async function ttsSpeak() {
  const text = document.getElementById('tts-text').value;
  if (!text.trim()) { toast('Tape du texte'); return; }
  speechSynthesis.cancel();
  const u = new SpeechSynthesisUtterance(text);
  const voices = await getVoices();
  const idx = parseInt(document.getElementById('tts-voice').value);
  u.voice = voices[idx];
  u.rate = parseFloat(document.getElementById('tts-rate').value);
  u.pitch = parseFloat(document.getElementById('tts-pitch').value);
  speechSynthesis.speak(u);
}
function ttsStop() { speechSynthesis.cancel(); }
function ttsPause() { 
  if (speechSynthesis.paused) speechSynthesis.resume();
  else speechSynthesis.pause();
}

// === BRUIT BLANC / ROSE / BROWN / NATURE ===
let _noiseCtx = null;
let _noiseNode = null;
let _noiseFilter = null;
function renderNoise() {
  let html = `<div style="background:linear-gradient(135deg,#3498DB,#2C3E50); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🌊</div>
    <div style="font-size:16px; font-weight:800;">Bruits ambiants</div>
    <div style="font-size:11px; opacity:0.9;">Génération en temps réel · 0 fichier</div>
  </div>
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">🎚️ Type de bruit</h3>
  <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:6px; margin-top:8px;">
    <button class="btn alt full" onclick="noisePlay('white')">⚪ Blanc</button>
    <button class="btn alt full" onclick="noisePlay('pink')">🩷 Rose</button>
    <button class="btn alt full" onclick="noisePlay('brown')">🟫 Brown</button>
  </div>
  <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:6px; margin-top:6px;">
    <button class="btn alt full" onclick="noisePlay('rain')">🌧 Pluie</button>
    <button class="btn alt full" onclick="noisePlay('ocean')">🌊 Vagues</button>
    <button class="btn alt full" onclick="noisePlay('wind')">💨 Vent</button>
  </div>
  <button class="btn primary full" onclick="noiseStop()" style="margin-top:14px;">⏹ Stop</button>
  <p style="font-size:11px; color:var(--textSec); margin-top:10px; text-align:center;">💤 Pour sommeil, focus, méditation. Faible volume conseillé.</p>`;
  document.getElementById('noise-content').innerHTML = html;
}
function noisePlay(type) {
  noiseStop();
  _noiseCtx = new (window.AudioContext || window.webkitAudioContext)();
  const bufferSize = 2 * _noiseCtx.sampleRate;
  const buffer = _noiseCtx.createBuffer(1, bufferSize, _noiseCtx.sampleRate);
  const data = buffer.getChannelData(0);
  
  if (type === 'white' || type === 'rain') {
    for (let i = 0; i < bufferSize; i++) data[i] = (Math.random() * 2 - 1) * 0.5;
  } else if (type === 'pink') {
    let b0=0, b1=0, b2=0, b3=0, b4=0, b5=0, b6=0;
    for (let i = 0; i < bufferSize; i++) {
      const w = Math.random() * 2 - 1;
      b0 = 0.99886 * b0 + w * 0.0555179;
      b1 = 0.99332 * b1 + w * 0.0750759;
      b2 = 0.96900 * b2 + w * 0.1538520;
      b3 = 0.86650 * b3 + w * 0.3104856;
      b4 = 0.55000 * b4 + w * 0.5329522;
      b5 = -0.7616 * b5 - w * 0.0168980;
      data[i] = (b0 + b1 + b2 + b3 + b4 + b5 + b6 + w * 0.5362) * 0.11;
      b6 = w * 0.115926;
    }
  } else if (type === 'brown') {
    let last = 0;
    for (let i = 0; i < bufferSize; i++) {
      const w = Math.random() * 2 - 1;
      last = (last + 0.02 * w) / 1.02;
      data[i] = last * 3.5;
    }
  } else if (type === 'ocean' || type === 'wind') {
    for (let i = 0; i < bufferSize; i++) data[i] = (Math.random() * 2 - 1) * 0.5;
  }
  
  _noiseNode = _noiseCtx.createBufferSource();
  _noiseNode.buffer = buffer;
  _noiseNode.loop = true;
  
  // Filtrage selon le type pour donner pluie/vague/vent
  if (type === 'rain') {
    _noiseFilter = _noiseCtx.createBiquadFilter();
    _noiseFilter.type = 'highpass';
    _noiseFilter.frequency.value = 1000;
    _noiseNode.connect(_noiseFilter);
    _noiseFilter.connect(_noiseCtx.destination);
  } else if (type === 'ocean') {
    _noiseFilter = _noiseCtx.createBiquadFilter();
    _noiseFilter.type = 'lowpass';
    _noiseFilter.frequency.value = 400;
    // Modulation lente
    const lfo = _noiseCtx.createOscillator();
    const lfoGain = _noiseCtx.createGain();
    lfo.frequency.value = 0.15;
    lfoGain.gain.value = 200;
    lfo.connect(lfoGain);
    lfoGain.connect(_noiseFilter.frequency);
    lfo.start();
    _noiseNode.connect(_noiseFilter);
    _noiseFilter.connect(_noiseCtx.destination);
  } else if (type === 'wind') {
    _noiseFilter = _noiseCtx.createBiquadFilter();
    _noiseFilter.type = 'bandpass';
    _noiseFilter.frequency.value = 300;
    _noiseFilter.Q.value = 0.5;
    const lfo = _noiseCtx.createOscillator();
    const lfoGain = _noiseCtx.createGain();
    lfo.frequency.value = 0.3;
    lfoGain.gain.value = 150;
    lfo.connect(lfoGain);
    lfoGain.connect(_noiseFilter.frequency);
    lfo.start();
    _noiseNode.connect(_noiseFilter);
    _noiseFilter.connect(_noiseCtx.destination);
  } else {
    _noiseNode.connect(_noiseCtx.destination);
  }
  
  _noiseNode.start();
  toast('▶ ' + type);
}
function noiseStop() {
  if (_noiseNode) { try { _noiseNode.stop(); } catch {} _noiseNode = null; }
  if (_noiseCtx) { try { _noiseCtx.close(); } catch {} _noiseCtx = null; }
  _noiseFilter = null;
}

// === MÉTRONOME AVANCÉ ===
let _metroPlus = { ctx: null, playing: false, bpm: 100, beats: 4, accent: true, sub: 1, timeoutId: null, currentBeat: 0 };
function renderMetroPlus() {
  let html = `<div style="background:linear-gradient(135deg,#FF8C42,#FFD166); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🎼</div>
    <div style="font-size:16px; font-weight:800;">Métronome avancé</div>
  </div>
  <div style="background:var(--surface); padding:14px; border-radius:12px; margin-top:14px; text-align:center;">
    <div style="font-size:48px; font-weight:900; color:var(--primary);" id="mp-bpm-display">${_metroPlus.bpm}</div>
    <div style="font-size:11px; color:var(--textSec);">BPM</div>
    <input type="range" id="mp-bpm" min="40" max="240" value="${_metroPlus.bpm}" oninput="mpSetBpm(this.value)" style="width:100%; margin-top:10px;">
    <div style="display:flex; gap:4px; margin-top:8px; justify-content:center;">
      <button class="btn alt" onclick="mpSetBpm(${_metroPlus.bpm-5})" style="font-size:11px; padding:5px 10px;">−5</button>
      <button class="btn alt" onclick="mpSetBpm(${_metroPlus.bpm-1})" style="font-size:11px; padding:5px 10px;">−1</button>
      <button class="btn alt" onclick="mpSetBpm(${_metroPlus.bpm+1})" style="font-size:11px; padding:5px 10px;">+1</button>
      <button class="btn alt" onclick="mpSetBpm(${_metroPlus.bpm+5})" style="font-size:11px; padding:5px 10px;">+5</button>
    </div>
  </div>
  
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">🎵 Mesure & subdivisions</h3>
  <span class="label">Battements par mesure</span>
  <div style="display:grid; grid-template-columns:repeat(6,1fr); gap:4px;">
    ${[2,3,4,5,6,7].map(b => `<button class="btn ${_metroPlus.beats===b?'primary':'alt'} full" onclick="mpSetBeats(${b})" style="font-size:11px;">${b}/4</button>`).join('')}
  </div>
  <span class="label" style="margin-top:8px;">Subdivisions</span>
  <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:4px;">
    ${[1,2,3,4].map(s => `<button class="btn ${_metroPlus.sub===s?'primary':'alt'} full" onclick="mpSetSub(${s})" style="font-size:11px;">${s===1?'♩':s===2?'♫':s===3?'♪♪♪':'♬'}</button>`).join('')}
  </div>
  
  <h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:14px;">🎯 Accent fort</h3>
  <button class="btn ${_metroPlus.accent?'primary':'alt'} full" onclick="mpToggleAccent()">${_metroPlus.accent?'✓ Accent activé':'Accent désactivé'}</button>
  
  <div style="background:var(--bg); padding:14px; border-radius:14px; margin-top:14px; display:flex; gap:6px; justify-content:center;" id="mp-visual">`;
  for (let i = 0; i < _metroPlus.beats; i++) {
    html += `<div style="width:14px; height:14px; border-radius:50%; background:var(--surface); border:2px solid var(--border);" id="mp-dot-${i}"></div>`;
  }
  html += `</div>
  <button class="btn primary full" onclick="mpToggle()" style="margin-top:14px; padding:18px; font-size:16px;">${_metroPlus.playing?'⏹ Stop':'▶ Démarrer'}</button>`;
  document.getElementById('metroplus-content').innerHTML = html;
}
function mpSetBpm(v) { _metroPlus.bpm = Math.max(40, Math.min(240, parseInt(v))); renderMetroPlus(); }
function mpSetBeats(b) { _metroPlus.beats = b; renderMetroPlus(); }
function mpSetSub(s) { _metroPlus.sub = s; renderMetroPlus(); }
function mpToggleAccent() { _metroPlus.accent = !_metroPlus.accent; renderMetroPlus(); }
function mpToggle() {
  if (_metroPlus.playing) mpStop();
  else mpStart();
}
function mpStart() {
  _metroPlus.ctx = new (window.AudioContext || window.webkitAudioContext)();
  _metroPlus.playing = true;
  _metroPlus.currentBeat = 0;
  mpTick();
  renderMetroPlus();
}
function mpStop() {
  _metroPlus.playing = false;
  if (_metroPlus.timeoutId) clearTimeout(_metroPlus.timeoutId);
  if (_metroPlus.ctx) { try { _metroPlus.ctx.close(); } catch {} _metroPlus.ctx = null; }
  renderMetroPlus();
}
function mpTick() {
  if (!_metroPlus.playing) return;
  const beat = _metroPlus.currentBeat;
  const isAccent = _metroPlus.accent && (beat % _metroPlus.sub === 0) && (Math.floor(beat / _metroPlus.sub) % _metroPlus.beats === 0);
  const isSub = beat % _metroPlus.sub !== 0;
  
  // Visual
  const beatIdx = Math.floor(beat / _metroPlus.sub) % _metroPlus.beats;
  for (let i = 0; i < _metroPlus.beats; i++) {
    const el = document.getElementById('mp-dot-'+i);
    if (el) el.style.background = i === beatIdx ? (isAccent ? 'var(--danger)' : 'var(--primary)') : 'var(--surface)';
  }
  
  // Sound
  const osc = _metroPlus.ctx.createOscillator();
  const gain = _metroPlus.ctx.createGain();
  osc.frequency.value = isAccent ? 1200 : (isSub ? 600 : 800);
  gain.gain.value = isSub ? 0.15 : 0.4;
  gain.gain.exponentialRampToValueAtTime(0.01, _metroPlus.ctx.currentTime + 0.05);
  osc.connect(gain);
  gain.connect(_metroPlus.ctx.destination);
  osc.start();
  osc.stop(_metroPlus.ctx.currentTime + 0.05);
  
  _metroPlus.currentBeat = (beat + 1) % (_metroPlus.beats * _metroPlus.sub);
  _metroPlus.timeoutId = setTimeout(mpTick, (60000 / _metroPlus.bpm) / _metroPlus.sub);
}

// === BIBLIOTHÈQUE DE SONS PERSO ===
function getSoundLib() { try { return JSON.parse(localStorage.getItem('nw_soundlib') || '[]'); } catch { return []; } }
function saveSoundLib(d) { localStorage.setItem('nw_soundlib', JSON.stringify(d)); }
function getSoundLibStorageMo() {
  try {
    const data = localStorage.getItem('nw_soundlib') || '[]';
    return (data.length * 2) / (1024 * 1024); // UTF-16, 2 bytes per char
  } catch { return 0; }
}
function renderSoundLib() {
  const sounds = getSoundLib();
  const usedMo = getSoundLibStorageMo();
  
  // Total localStorage usage
  let totalMo = 0;
  try {
    for (const k in localStorage) {
      if (Object.prototype.hasOwnProperty.call(localStorage, k)) {
        totalMo += (localStorage[k].length * 2) / (1024 * 1024);
      }
    }
  } catch {}
  
  // Approximate browser limit ~5-10Mo, we estimate
  const estLimit = 10; // Mo browser typical limit
  const remainMo = Math.max(0, estLimit - totalMo);
  
  let html = `<div style="background:var(--surface); padding:12px 14px; border-radius:12px; margin-bottom:10px;">
    <div style="display:flex; justify-content:space-between; align-items:center; font-size:12px; font-weight:700;">
      <span>🎵 ${sounds.length} son${sounds.length>1?'s':''} stocké${sounds.length>1?'s':''}</span>
      <span style="color:var(--primary);">${usedMo.toFixed(2)} Mo</span>
    </div>
    <div style="font-size:10px; color:var(--textSec); margin-top:4px;">Storage app total : ${totalMo.toFixed(2)} Mo · disponible env. ${remainMo.toFixed(2)} Mo</div>
    <div style="background:var(--bg); height:6px; border-radius:3px; margin-top:6px; overflow:hidden;">
      <div style="background:linear-gradient(90deg, var(--primary), var(--accent)); height:100%; width:${Math.min(100, totalMo / estLimit * 100).toFixed(1)}%; transition:width 0.3s;"></div>
    </div>
    <div style="font-size:10px; color:var(--textSec); margin-top:6px;">💡 Stockage local. Pas de limite imposée par l'app, mais ton navigateur a une limite globale (~5-10Mo).</div>
  </div>`;
  
  if (!sounds.length) html += '<p style="text-align:center; color:var(--textSec); padding:30px;">Aucun son. Tap + pour uploader.</p>';
  
  if (sounds.length) {
    html += '<div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:10px;">';
    sounds.forEach(s => {
      const sizeMo = s.data ? (s.data.length * 0.75 / (1024*1024)) : 0; // base64 → bytes
      html += `<div style="background:var(--surface); padding:14px; border-radius:14px; text-align:center; cursor:pointer; aspect-ratio:1; display:flex; flex-direction:column; justify-content:center; align-items:center; position:relative;" onclick="soundLibPlay('${s.id}')">
        <div style="font-size:32px;">${escapeHtml(s.icon || '🔊')}</div>
        <div style="font-size:11px; font-weight:700; margin-top:6px;">${escapeHtml(s.name)}</div>
        <div style="font-size:9px; color:var(--textSec); margin-top:2px;">${sizeMo.toFixed(2)} Mo</div>
        <button onclick="event.stopPropagation(); soundLibDel('${s.id}')" style="background:none; border:none; color:var(--danger); font-size:14px; margin-top:4px;">✗</button>
      </div>`;
    });
    html += '</div>';
  }
  document.getElementById('soundlib-content').innerHTML = html;
}
function soundLibAdd() {
  const inp = document.createElement('input');
  inp.type = 'file'; inp.accept = 'audio/*';
  inp.onchange = async (e) => {
    const file = e.target.files[0];
    if (!file) return;
    // No artificial limit on file size or count - try and see
    const reader = new FileReader();
    reader.onload = () => {
      const name = prompt('Nom du son :', file.name.replace(/\.[^.]+$/, '')) || 'Son';
      const icon = prompt('Emoji :', '🔊') || '🔊';
      const sounds = getSoundLib();
      sounds.unshift({ id:'snd_'+Date.now(), name, icon, data: reader.result });
      try { 
        saveSoundLib(sounds); 
        renderSoundLib(); 
        toast('✅ Son ajouté'); 
      }
      catch (err) { 
        // Storage full - let user know precisely
        const sizeMo = (reader.result.length * 0.75 / (1024*1024)).toFixed(2);
        toast(`❌ Storage plein (${sizeMo} Mo trop). Supprime des sons ou réduis la taille.`, 4000);
      }
    };
    reader.onerror = () => toast('❌ Erreur lecture fichier');
    reader.readAsDataURL(file);
  };
  inp.click();
}
function soundLibPlay(id) {
  const s = getSoundLib().find(x => x.id === id); if (!s) return;
  const audio = new Audio(s.data);
  audio.play();
}
function soundLibDel(id) {
  if (!confirm('Supprimer ?')) return;
  saveSoundLib(getSoundLib().filter(s => s.id !== id));
  renderSoundLib();
}



