let _sdImg = null;
function sdLoad(input) {
  const f = (input.files || [])[0]; if (!f) return;
  const r = new FileReader();
  r.onload = e => {
    _sdImg = e.target.result;
    document.getElementById('sd-preview').innerHTML = `<img src="${_sdImg}" style="width:100%; border-radius:12px; max-height:300px; object-fit:contain; background:var(--surface);">`;
    document.getElementById('sd-btn').disabled = false;
  };
  r.readAsDataURL(f);
}
async function sdSave() {
  if (!_sdImg) return;
  const subject = document.getElementById('sd-subject').value;
  const title = document.getElementById('sd-title').value.trim() || 'Devoir ' + new Date().toLocaleDateString('fr-FR');
  const compressed = await new Promise(res => {
    const img = new Image();
    img.onload = () => {
      const max = 1600;
      let w = img.width, h = img.height;
      if (w > max || h > max) { const r = Math.min(max/w, max/h); w *= r; h *= r; }
      const c = document.createElement('canvas'); c.width = w; c.height = h;
      const ctx = c.getContext('2d');
      ctx.fillStyle = '#fff'; ctx.fillRect(0, 0, w, h);
      ctx.drawImage(img, 0, 0, w, h);
      res(c.toDataURL('image/jpeg', 0.85));
    };
    img.src = _sdImg;
  });
  const tx = db.transaction('files', 'readwrite');
  tx.objectStore('files').add({
    name: `${subject}-${title}.jpg`, mime: 'image/jpeg',
    size: compressed.length * 0.75, originalSize: compressed.length * 0.75,
    compressed: true, data: compressed, folder: null,
    added: Date.now(), tag: 'scandev', subject, title
  });
  document.getElementById('sd-title').value = '';
  document.getElementById('sd-preview').innerHTML = '';
  document.getElementById('sd-btn').disabled = true;
  _sdImg = null;
  toast('💾 Devoir sauvé !');
  renderSdList();
}
let _sdFilter = 'Tous';
async function renderSdList() {
  if (!db) return;
  const all = await new Promise(r => { const req = db.transaction('files','readonly').objectStore('files').getAll(); req.onsuccess = () => r(req.result); });
  const devs = all.filter(f => f.tag === 'scandev');
  const subs = ['Tous', ...new Set(devs.map(d => d.subject))];
  document.getElementById('sd-filters').innerHTML = subs.map(s => 
    `<div class="home-tab ${_sdFilter === s ? 'active' : ''}" onclick="sdFilter('${s}')">${s} ${s === 'Tous' ? `(${devs.length})` : `(${devs.filter(d => d.subject === s).length})`}</div>`
  ).join('');
  let visible = devs;
  if (_sdFilter !== 'Tous') visible = devs.filter(d => d.subject === _sdFilter);
  visible.sort((a,b) => b.added - a.added);
  if (!visible.length) {
    document.getElementById('sd-list').innerHTML = '<p style="text-align:center; color:var(--textSec); font-size:12px; padding:20px;">Aucun devoir scanné</p>';
    return;
  }
  document.getElementById('sd-list').innerHTML = visible.map(d => `
    <div onclick="fdOpen(${d.id})" style="display:flex; gap:10px; align-items:center; padding:8px; background:var(--surface); border-radius:8px; margin-bottom:4px; cursor:pointer;">
      <img src="${d.data}" style="width:50px; height:50px; object-fit:cover; border-radius:6px;">
      <div style="flex:1; min-width:0;">
        <div style="font-size:13px; font-weight:600; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${escapeHtml(d.title || d.name)}</div>
        <div style="font-size:11px; color:var(--primary);">${escapeHtml(d.subject)} · ${new Date(d.added).toLocaleDateString('fr-FR')}</div>
      </div>
    </div>
  `).join('');
}
function sdFilter(s) { _sdFilter = s; renderSdList(); }


