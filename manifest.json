}
function pwgenSetMode(mode) {
  document.getElementById('pwgen-mode').value = mode;
  document.querySelectorAll('.pwgen-mode').forEach(b => {
    if (b.dataset.mode === mode) { b.classList.remove('alt'); b.classList.add('primary'); }
    else { b.classList.remove('primary'); b.classList.add('alt'); }
  });
  let html = '';
  if (mode === 'strong') {
    html = `<div style="background:var(--surface); padding:12px; border-radius:10px;">
      <label style="font-size:12px;">Longueur : <span id="pwgen-len-val">16</span></label>
      <input type="range" id="pwgen-len" min="8" max="64" value="16" oninput="document.getElementById('pwgen-len-val').textContent = this.value;" style="width:100%; margin-top:6px;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:8px; font-size:11px;">
        <label><input type="checkbox" id="pwgen-up" checked> Majuscules (A-Z)</label>
        <label><input type="checkbox" id="pwgen-lo" checked> Minuscules (a-z)</label>
        <label><input type="checkbox" id="pwgen-num" checked> Chiffres (0-9)</label>
        <label><input type="checkbox" id="pwgen-sym" checked> Symboles (!@#$%)</label>
        <label><input type="checkbox" id="pwgen-amb"> Sans ambiguïté (0 O l 1 I)</label>
      </div>
    </div>`;
  } else if (mode === 'speak') {
    html = `<div style="background:var(--surface); padding:12px; border-radius:10px;">
      <label style="font-size:12px;">Longueur : <span id="pwgen-len-val">12</span></label>
      <input type="range" id="pwgen-len" min="8" max="24" value="12" oninput="document.getElementById('pwgen-len-val').textContent = this.value;" style="width:100%; margin-top:6px;">
      <div style="font-size:11px; margin-top:8px; color:var(--textSec); line-height:1.5;">Génère un mot de passe alternant consonne/voyelle, donc lisible et mémorisable. Ajoute chiffres + 1 majuscule à la fin.</div>
    </div>`;
  } else if (mode === 'phrase') {
    html = `<div style="background:var(--surface); padding:12px; border-radius:10px;">
      <label style="font-size:12px;">Nombre de mots : <span id="pwgen-words-val">4</span></label>
      <input type="range" id="pwgen-words" min="3" max="8" value="4" oninput="document.getElementById('pwgen-words-val').textContent = this.value;" style="width:100%; margin-top:6px;">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:8px; font-size:11px;">
        <label><input type="checkbox" id="pwgen-cap" checked> Capitaliser</label>
        <label><input type="checkbox" id="pwgen-numend" checked> + chiffre</label>
      </div>
      <div style="font-size:11px; margin-top:8px; color:var(--textSec); line-height:1.5;">Style "correcthorsebatterystaple" : très fort + facile à retenir.</div>
    </div>`;
  }
  document.getElementById('pwgen-opts').innerHTML = html;
}
function pwgenGenerate() {
  const mode = document.getElementById('pwgen-mode').value;
  let pw = '';
  if (mode === 'strong') {
    const len = parseInt(document.getElementById('pwgen-len').value);
    let charset = '';
    if (document.getElementById('pwgen-lo').checked) charset += 'abcdefghijklmnopqrstuvwxyz';
    if (document.getElementById('pwgen-up').checked) charset += 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    if (document.getElementById('pwgen-num').checked) charset += '0123456789';
    if (document.getElementById('pwgen-sym').checked) charset += '!@#$%^&*()_+-=[]{}|;:,.<>?';
    if (document.getElementById('pwgen-amb').checked) charset = charset.replace(/[0Ol1I]/g, '');
    if (!charset) { toast('Choisis au moins un type'); return; }
    const arr = new Uint32Array(len);
    crypto.getRandomValues(arr);
    for (let i = 0; i < len; i++) pw += charset[arr[i] % charset.length];
  } else if (mode === 'speak') {
    const len = parseInt(document.getElementById('pwgen-len').value);
    const cons = 'bcdfghjklmnprstvwz';
    const vow = 'aeiouy';
    const targetLen = len - 3; // reserve for digits + caps
    const arr = new Uint32Array(targetLen);
    crypto.getRandomValues(arr);
    for (let i = 0; i < targetLen; i++) {
      pw += i % 2 === 0 ? cons[arr[i] % cons.length] : vow[arr[i] % vow.length];
    }
    // Capitalize first letter
    pw = pw[0].toUpperCase() + pw.slice(1);
    // Add 2 random digits
    const dArr = new Uint32Array(2);
    crypto.getRandomValues(dArr);
    pw += (dArr[0] % 100).toString().padStart(2, '0');
    // Add a symbol
    const syms = '!@#$&*';
    const sArr = new Uint32Array(1);
    crypto.getRandomValues(sArr);
    pw += syms[sArr[0] % syms.length];
  } else if (mode === 'phrase') {
    const n = parseInt(document.getElementById('pwgen-words').value);
    const cap = document.getElementById('pwgen-cap').checked;
    const numEnd = document.getElementById('pwgen-numend').checked;
    const wordlist = ['chat','chien','soleil','lune','etoile','arbre','maison','livre','musique','danse','ocean','nuage','foret','champion','tigre','dragon','fleur','jardin','mer','vague','feu','glace','vent','tempete','riviere','montagne','volcan','phare','navire','aigle','renard','loup','panda','baleine','pomme','mangue','chocolat','cafe','pluie','neige','aurore','crepuscule','melodie','rythme','silence','cristal','diamant','perle','rubis','emeraude','saphir','topaze','onyx','jade','ambre','velours','soie','laine','coton','cuir','bronze','cuivre','platine','obsidienne','marbre','granite','quartz','geode','prisme','horizon','infini','liberte','passion','aventure','mystere','souvenir','reve','espoir','amitie','sagesse','courage','etoile','planete','galaxie','univers','cosmos','tourbillon','cascade','sentier','jungle','desert','oasis','toundra','prairie','bambou','cedre','chene','erable','saule','peuplier','cypres','tilleul','romarin','lavande','rose','orchidee','tulipe','jasmin','muguet','papillon','colibri','phoenix','licorne','sirene','centaure','dauphin','requin','tortue','serpent','condor','faucon'];
    const arr = new Uint32Array(n);
    crypto.getRandomValues(arr);
    const words = [];
    for (let i = 0; i < n; i++) {
      let w = wordlist[arr[i] % wordlist.length];
      if (cap) w = w[0].toUpperCase() + w.slice(1);
      words.push(w);
    }
    pw = words.join('-');
    if (numEnd) {
      const dArr = new Uint32Array(1);
      crypto.getRandomValues(dArr);
      pw += '-' + (dArr[0] % 100);
    }
  }
  
  // Analyze strength
  const a = pwAuditAnalyze(pw);
  
  let html = `<div style="background:${a.color}; color:white; padding:16px; border-radius:14px;">
    <div style="font-size:11px; opacity:0.9; letter-spacing:1px; text-transform:uppercase;">${a.strength} · ${a.crackTime}</div>
    <div style="font-family:monospace; font-size:18px; font-weight:700; word-break:break-all; margin-top:8px; padding:10px; background:rgba(0,0,0,0.15); border-radius:8px;">${escapeHtml(pw)}</div>
  </div>
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px; margin-top:8px;">
    <button class="btn primary" onclick="pwgenCopy('${escapeJs(pw)}')" style="padding:12px;">📋 Copier</button>
    <button class="btn alt" onclick="pwgenGenerate()" style="padding:12px;">🔄 Refaire</button>
  </div>`;
  document.getElementById('pwgen-result').innerHTML = html;
}
function pwgenCopy(pw) {
  navigator.clipboard.writeText(pw).then(() => toast('📋 Copié — colle-le vite et range-le dans un gestionnaire de mots de passe'));
}

