}
function g2048Move(dir) {
  if (!V54__g2048) return;
  const g = V54__g2048.grid.map(r => r.slice());
  let moved = false;
  function slide(arr) {
    arr = arr.filter(x => x !== 0);
    for (let i = 0; i < arr.length - 1; i++) {
      if (arr[i] === arr[i+1]) { arr[i] *= 2; V54__g2048.score += arr[i]; arr.splice(i+1, 1); }
    }
    while (arr.length < 4) arr.push(0);
    return arr;
  }
  if (dir === 'L') { for (let r = 0; r < 4; r++) g[r] = slide(g[r]); }
  if (dir === 'R') { for (let r = 0; r < 4; r++) g[r] = slide(g[r].reverse()).reverse(); }
  if (dir === 'U') { for (let c = 0; c < 4; c++) { const col = slide([g[0][c],g[1][c],g[2][c],g[3][c]]); for (let r = 0; r < 4; r++) g[r][c] = col[r]; } }
  if (dir === 'D') { for (let c = 0; c < 4; c++) { const col = slide([g[3][c],g[2][c],g[1][c],g[0][c]]); for (let r = 0; r < 4; r++) g[3-r][c] = col[r]; } }
  // Detect change
  for (let r = 0; r < 4; r++) for (let c = 0; c < 4; c++) if (g[r][c] !== V54__g2048.grid[r][c]) moved = true;
  if (moved) { V54__g2048.grid = g; g2048Add(); g2048Render(); }
  // Check 2048
  for (let r = 0; r < 4; r++) for (let c = 0; c < 4; c++) if (g[r][c] === 2048) { toast('🎉 Tu as fait 2048 !'); break; }
}

