// CALC SCIENTIFIQUE
// ============================================================
function sciIns(s) { document.getElementById('sci-display').value += s; }
function sciClear() { document.getElementById('sci-display').value = ''; }
function sciBack() { const el = document.getElementById('sci-display'); el.value = el.value.slice(0, -1); }
function sciEval() {
  const el = document.getElementById('sci-display');
  let expr = el.value;
  try {
    // factorial !
    expr = expr.replace(/(\d+)!/g, (_, n) => {
      let r = 1; for (let i=2; i<=parseInt(n); i++) r *= i; return r;
    });
    const result = Function('"use strict"; return (' + expr + ')')();
    if (isNaN(result) || !isFinite(result)) throw 'erreur';
    const histEl = document.getElementById('sci-history');
    histEl.innerHTML = (expr + ' = ' + result + '<br>') + histEl.innerHTML;
    el.value = String(result);
  } catch (e) {
    toast('Erreur de calcul');
  }
}

