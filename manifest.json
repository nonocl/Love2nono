function rollDice(faces) {
  const d = document.getElementById('dice-display');
  let i = 0;
  const final = 1 + Math.floor(Math.random()*faces);
  const interval = setInterval(() => {
    d.textContent = 1 + Math.floor(Math.random()*faces);
    i++;
    if (i > 12) { clearInterval(interval); d.textContent = final; }
  }, 60);
}
function flipCoin() {
  const d = document.getElementById('dice-display');
  let i = 0;
  const final = Math.random() < 0.5 ? 'PILE' : 'FACE';
  const interval = setInterval(() => {
    d.textContent = i%2 ? '🪙' : '🟡';
    i++;
    if (i > 12) { clearInterval(interval); d.textContent = final; }
  }, 80);
}

