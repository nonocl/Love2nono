// === 21. DETOX DIGITAL ===
function getDetox() {
  let d;
  try { d = JSON.parse(localStorage.getItem('nw_detox') || 'null'); } catch { d = null; }
  if (!d) d = { active: false, startedAt: null, longestStreak: 0, totalSessions: 0 };
  return d;
}
function saveDetox(d) { localStorage.setItem('nw_detox', JSON.stringify(d)); }
function renderDetox() {
  const d = getDetox();
  let elapsed = 0, hours = 0, days = 0;
  if (d.active && d.startedAt) {
    elapsed = Math.floor((Date.now() - d.startedAt) / 1000);
    days = Math.floor(elapsed / 86400);
    hours = Math.floor((elapsed % 86400) / 3600);
  }
  const badges = [
    { d: 1, name: '🌱 1 jour', unlocked: (d.longestStreak||0) >= 1 || days >= 1 },
    { d: 3, name: '💪 3 jours', unlocked: (d.longestStreak||0) >= 3 || days >= 3 },
    { d: 7, name: '🔥 1 semaine', unlocked: (d.longestStreak||0) >= 7 || days >= 7 },
    { d: 14, name: '⚡ 2 semaines', unlocked: (d.longestStreak||0) >= 14 || days >= 14 },
    { d: 30, name: '👑 1 mois', unlocked: (d.longestStreak||0) >= 30 || days >= 30 },
    { d: 60, name: '🌟 2 mois', unlocked: (d.longestStreak||0) >= 60 || days >= 60 }
  ];
  
  let html = `<div style="background:linear-gradient(135deg,#06FFA5,#5DADE2); color:white; padding:18px; border-radius:18px; text-align:center;">
    <div style="font-size:36px;">🧘</div>
    <div style="font-size:16px; font-weight:800;">Detox digital</div>
    <div style="font-size:11px; opacity:0.9;">État : ${d.active ? '🟢 EN COURS' : '⚪ Pause'}</div>
  </div>`;
  if (d.active) {
    html += `<div style="background:var(--surface); padding:18px; border-radius:14px; margin-top:14px; text-align:center;">
      <div style="font-size:11px; color:var(--textSec); letter-spacing:2px;">DEPUIS</div>
      <div style="font-size:42px; font-weight:900; color:var(--success); margin-top:6px;">${days}j ${hours}h</div>
      <div style="font-size:11px; color:var(--textSec); margin-top:4px;">Continue, t'es fort·e 💪</div>
    </div>
    <button class="btn alt full" onclick="detoxStop()" style="margin-top:10px; color:var(--danger);">⏹ Arrêter le compteur</button>`;
  } else {
    html += `<button class="btn primary full" onclick="detoxStart()" style="margin-top:14px; padding:18px; font-size:15px;">🌿 Démarrer une session detox</button>
    <p style="font-size:11px; color:var(--textSec); text-align:center; margin-top:10px;">${(d.longestStreak||0)>0 ? `🏆 Record perso : ${d.longestStreak} jour${d.longestStreak>1?'s':''}` : ''}</p>`;
  }
  
  html += `<h3 style="font-size:13px; font-weight:700; color:var(--primary); margin-top:18px;">🏆 Badges</h3>
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:6px; margin-top:8px;">`;
  badges.forEach(b => {
    html += `<div style="background:${b.unlocked?'linear-gradient(135deg,#06FFA5,#5DADE2)':'var(--surface)'}; color:${b.unlocked?'white':'var(--textSec)'}; padding:14px 6px; border-radius:10px; text-align:center; opacity:${b.unlocked?'1':'0.4'};">
      <div style="font-size:18px; font-weight:800;">${escapeHtml(b.name)}</div>
    </div>`;
  });
  html += `</div>
  <p style="font-size:11px; color:var(--textSec); text-align:center; margin-top:14px;">📊 Sessions totales : ${d.totalSessions||0}</p>`;
  document.getElementById('detox-content').innerHTML = html;
}
function detoxStart() {
  const d = getDetox();
  d.active = true;
  d.startedAt = Date.now();
  d.totalSessions = (d.totalSessions||0) + 1;
  saveDetox(d); renderDetox();
  toast('🌿 C\'est parti !');
}
function detoxStop() {
  if (!confirm('Arrêter ? Tu casses ta streak en cours.')) return;
  const d = getDetox();
  if (d.startedAt) {
    const days = Math.floor((Date.now() - d.startedAt) / (24*60*60*1000));
    if (days > (d.longestStreak||0)) d.longestStreak = days;
  }
  d.active = false;
  d.startedAt = null;
  saveDetox(d); renderDetox();
}

