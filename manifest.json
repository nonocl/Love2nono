let _editingWheel = null;
let _currentWheel = null;
let _wheelAngle = 0;
async function renderWheels() {
  const wheels = await dbAll('wheels');
  const el = document.getElementById('wheels-list');
  el.innerHTML = '';
  if (wheels.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">🎡</div><h3>Aucune roue</h3><p>Crée tes propres roues pour décider ("Que faire ce soir ?", "Où manger ?"...).</p></div>`;
    return;
  }
  for (const w of wheels) {
    const row = document.createElement('button');
    row.className = 'list-row';
    row.innerHTML = `
      <div style="width:42px; height:42px; border-radius:21px; background:linear-gradient(135deg, var(--primary), var(--accent)); display:flex; align-items:center; justify-content:center; font-size:20px;">🎡</div>
      <div class="info">
        <div class="name">${escapeHtml(w.name)}</div>
        <div class="sub">${w.options.length} options</div>
      </div>
      <span style="color:var(--textSec); font-size:20px;">›</span>
    `;
    row.onclick = () => openWheelSpin(w);
    el.appendChild(row);
  }
}
function openWheelModal(w) {
  _editingWheel = w;
  document.getElementById('wheel-modal-title').textContent = w ? 'Modifier' : 'Nouvelle roue';
  document.getElementById('wheel-name-input').value = w ? w.name : '';
  document.getElementById('wheel-options-input').value = w ? w.options.join('\n') : '';
  document.getElementById('wheel-del-btn').style.display = w ? 'inline-flex' : 'none';
  openModal('modal-wheel');
}
async function saveWheel() {
  const name = document.getElementById('wheel-name-input').value.trim();
  const options = document.getElementById('wheel-options-input').value.split('\n').map(s=>s.trim()).filter(Boolean);
  if (!name || options.length < 2) { alert('Nom + au moins 2 options.'); return; }
  if (_editingWheel) await dbPut('wheels', { ..._editingWheel, name, options });
  else await dbAdd('wheels', { name, options, created_at: new Date().toISOString() });
  closeModal('modal-wheel');
  renderWheels();
}
async function deleteWheelNow() {
  if (!confirm(`Supprimer "${_editingWheel.name}" ?`)) return;
  await dbDel('wheels', _editingWheel.id);
  closeModal('modal-wheel');
  renderWheels();
}
function openWheelSpin(w) {
  _currentWheel = w;
  document.getElementById('wheel-spin-title').textContent = w.name;
  document.getElementById('wheel-result').textContent = '';
  drawWheelSvg();
  goTo('wheel-spin');
}
function editCurrentWheel() {
  if (_currentWheel) openWheelModal(_currentWheel);
}
function drawWheelSvg() {
  if (!_currentWheel) return;
  const svg = document.getElementById('wheel-svg');
  svg.innerHTML = '';
  const N = _currentWheel.options.length;
  const colors = ['#FF6FA3','#7B61FF','#5B8DEF','#5DD68F','#FFD166','#FF8C42','#FF6B7A','#C77DFF','#5DD6E5','#06FFA5'];
  const sliceAngle = 360 / N;
  for (let i=0; i<N; i++) {
    const a1 = (i * sliceAngle - 90) * Math.PI / 180;
    const a2 = ((i+1) * sliceAngle - 90) * Math.PI / 180;
    const x1 = 140 * Math.cos(a1), y1 = 140 * Math.sin(a1);
    const x2 = 140 * Math.cos(a2), y2 = 140 * Math.sin(a2);
    const large = sliceAngle > 180 ? 1 : 0;
    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    path.setAttribute('d', `M0,0 L${x1},${y1} A140,140 0 ${large} 1 ${x2},${y2} Z`);
    path.setAttribute('fill', colors[i % colors.length]);
    path.setAttribute('stroke', '#000');
    path.setAttribute('stroke-width', '1');
    svg.appendChild(path);
    // Text
    const ta = (i + 0.5) * sliceAngle - 90;
    const tx = 90 * Math.cos(ta * Math.PI / 180), ty = 90 * Math.sin(ta * Math.PI / 180);
    const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    text.setAttribute('x', tx); text.setAttribute('y', ty);
    text.setAttribute('fill', 'white');
    text.setAttribute('font-size', N > 8 ? '10' : '13');
    text.setAttribute('font-weight', '700');
    text.setAttribute('text-anchor', 'middle');
    text.setAttribute('dominant-baseline', 'middle');
    text.setAttribute('transform', `rotate(${ta+90}, ${tx}, ${ty})`);
    text.textContent = _currentWheel.options[i].slice(0, 14);
    svg.appendChild(text);
  }
}
function spinWheel() {
  if (!_currentWheel) return;
  const N = _currentWheel.options.length;
  const winnerIdx = Math.floor(Math.random() * N);
  const sliceAngle = 360 / N;
  const targetAngle = -(winnerIdx * sliceAngle) - sliceAngle/2 + (Math.random()*sliceAngle*0.6 - sliceAngle*0.3);
  const totalRotation = 360 * 6 + targetAngle; // 6 tours + position cible
  _wheelAngle = totalRotation;
  document.getElementById('wheel-svg').style.transform = `rotate(${totalRotation}deg)`;
  document.getElementById('wheel-result').textContent = '...';
  setTimeout(() => {
    document.getElementById('wheel-result').textContent = `🎉 ${_currentWheel.options[winnerIdx]}`;
  }, 4100);
}

