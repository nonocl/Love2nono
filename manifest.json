const SELFCARE_IDEAS = [
  {emoji:'🛁', text:'Bain chaud avec mousse', cat:'corps'},
  {emoji:'🧖‍♀️', text:'Masque visage', cat:'beauté'},
  {emoji:'💅', text:'Manucure / pédicure', cat:'beauté'},
