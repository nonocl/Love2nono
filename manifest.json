};

function getMuscu() { try { return JSON.parse(localStorage.getItem('nw_muscu') || '{}'); } catch { return {}; } }
function saveMuscu(d) { localStorage.setItem('nw_muscu', JSON.stringify(d)); }
function getMuscuLog() { try { return JSON.parse(localStorage.getItem('nw_muscu_log') || '[]'); } catch { return []; } }
function saveMuscuLog(d) { localStorage.setItem('nw_muscu_log', JSON.stringify(d)); }

let _curMuscuSession = null;

function renderMuscu() {
  const data = getMuscu();
  const log = getMuscuLog();
  const today = todayKey();
  
  let html = '';
  if (!data.program) {
    html = `<div style="background:linear-gradient(135deg, #FF4757, #FF8C42); color:white; padding:18px; border-radius:14px; text-align:center;">
      <div style="font-size:48px;">💪</div>
      <div style="font-size:18px; font-weight:800; margin-top:8px;">Choisis ton programme</div>
    </div>`;
    Object.entries(MUSCU_PROGRAMS).forEach(([k, p]) => {
      html += `<div onclick="muscuPickProgram('${k}')" style="background:var(--surface); padding:14px; border-radius:14px; margin-top:10px; cursor:pointer; border-left:4px solid var(--primary);">
        <div style="font-size:15px; font-weight:700;">${escapeHtml(p.name)}</div>
        <div style="font-size:11px; color:var(--textSec); margin-top:2px;">${escapeHtml(p.desc)}</div>
        <div style="font-size:10px; color:var(--primary); margin-top:6px;">${p.sessions.length} type${p.sessions.length>1?'s':''} de séance</div>
      </div>`;
    });
    html += `<button class="btn alt full" onclick="muscuCustom()" style="margin-top:14px;">⚙ Programme custom</button>`;
    document.getElementById('muscu-content').innerHTML = html;
    return;
  }
  
  const prog = MUSCU_PROGRAMS[data.program] || data.customProg;
  const last7 = log.filter(l => {
    const d = new Date(l.date); const now = new Date();
    return (now - d) < 7 * 86400000;
  });
  
  html = `<div style="background:linear-gradient(135deg, #FF4757, #FF8C42); color:white; padding:14px; border-radius:14px;">
    <div style="font-size:11px; opacity:0.85;">Programme actuel</div>
    <div style="font-size:18px; font-weight:800;">💪 ${escapeHtml(prog.name)}</div>
    <div style="font-size:11px; opacity:0.9; margin-top:2px;">${escapeHtml(prog.desc || '')}</div>
  </div>`;
  
  // Stats
  html += `<div style="display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin-top:10px;">
    <div style="background:var(--surface); padding:12px; border-radius:10px; text-align:center;">
      <div style="font-size:10px; color:var(--textSec);">Cette semaine</div>
      <div style="font-size:24px; font-weight:900; color:var(--primary);">${last7.length}</div>
      <div style="font-size:10px; color:var(--textSec);">séances</div>
    </div>
    <div style="background:var(--surface); padding:12px; border-radius:10px; text-align:center;">
      <div style="font-size:10px; color:var(--textSec);">Total</div>
      <div style="font-size:24px; font-weight:900; color:var(--primary);">${log.length}</div>
      <div style="font-size:10px; color:var(--textSec);">séances</div>
    </div>
    <div style="background:var(--surface); padding:12px; border-radius:10px; text-align:center;">
      <div style="font-size:10px; color:var(--textSec);">Streak</div>
      <div style="font-size:24px; font-weight:900; color:var(--primary);">${muscuStreak()}</div>
      <div style="font-size:10px; color:var(--textSec);">jours</div>
    </div>
  </div>`;
  
  // Sessions du programme
  html += `<h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-top:16px;">🔥 Choisis ta séance</h3>`;
  prog.sessions.forEach((s, i) => {
    const lastDone = log.filter(l => l.sessionIdx === i).sort((a,b) => b.date.localeCompare(a.date))[0];
    html += `<div onclick="muscuStartSession(${i})" style="background:var(--surface); padding:14px; border-radius:12px; margin-bottom:6px; cursor:pointer;">
      <div style="font-size:14px; font-weight:700;">${escapeHtml(s.name)}</div>
      <div style="font-size:10px; color:var(--textSec); margin-top:2px;">${s.exos.length} exercices</div>
      ${lastDone ? `<div style="font-size:10px; color:var(--primary); margin-top:4px;">Dernière fois : ${new Date(lastDone.date).toLocaleDateString('fr-FR')}</div>` : ''}
    </div>`;
  });
  
  // Historique
  if (log.length) {
    html += `<h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-top:18px;">📊 Historique</h3>`;
    log.slice(0, 10).forEach(l => {
      const sess = (prog.sessions[l.sessionIdx]) || {name:'?'};
      const totalSets = (l.exos || []).reduce((s, e) => s + (e.sets || []).length, 0);
      html += `<div style="background:var(--surface); padding:10px 14px; border-radius:10px; margin-bottom:4px;">
        <div style="font-size:11px; color:var(--textSec);">${new Date(l.date).toLocaleDateString('fr-FR')}</div>
        <div style="font-size:13px; font-weight:700;">${escapeHtml(sess.name)}</div>
        <div style="font-size:10px; color:var(--primary); margin-top:2px;">${totalSets} sets total</div>
      </div>`;
    });
  }
  
  html += `<button class="btn alt full" onclick="muscuChangeProgram()" style="margin-top:14px;">↻ Changer de programme</button>`;
  document.getElementById('muscu-content').innerHTML = html;
}

function muscuStreak() {
  const log = getMuscuLog();
  if (!log.length) return 0;
  const sorted = log.map(l => l.date.slice(0,10)).sort();
  const set = new Set(sorted);
  let streak = 0;
  let d = new Date(); d.setHours(0,0,0,0);
  // Compte combien de jours consécutifs avec au moins 1 séance dans la fenêtre roulante (séance 1× tous les 1-3 jours)
  for (let i = 0; i < 30; i++) {
    const dd = new Date(d); dd.setDate(dd.getDate() - i);
    const k = dd.toISOString().slice(0,10);
    if (set.has(k)) { streak++; }
    else if (streak > 0) break;
  }
  return streak;
}

function muscuPickProgram(k) {
  const data = getMuscu();
  data.program = k;
  saveMuscu(data);
  renderMuscu();
}
function muscuChangeProgram() {
  if (!confirm('Changer de programme ? Ton historique est conservé.')) return;
  const data = getMuscu(); delete data.program; saveMuscu(data);
  renderMuscu();
}
function muscuCustom() {
  toast('Bientôt : programme 100% personnalisé');
}

function muscuStartSession(idx) {
  _curMuscuSession = {
    sessionIdx: idx,
    date: new Date().toISOString(),
    exos: [],
    notes: ''
  };
  const data = getMuscu();
  const prog = MUSCU_PROGRAMS[data.program];
  prog.sessions[idx].exos.forEach(name => {
    _curMuscuSession.exos.push({ name, sets: [{ weight: '', reps: '' }] });
  });
  goTo('muscu-session');
}
function renderMuscuSession() {
  if (!_curMuscuSession) { goTo('muscu'); return; }
  const data = getMuscu();
  const prog = MUSCU_PROGRAMS[data.program];
  const sess = prog.sessions[_curMuscuSession.sessionIdx];
  
  let html = `<div style="background:linear-gradient(135deg, #FF4757, #FF8C42); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:18px; font-weight:800;">🔥 ${escapeHtml(sess.name)}</div>
    <div style="font-size:11px; opacity:0.9; margin-top:2px;">${new Date(_curMuscuSession.date).toLocaleDateString('fr-FR')}</div>
  </div>`;
  
  _curMuscuSession.exos.forEach((exo, ei) => {
    const lastSession = getMuscuLog().filter(l => l.sessionIdx === _curMuscuSession.sessionIdx).sort((a,b) => b.date.localeCompare(a.date))[0];
    const lastExo = lastSession?.exos?.find(e => e.name === exo.name);
    const lastSet = lastExo?.sets?.[lastExo.sets.length - 1];
    const hint = lastSet ? `Dernière fois: ${lastSet.weight}kg × ${lastSet.reps}` : '';
    
    html += `<div style="background:var(--surface); padding:14px; border-radius:14px; margin-top:10px;">
      <div style="font-size:14px; font-weight:700;">${escapeHtml(exo.name)}</div>
      ${hint ? `<div style="font-size:10px; color:var(--primary); margin-top:2px;">💡 ${hint}</div>` : ''}
      <div style="margin-top:10px;">`;
    exo.sets.forEach((set, si) => {
      html += `<div style="display:flex; gap:6px; align-items:center; margin-bottom:6px;">
        <div style="width:24px; font-size:12px; color:var(--textSec); font-weight:700;">#${si+1}</div>
        <input type="number" value="${set.weight || ''}" placeholder="kg" onchange="muscuSet(${ei},${si},'weight',this.value)" style="flex:1; min-width:50px; padding:8px; background:var(--bg); border:1px solid var(--border); border-radius:8px; color:var(--text); outline:none;" inputmode="decimal">
        <span style="color:var(--textSec); font-size:11px;">×</span>
        <input type="number" value="${set.reps || ''}" placeholder="reps" onchange="muscuSet(${ei},${si},'reps',this.value)" style="flex:1; min-width:50px; padding:8px; background:var(--bg); border:1px solid var(--border); border-radius:8px; color:var(--text); outline:none;" inputmode="numeric">
        ${exo.sets.length > 1 ? `<button onclick="muscuDelSet(${ei},${si})" style="background:none; border:none; color:var(--danger); font-size:18px; cursor:pointer;">✗</button>` : ''}
      </div>`;
    });
    html += `<button class="btn alt" onclick="muscuAddSet(${ei})" style="font-size:11px; padding:6px 12px; margin-top:4px;">+ Set</button>
    </div></div>`;
  });
  
  html += `<textarea class="input" placeholder="Notes (forme, énergie, douleurs...)" rows="2" onchange="_curMuscuSession.notes=this.value" style="margin-top:14px;">${escapeHtml(_curMuscuSession.notes || '')}</textarea>
    <button class="btn primary full" onclick="muscuFinishSession()" style="margin-top:14px;">✓ Terminer la séance</button>`;
  
  document.getElementById('muscu-session-content').innerHTML = html;
}
function muscuSet(ei, si, field, val) {
  if (!_curMuscuSession) return;
  _curMuscuSession.exos[ei].sets[si][field] = val;
}
function muscuAddSet(ei) {
  _curMuscuSession.exos[ei].sets.push({ weight:'', reps:'' });
  renderMuscuSession();
}
function muscuDelSet(ei, si) {
  _curMuscuSession.exos[ei].sets.splice(si, 1);
  renderMuscuSession();
}
function muscuFinishSession() {
  if (!_curMuscuSession) return goTo('muscu');
  // Filter sets vides
  _curMuscuSession.exos.forEach(e => {
    e.sets = e.sets.filter(s => s.weight || s.reps);
  });
  _curMuscuSession.exos = _curMuscuSession.exos.filter(e => e.sets.length);
  if (!_curMuscuSession.exos.length) {
    if (!confirm('Séance vide. Quitter sans sauvegarder ?')) return;
    _curMuscuSession = null;
    goTo('muscu');
    return;
  }
  const log = getMuscuLog();
  log.unshift(_curMuscuSession);
  saveMuscuLog(log);
  _curMuscuSession = null;
  toast('💪 Séance enregistrée !');
  goTo('muscu');
}

// === PR PERSONNELS ===
const PR_PRESETS = [
  {key:'squat', name:'Squat', emoji:'🦵', unit:'kg'},
  {key:'bench', name:'Développé couché', emoji:'💪', unit:'kg'},
  {key:'sdt', name:'Soulevé de terre', emoji:'🏋️', unit:'kg'},
  {key:'dm', name:'Développé militaire', emoji:'🏋️‍♂️', unit:'kg'},
  {key:'pullup', name:'Tractions max', emoji:'🤸', unit:'reps'},
  {key:'pushup', name:'Pompes max', emoji:'🦾', unit:'reps'},
  {key:'plank', name:'Gainage max', emoji:'⏱', unit:'secondes'},
  {key:'run5k', name:'5km course', emoji:'🏃', unit:'min'},
  {key:'run10k', name:'10km course', emoji:'🏃‍♂️', unit:'min'},
  {key:'sprint100', name:'100m sprint', emoji:'⚡', unit:'sec'},
];
function getPRs() { try { return JSON.parse(localStorage.getItem('nw_prs') || '[]'); } catch { return []; } }
function savePRs(d) { localStorage.setItem('nw_prs', JSON.stringify(d)); }
function renderPR() {
  const prs = getPRs();
  let html = `<div style="background:linear-gradient(135deg, #FFD700, #FF8C42); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🏆</div>
    <div style="font-size:16px; font-weight:800; margin-top:4px;">Mes records personnels</div>
    <div style="font-size:11px; opacity:0.9;">${prs.length} record${prs.length>1?'s':''}</div>
  </div>`;
  
  if (!prs.length) {
    html += '<p style="text-align:center; color:var(--textSec); padding:30px;">Aucun PR. Tap + pour ajouter ton 1er record.</p>';
  } else {
    html += `<div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-top:14px;">`;
    prs.forEach(pr => {
      const preset = PR_PRESETS.find(p => p.key === pr.type) || {};
      html += `<div style="background:var(--surface); padding:12px; border-radius:12px; text-align:center;">
        <div style="font-size:28px;">${preset.emoji || '🏆'}</div>
        <div style="font-size:11px; color:var(--textSec); margin-top:4px;">${escapeHtml(preset.name || pr.name)}</div>
        <div style="font-size:22px; font-weight:900; color:var(--primary); margin-top:4px;">${pr.value}<span style="font-size:11px; color:var(--textSec); font-weight:400;"> ${escapeHtml(preset.unit || pr.unit || '')}</span></div>
        <div style="font-size:9px; color:var(--textSec); margin-top:2px;">${new Date(pr.date).toLocaleDateString('fr-FR')}</div>
        <div style="display:flex; gap:4px; margin-top:6px;">
          <button class="btn alt" onclick="prUpdate('${pr.id}')" style="font-size:10px; padding:3px 6px; flex:1;">✎</button>
          <button class="btn alt" onclick="prDel('${pr.id}')" style="font-size:10px; padding:3px 6px; color:var(--danger);">🗑</button>
        </div>
      </div>`;
    });
    html += `</div>`;
  }
  document.getElementById('pr-content').innerHTML = html;
}
function prAdd() {
  let opts = PR_PRESETS.map((p, i) => `${i+1}. ${p.emoji} ${p.name}`).join('\n');
  opts += '\n0. Custom (autre)';
  const ch = prompt('Type de PR :\n\n' + opts);
  if (!ch) return;
  const idx = parseInt(ch);
  let preset = null, name = '', unit = '';
  if (idx > 0 && idx <= PR_PRESETS.length) {
    preset = PR_PRESETS[idx - 1];
    name = preset.name; unit = preset.unit;
  } else {
    name = prompt('Nom du PR ?'); if (!name) return;
    unit = prompt('Unité ? (kg, reps, sec, min, m...)') || '';
  }
  const value = prompt(`${name} (${unit}) :`);
  if (!value) return;
  const prs = getPRs();
  prs.push({
    id: 'pr_'+Date.now(),
    type: preset ? preset.key : 'custom',
    name, unit,
    value: parseFloat(value) || value,
    date: new Date().toISOString()
  });
  savePRs(prs);
  toast('🏆 PR enregistré !');
  renderPR();
}
function prUpdate(id) {
  const prs = getPRs();
  const pr = prs.find(p => p.id === id); if (!pr) return;
  const preset = PR_PRESETS.find(p => p.key === pr.type) || {};
  const v = prompt(`Nouveau record pour ${preset.name || pr.name} (${preset.unit || pr.unit}) :`, pr.value);
  if (v === null) return;
  pr.value = parseFloat(v) || v;
  pr.date = new Date().toISOString();
  savePRs(prs);
  toast('🏆 Record battu !');
  renderPR();
}
function prDel(id) {
  if (!confirm('Supprimer ce PR ?')) return;
  savePRs(getPRs().filter(p => p.id !== id));
  renderPR();
}

// === FITNESS DAILY (compteur rapide) ===
function getFit() { try { return JSON.parse(localStorage.getItem('nw_fit') || '{}'); } catch { return {}; } }
function saveFit(d) { localStorage.setItem('nw_fit', JSON.stringify(d)); }
const FIT_TYPES = [
  {id:'pushup', name:'Pompes', emoji:'🦾', color:'#FF4757'},
  {id:'situp', name:'Abdos', emoji:'🔥', color:'#FF8C42'},
  {id:'pullup', name:'Tractions', emoji:'🤸', color:'#5DD68F'},
  {id:'squat', name:'Squats', emoji:'🦵', color:'#A78BFA'},
  {id:'plank', name:'Gainage (sec)', emoji:'⏱', color:'#5DADE2'},
  {id:'run', name:'Course (km)', emoji:'🏃', color:'#FFD166'}
];
function renderFit() {
  const today = todayKey();
  const data = getFit();
  const todayFit = data[today] || {};
  
  let html = `<div style="background:linear-gradient(135deg, #FF4757, #FF8C42); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:18px; font-weight:800;">⚡ Fitness daily</div>
    <div style="font-size:11px; opacity:0.9;">Logge tes exos express du jour</div>
  </div>`;
  
  html += `<div style="display:grid; grid-template-columns:repeat(2,1fr); gap:8px; margin-top:14px;">`;
  FIT_TYPES.forEach(t => {
    const v = todayFit[t.id] || 0;
    html += `<div style="background:var(--surface); padding:14px; border-radius:14px; text-align:center; border-top:4px solid ${t.color};">
      <div style="font-size:32px;">${t.emoji}</div>
      <div style="font-size:11px; color:var(--textSec); margin-top:4px;">${escapeHtml(t.name)}</div>
      <div style="font-size:28px; font-weight:900; color:${t.color}; margin-top:4px;">${v}</div>
      <div style="display:flex; gap:4px; margin-top:6px;">
        <button class="btn alt" onclick="fitAdd('${t.id}', -10)" style="font-size:10px; padding:4px; flex:1;">-10</button>
        <button class="btn alt" onclick="fitAdd('${t.id}', -1)" style="font-size:10px; padding:4px; flex:1;">-1</button>
        <button class="btn primary" onclick="fitAdd('${t.id}', 1)" style="font-size:10px; padding:4px; flex:1;">+1</button>
        <button class="btn primary" onclick="fitAdd('${t.id}', 10)" style="font-size:10px; padding:4px; flex:1;">+10</button>
      </div>
    </div>`;
  });
  html += `</div>`;
  
  // Stats 7 jours
  html += `<h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-top:18px;">📈 7 derniers jours</h3>`;
  let totals = {};
  for (let i = 0; i < 7; i++) {
    const d = new Date(); d.setDate(d.getDate() - i);
    const k = d.toISOString().slice(0,10);
    const day = data[k] || {};
    Object.entries(day).forEach(([id, v]) => { totals[id] = (totals[id] || 0) + v; });
  }
  html += `<div style="display:grid; grid-template-columns:repeat(2,1fr); gap:6px; margin-top:8px;">`;
  FIT_TYPES.forEach(t => {
    const total = totals[t.id] || 0;
    html += `<div style="background:var(--surface); padding:10px; border-radius:10px; display:flex; gap:8px; align-items:center;">
      <div style="font-size:20px;">${t.emoji}</div>
      <div style="flex:1;">
        <div style="font-size:10px; color:var(--textSec);">${escapeHtml(t.name)}</div>
        <div style="font-size:14px; font-weight:800;">${total}</div>
      </div>
    </div>`;
  });
  html += `</div>`;
  
  document.getElementById('fit-content').innerHTML = html;
}
function fitAdd(id, delta) {
  const today = todayKey();
  const data = getFit();
  if (!data[today]) data[today] = {};
  data[today][id] = Math.max(0, (data[today][id] || 0) + delta);
  saveFit(data);
  renderFit();
}



// === WALLET FINANCES ===
const WALLET_CATS = {
  argent_poche: {emoji:'💸', name:'Argent de poche', type:'in', color:'#5DD68F'},
  cadeau: {emoji:'🎁', name:'Cadeau', type:'in', color:'#FF6FA3'},
  job: {emoji:'💼', name:'Petit job', type:'in', color:'#5DADE2'},
  autre_in: {emoji:'➕', name:'Autre revenu', type:'in', color:'#A78BFA'},
  bouffe: {emoji:'🍔', name:'Bouffe', type:'out', color:'#FF8C42'},
  sortie: {emoji:'🎉', name:'Sortie', type:'out', color:'#FFD166'},
  vetement: {emoji:'👕', name:'Vêtements', type:'out', color:'#FF6FA3'},
  tech: {emoji:'📱', name:'Tech', type:'out', color:'#5DADE2'},
  jeux: {emoji:'🎮', name:'Jeux', type:'out', color:'#A78BFA'},
  transport: {emoji:'🚌', name:'Transport', type:'out', color:'#06FFA5'},
  autre_out: {emoji:'🛒', name:'Autre dépense', type:'out', color:'#888'}
};
let _walletType = 'out';
function getWallet() { try { return JSON.parse(localStorage.getItem('nw_wallet2') || '[]'); } catch { return []; } }
function saveWallet(d) { localStorage.setItem('nw_wallet2', JSON.stringify(d)); }
function renderWallet2() {
  const tx = getWallet().sort((a,b) => b.date.localeCompare(a.date));
  const now = new Date();
  const monthKey = now.toISOString().slice(0, 7);
  const monthTx = tx.filter(t => t.date.startsWith(monthKey));
  const totalIn = monthTx.filter(t => t.amount > 0).reduce((s, t) => s + t.amount, 0);
  const totalOut = monthTx.filter(t => t.amount < 0).reduce((s, t) => s + Math.abs(t.amount), 0);
  const balance = totalIn - totalOut;
  const allBalance = tx.reduce((s, t) => s + t.amount, 0);
  
  let html = `<div style="background:linear-gradient(135deg, ${balance >= 0 ? '#5DD68F, #06FFA5' : '#FF4757, #FF8C42'}); color:white; padding:18px; border-radius:14px; text-align:center;">
    <div style="font-size:11px; opacity:0.85;">Balance ce mois</div>
    <div style="font-size:36px; font-weight:900;">${balance >= 0 ? '+' : ''}${balance.toFixed(2)}€</div>
    <div style="display:flex; justify-content:space-around; margin-top:10px; font-size:12px;">
      <div>📥 +${totalIn.toFixed(2)}€</div>
      <div>📤 -${totalOut.toFixed(2)}€</div>
    </div>
  </div>`;
  
  html += `<div style="background:var(--surface); padding:12px; border-radius:10px; margin-top:8px; text-align:center;">
    <div style="font-size:10px; color:var(--textSec);">Total cumulé depuis le début</div>
    <div style="font-size:20px; font-weight:800; color:${allBalance >= 0 ? 'var(--success)' : 'var(--danger)'};">${allBalance >= 0 ? '+' : ''}${allBalance.toFixed(2)}€</div>
  </div>`;
  
  // Bouton goals
  html += `<button class="btn alt full" onclick="goTo('wallet2-goals')" style="margin-top:8px;">🎯 Mes objectifs épargne</button>`;
  
  // Stats par catégorie ce mois
  if (monthTx.length) {
    html += `<h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-top:18px;">📊 Top dépenses ce mois</h3>`;
    const byCat = {};
    monthTx.filter(t => t.amount < 0).forEach(t => {
      byCat[t.cat] = (byCat[t.cat] || 0) + Math.abs(t.amount);
    });
    const sorted = Object.entries(byCat).sort((a,b) => b[1] - a[1]).slice(0, 5);
    sorted.forEach(([cat, amt]) => {
      const c = WALLET_CATS[cat] || {};
      const pct = (amt / totalOut * 100) || 0;
      html += `<div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-bottom:4px;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <div><span style="font-size:18px;">${c.emoji || '💸'}</span> <span style="font-size:13px; font-weight:700;">${escapeHtml(c.name || cat)}</span></div>
          <div style="font-size:14px; font-weight:800; color:var(--danger);">-${amt.toFixed(2)}€</div>
        </div>
        <div style="background:var(--surfaceAlt); height:5px; border-radius:3px; margin-top:4px; overflow:hidden;">
          <div style="background:${c.color || 'var(--danger)'}; height:100%; width:${pct}%;"></div>
        </div>
      </div>`;
    });
  }
  
  // Historique récent
  if (tx.length) {
    html += `<h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-top:18px;">📜 Dernières transactions</h3>`;
    tx.slice(0, 20).forEach(t => {
      const c = WALLET_CATS[t.cat] || {};
      const isPositive = t.amount > 0;
      html += `<div style="background:var(--surface); padding:10px 12px; border-radius:10px; margin-bottom:4px; display:flex; gap:8px; align-items:center;">
        <div style="font-size:24px;">${c.emoji || '💸'}</div>
        <div style="flex:1; min-width:0;">
          <div style="font-size:13px; font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${escapeHtml(t.desc || c.name || '')}</div>
          <div style="font-size:10px; color:var(--textSec);">${new Date(t.date).toLocaleDateString('fr-FR')}</div>
        </div>
        <div style="font-size:14px; font-weight:800; color:${isPositive ? 'var(--success)' : 'var(--danger)'};">${isPositive ? '+' : ''}${t.amount.toFixed(2)}€</div>
        <button onclick="walletDel('${t.id}')" style="background:none; border:none; color:var(--danger); font-size:16px;">✗</button>
      </div>`;
    });
  } else {
    html += `<p style="text-align:center; color:var(--textSec); padding:30px;">Aucune transaction. Tap + pour commencer.</p>`;
  }
  
  document.getElementById('wallet2-content').innerHTML = html;
}
function walletAdd() {
  document.getElementById('wt-amount').value = '';
  document.getElementById('wt-desc').value = '';
  document.getElementById('wt-date').value = todayKey();
  walletSetType('out');
  goTo('wallet2-add');
}
function walletSetType(t) {
  _walletType = t;
  document.getElementById('wt-in-btn').className = 'btn full ' + (t === 'in' ? 'primary' : 'alt');
  document.getElementById('wt-out-btn').className = 'btn full ' + (t === 'out' ? 'primary' : 'alt');
  // Filter cat options
  const sel = document.getElementById('wt-cat');
  Array.from(sel.options).forEach(opt => {
    const ot = opt.dataset.type;
    if (!ot) opt.style.display = (t === 'in' ? '' : 'none');
    else opt.style.display = (ot === t ? '' : 'none');
  });
  // Set first visible
  const visible = Array.from(sel.options).filter(o => o.style.display !== 'none')[0];
  if (visible) sel.value = visible.value;
}
function walletSave() {
  const amt = parseFloat(document.getElementById('wt-amount').value);
  if (!amt) return toast('Montant requis');
  const tx = {
    id: 't_' + Date.now(),
    cat: document.getElementById('wt-cat').value,
    amount: _walletType === 'in' ? Math.abs(amt) : -Math.abs(amt),
    desc: document.getElementById('wt-desc').value.trim(),
    date: document.getElementById('wt-date').value || todayKey()
  };
  const all = getWallet(); all.unshift(tx); saveWallet(all);
  toast('💰 Sauvegardé');
  goTo('wallet2');
}
function walletDel(id) {
  if (!confirm('Supprimer ?')) return;
  saveWallet(getWallet().filter(t => t.id !== id));
  renderWallet2();
}

// === GOALS ÉPARGNE ===
function getGoals() { try { return JSON.parse(localStorage.getItem('nw_goals') || '[]'); } catch { return []; } }
function saveGoals(d) { localStorage.setItem('nw_goals', JSON.stringify(d)); }
function renderGoals() {
  const goals = getGoals();
  let html = `<p style="font-size:11px; color:var(--textSec);">Définis tes objectifs (PS5, voyage, vélo...) et suis ta progression.</p>`;
  if (!goals.length) {
    html += '<p style="text-align:center; color:var(--textSec); padding:30px;">Pas d\'objectif. Tap + pour démarrer.</p>';
  } else {
    goals.forEach(g => {
      const pct = Math.min(100, (g.current / g.target) * 100);
      const isDone = g.current >= g.target;
      html += `<div style="background:var(--surface); padding:14px; border-radius:14px; margin-top:10px; ${isDone ? 'border:2px solid var(--success);' : ''}">
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <div style="font-size:15px; font-weight:700;">${isDone ? '✅' : '🎯'} ${escapeHtml(g.name)}</div>
          <button onclick="goalDel('${g.id}')" style="background:none; border:none; color:var(--danger); font-size:16px;">✗</button>
        </div>
        <div style="font-size:11px; color:var(--textSec); margin-top:4px;">${g.current.toFixed(2)}€ / ${g.target.toFixed(2)}€</div>
        <div style="background:var(--surfaceAlt); height:10px; border-radius:5px; margin-top:6px; overflow:hidden;">
          <div style="background:linear-gradient(90deg, var(--primary), var(--accent)); height:100%; width:${pct}%; transition:width 0.3s;"></div>
        </div>
        <div style="font-size:11px; color:var(--primary); font-weight:700; margin-top:4px; text-align:right;">${pct.toFixed(0)}%</div>
        <div style="display:flex; gap:4px; margin-top:8px;">
          <button class="btn alt" onclick="goalAddAmount('${g.id}', 5)" style="font-size:11px; padding:4px 8px; flex:1;">+5€</button>
          <button class="btn alt" onclick="goalAddAmount('${g.id}', 10)" style="font-size:11px; padding:4px 8px; flex:1;">+10€</button>
          <button class="btn alt" onclick="goalAddAmount('${g.id}', 50)" style="font-size:11px; padding:4px 8px; flex:1;">+50€</button>
          <button class="btn alt" onclick="goalCustom('${g.id}')" style="font-size:11px; padding:4px 8px; flex:1;">€...</button>
        </div>
      </div>`;
    });
  }
  document.getElementById('wallet2-goals-content').innerHTML = html;
}
function goalAdd() {
  const name = prompt('Nom de l\'objectif (ex: PS5, voyage Italie, vélo) :');
  if (!name) return;
  const target = parseFloat(prompt(`Montant à atteindre pour "${name}" (€) ?`));
  if (!target) return;
  const goals = getGoals();
  goals.push({ id:'g_'+Date.now(), name, target, current:0, created:Date.now() });
  saveGoals(goals); renderGoals();
}
function goalAddAmount(id, amt) {
  const goals = getGoals();
  const g = goals.find(x => x.id === id); if (!g) return;
  g.current = Math.max(0, g.current + amt);
  saveGoals(goals); renderGoals();
  if (g.current >= g.target) toast('🎉 Objectif atteint !');
}
function goalCustom(id) {
  const v = parseFloat(prompt('Montant à ajouter (négatif pour retirer) :'));
  if (!v) return;
  goalAddAmount(id, v);
}
function goalDel(id) {
  if (!confirm('Supprimer cet objectif ?')) return;
  saveGoals(getGoals().filter(g => g.id !== id));
  renderGoals();
}

// === GAMING HUB ===
let _gamingTab = 'playing';
function getGames() { try { return JSON.parse(localStorage.getItem('nw_games2') || '[]'); } catch { return []; } }
function saveGames(d) { localStorage.setItem('nw_games2', JSON.stringify(d)); }
function gamingTab(t) {
  _gamingTab = t;
  ['playing','done','wishlist','drop'].forEach(x => {
    const el = document.getElementById('gt-'+x);
    if (el) el.className = 'btn ' + (x === t ? 'primary' : 'alt');
    if (el) el.style.cssText = 'font-size:11px; padding:6px 10px; flex-shrink:0;';
  });
  renderGames();
}
function renderGames() {
  const games = getGames().filter(g => g.status === _gamingTab);
  const grid = document.getElementById('gaming-list');
  const platEmojis = {ps5:'🎮 PS5', ps4:'🎮 PS4', xbox:'🎮 Xbox', switch:'🎮 Switch', pc:'💻 PC', mobile:'📱'};
  if (!games.length) {
    grid.innerHTML = '<p style="text-align:center; color:var(--textSec); padding:30px;">Aucun jeu dans cette catégorie.</p>';
    return;
  }
  grid.innerHTML = games.map(g => `<div style="background:var(--surface); padding:14px; border-radius:14px; margin-bottom:6px;">
    <div style="display:flex; justify-content:space-between; align-items:flex-start;">
      <div style="flex:1;">
        <div style="font-size:14px; font-weight:700;">🎮 ${escapeHtml(g.name)}</div>
        <div style="font-size:11px; color:var(--textSec); margin-top:2px;">${platEmojis[g.platform] || g.platform}${g.genre ? ' · ' + escapeHtml(g.genre) : ''}</div>
        ${g.hours ? `<div style="font-size:11px; color:var(--primary); margin-top:2px;">⏱ ${g.hours}h</div>` : ''}
        ${g.rating ? `<div style="font-size:11px; margin-top:2px;">${'⭐'.repeat(Math.round(g.rating/2))} ${g.rating}/10</div>` : ''}
        ${g.notes ? `<div style="font-size:11px; color:var(--textSec); margin-top:6px; line-height:1.4;">${escapeHtml(g.notes)}</div>` : ''}
      </div>
    </div>
    <div style="display:flex; gap:4px; margin-top:8px; flex-wrap:wrap;">
      <button class="btn alt" onclick="gameMove('${g.id}', 'playing')" style="font-size:10px; padding:3px 8px;">🎮 En cours</button>
      <button class="btn alt" onclick="gameMove('${g.id}', 'done')" style="font-size:10px; padding:3px 8px;">✅ Fini</button>
      <button class="btn alt" onclick="gameMove('${g.id}', 'wishlist')" style="font-size:10px; padding:3px 8px;">⭐ Wish</button>
      <button class="btn alt" onclick="gameMove('${g.id}', 'drop')" style="font-size:10px; padding:3px 8px;">⏸ Drop</button>
      <button class="btn alt" onclick="gameDel('${g.id}')" style="font-size:10px; padding:3px 8px; color:var(--danger);">🗑</button>
    </div>
  </div>`).join('');
}
function gameAdd() {
  document.getElementById('gm-name').value = '';
  document.getElementById('gm-genre').value = '';
  document.getElementById('gm-hours').value = '';
  document.getElementById('gm-rating').value = '';
  document.getElementById('gm-notes').value = '';
  goTo('gaming-add');
}
function gameSave() {
  const name = document.getElementById('gm-name').value.trim();
  if (!name) return toast('Nom requis');
  const game = {
    id: 'g_'+Date.now(),
    name,
    platform: document.getElementById('gm-plat').value,
    status: document.getElementById('gm-status').value,
    genre: document.getElementById('gm-genre').value.trim(),
    hours: parseFloat(document.getElementById('gm-hours').value) || 0,
    rating: parseInt(document.getElementById('gm-rating').value) || 0,
    notes: document.getElementById('gm-notes').value.trim(),
    added: Date.now()
  };
  const games = getGames(); games.unshift(game); saveGames(games);
  toast('🎮 Ajouté');
  goTo('gaming');
}
function gameMove(id, status) {
  const games = getGames();
  const g = games.find(x => x.id === id); if (!g) return;
  g.status = status;
  if (status === 'done') g.finished = Date.now();
  saveGames(games);
  renderGames();
}
function gameDel(id) {
  if (!confirm('Supprimer ce jeu ?')) return;
  saveGames(getGames().filter(g => g.id !== id));
  renderGames();
}

// === MODE FOCUS ===
let _focusInterval = null;
let _focusEnd = 0;
let _focusDuration = 0;

function getFocusStats() { try { return JSON.parse(localStorage.getItem('nw_focus') || '[]'); } catch { return []; } }
function saveFocusStats(d) { localStorage.setItem('nw_focus', JSON.stringify(d)); }

function renderFocus() {
  const stats = getFocusStats();
  const today = todayKey();
  const todayMins = stats.filter(s => s.date.startsWith(today)).reduce((sum, s) => sum + s.duration, 0);
  const totalMins = stats.reduce((sum, s) => sum + s.duration, 0);
  
  let html = '';
  if (_focusEnd && _focusEnd > Date.now()) {
    const remaining = _focusEnd - Date.now();
    const mins = Math.floor(remaining / 60000);
    const secs = Math.floor((remaining % 60000) / 1000);
    html = `<div style="background:linear-gradient(135deg, #5DD68F, #06FFA5); color:white; padding:30px 18px; border-radius:24px; text-align:center;">
      <div style="font-size:16px; opacity:0.9;">🎯 Mode Focus actif</div>
      <div style="font-size:64px; font-weight:900; line-height:1; margin-top:12px;">${String(mins).padStart(2,'0')}:${String(secs).padStart(2,'0')}</div>
      <div style="font-size:13px; opacity:0.9; margin-top:14px;">📵 Pose ton téléphone</div>
      <div style="font-size:11px; opacity:0.8; margin-top:6px;">Reste fort 💪</div>
    </div>
    <button class="btn alt full" onclick="focusStop()" style="margin-top:14px; color:var(--danger);">✗ Arrêter (perd la session)</button>`;
  } else {
    html = `<div style="background:linear-gradient(135deg, #FF4757, #A78BFA); color:white; padding:18px; border-radius:18px; text-align:center;">
      <div style="font-size:36px;">🎯</div>
      <div style="font-size:18px; font-weight:800; margin-top:6px;">Mode Focus</div>
      <div style="font-size:11px; opacity:0.9; margin-top:4px;">Pose ton tel et concentre-toi.</div>
    </div>
    <h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-top:18px;">⏱ Durée</h3>
    <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:6px; margin-top:8px;">
      <button class="btn alt" onclick="focusStart(15)">15 min</button>
      <button class="btn alt" onclick="focusStart(25)">25 min (Pomodoro)</button>
      <button class="btn alt" onclick="focusStart(45)">45 min</button>
      <button class="btn alt" onclick="focusStart(60)">1h</button>
      <button class="btn alt" onclick="focusStart(90)">1h30</button>
      <button class="btn alt" onclick="focusStart(120)">2h</button>
    </div>
    <button class="btn primary full" onclick="focusCustom()" style="margin-top:8px;">⚙ Durée custom</button>`;
  }
  
  // Stats
  html += `<h3 style="font-size:14px; font-weight:700; color:var(--primary); margin-top:18px;">📊 Stats</h3>
    <div style="display:grid; grid-template-columns:repeat(2,1fr); gap:8px; margin-top:8px;">
      <div style="background:var(--surface); padding:14px; border-radius:12px; text-align:center;">
        <div style="font-size:10px; color:var(--textSec);">Aujourd'hui</div>
        <div style="font-size:24px; font-weight:900; color:var(--primary);">${todayMins}</div>
        <div style="font-size:10px; color:var(--textSec);">min focus</div>
      </div>
      <div style="background:var(--surface); padding:14px; border-radius:12px; text-align:center;">
        <div style="font-size:10px; color:var(--textSec);">Total</div>
        <div style="font-size:24px; font-weight:900; color:var(--primary);">${(totalMins/60).toFixed(1)}h</div>
        <div style="font-size:10px; color:var(--textSec);">cumulés</div>
      </div>
    </div>`;
  
  if (stats.length) {
    html += `<h3 style="font-size:13px; font-weight:700; color:var(--textSec); margin-top:14px;">🕐 Sessions récentes</h3>`;
    stats.slice(-5).reverse().forEach(s => {
      html += `<div style="background:var(--surface); padding:10px 12px; border-radius:8px; margin-top:4px; display:flex; justify-content:space-between;">
        <span style="font-size:12px;">${new Date(s.date).toLocaleString('fr-FR', {weekday:'short', day:'numeric', hour:'2-digit', minute:'2-digit'})}</span>
        <span style="font-size:12px; font-weight:700; color:var(--success);">${s.duration} min</span>
      </div>`;
    });
  }
  
  document.getElementById('focus-content').innerHTML = html;
}
function focusStart(mins) {
  if (!confirm(`Démarrer ${mins} min de focus ?\n\n📵 Pose ton tel et reviens dans ${mins} min.\n\nSi tu reviens avant, la session ne compte pas.`)) return;
  _focusDuration = mins;
  _focusEnd = Date.now() + mins * 60000;
  if (_focusInterval) clearInterval(_focusInterval);
  _focusInterval = setInterval(() => {
    if (Date.now() >= _focusEnd) {
      clearInterval(_focusInterval);
      _focusInterval = null;
      // Save session
      const stats = getFocusStats();
      stats.push({ date:new Date().toISOString(), duration:_focusDuration });
      saveFocusStats(stats);
      _focusEnd = 0;
      // Vibrate
      if (navigator.vibrate) navigator.vibrate([200,100,200,100,200]);
      toast('🎉 Bravo, session focus terminée !');
      renderFocus();
    } else if (document.querySelector('.page.active')?.id === 'page-focus') {
      renderFocus();
    }
  }, 1000);
  renderFocus();
}
function focusStop() {
  if (!confirm('Arrêter ? La session ne sera pas comptabilisée.')) return;
  clearInterval(_focusInterval); _focusInterval = null;
  _focusEnd = 0;
  toast('Session arrêtée');
  renderFocus();
}
function focusCustom() {
  const v = parseInt(prompt('Durée en minutes :', '30'));
  if (v && v > 0) focusStart(v);
}
function focusStats() { goTo('focus'); renderFocus(); }



