function renderCoinFlip() {
  let html = `<div style="background:linear-gradient(135deg,#FFD166,#FFC542); color:white; padding:14px; border-radius:14px; text-align:center;">
    <div style="font-size:36px;">🪙</div><div style="font-size:16px; font-weight:800;">Pile ou face</div>
  </div>
